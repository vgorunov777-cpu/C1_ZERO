# === LLM-провайдер для llm_query() (необязательно) ===
# Без настройки сервер работает, но llm_query() будет недоступен.

# Вариант 1: OpenAI-совместимый endpoint (OpenRouter, LiteLLM, Ollama, vLLM)
# Имеет приоритет над ANTHROPIC_API_KEY, если оба заданы.
# RLM_LLM_BASE_URL=http://localhost:11434/v1
# RLM_LLM_API_KEY=
# RLM_LLM_MODEL=qwen2.5:7b

# Вариант 2: Anthropic API
# ANTHROPIC_API_KEY=sk-ant-...
# RLM_SUB_MODEL=claude-haiku-4-5-20251001

# === Общие настройки (необязательно) ===

# Путь к файлу конфигурации сервиса (service.json).
# Каталог этого файла определяет расположение всех связанных данных:
#   service.json   — конфигурация сервиса
#   projects.json  — реестр проектов (управляется через rlm_projects)
#   .env           — переменные окружения (если env_file не указан в service.json)
#   logs/          — логи сервера (при HTTP-транспорте)
# По умолчанию: ~/.config/rlm-tools-bsl/service.json
# RLM_CONFIG_FILE=%USERPROFILE%\.config\rlm-tools-bsl\service.json

# Макс. параллельных сессий (default: 5)
# RLM_MAX_SESSIONS=5

# Двухуровневый таймаут сессий:
#   idle  (calls=0) — сессия без единого execute-вызова (default: 10 мин)
#   active (calls>0) — сессия с выполненными вызовами (default: 30 мин)
# RLM_SESSION_TIMEOUT_IDLE=10
# RLM_SESSION_TIMEOUT_ACTIVE=30
#
# Единый таймаут (переопределяет оба, backward compat):
# RLM_SESSION_TIMEOUT=10

# === Индекс методов (необязательно) ===
# Подробности: docs/INDEXING.md
#
# Признак «включённости» индекса — не переменная окружения,
# а наличие файла bsl_index.db в каталоге хранения.
# Индекс создаётся командой: rlm-bsl-index index build <path>
# Если файл bsl_index.db существует — хелперы автоматически используют его.
# Если файла нет — всё работает как раньше, без индекса.

# Каталог хранения индексов.
# По умолчанию: ~/.cache/rlm-tools-bsl/
#   Linux/macOS: /home/user/.cache/rlm-tools-bsl/
#   Windows:     C:\Users\user\.cache\rlm-tools-bsl\
# Внутри каталога создаётся подпапка с хешем пути конфигурации, например:
#   C:\Users\user\.cache\rlm-tools-bsl\a3f8b2c1d4e5\bsl_index.db
# RLM_INDEX_DIR=D:\MyIndexes\1C

# Параметры проверки свежести индекса
# RLM_INDEX_MAX_AGE_DAYS=7       # предупреждать если индекс старше N дней (default: 7)
# RLM_INDEX_SAMPLE_SIZE=20       # файлов для выборочной проверки mtime (default: 20, 0=off)
# RLM_INDEX_SAMPLE_THRESHOLD=30  # % изменённых для предупреждения (default: 30)

# === Диагностика (необязательно) ===

# Логировать ВСЕ вызовы хелперов с таймингами (default: off, только >0.1s)
# RLM_LOG_HELPERS=all
