////////////////////////////////////////////////////////////////////////////////
// Управление печатью: формирование печатных форм документов
////////////////////////////////////////////////////////////////////////////////

#Область ПрограммныйИнтерфейс

Процедура ДобавитьКомандуПечати(КомандыПечати, ИдентификаторКоманды, Представление) Экспорт
    НоваяКоманда = КомандыПечати.Добавить();
    НоваяКоманда.Идентификатор = ИдентификаторКоманды;
    НоваяКоманда.Представление = Представление;
КонецПроцедуры

Функция СформироватьПечатнуюФорму(ИмяМакета, ДанныеПечати) Экспорт
    Макет = ПолучитьМакет(ИмяМакета);
    Если Макет = Неопределено Тогда
        ОбщегоНазначения.ВывестиСообщение("Макет не найден: " + ИмяМакета);
        Возврат Неопределено;
    КонецЕсли;
    ТабличныйДокумент = Новый ТабличныйДокумент;
    ОбластьШапки = Макет.ПолучитьОбласть("Шапка");
    ОбластьШапки.Параметры.Заполнить(ДанныеПечати);
    ТабличныйДокумент.Вывести(ОбластьШапки);
    Возврат ТабличныйДокумент;
КонецФункции

Процедура РаспечататьДокумент(ТабличныйДокумент) Экспорт
    Если ТабличныйДокумент = Неопределено Тогда
        Возврат;
    КонецЕсли;
    ТабличныйДокумент.Напечатать();
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ПолучитьМакет(ИмяМакета)
    Попытка
        Возврат ПолучитьОбщийМакет(ИмяМакета);
    Исключение
        Возврат Неопределено;
    КонецПопытки;
КонецФункции

Функция ПодготовитьДанныеПечатиНакладной(СсылкаНаДокумент)
    Результат = ОбщегоНазначения.ЗначениеРеквизитаОбъекта(СсылкаНаДокумент, "Номер");
    Если Не ОбщегоНазначения.ПроверитьЗаполнениеРеквизитов(СсылкаНаДокумент, "Номер,Дата,Контрагент") Тогда
        ОбщегоНазначения.ВывестиСообщение("Не заполнены обязательные реквизиты документа");
        Возврат Неопределено;
    КонецЕсли;
    Возврат Результат;
КонецФункции

#КонецОбласти
