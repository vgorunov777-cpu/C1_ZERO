#Область ПрограммныйИнтерфейс

// Проверяет заполненность обязательных реквизитов объекта.
//
// Параметры:
//  Объект - ЛюбаяСсылка - проверяемый объект
//  ИменаРеквизитов - Строка - имена реквизитов через запятую
//
// Возвращаемое значение:
//  Булево - Истина, если все реквизиты заполнены
//
Функция ПроверитьЗаполнениеРеквизитов(Объект, ИменаРеквизитов) Экспорт
    МассивИмен = СтрРазделить(ИменаРеквизитов, ",");
    Для Каждого ИмяРеквизита Из МассивИмен Цикл
        Если Не ЗначениеЗаполнено(Объект[СокрЛП(ИмяРеквизита)]) Тогда
            Возврат Ложь;
        КонецЕсли;
    КонецЦикла;
    Возврат Истина;
КонецФункции

// Возвращает значение реквизита объекта по ссылке.
//
// Параметры:
//  Ссылка - ЛюбаяСсылка - ссылка на объект
//  ИмяРеквизита - Строка - имя реквизита
//
// Возвращаемое значение:
//  Произвольный - значение реквизита
//
Функция ЗначениеРеквизитаОбъекта(Ссылка, ИмяРеквизита) Экспорт
    Запрос = Новый Запрос;
    Запрос.Текст = "ВЫБРАТЬ " + ИмяРеквизита + " КАК Значение ИЗ " + Ссылка.Метаданные().ПолноеИмя() + " ГДЕ Ссылка = &Ссылка";
    Запрос.УстановитьПараметр("Ссылка", Ссылка);
    Выборка = Запрос.Выполнить().Выбрать();
    Если Выборка.Следующий() Тогда
        Возврат Выборка.Значение;
    КонецЕсли;
    Возврат Неопределено;
КонецФункции

// Форматирует сумму с точностью до копеек.
Функция ФорматСуммы(Сумма) Экспорт
    Возврат Формат(Сумма, "ЧДЦ=2; ЧРГ=' '");
КонецФункции

Процедура ВывестиСообщение(ТекстСообщения, ПолеОшибки = "") Экспорт
    Сообщение = Новый СообщениеПользователю;
    Сообщение.Текст = ТекстСообщения;
    Сообщение.Поле = ПолеОшибки;
    Сообщение.Сообщить();
КонецПроцедуры

Функция ЭтоНовыйОбъект(Ссылка) Экспорт
    Возврат Ссылка.Пустая();
КонецФункции

// Получает текущую дату сеанса с учётом часового пояса.
Функция ТекущаяДатаСеанса() Экспорт
    Возврат ТекущаяДатаСеанса();
КонецФункции

Функция ПолучитьМенеджерОбъекта(ИмяОбъекта) Экспорт
    Части = СтрРазделить(ИмяОбъекта, ".");
    Если Части.Количество() <> 2 Тогда
        ВызватьИсключение "Неверный формат имени объекта: " + ИмяОбъекта;
    КонецЕсли;
    Возврат Неопределено;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаписатьВЖурналРегистрации(ИмяСобытия, Уровень, Комментарий) Экспорт
    ЗаписьЖурналаРегистрации(ИмяСобытия, Уровень, , , Комментарий);
КонецПроцедуры

Функция ПолучитьНастройкуХранилища(ИмяНастройки, ЗначениеПоУмолчанию = Неопределено)
    Попытка
        Значение = ХранилищеОбщихНастроек.Загрузить(ИмяНастройки);
        Если Значение = Неопределено Тогда
            Возврат ЗначениеПоУмолчанию;
        КонецЕсли;
        Возврат Значение;
    Исключение
        Возврат ЗначениеПоУмолчанию;
    КонецПопытки;
КонецФункции

Процедура СохранитьНастройкуХранилища(ИмяНастройки, Значение)
    ХранилищеОбщихНастроек.Сохранить(ИмяНастройки, , Значение);
КонецПроцедуры

Функция СтрокаВМассив(Строка, Разделитель = ",")
    Результат = Новый Массив;
    Части = СтрРазделить(Строка, Разделитель);
    Для Каждого Часть Из Части Цикл
        Результат.Добавить(СокрЛП(Часть));
    КонецЦикла;
    Возврат Результат;
КонецФункции

Функция МассивВСтроку(Массив, Разделитель = ", ")
    Возврат СтрСоединить(Массив, Разделитель);
КонецФункции

Функция СоздатьТаблицуЗначений(ИменаКолонок)
    ТЗ = Новый ТаблицаЗначений;
    Для Каждого ИмяКолонки Из СтрокаВМассив(ИменаКолонок) Цикл
        ТЗ.Колонки.Добавить(ИмяКолонки);
    КонецЦикла;
    Возврат ТЗ;
КонецФункции

#КонецОбласти
