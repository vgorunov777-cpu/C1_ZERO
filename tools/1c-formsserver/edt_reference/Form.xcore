//----END GROUPS -----
//---- FIELDS ---ToolTip
/*
 * origin name Field
 */
abstract class DataItem extends FormItem, NamedElement, Titled, TitleStyle, Visible, ExtensionAdoptedProperty
{
    contains AbstractDataPath dataPath
    boolean defaultItem
    Boolean skipOnInput
    contains Color titleBackColor
    FormElementTitleLocation titleLocation
    int titleHeight
    Shortcut shortcut
}

class Button extends DataItem, ExtendedTooltipHolder
{
    ManagedFormButtonType ^type
    refers Command commandName
    contains Value parameter // can be ReferenceValue or TypeDescriptionValue
    ButtonImportance buttonImportance // since 8.5.1
    ButtonRepresentation representation
    boolean defaultButton
    Boolean onlyInAllActions // important
    @FormProperty(^id="width[0:max]")
    int width
    boolean autoMaxWidth
    int maxWidth
    int minWidth
    @FormProperty(^id="height[0:max]")
    int height
    boolean autoMaxHeight
    int maxHeight
    @FormProperty(^id="horizontalStretch[chbox]")
    boolean horizontalStretch
    @FormProperty(^id="verticalStretch[chbox]")
    boolean verticalStretch
    ItemHorizontalAlignment groupHorizontalAlign
    ItemVerticalAlignment groupVerticalAlign
    // TODO: Check whether this is used in UI and serializable. If not, it should be changed to transient
    MenuElementPlacementArea placementArea
    boolean check
    contains Color textColor
    contains Color backColor
    contains Color borderColor
    contains Font font
    contains Picture picture
    TooltipRepresentation toolTipRepresentation
    RepresentationInContextMenu representationInContextMenu
    ButtonShape shape
    ButtonShapeRepresentation shapeRepresentation
    FormButtonPictureLocation pictureLocation
    contains Picture backPicture // since 8.5.1
    PictureRepresentationEffect backPictureEffect // since 8.5.1
    int pictureHeight // since 8.5.1
    CardPictureAndTitleAlignVariant cardPictureAndTitleAlign // since 8.5.1
    ButtonLocationInCommandBar locationInCommandBar // since 8.3.15
    boolean commandUniqueness = "true" // since 8.3.15
    OnMainServerUnavalableBehavior onMainServerUnavalableBehavior // since 8.3.16
    boolean showAsCard // since 8.5.1
    op boolean validate(EDiagnosticChain diagnostics, EMap<Object, Object> context) {
        ButtonValidator::validate(this, diagnostics, context)
    }

    // Used in logical layouter only, e.g. MenuButtonGenerator
    transient String extName = "" // since 8.5.1
}

class FormField extends DataItem, FormStandardCommandSource, TitleStyle, TooltipContainer, EventHandlerContainer, ExtendedTooltipHolder, ContextMenuHolder, SelectedItemsActionsPanelHolder, AdditionSource, ExtensionAdoptedProperty
{
    // properties -----------------------------------------
    ManagedFormFieldType ^type
    boolean readOnly
    WarningOnEditRepresentation warningOnEditRepresentation
    contains LocalStringMapEntry[] warningOnEdit
    Boolean markRequiredComplete // since 8.5.1
    ItemHorizontalAlignment horizontalAlign
    ItemVerticalAlignment verticalAlign
    ItemHorizontalAlignment groupHorizontalAlign
    ItemVerticalAlignment groupVerticalAlign
    TableFieldEditMode editMode
    FormFixedInTable fixingInTable
    boolean cellHyperlink
    boolean autoCellHeight
    boolean showInHeader
    contains Picture headerPicture
    ItemHorizontalAlignment headerHorizontalAlign
    boolean showInFooter
    contains AbstractDataPath footerDataPath
    contains LocalStringMapEntry[] footerText
    contains Color footerTextColor
    contains Color footerBackColor
    contains Font footerFont
    contains Picture footerPicture
    ItemHorizontalAlignment footerHorizontalAlign
    OnMainServerUnavalableBehavior onMainServerUnavalableBehavior // since 8.3.16
    boolean showInCard // since 8.5.1
    Boolean fixInCard // since 8.5.1
    WidthVariantInCard widthInCard // since 8.5.1
    TableCellMarkType cellMark // since 8.5.1
    AppearanceVariantInCard appearanceInCard // since 8.5.1
    AutoWidthInTable autoWidthInTable // since 8.5.1
    Boolean showTitleInCard // since 8.5.1
    CellHyperlinkRepresentation cellHyperlinkRepresentation // since 8.5.1
    CellHyperlinkDisplayVariant cellHyperlinkDisplayVariant // since 8.5.1
    // extension ------------------------------------------
    contains FieldExtInfo extInfo
    op boolean validate(EDiagnosticChain diagnostics, EMap<Object, Object> context) {
        FieldValidator::validate(this, diagnostics, context)
    }
}

