//----END Form
abstract class AbstractFormAttribute extends NamedElement, Titled
{
    int ^id // originally: decimal id
    contains TypeDescription[1] valueType
    contains AdjustableBoolean[1] view
    contains AdjustableBoolean[1] edit
    FillChecking fillChecking
    refers FunctionalOption[] functionalOptions
}

class FormAttribute extends AbstractFormAttribute, ExtensionAdoptedProperty // AttributeType in xcf_logform.xsd
{
    contains AbstractDataPath[] notDefaultUseAlwaysAttributes // instead of ContentType[1]  // Колонки атрибута, для которых НЕ установлено 'Использовать всегда'
    contains AbstractDataPath[] settingsSavedData // instead of ContentType[1]  // Колонки атрибута, для которых установлено 'Сохранение'
    boolean main // originally MainAttribute
    boolean savedData
    contains FormAttributeColumn[] columns // instead of 'contains AttributeColumns[1] columns'
    @CollectionItemId(feature="tablePath")
    contains FormAttributeAdditionalColumns[] additionalColumns // ----||-----
    contains FormAttributeExtInfo extInfo
    String comment // not supported by Designer. import\export must ignore
    op boolean validate(EDiagnosticChain diagnostics, EMap<Object, Object> context) {
        FormAttributeValidator::validate(this, diagnostics, context)
    }
}

abstract class AbstractDataPath
{
    String[1..*] segments
    contains transient DataPathReferredObject[] objects
    op boolean validate(EDiagnosticChain diagnostics, EMap<Object, Object> context) {
        DataPathValidator::validate(this, diagnostics, context)
    }
    op String toString() {
        "/" + getSegments.join("/") // $NON-NLS-1$ $NON-NLS-2$
    }
    // First unresolved data path resides inside of the data path object itself, the remainder is
    // scattered into extra paths array. This is used to substitute deprected MultiLanguageDataPath
    // approach which turned out to be inappropriate
    transient String[] extraPaths
}

class DataPathReferredObject
{
    refers EObject object
    contains TypeDescription valueType
    int segmentIdx
    boolean aggregateFunction
    boolean index
    boolean virtual // such referred object does not assume the presence of an object source
    op boolean validate(EDiagnosticChain diagnostics, EMap<Object, Object> context) {
        true
    }
}

class DataPath extends AbstractDataPath
{
}

/*
 * The Multy language data path implementation.
 * 
 * <p>Do not attempt to get access to <code>segments</code> or <code>objects</code> fields
 * by <code>eGet</code> method, because they are not used in this implementation.
 * Use {@link #getSegments()}, {@link #getObjects()} or <code>eGet</code> with <code>paths</code>
 * field and current <code>activeLanguage</code> as index instead. </p>
 * 
 * @NotThreadSafe
 * 
 * @Deprecated use DataPath
 */
class MultiLanguageDataPath extends DataPath
{
    int activeLanguage
    contains AbstractDataPath[] paths
    op DataPathReferredObject[] getObjects() {
        if (paths.get(activeLanguage) !== null) {
            return paths.get(activeLanguage).objects
        }
        return null
    }
    op String[] getSegments() {
        if (paths.get(activeLanguage) !== null) {
            return paths.get(activeLanguage).segments
        }
        return null
    }
}

class IrresolvableDataPath extends AbstractDataPath
{
}

