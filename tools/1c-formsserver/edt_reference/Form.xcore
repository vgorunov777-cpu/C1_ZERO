class Table extends DataItem, FieldSource, FormStandardCommandSource, AdditionSource, TooltipContainer, FormItemContainer, CommandBarHolder, EventHandlerContainer, AdditionContainer,  ExtendedTooltipHolder, ContextMenuHolder, SelectedItemsActionsPanelHolder, RowActionsPanelHolder
{
    // properties -----------------------------------------
    TableRepresentation representation
    boolean autoFill
    boolean readOnly
    boolean changeRowSet
    boolean changeRowOrder
    @FormProperty(^id="width[0:max]")
    int width
    boolean autoMaxWidth
    int maxWidth
    int minWidth
    @FormProperty(^id="height[0:max]")
    int height
    boolean autoMaxHeight
    int maxHeight
    int heightInTableRows
    LogFormTableHeightControlVariant heightControlVariant // since 8.3.9
    boolean autoMaxRowsCount // since 8.3.10
    int maxRowsCount // since 8.3.10
    boolean choiceMode
    boolean multipleChoice
    TableRowInputMode rowInputMode
    TableSelectionMode selectionMode
    TableRowSelectionMode rowSelectionMode
    TableRowActionsShowType rowActionsShowType // since 8.5.1
    boolean header
    int headerHeight
    boolean footer
    int footerHeight
    TableScrollBarUse horizontalScrollBar
    TableScrollBarUse verticalScrollBar
    boolean horizontalLines // deprecated since 8.5.1
    boolean verticalLines // deprecated since 8.5.1
    // long fixedLeft     //  it seems to be runtime
    // long fixedRight    //  it seems to be runtime
    boolean useAlternationRowColor // deprecated since 8.5.1
    Boolean horizontalLinesBWA // since 8.5.1
    Boolean verticalLinesBWA // since 8.5.1
    Boolean useAlternationRowColorBWA // since 8.5.1
    boolean autoInsertNewRow
    Boolean autoAddIncomplete
    Boolean autoMarkIncomplete
    SearchOnInput searchOnInput
    Boolean markRequiredComplete // since 8.5.1
    TableInitialListView initialListView
    TableInitialTreeView initialTreeView
    TableInitialRowActivation initialRowActivation // since 8.5.1
    UseOutput output
    @FormProperty(^id="horizontalStretch[chbox]")
    boolean horizontalStretch
    @FormProperty(^id="verticalStretch[chbox]")
    boolean verticalStretch
    boolean enableStartDrag
    boolean enableDrag
    FileDragMode fileDragMode // since 8.3.13
    // данные, предоставляемые интерфейсом ILogFormDataElement и ему подобным
    contains AbstractDataPath rowPictureDataPath
    contains Picture rowsPicture
    contains Color textColor
    contains Color backColor
    contains Color borderColor
    contains Font font
    SaveTableAppearance saveColors // since 8.5.1
    String iconSaveColorsKey // since 8.5.1
    String shapeSaveColorsKey // since 8.5.1
    CellHyperlinksRepresentation cellHyperlinksRepresentation // since 8.5.1, 8.5 mode only
    SearchStringLocation searchStringLocation
    ViewStatusLocation viewStatusLocation
    SearchControlLocation searchControlLocation
    HierarchyPanelLocation hierarchyPanelLocation // since 8.5.1
    boolean hierarchyPanelVisible // since 8.5.1
    boolean verticalScrollPanelVisible // since 8.5.1
    ItemHorizontalAlignment groupHorizontalAlign
    ItemVerticalAlignment groupVerticalAlign
    RefreshRequestMethod refreshRequest
    TableCurrentRowUse currentRowUse // since 8.3.12
    TableBehaviorOnHorizontalCompression behaviorOnHorizontalCompression // since 8.3.12
    CardBehaviorOnVerticalCompression cardBehaviorOnVerticalCompression // since 8.5.1
    boolean autoMaxCardHeight // since 8.5.1
    int maxCardHeight // since 8.5.1
    unsettable DataCompositionSettingsViewMode viewMode
    unsettable DataCompositionComplexSettingsViewMode complexSettingsViewMode // since 8.5.1
    unsettable boolean settingsNamedItemDetailedRepresentation
    contains Value rowFilter
    OnMainServerUnavalableBehavior onMainServerUnavalableBehavior // since 8.3.16 // all tables! not in extinfo
    FormTableType mobileDeviceTableType // since 8.5.1 
    contains TableExtInfo extInfo
    boolean showCommandBarNeedDereferenced // since 8.5.1
    op boolean validate(EDiagnosticChain diagnostics, EMap<Object, Object> context) {
        TableValidator::validate(this, diagnostics, context)
    }
}

