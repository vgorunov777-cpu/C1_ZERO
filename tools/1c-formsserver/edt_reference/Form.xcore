interface Visible
{
    boolean visible
    unsettable boolean enabled
    contains AdjustableBoolean[1] userVisible
}

interface Titled
{
    contains LocalStringMapEntry[] title
}

interface TitleStyle
{
    contains Color titleTextColor
    contains Font titleFont
}

interface TooltipContainer
{
    contains LocalStringMapEntry[] toolTip
    TooltipRepresentation toolTipRepresentation
}

interface AdditionSource
{
}

interface ExtendedTooltipHolder
{
    // predefined elements --------------------------------
    contains ExtendedTooltip extendedTooltip
}

//since 8.5.1
interface SelectedItemsActionsPanelHolder
{
    // predefined elements --------------------------------
    contains transient SelectedItemsActionsPanel selectedItemsActionsPanel // layouter only
}

//since 8.5.1
interface RowActionsPanelHolder
{
    // predefined elements --------------------------------
    contains transient RowActionsPanel rowActionsPanel // layouter only
}

interface ContextMenuHolder
{
    // predefined elements --------------------------------
    contains ContextMenu contextMenu
}

/* Event handler container is an abstraction that contains collection of event handlers. */
interface EventHandlerContainer
{
    contains EventHandler[] handlers
}

/* The flag of the user changes being applied to the extension form object property */
class ExtensionUserChangedPropertyEntry wraps java.util.Map$Entry
{
    String[1] key
    Boolean[1] value
}

/* Event handler handles some event and contains information about module handler method name. */
class EventHandler
{
    refers Event[1] event
    String[1] name
}

/* Event handler extension handles some event and contains information about module handler method name and method call interception type. */
class EventHandlerExtension extends EventHandler
{
    ExtendedMethodCallType callType
}

/* Command handler container is an abstraction that contains information about command handlers. */
interface CommandHandlerContainer
{
}

/* Form command handler container contains single command handler. */
class FormCommandHandlerContainer extends CommandHandlerContainer
{
    contains CommandHandler handler
}

/* Form extension command handler container contains collection of command handler. */
class FormExtensionCommandHandlerContainer extends CommandHandlerContainer
{
    contains CommandHandlerExtension[] handlers
}

/* Command handler handles some command and contains information about module handler method name. */
class CommandHandler
{
    String[1] name
}

/* Command handler extension handles some command and contains information about module handler method name and method call interception type. */
class CommandHandlerExtension extends CommandHandler
{
    ExtendedMethodCallType callType
}

interface CommandBarHolder
{
    FormElementCommandBarLocation commandBarLocation
    Boolean showCommandBar // since 8.5.1
    // predefined elements --------------------------------
    contains AutoCommandBar autoCommandBar // instead of 'contains PredefinedChildItems predefinedContainedItems'
    contains transient AutoCommandBar topCommandBar // since 8.5.1
    contains transient AutoCommandBar bottomCommandBar // since 8.5.1
    contains transient AutoCommandBar fABCommandBar // since 8.5.1
}

// since 8.3.21
interface TableHolder
{
    contains Table autoTable
}

class FormStandardCommand extends DuallyNamedElement, Command
{
    String text
    String tooltip // layouter only
    Shortcut shortcut // layouter only
    contains Picture picture
    boolean defaultCommand // layouter only
    DefaultRepresentation representation // layouter only
    boolean important // layouter only
    boolean modifiesData // layouter only
    boolean usesExtraParameter // layouter only
    boolean topFormCommandBar // since 8.5.1, layouter only
    boolean userVisible // since 8.5.1
    boolean createButton // since 8.5.1, layouter only
    CurrentRowUse currentRowUse // since 8.5.1, layouter only
    SelectedRowsUse selectedRowsUse // since 8.5.1, layouter only
}

interface FormStandardCommandSource
{
    contains transient FormStandardCommand[] commands // inferred
    refers FormStandardCommand[] excludedCommands // CommandSet
}

/**
 * The marker object that points to the command panel of the form command intrerface. Being used
 * as a standard command source.
 */
class FormCommandPanelGlobalCommandSource extends FormStandardCommandSource
{
}

class FormCommandInterface
{
    contains FormCommandInterfaceItems navigationPanel
    contains FormCommandInterfaceItems commandBar
}

interface FormItemContainer extends FormVisualEntity
{
    contains FormItem[] items
}

interface AdditionContainer
{
    // predefined elements --------------------------------
    contains Addition searchStringAddition
    contains Addition viewStatusAddition
    contains Addition searchControlAddition
}

/*
 * this model it is aggregate origin PredefinedChildItems and origin FormVisualEntity
 */
abstract class FormVisualEntity
{
    /* Collection of form item extension property user change flags */
    contains transient ExtensionUserChangedPropertyEntry[] userChangedProperties
}

type PropertyInfo wraps com._1c.g5.v8.dt.form.model.PropertyInfo

type ElementDataSourceInfo wraps com._1c.g5.v8.dt.form.model.ElementDataSourceInfo

//----Form
class Form extends Titled, FormVisualEntity, FormItemContainer, CommandBarHolder, EventHandlerContainer,
      AbstractForm, FieldSource, FormStandardCommandSource, ExtensionAdoptedProperty  // LogForm in xcf_logform.xsd
{
    @FormProperty(^id="width[0:max]")
    int width
    @FormProperty(^id="height[0:max]")
    int height
    FormWindowOpeningMode windowOpeningMode // deprecated since 8.5.1
    OnFormWindowOpenLockMode onFormWindowOpenLockMode // since 8.5.1
    FormWindowViewMode windowViewMode // since 8.5.1
    FormEnterKeyBehavior enterKeyBehavior
    AutoSaveFormDataInSettings autoSaveDataInSettings
    SaveFormDataInSettings saveDataInSettings
    boolean saveWindowSettings // since 8.3.23
    refers SettingsStorage settingsStorage
    boolean autoTitle
    boolean autoUrl
    FormChildrenGroup group
    FormChildrenAlign childrenAlign
    FormItemSpacing horizontalSpacing
    FormItemSpacing verticalSpacing
    ItemHorizontalAlignment horizontalAlign
    ItemVerticalAlignment verticalAlign
    ChildrenTitleLocation childItemsTitleLocation // since 8.5.1
    FormChildrenWidth childItemsWidth
    boolean autoFillCheck
    boolean allowFormCustomize
    boolean enabled
    // boolean readOnly     --runtime
    LogFormScrollMode verticalScroll
    FormBaseFontVariant scalingMode
    double scale = "100" // since 8.3.10
    boolean showTitle // since 8.3.10, deprecated since 8.5.1
    ShowTitle851 showTitle851 // since 8.5.1
    boolean showCloseButton // since 8.3.10
    FormConversationsRepresentation conversationsRepresentation // since 8.3.10
    CollapseFormItemsByImportance collapseItemsByImportanceVariant // since 8.3.12
    contains LocalStringMapEntry[] createButtonsGroupTitle // since 8.5.1
    contains Picture createButtonsGroupPicture // since 8.5.1
    contains ValueListItem[] mobileDeviceCommandBarContent // since 8.3.12.1658
    ClientApplicationFormScaleVariant scaleVariant // since 8.5.1
    @ExternalProperty
    refers transient Form baseForm
    refers transient Form extensionForm // back ref to extension form from base form
    // #start FormAttributes
    contains FormAttribute[] attributes
    @ExternalProperty
    refers transient DataCompositionConditionalAppearance conditionalAppearance
    // #end FormAttributes
    contains FormCommand[] formCommands
    contains FormParameter[] parameters
    contains FormCommandInterface[1] commandInterface
    contains FormExtInfo extInfo
    contains transient FormCommandPanelGlobalCommandSource commandPanelGlobalCommandSource
    transient InterfaceType interfaceType = "Any" // since 8.5.1, ui-only
    op PropertyInfo[] propertyInfos() {
        return new UnmodifiableEList(FormPropertyInfoExtension::getPropertyInfoBySource(this))
    }
    op ElementDataSourceInfo[] elementDataSourceInfos() {
        return new UnmodifiableEList(FormElementDataSourceInfoExtension::getElementDataSourceInfoBySource(this))
    }
    op boolean validate(EDiagnosticChain diagnostics, EMap<Object, Object> context) {

        // TODO add main item validation G5V8DT-2606
        FormValidator::validate(this, diagnostics, context)
    }
}

