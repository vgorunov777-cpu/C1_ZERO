/*
 * <b>!!! Attention !!!</b> Add new FormItem you must
 *  1) add corresponding type to com._1c.g5.v8.dt.form.resource.FormItemInformationService
 *  2) if new FormItem contains ExtInfo you must update method "getExtensionInfo" in com._1c.g5.v8.dt.form.resource.FormItemInformationService
 *  3) if new FormItem contains ExtInfo you must update method "getBindEvents" in com._1c.g5.v8.dt.form.resource.FormItemInformationService
 */
abstract class FormItem extends NamedElement, FormVisualEntity
{
    int ^id
    DisplayImportance displayImportance // since 8.3.12
    /* form item extension property position change flag */
    transient boolean positionChanged
    transient Origin origin // layouter only
}

// FormItems -----
/*
 * Origin GroupBase
 */
abstract class Group extends FormItem, FormItemContainer, Visible, Titled, TitleStyle, TooltipContainer
{
    boolean readOnly
    boolean enableContentChange
    Shortcut shortcut
    @FormProperty(^id="width[0:max]")
    int width
    @FormProperty(^id="height[0:max]")
    int height
    @FormProperty(^id="horizontalStretch[enum]")
    Boolean horizontalStretch
    @FormProperty(^id="verticalStretch[enum]")
    Boolean verticalStretch
    ItemHorizontalAlignment groupHorizontalAlign
    ItemVerticalAlignment groupVerticalAlign
    // see m_degeneratable mngcore\src\res\logform.xsd
    // Used in logical layouter only
    transient boolean degeneratable
}

