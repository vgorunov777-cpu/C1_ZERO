// since 8.3.21, mngcore/ILogForm.h
/**
 * Положение таблицы диаграммы Ганта.
*/
enum GanttChartTableLocation
{
    Auto = 0 // eGCTLAuto
    Left = 1 // eGCTLLeft
    Right = 2 // eGCTLRight
    None = 3 // eGCTLNone
}

// since 8.3.23, mngcore/ILogForm.h
/**
 * Режим выделения значений диаграммы Ганта.
*/ 
enum GanttChartValuesSelectionMode
{
    Auto = 0 // eGCVSMAuto
    Multiple = 1 // eGCVSMMultiValue
    Single = 2 // eGCVSMSingleValue
    None = 3 // eGCVSMNone
}

// since 8.3.23, mngcore/ILogForm.h
/**
 * Режим выделения интервалов диаграммы Ганта.
*/
enum GanttChartIntervalsSelectionMode
{
    Auto = 0 // eGCISMAuto
    Multiple = 1 // eGCISMMultiValue
    Single = 2 // eGCISMSingleValue
    None = 3 // eGCISMNone
}

