&НаКлиенте
Процедура ВыгрузитьТаблицуВExcel(Команда)

	ИмяФайла = "Таблица.xlsx";

	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
	Диалог.Заголовок = "Сохранить таблицу в Excel";
	Диалог.Фильтр = "Файлы Excel (*.xlsx)|*.xlsx";
	Диалог.ПолноеИмяФайла = ИмяФайла;
	Диалог.Расширение = "xlsx";

	ОписаниеОповещения = Новый ОписаниеОповещения("ВыгрузитьТаблицуЗавершение", ЭтотОбъект);
	Диалог.Показать(ОписаниеОповещения);

КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьТаблицуЗавершение(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт

	Если ВыбранныеФайлы = Неопределено Или ВыбранныеФайлы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;

	ПутьКФайлу = ВыбранныеФайлы[0];
	ТаблицаЗначений = РеквизитФормыВЗначение("ИмяРеквизитаФормыСТаблицей", Тип("ТаблицаЗначений"));
	ТабличныйДокумент = ВывестиТаблицуЗначенийВТабличныйДокумент(ТаблицаЗначений);

	Попытка
		ТабличныйДокумент.Записать(ПутьКФайлу, ТипФайлаТабличногоДокумента.XLSX);
		ПоказатьПредупреждение(, "Файл сохранён: " + ПутьКФайлу);
	Исключение
		ПоказатьПредупреждение(, "Ошибка сохранения: " + ОписаниеОшибки());
	КонецПопытки;

КонецПроцедуры
