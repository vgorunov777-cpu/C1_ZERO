{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ensure MCP Services (1c-forms-mcp + 1c-templates)",
      "type": "shell",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-File", "${workspaceFolder}/.cursor/ensure-mcp-services.ps1"
      ],
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "group": "build"
    }
  ]
}
