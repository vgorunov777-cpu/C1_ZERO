{
  "name": "Валидация роли с несколькими объектами",
  "preRun": [
    {
      "script": "meta-compile/scripts/meta-compile",
      "input": {
        "type": "Catalog",
        "name": "Товары"
      },
      "args": {
        "-JsonPath": "{inputFile}",
        "-OutputDir": "{workDir}"
      }
    },
    {
      "script": "meta-compile/scripts/meta-compile",
      "input": {
        "type": "Document",
        "name": "Заказ"
      },
      "args": {
        "-JsonPath": "{inputFile}",
        "-OutputDir": "{workDir}"
      }
    },
    {
      "script": "role-compile/scripts/role-compile",
      "input": {
        "name": "Менеджер",
        "objects": [
          "Catalog.Товары: @view",
          "Document.Заказ: @edit"
        ]
      },
      "args": {
        "-JsonPath": "{inputFile}",
        "-OutputDir": "{workDir}"
      }
    }
  ],
  "params": {
    "rightsPath": "Roles/Менеджер/Ext/Rights.xml"
  }
}
