          "fields": ["Номенклатура", "Количество: decimal(15,3)"]
        }]
      },
      "args": { "-DefinitionFile": "{inputFile}", "-OutputPath": "{workDir}/Template.xml" }
    }
  ],
  "params": {
    "templatePath": "Template.xml",
    "operation": "add-total",
    "value": "Количество: Сумма"
  }
}
