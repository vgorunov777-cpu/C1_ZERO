{
  "script": "cf-init/scripts/cf-init",
  "setup": "none",
  "args": [
    { "flag": "-Name", "from": "case.name" },
    { "flag": "-OutputDir", "from": "workDir" }
  ],
  "snapshot": {
    "root": "workDir",
    "normalizeUuids": true
  },
  "postValidate": { "script": "cf-validate/scripts/cf-validate", "flag": "-ConfigPath", "pathFrom": "workDir" }
}
