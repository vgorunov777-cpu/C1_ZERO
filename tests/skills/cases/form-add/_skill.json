{
  "script": "form-add/scripts/form-add",
  "setup": "empty-config",
  "args": [
    { "flag": "-ObjectPath", "from": "workPath", "field": "objectPath" },
    { "flag": "-FormName", "from": "case.formName" }
  ],
  "snapshot": {
    "root": "workDir",
    "normalizeUuids": true
  },
  "postValidate": { "script": "form-validate/scripts/form-validate", "flag": "-FormPath", "pathFrom": "validatePath" }
}
