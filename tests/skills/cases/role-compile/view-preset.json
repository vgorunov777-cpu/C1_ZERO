{
  "name": "Роль с пресетом @view",
  "preRun": [
    {
      "script": "meta-compile/scripts/meta-compile",
      "input": {
        "type": "Catalog",
        "name": "Номенклатура"
      },
      "args": {
        "-JsonPath": "{inputFile}",
        "-OutputDir": "{workDir}"
      }
    },
    {
      "script": "meta-compile/scripts/meta-compile",
      "input": {
        "type": "DataProcessor",
        "name": "Загрузка"
      },
      "args": {
        "-JsonPath": "{inputFile}",
        "-OutputDir": "{workDir}"
      }
    }
  ],
  "input": {
    "name": "ЧтениеНоменклатуры",
    "synonym": "Чтение номенклатуры",
    "objects": [
      "Catalog.Номенклатура: @view",
      "DataProcessor.Загрузка: @view"
    ]
  },
  "validatePath": "Roles/ЧтениеНоменклатуры",
  "expect": {
    "files": [
      "Roles/ЧтениеНоменклатуры.xml",
      "Roles/ЧтениеНоменклатуры/Ext/Rights.xml"
    ]
  }
}
