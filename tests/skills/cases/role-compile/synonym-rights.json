{
  "name": "Синоним: rights вместо objects",
  "preRun": [
    {
      "script": "meta-compile/scripts/meta-compile",
      "input": {
        "type": "Catalog",
        "name": "Товары"
      },
      "args": {
        "-JsonPath": "{inputFile}",
        "-OutputDir": "{workDir}"
      }
    }
  ],
  "input": {
    "name": "Кладовщик",
    "rights": [
      "Catalog.Товары: Read View"
    ]
  },
  "validatePath": "Roles/Кладовщик",
  "expect": {
    "files": [
      "Roles/Кладовщик.xml",
      "Roles/Кладовщик/Ext/Rights.xml"
    ]
  }
}
