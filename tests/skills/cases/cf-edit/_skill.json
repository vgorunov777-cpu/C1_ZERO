{
  "script": "cf-edit/scripts/cf-edit",
  "setup": "empty-config",
  "args": [
    { "flag": "-ConfigPath", "from": "workDir" },
    { "flag": "-DefinitionFile", "from": "inputFile" }
  ],
  "snapshot": {
    "root": "workDir",
    "normalizeUuids": true
  },
  "postValidate": { "script": "cf-validate/scripts/cf-validate", "flag": "-ConfigPath", "pathFrom": "workDir" }
}
