{
  "script": "epf-init/scripts/init",
  "setup": "none",
  "args": [
    { "flag": "-Name", "from": "case.name" },
    { "flag": "-SrcDir", "from": "workDir" }
  ],
  "snapshot": {
    "root": "workDir",
    "normalizeUuids": true
  },
  "postValidate": { "script": "epf-validate/scripts/epf-validate", "flag": "-ObjectPath", "pathFrom": "validatePath" }
}
