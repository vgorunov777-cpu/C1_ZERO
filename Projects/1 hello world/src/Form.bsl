// Модуль формы внешней обработки "Hello World"

Перем ЭлементФормыТекст;

Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ЭлементФормыТекст = "Загрузка...";
КонецПроцедуры

Процедура ПриОткрытии(Отказ)
	ЭлементФормыТекст = Объект.ПолучитьПриветствие();
КонецПроцедуры

Процедура КнопкаОК(Элемент)
	Сообщить(Объект.ПолучитьПриветствие());
	Закрыть();
КонецПроцедуры

Процедура КнопкаЗакрыть(Элемент)
	Закрыть();
КонецПроцедуры
