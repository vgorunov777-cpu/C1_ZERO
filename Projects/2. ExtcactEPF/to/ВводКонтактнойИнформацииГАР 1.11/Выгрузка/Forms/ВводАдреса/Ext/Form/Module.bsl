// Возвращает варианты типов домов (по признаку владения).
&НаСервере 
Функция Обработки_РасширенныйВводКонтактнойИнформации_ВариантыДанныхДом() Экспорт
	
	Результат = Новый Структура("ВариантыТипа, МожноПодбиратьЗначения", Новый Массив, Ложь);
	
	//Если ОбщегоНазначения_ПодсистемаСуществует("СтандартныеПодсистемы.АдресныйКлассификатор") Тогда
	//	МодульАдресныйКлассификаторПовтИсп = ОбщегоНазначения_ОбщийМодуль("АдресныйКлассификаторПовтИсп");
		ВладенияИСтроения = АдресныйКлассификаторПовтИсп_НаименованияВладенийИСтроений();
		
		Для каждого КлючИЗначение Из ВладенияИСтроения.Владения Цикл
			Результат.ВариантыТипа.Добавить(КлючИЗначение.Значение);
		КонецЦикла;
		
	//КонецЕсли;
	
	ДополнительныеВариантыТипов = РаботаСАдресами_НаименованияОбъектовАдресацииПоТипу(1, Ложь);
	ОбщегоНазначенияКлиентСервер_ДополнитьМассив(Результат.ВариантыТипа, ДополнительныеВариантыТипов);
	
	Позиция = Результат.ВариантыТипа.Найти(ДополнительныеВариантыТипов.Получить(0));
	Если Позиция <> Неопределено И Позиция > 0 Тогда
		ЗаписьОДоме = Результат.ВариантыТипа.Получить(Позиция);
		Результат.ВариантыТипа.Удалить(Позиция);
		Результат.ВариантыТипа.Вставить(0, ЗаписьОДоме);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

