Процедура РаботаСАдресами_ПриДобавленииКлассификаторов(Классификаторы) 
	
	Описание = Неопределено;
	//Если ОбщегоНазначения_ПодсистемаСуществует("ИнтернетПоддержкаПользователей.РаботаСКлассификаторами") Тогда
	//	МодульРаботаСКлассификаторами = ОбщегоНазначения_ОбщийМодуль("РаботаСКлассификаторами");
		Описание = РаботаСКлассификаторами_ОписаниеКлассификатора();
	//КонецЕсли;
	Если Описание = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Описание.Идентификатор              = РаботаСАдресами_ИдентификаторКлассификатора();
	Описание.Наименование               = НСтр("ru = 'Общероссийский классификатор стран мира'");
