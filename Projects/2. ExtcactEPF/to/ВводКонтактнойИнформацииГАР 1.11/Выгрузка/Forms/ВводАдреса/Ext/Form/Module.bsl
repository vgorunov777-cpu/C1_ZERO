// Возвращает пустую структура адреса.
//
// Возвращаемое значение:
//    Структура - адрес, ключи - имена полей, значения поля.
//
Функция УправлениеКонтактнойИнформациейКлиентСервер_СтруктураПолейАдреса() 
	
	СтруктураАдреса = Новый Структура;
	СтруктураАдреса.Вставить("Представление", "");
	СтруктураАдреса.Вставить("Страна", "");
	СтруктураАдреса.Вставить("НаименованиеСтраны", "");
	СтруктураАдреса.Вставить("КодСтраны","");
	
	Возврат СтруктураАдреса;
	
КонецФункции

#Область СлужебныеПроцедурыИФункцииПоРаботеСXMLАдресами

// Возвращает структуру с наименованием и сокращением от значения.
//
// мПараметры:
//     Текст - Строка - полное наименование.
//
// Возвращаемое значение:
//     Структура:
//         * Наименование - Строка - часть текста.
//         * Сокращение   - Строка - часть текста.
//
Функция УправлениеКонтактнойИнформациейКлиентСервер_НаименованиеСокращение(Знач мТекст) 
	мРезультат = Новый Структура("Наименование, Сокращение");
	
	мТекст = СокрЛП(мТекст);
	
	ТекстВерхнийРегистр = ВРег(мТекст);
	Если СтрЗаканчиваетсяНа(ТекстВерхнийРегистр, "ТЕР. СНТ")
		Или СтрЗаканчиваетсяНа(ТекстВерхнийРегистр, "ТЕР. ДНТ") Тогда
		мРезультат.Сокращение = Прав(мТекст, 8);
		мРезультат.Наименование = Лев(мТекст, СтрДлина(мТекст) - 9);
		Возврат мРезультат;
	КонецЕсли;
	
	мЧасти = УправлениеКонтактнойИнформациейКлиентСервер_НаборНаименованийИСокращений(мТекст, Истина);
	Если мЧасти.Количество() > 0 Тогда
		ЗаполнитьЗначенияСвойств(мРезультат, мЧасти[0]);
	Иначе
		мРезультат.Наименование = мТекст;
	КонецЕсли;
	
	Возврат мРезультат;
КонецФункции

Функция УправлениеКонтактнойИнформациейКлиентСервер_СоединитьНаименованиеИТипАдресногоОбъекта(Знач Наименование, Знач ТипАдресногоОбъекта, ЭтоРегион = Ложь) 
	
	Если ПустаяСтрока(ТипАдресногоОбъекта) Тогда
		Возврат Наименование;
	КонецЕсли;
	
	Если ЭтоРегион Тогда
		
		// Локализация
		Если УправлениеКонтактнойИнформациейКлиентСервер_НаименованиеРегионаБезТипа(Наименование) Тогда
			Возврат СокрЛП(Наименование);
		КонецЕсли;
		// Конец Локализация
		
		Возврат СокрЛП(Наименование + " " + ТипАдресногоОбъекта);
	КонецЕсли;
	
	Возврат СокрЛП(ТипАдресногоОбъекта + " "+ Наименование);
	
КонецФункции

// Разделяет текст на слова по указанным разделителям. По умолчанию разделители - пробельные символы.
//
// мПараметры:
//     Текст       - Строка - разделяемая строка.
//     Разделители - Строка - необязательная строка символов-разделителей.
//
// Возвращаемое значение:
//     Массив - строки, слова
//
Функция УправлениеКонтактнойИнформациейКлиентСервер_СловаТекста(Знач Текст, Знач Разделители = Неопределено)
	
	НачалоСлова = 0;
	Состояние   = 0;
	Результат   = Новый Массив;
	
	Для Позиция = 1 По СтрДлина(Текст) Цикл
		ТекущийСимвол = Сред(Текст, Позиция, 1);
		ЭтоРазделитель = ?(Разделители = Неопределено, ПустаяСтрока(ТекущийСимвол), СтрНайти(Разделители, ТекущийСимвол) > 0);
		
		Если Состояние = 0 И (Не ЭтоРазделитель) Тогда
			НачалоСлова = Позиция;
			Состояние   = 1;
		ИначеЕсли Состояние = 1 И ЭтоРазделитель Тогда
			Результат.Добавить(Сред(Текст, НачалоСлова, Позиция-НачалоСлова));
			Состояние = 0;
		КонецЕсли;
	КонецЦикла;
	
	Если Состояние = 1 Тогда
		Результат.Добавить(Сред(Текст, НачалоСлова, Позиция-НачалоСлова));    
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

// Разделяет текст, разделенный запятыми.
//
// мПараметры:
//     Текст              - Строка - разделяемый текст.
//     ВыделятьСокращения - Булево - опциональный параметр режима работы.
//
// Возвращаемое значение:
//     Массив - содержит структуры "Наименование, Сокращение".
//
Функция УправлениеКонтактнойИнформациейКлиентСервер_НаборНаименованийИСокращений(Знач мТекст, Знач мВыделятьСокращения = Истина)
	
	мРезультат = Новый Массив;
	Для Каждого мЧасть Из УправлениеКонтактнойИнформациейКлиентСервер_СловаТекста(мТекст, ",") Цикл
		мСтрокаЧасти = СокрЛП(мЧасть);
		Если ПустаяСтрока(мСтрокаЧасти) Тогда
			Продолжить;
		КонецЕсли;
		
		мПозиция = ?(мВыделятьСокращения, СтрДлина(мСтрокаЧасти), 0);
		Пока мПозиция > 0 Цикл
			Если Сред(мСтрокаЧасти, мПозиция, 1) = " " Тогда
				мРезультат.Добавить(Новый Структура("Наименование, Сокращение",
					СокрЛП(Лев(мСтрокаЧасти, мПозиция-1)), СокрЛП(Сред(мСтрокаЧасти, мПозиция))));
				мПозиция = -1;
				Прервать;
			КонецЕсли;
			мПозиция = мПозиция - 1;
		КонецЦикла;
		Если мПозиция = 0 Тогда
			мРезультат.Добавить(Новый Структура("Наименование, Сокращение", мСтрокаЧасти));
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат мРезультат;
КонецФункции

#КонецОбласти

#Область ПрочиеСлужебныеПроцедурыИФункции

// Дополняет представление адреса строкой.
//
// мПараметры:
//    Дополнение         - Строка - дополнение адреса.
//    СтрокаКонкатенации - Строка - строка конкатенации.
//    Представление      - Строка - представление адреса.
//
Процедура УправлениеКонтактнойИнформациейКлиентСервер_ДополнитьПредставлениеАдреса(Дополнение, СтрокаКонкатенации, Представление)
	
	Если Дополнение <> "" Тогда
		Представление = Представление + СтрокаКонкатенации + Дополнение;
	КонецЕсли;
	
КонецПроцедуры

// Возвращает строку значения по свойству структуры.
// 
// мПараметры:
//    Ключ - Строка - ключ структуры.
//    Структура - Структура - передаваемая структура.
//
// Возвращаемое значение:
//    Произвольный - значение.
//    Строка       - пустая строка, если нет значения.
//
Функция УправлениеКонтактнойИнформациейКлиентСервер_ЗначениеПоКлючуСтруктуры(Ключ, Структура)
	
	Значение = Неопределено;
	
	Если Структура.Свойство(Ключ, Значение) Тогда 
		Возврат Строка(Значение);
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

Процедура УправлениеКонтактнойИнформациейКлиентСервер_ПредставлениеАдресаПоСтруктуре(СтруктураАдреса, КлючНаименование, Представление, КлючСокращения = "", ДобавлятьСокращения = Ложь, СтрокаКонкатенации = ", ")
	
	Если СтруктураАдреса.Свойство(КлючНаименование) Тогда
		Дополнение = СокрЛП(СтруктураАдреса[КлючНаименование]);
		Если ЗначениеЗаполнено(Дополнение) Тогда
			Если ДобавлятьСокращения И СтруктураАдреса.Свойство(КлючСокращения) Тогда
				Дополнение = Дополнение + " " + СокрЛП(СтруктураАдреса[КлючСокращения]);
			КонецЕсли;
			Если ЗначениеЗаполнено(Представление) Тогда
				Представление = Представление + СтрокаКонкатенации + Дополнение;
			Иначе
				Представление = Дополнение;
			КонецЕсли;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

// Возвращает пустую структура телефона.
//
// Возвращаемое значение:
//    Структура - ключи - имена полей, значения поля.
//
Функция УправлениеКонтактнойИнформациейКлиентСервер_СтруктураПолейТелефона() 
	
	СтруктураТелефона = Новый Структура;
	СтруктураТелефона.Вставить("Представление", "");
	СтруктураТелефона.Вставить("КодСтраны", "");
	СтруктураТелефона.Вставить("КодГорода", "");
	СтруктураТелефона.Вставить("НомерТелефона", "");
	СтруктураТелефона.Вставить("Добавочный", "");
	СтруктураТелефона.Вставить("Комментарий", "");
	
	Возврат СтруктураТелефона;
	
КонецФункции

Функция УправлениеКонтактнойИнформациейКлиентСервер_АдресСайта(Знач Представление, Знач Ссылка, ТолькоПросмотр) 
	
	Если ПустаяСтрока(Представление) Или ПустаяСтрока(Ссылка)  Тогда
		Представление = УправлениеКонтактнойИнформациейКлиентСервер_ТекстПустогоАдресаВВидеГиперссылки();
		Ссылка = УправлениеКонтактнойИнформациейКлиентСервер_НавигационнаяСсылкаВебСайта();
	КонецЕсли;
	
	Если СтрСравнить(Представление, УправлениеКонтактнойИнформациейКлиентСервер_ТекстПустогоАдресаВВидеГиперссылки()) = 0 И ТолькоПросмотр Тогда
		Возврат Представление;
	КонецЕсли;
	
	ТекстПредставления = Новый ФорматированнаяСтрока(Представление,,,, Ссылка);
	
	Если ТолькоПросмотр Тогда
		Возврат ТекстПредставления;
	КонецЕсли;
	
	КартинкаИзменить = Новый ФорматированнаяСтрока(БиблиотекаКартинок.РедактироватьАдресСайта,,,, УправлениеКонтактнойИнформациейКлиентСервер_НавигационнаяСсылкаВебСайта());
	Возврат Новый ФорматированнаяСтрока(ТекстПредставления, "  ", КартинкаИзменить);

КонецФункции

Функция УправлениеКонтактнойИнформациейКлиентСервер_НавигационнаяСсылкаВебСайта() 
	//Возврат "e1cib/app/Обработка.ВводКонтактнойИнформации.Форма.ВебСайт";
	Возврат "e1cib/app/ВнешняяОбработка.ВводКонтактнойИнформации.Форма.ВебСайт";
КонецФункции

// Локализация

Функция УправлениеКонтактнойИнформациейКлиентСервер_НаименованиеРегионаБезТипа(Наименование)
	
	// АПК: 1297-выкл адресные сведения не локализуются
	Если СтрНачинаетсяС(ВРег(Наименование), ВРег("Ханты-Мансийский Автономный округ - Югра")) // @Non-NLS-1
		Или СтрНачинаетсяС(ВРег(Наименование), ВРег("Кемеровская область - Кузбасс")) Тогда // @Non-NLS-1
			Возврат Истина; 
	КонецЕсли;
	
	Возврат Ложь;
	// АПК: 1297-вкл
	
КонецФункции

