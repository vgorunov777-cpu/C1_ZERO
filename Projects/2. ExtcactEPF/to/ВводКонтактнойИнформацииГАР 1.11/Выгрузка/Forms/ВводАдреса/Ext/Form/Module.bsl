		Попытка
			НаселенныйПунктДетально.AddressType = РаботаСАдресамиКлиентСервер_МуниципальныйАдрес(); 
		Исключение 
			НаселенныйПунктДетально = УправлениеКонтактнойИнформацией_ОписаниеНовойКонтактнойИнформации(Перечисления.ТипыКонтактнойИнформации.Адрес); // Новый адрес
			НаселенныйПунктДетально.AddressType = РаботаСАдресамиКлиентСервер_МуниципальныйАдрес();  
		КонецПопытки; 
	Иначе
		Попытка
			НаселенныйПунктДетально.AddressType = РаботаСАдресамиКлиентСервер_АдминистративноТерриториальныйАдрес(); 
		Исключение 
			НаселенныйПунктДетально = УправлениеКонтактнойИнформацией_ОписаниеНовойКонтактнойИнформации(Перечисления.ТипыКонтактнойИнформации.Адрес); // Новый адрес
			НаселенныйПунктДетально.AddressType = РаботаСАдресамиКлиентСервер_АдминистративноТерриториальныйАдрес();  
		КонецПопытки; 
	КонецЕсли;
	
КонецПроцедуры

