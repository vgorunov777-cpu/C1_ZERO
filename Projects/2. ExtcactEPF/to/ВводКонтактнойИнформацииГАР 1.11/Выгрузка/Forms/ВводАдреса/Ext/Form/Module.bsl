// Возвращает список ошибок заполнения в виде списка значений
//
// мПараметры:
//  СведенияОТелефоне  - см. СтруктураПолейТелефона
//  МодульДополнительныхПроверок - Произвольный
// 
// Возвращаемое значение:
//  СписокЗначений - ошибки заполнения телефона:
//    * Представление   - описание ошибки.
//    * Значение        - XPath для поля.
//
Функция УправлениеКонтактнойИнформациейКлиентСервер_ОшибкиЗаполненияТелефона(СведенияОТелефоне, МодульДополнительныхПроверок = Неопределено) 
	
	СписокОшибок = Новый СписокЗначений;
	ПолныйНомерТелефона = СведенияОТелефоне.КодСтраны + СведенияОТелефоне.КодГорода + СведенияОТелефоне.НомерТелефона;
	
	КодСтраныТолькоЦифры = УправлениеКонтактнойИнформациейКлиентСервер_ОставитьТолькоЦифрыВСтроке(СведенияОТелефоне.КодСтраны);
	Если ЗначениеЗаполнено(СведенияОТелефоне.КодСтраны) И ПустаяСтрока(КодСтраныТолькоЦифры) Тогда
		СписокОшибок.Добавить("КодСтраны", НСтр("ru = 'Код страны содержит недопустимые символы'"));
	КонецЕсли;
	
	НомерТелефонаТолькоЦифры = УправлениеКонтактнойИнформациейКлиентСервер_ОставитьТолькоЦифрыВСтроке(СведенияОТелефоне.Представление);
	Если ПустаяСтрока(НомерТелефонаТолькоЦифры) Тогда
		СписокОшибок.Добавить("НомерТелефона", НСтр("ru = 'Номер телефона не содержит цифр'"));
	КонецЕсли;

	ПолныйНомерТелефонаТолькоЦифры = УправлениеКонтактнойИнформациейКлиентСервер_ОставитьТолькоЦифрыВСтроке(ПолныйНомерТелефона);
	Если СтрДлина(ПолныйНомерТелефонаТолькоЦифры) > 15 Тогда
		СписокОшибок.Добавить("НомерТелефона", НСтр("ru = 'Номер телефона слишком длинный'"));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СведенияОТелефоне.КодСтраны) И УправлениеКонтактнойИнформациейКлиентСервер_НомерТелефонаСодержитНедопустимыеСимволы(СведенияОТелефоне.КодСтраны) Тогда
		СписокОшибок.Добавить("КодСтраны", НСтр("ru = 'Код страны содержит недопустимые символы'"));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СведенияОТелефоне.КодГорода) И УправлениеКонтактнойИнформациейКлиентСервер_НомерТелефонаСодержитНедопустимыеСимволы(СведенияОТелефоне.КодГорода) Тогда
		СписокОшибок.Добавить("КодГорода", НСтр("ru = 'Код города содержит недопустимые символы'"));
	КонецЕсли;
	
	Если ЗначениеЗаполнено(СведенияОТелефоне.НомерТелефона) И УправлениеКонтактнойИнформациейКлиентСервер_НомерТелефонаСодержитНедопустимыеСимволы(СведенияОТелефоне.НомерТелефона) Тогда
		СписокОшибок.Добавить("НомерТелефона", НСтр("ru = 'Номер телефона содержит недопустимые символы'"));
	КонецЕсли;
	
	//Если МодульДополнительныхПроверок <> Неопределено Тогда
		РаботаСАдресами_ПроверитьКорректностьКодовСтраныИГорода(СведенияОТелефоне, СписокОшибок);
	//КонецЕсли;
	
	Возврат СписокОшибок;
	
КонецФункции

Функция УправлениеКонтактнойИнформациейКлиентСервер_ОставитьТолькоЦифрыВСтроке(Знач Строка) 
	
	ЛишниеСимволы = СтрСоединить(СтрРазделить83(Строка, "0123456789"), "");
	Результат     = СтрСоединить(СтрРазделить83(Строка, ЛишниеСимволы), "");
	
	Возврат Результат;
	
КонецФункции

// Проверяет, содержит ли строка только ~
//
// мПараметры:
//  СтрокаПроверки          - Строка - строка для проверки.
//
// Возвращаемое значение:
//   Булево - Истина - строка содержит только цифры или пустая, Ложь - строка содержит иные символы.
//
Функция УправлениеКонтактнойИнформациейКлиентСервер_НомерТелефонаСодержитНедопустимыеСимволы(Знач СтрокаПроверки)
	
	СписокДопустимыхСимволов = "+-.,() wp1234567890";
	Возврат СтрРазделить83(СтрокаПроверки, СписокДопустимыхСимволов, Ложь).Количество() > 0;
	
КонецФункции

