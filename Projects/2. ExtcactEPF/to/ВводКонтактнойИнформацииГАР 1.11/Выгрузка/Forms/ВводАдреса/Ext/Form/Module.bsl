//ОбщегоНазначения_СтрокаТаблицыЗначенийВСтруктуру
&НаСервере
Функция ОбщегоНазначения_СтрокаТаблицыЗначенийВСтруктуру(СтрокаТаблицыЗначений) 
	
	Структура = Новый Структура;
	Для каждого Колонка Из СтрокаТаблицыЗначений.Владелец().Колонки Цикл
		Структура.Вставить(Колонка.Имя, СтрокаТаблицыЗначений[Колонка.Имя]);
	КонецЦикла;
	
	Возврат Структура;
	
