	Описание.ОбщиеДанные                = Истина;
	Описание.СохранятьФайлВКэш          = Истина;
	Описание.ОбработкаРазделенныхДанных = Ложь;
	
	Классификаторы.Добавить(Описание);
	
КонецПроцедуры  

