// Обратная совместимость

// Возвращает поля контактной информации.
//
// мПараметры:
//   XDTOКонтактнаяИнформация - ОбъектXDTO
//                            - Строка - контактная информация или строка XML.
//   СтарыйСоставПолей        - Булево - флаг того, что из состава полей будут исключены
//                                          поля, отсутствующие в версиях БСП младше 2.1.3.
//
// Возвращаемое значение:
//   Структура:
//     * Представление        - Строка - представление адреса.
//     * ЗначенияПолей        - СписокЗначений - значения. Состав значений для адреса:
//        ** Страна           - Строка - текстовое представление страны.
//        ** КодСтраны        - Строка - код страны по ОКСМ.
//        ** Индекс           - Строка - почтовый индекс (только для адресов РФ).
//        ** Регион           - Строка - текстовое представление региона РФ (только для адресов РФ).
//        ** КодРегиона       - Строка - код региона РФ (только для адресов РФ).
//        ** РегионСокращение - Строка - сокращение региона (если СтарыйСоставПолей = Ложь).
//        ** Район            - Строка - текстовое представление района (только для адресов РФ).
//        ** РайонСокращение  - Строка - сокращение района (если СтарыйСоставПолей = Ложь).
//        ** Город            - Строка - текстовое представление города (только для адресов РФ).
//        ** ГородСокращение  - Строка - сокращение города (только для адресов РФ).
//        ** НаселенныйПункт  - Строка - текстовое представление населенного пункта (только для адресов РФ).
//        ** НаселенныйПунктСокращение - сокращение населенного пункта (если СтарыйСоставПолей = Ложь).
//        ** ТипДома          - см. РаботаСАдресами_ТипыОбъектовАдресацииАдресаРФ.
//        ** Дом              - Строка - текстовое представление дома (только для адресов РФ).
//        ** ТипКорпуса       - см. РаботаСАдресами_ТипыОбъектовАдресацииАдресаРФ.
//        ** Корпус           - Строка - текстовое представление корпуса (только для адресов РФ).
//        ** ТипКвартиры      - см. РаботаСАдресами_ТипыОбъектовАдресацииАдресаРФ.
//        ** Квартира         - Строка - текстовое представление квартиры (только для адресов РФ).
//       Состав значений для телефона:
//        ** КодСтраны        - Строка - код страны. Например, +7.
//        ** КодГорода        - Строка - код города. Например, 495.
//        ** НомерТелефона    - Строка - номер телефона.
//        ** Добавочный       - Строка - добавочный номер телефона.
//
&НаСервере 
Функция Обработки_РасширенныйВводКонтактнойИнформации_КонтактнаяИнформацияВСтаруюСтруктуру(XDTOКонтактнаяИнформация, СтарыйСоставПолей = Ложь) Экспорт
	
	Если УправлениеКонтактнойИнформациейКлиентСервер_ЭтоКонтактнаяИнформацияВXML(XDTOКонтактнаяИнформация) Тогда
		XDTOКонтактная = УправлениеКонтактнойИнформациейЛокализация_КонтактнаяИнформацияИзXML(XDTOКонтактнаяИнформация);
	Иначе
		XDTOКонтактная = XDTOКонтактнаяИнформация;
	КонецЕсли;
	
	Результат = Новый Структура("Представление, ЗначенияПолей", XDTOКонтактная.Представление, Новый СписокЗначений);
	
	ПространствоИмен = УправлениеКонтактнойИнформациейЛокализация_ПространствоИмен();
	Состав = XDTOКонтактная.Состав;
	
	Если Состав = Неопределено Тогда
		Возврат Результат;
	КонецЕсли;
	
	Тип = Состав.Тип();
	Если Тип = ФабрикаXDTO.Тип(ПространствоИмен, "Адрес") Тогда
		Результат.ЗначенияПолей = Обработки_РасширенныйВводКонтактнойИнформации_АдресВСтарыйСписокПолей(Состав, Не СтарыйСоставПолей);
		Результат.ЗначенияПолей.Добавить(Результат.Представление, "Представление");
		
	ИначеЕсли Тип = ФабрикаXDTO.Тип(ПространствоИмен, "НомерТелефона") Тогда
		Результат.ЗначенияПолей = УправлениеКонтактнойИнформациейЛокализация_НомерТелефонаВСтарыйСписокПолей(Состав);
		Результат.ЗначенияПолей.Добавить(XDTOКонтактная.Комментарий, "Комментарий");
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

// Преобразует адрес формата XDTO в старый список полей типа СписокЗначений.
//
// мПараметры:
//     XDTOАдрес               - ОбъектXDTO
//                             - Строка - контактная информация или строка XML.
//     РасширенныйСоставПолей - Булево - флаг того, что состав полей будет сокращен для совместимости
//                                     с обменом БСП 2.1.2.
//
//  Возвращаемое значение:
//     СписокЗначений
//
&НаСервере 
Функция Обработки_РасширенныйВводКонтактнойИнформации_АдресВСтарыйСписокПолей(XDTOАдрес, РасширенныйСоставПолей = Истина)
	Список = Новый СписокЗначений;
	
	ПространствоИмен = УправлениеКонтактнойИнформациейЛокализация_ПространствоИмен();
	XDTOТип = XDTOАдрес.Тип();  
	Если XDTOТип = ФабрикаXDTO.Тип(ПространствоИмен, "Адрес") Тогда
		
		// Страна с кодом
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Страна", XDTOАдрес.Страна);
		Если ПустаяСтрока(XDTOАдрес.Страна) Тогда
			КодСтраны = "";
		Иначе
			Страна = Справочники.СтраныМира.НайтиПоНаименованию(XDTOАдрес.Страна, Истина);
			КодСтраны = СокрЛП(Страна.Код);
		КонецЕсли;
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "КодСтраны", КодСтраны);
		
		Если Не РаботаСАдресамиКлиентСервер_ЭтоОсновнаяСтрана(XDTOАдрес.Страна) Тогда
			Возврат Список;
		КонецЕсли;
		
		АдресРФ = XDTOАдрес.Состав;
		
	ИначеЕсли XDTOТип = ФабрикаXDTO.Тип(РаботаСАдресами_ПространствоИмен(), "АдресРФ") Тогда
		АдресРФ = XDTOАдрес;
		
	Иначе
		Возврат Список;
		
	КонецЕсли;
	
	Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Индекс", Обработки_РасширенныйВводКонтактнойИнформации_ПочтовыйИндексАдреса(АдресРФ) );
	
	Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Регион", АдресРФ.СубъектРФ);
	Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "КодРегиона", РаботаСАдресами_КодРегиона(АдресРФ.СубъектРФ) );
	Если РасширенныйСоставПолей Тогда
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "РегионСокращение", Обработки_РасширенныйВводКонтактнойИнформации_Сокращение(АдресРФ.СубъектРФ));
	КонецЕсли;
	
	мРайон = Обработки_РасширенныйВводКонтактнойИнформации_РайонАдреса(АдресРФ);
	Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Район", мРайон);
	Если РасширенныйСоставПолей Тогда
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "РайонСокращение", Обработки_РасширенныйВводКонтактнойИнформации_Сокращение(мРайон));
	КонецЕсли;

	// Аникин a.anikin@magdv.com 31.07.2023 --> 
	//город может быть не выбран
	мГород = "";
	Если АдресРФ.Свойства().Получить("Город") <> Неопределено Тогда
		мГород = АдресРФ.Город; 
	КонецЕсли;  
	Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Город", мГород);
	Если РасширенныйСоставПолей Тогда
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ГородСокращение", Обработки_РасширенныйВводКонтактнойИнформации_Сокращение(мГород));
	КонецЕсли;
	//Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Город", АдресРФ.Город);
	//Если РасширенныйСоставПолей Тогда
	//	Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ГородСокращение", Обработки_РасширенныйВводКонтактнойИнформации_Сокращение(АдресРФ.Город));
	//КонецЕсли;
	// <-- Аникин 31.07.2023
	
	
	// преобразование в КЛАДР 
	мНаселенныйПункт = "";
	Если АдресРФ.Свойства().Получить("НаселПункт") <> Неопределено Тогда
		мНаселенныйПункт = АдресРФ.НаселПункт; 
	КонецЕсли;  
	мУлица = "";
	Если АдресРФ.Свойства().Получить("Улица") <> Неопределено Тогда
		мУлица = АдресРФ.Улица;
	КонецЕсли;
	ДополнительныйЭлементАдреса     = Обработки_РасширенныйВводКонтактнойИнформации_НайтиДополнительныйЭлементАдреса(АдресРФ).Значение;
	ПодчиненныйЭлементЭлементАдреса = Обработки_РасширенныйВводКонтактнойИнформации_ДополнительныйЭлементАдреса(АдресРФ,
		РаботаСАдресами_XPathДополнительногоОбъектаАдресации(91));
	
	ЕстьДополнительныйЭлементАдреса     = ЗначениеЗаполнено(ДополнительныйЭлементАдреса);
	ЕстьПодчиненныйЭлементЭлементАдреса = ЗначениеЗаполнено(ПодчиненныйЭлементЭлементАдреса);
	
	Если ЕстьДополнительныйЭлементАдреса Тогда
		
		Если ЕстьПодчиненныйЭлементЭлементАдреса Тогда
			мНаселенныйПункт = ДополнительныйЭлементАдреса;
			мУлица = ПодчиненныйЭлементЭлементАдреса;
		Иначе
			мУлица = ДополнительныйЭлементАдреса;
		КонецЕсли;
		
	ИначеЕсли ЕстьПодчиненныйЭлементЭлементАдреса Тогда
		мУлица = ПодчиненныйЭлементЭлементАдреса;
	КонецЕсли;
	
	Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "НаселенныйПункт", мНаселенныйПункт);
	Если РасширенныйСоставПолей Тогда
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "НаселенныйПунктСокращение", Обработки_РасширенныйВводКонтактнойИнформации_Сокращение(мНаселенныйПункт));
	КонецЕсли;

	Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Улица", мУлица);
	
	Если РасширенныйСоставПолей Тогда
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "УлицаСокращение", Обработки_РасширенныйВводКонтактнойИнформации_Сокращение(мУлица));
	КонецЕсли;
	
	// Дом и корпус
	ЗданияИПомещения = Обработки_РасширенныйВводКонтактнойИнформации_ЗданияИПомещенияАдреса(АдресРФ);
	
	Если ЗданияИПомещения.Здания.Количество() = 0 Тогда
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ТипДома", "");
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Дом",     "");
	Иначе
		СтрокаОбъекта = ЗданияИПомещения.Здания[0];
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ТипДома", СтрокаОбъекта.Тип,      Ложь);
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Дом",     СтрокаОбъекта.Значение, Ложь);
		
		ЗданияИПомещения.Удалить(СтрокаОбъекта);
		Если ЗданияИПомещения.Здания.Количество() > 0 Тогда
			
			ПараметрыОбъекта = Обработки_РасширенныйВводКонтактнойИнформации_ЗначениеЗданияИлиПомещения(ЗданияИПомещения.Здания, РаботаСАдресамиПовтИсп_ВариантыДанныхСтроение(), Ложь);
			Если ПараметрыОбъекта.Количество() = 0 Тогда
				Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ТипКорпуса", "");
				Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Корпус",     "");
			ИначеЕсли ПараметрыОбъекта.Количество() = 1 Тогда
				СтрокаОбъекта  = ПараметрыОбъекта[0];
				Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ТипКорпуса", СтрокаОбъекта.Тип,      Ложь);
				Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Корпус",     СтрокаОбъекта.Значение, Ложь);
			Иначе
				ТипКорпуса  = ПараметрыОбъекта[0].Тип;
				ЗначениеКорпуса = "";
				Разделитель = "";
				Сокращения = РаботаСАдресами_СокращенияОбъектовАдресацииАдресаРФ();
				Для Каждого СтрокаОбъекта Из ПараметрыОбъекта Цикл
					ИмяЗдания = ?(ЗначениеЗаполнено(Сокращения[СтрокаОбъекта.Тип]), Сокращения[СтрокаОбъекта.Тип], СтрокаОбъекта.Тип);
					ЗначениеКорпуса  = ЗначениеКорпуса  + Разделитель + ИмяЗдания + " " + СтрокаОбъекта.Значение;
					Разделитель = ", " ;
				КонецЦикла;
				Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ТипКорпуса", ТипКорпуса,      РасширенныйСоставПолей);
				Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Корпус",     ЗначениеКорпуса  , РасширенныйСоставПолей);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	ПараметрыОбъекта = Обработки_РасширенныйВводКонтактнойИнформации_ЗначениеЗданияИлиПомещения(ЗданияИПомещения.Помещения, РаботаСАдресамиПовтИсп_ВариантыДанныхПомещение(), РасширенныйСоставПолей);
	Если ПараметрыОбъекта.Количество() = 0 Тогда
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ТипКвартиры", "");
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Квартира",    "");
	ИначеЕсли ПараметрыОбъекта.Количество() = 1 Тогда
		СтрокаОбъекта  = ПараметрыОбъекта[0];
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ТипКвартиры", СтрокаОбъекта.Тип,      РасширенныйСоставПолей);
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Квартира",    СтрокаОбъекта.Значение, РасширенныйСоставПолей);
	Иначе
		мТипПомещения  = ПараметрыОбъекта[0].Тип;
		ЗначениеПомещения = "";
		Разделитель = "";
		Сокращения = РаботаСАдресами_СокращенияОбъектовАдресацииАдресаРФ();
		Для Каждого СтрокаОбъекта Из ПараметрыОбъекта Цикл
			ИмяПомещения = ?(ЗначениеЗаполнено(Сокращения[СтрокаОбъекта.Тип]), Сокращения[СтрокаОбъекта.Тип], СтрокаОбъекта.Тип);
			ЗначениеПомещения = ЗначениеПомещения + Разделитель + ИмяПомещения + " " + СтрокаОбъекта.Значение;
			Разделитель = ", " ;
		КонецЦикла;
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "ТипКвартиры", мТипПомещения,      РасширенныйСоставПолей);
		Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, "Квартира",    ЗначениеПомещения, РасширенныйСоставПолей);
	КонецЕсли;
	
	Возврат Список;
КонецФункции

&НаСервере 
Процедура Обработки_РасширенныйВводКонтактнойИнформации_ДобавитьЗначение(Список, ИмяПоля, Значение, РазрешитьДубли = Ложь)
	
	Если Не РазрешитьДубли Тогда
		Для Каждого Элемент Из Список Цикл
			Если Элемент.Представление = ИмяПоля Тогда
				Элемент.Значение = Строка(Значение);
				Возврат;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	Список.Добавить(Строка(Значение), ИмяПоля);
КонецПроцедуры

