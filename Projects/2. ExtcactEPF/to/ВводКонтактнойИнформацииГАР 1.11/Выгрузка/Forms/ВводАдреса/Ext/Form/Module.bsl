	КонецЕсли;
	
	//МодульРаботаСАдресами = ОбщегоНазначения_ОбщийМодуль("РаботаСАдресами");
	ДанныеВыбора = РаботаСАдресами_ЗаполнитьДанныеВыбораАвтоподбораПоСтранам(мПараметры);
