&НаСервере 
Функция РаботаСАдресами_ИнициализироватьПараметрыСведенийОбАдресе(Знач ДополнительныеПараметры)
	
	мПараметры = РаботаСАдресами_ПараметрыСведенийОбАдресе();
	
	Если ТипЗнч(ДополнительныеПараметры) = Тип("Структура") Тогда
		ЗаполнитьЗначенияСвойств(мПараметры, ДополнительныеПараметры);
	КонецЕсли;
	
	мПараметры.Вставить("ВозвращатьКоды", мПараметры.КодыАдреса Или мПараметры.КодыКЛАДР);
	
	Возврат мПараметры;
	
КонецФункции

&НаСервере 
Функция РаботаСАдресами_ПараметрыСведенийОбАдресе()
	
	мПараметры = Новый Структура();
	мПараметры.Вставить("БезПредставлений",               Ложь);
	мПараметры.Вставить("НаименованиеВключаетСокращение", Ложь);
