//
&НаСервере 
Функция Обработки_РасширенныйВводКонтактнойИнформации_РайонАдреса(XDTOАдрес, НовоеЗначение = Неопределено)
	
	Если НовоеЗначение = Неопределено Тогда
		// Чтение
		
		//ИсправлениеСовместимости
		//XDTOТип = XDTOАдрес.Тип();
		//Если XDTOТип = ФабрикаXDTO.Тип(РаботаСАдресами_ПространствоИмен(), "АдресРФ") Тогда 
		Если XDTOАдрес.Свойства().Получить("СубъектРФ")<>Неопределено Тогда
