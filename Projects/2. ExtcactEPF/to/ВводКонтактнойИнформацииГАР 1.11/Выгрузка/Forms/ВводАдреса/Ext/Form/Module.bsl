Функция РаботаСАдресамиКлиентСервер_ИменаУровнейАдреса(ТипАдреса, ВключатьУровеньУлицы, ВключатьУровеньДома = Ложь) 
	
	Уровни = Новый Массив;
	
	Если ТипАдреса = УправлениеКонтактнойИнформациейКлиентСервер_ИностранныйАдрес() Тогда
		
		Уровни.Добавить("area");
		
	Иначе
		
		Уровни.Добавить("area");
		Если ТипАдреса = УправлениеКонтактнойИнформациейКлиентСервер_АдресЕАЭС() Тогда
			
			Уровни.Добавить("district");
			Уровни.Добавить("city");
			Уровни.Добавить("locality");
			
		Иначе
			
			Если ТипАдреса = "Все" Тогда
				Уровни.Добавить("district");
				Уровни.Добавить("munDistrict");
				Уровни.Добавить("settlement");
			Иначе
				Если РаботаСАдресамиКлиентСервер_ЭтоМуниципальныйАдрес(ТипАдреса) Тогда
					Уровни.Добавить("munDistrict");
					Уровни.Добавить("settlement");
				Иначе
					Уровни.Добавить("district");
				КонецЕсли;
			КонецЕсли;
			
			Уровни.Добавить("city");
			Уровни.Добавить("locality");
			Уровни.Добавить("territory");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если ВключатьУровеньУлицы Тогда
		Уровни.Добавить("street");
	КонецЕсли;
	
	Если ВключатьУровеньДома Тогда
		Уровни.Добавить("house");
	КонецЕсли;
	
	Возврат Уровни;
	
КонецФункции

Функция РаботаСАдресамиКлиентСервер_ИменаУровнейАдресаПоАдресу(мАдрес, мВключатьУровеньУлицы, мВключатьУровеньДома = Ложь, мТипАдреса = Неопределено) 
	
	Попытка
		Если мТипАдреса = Неопределено Тогда
			мТипАдреса = мАдрес.AddressType;
		КонецЕсли; 
	Исключение
		Возврат Новый Массив;
	КонецПопытки;
	
	Если РаботаСАдресамиКлиентСервер_ЭтоМуниципальныйАдрес(мТипАдреса) Тогда
		мУровни = мАдрес.munLevels; 
	ИначеЕсли РаботаСАдресамиКлиентСервер_ЭтоАдминистративноТерриториальныйАдрес(мТипАдреса) Тогда
		 мУровни = мАдрес.admLevels;
	Иначе
		мУровни = Новый Массив;
	КонецЕсли; 
	
	мУровни = ?(ТипЗнч(мУровни) = Тип("Массив"), Новый Массив(Новый ФиксированныйМассив(мУровни)), Новый Массив);
	
	Если мУровни.Количество() > 0 Тогда
		
		Если Не мВключатьУровеньУлицы Тогда
			мПозиция = мУровни.Найти("street");
			Если мПозиция <> Неопределено Тогда
				мУровни.Удалить(мПозиция);
			КонецЕсли;
		КонецЕсли;
		
		мПозиция = мУровни.Найти("house");
		Если мВключатьУровеньДома Тогда
			Если мПозиция = Неопределено Тогда
				мУровни.Добавить("house");
			КонецЕсли;
		Иначе
			Если мПозиция <> Неопределено Тогда
				мУровни.Удалить(мПозиция);
			КонецЕсли;
		КонецЕсли;
		
		мПозиция = мУровни.Найти("stead");
		Если мВключатьУровеньДома Тогда
			Если мПозиция = Неопределено Тогда
				мУровни.Добавить("stead");
			КонецЕсли;
		Иначе
			Если мПозиция <> Неопределено Тогда
				мУровни.Удалить(мПозиция);
			КонецЕсли;
		КонецЕсли;
		
		Для мПозиция = -мУровни.ВГраница() По 0 Цикл
			Если ТипЗнч(мУровни[-мПозиция]) <> Тип("Строка")
				 Или РаботаСАдресамиКлиентСервер_СопоставлениеНаименованиеУровнюАдреса(ВРег(Строка(мУровни[-мПозиция]))) = Неопределено Тогда
					мУровни.Удалить(-мПозиция);
			КонецЕсли;
		КонецЦикла;
		
		Возврат мУровни;
		
	КонецЕсли;
	
	Если мТипАдреса = УправлениеКонтактнойИнформациейКлиентСервер_ИностранныйАдрес() Тогда
		
		мУровни.Добавить("area");
		
	Иначе
		
		мУровни.Добавить("area");
		Если мТипАдреса = УправлениеКонтактнойИнформациейКлиентСервер_АдресЕАЭС() Тогда
			
			мУровни.Добавить("district");
			мУровни.Добавить("city");
			мУровни.Добавить("locality");
			
		Иначе
			
			Если мТипАдреса = "Все" Тогда
				мУровни.Добавить("district");
				мУровни.Добавить("munDistrict");
				мУровни.Добавить("settlement");

			Иначе
				Если РаботаСАдресамиКлиентСервер_ЭтоМуниципальныйАдрес(мТипАдреса) Тогда
					мУровни.Добавить("munDistrict");
					мУровни.Добавить("settlement");
				Иначе
					мУровни.Добавить("district");
				КонецЕсли;
			КонецЕсли;
			мУровни.Добавить("city");
			мУровни.Добавить("locality");
			мУровни.Добавить("territory");
			
		КонецЕсли;
		
	КонецЕсли;
	
	Если мВключатьУровеньУлицы Тогда
		мУровни.Добавить("street");
	КонецЕсли;
	
	Если мВключатьУровеньДома Тогда
		мУровни.Добавить("house");
	КонецЕсли;
	
	Возврат мУровни;
	
КонецФункции

Процедура РаботаСАдресамиКлиентСервер_ОбновитьПредставлениеАдреса(Адрес, ВключатьСтрануВПредставление) 
	
	Представление = РаботаСАдресамиКлиентСервер_ПредставлениеАдреса(Адрес, ВключатьСтрануВПредставление);
	Адрес.Value = Представление;
	
КонецПроцедуры

Функция РаботаСАдресамиКлиентСервер_ПредставлениеУровняАдреса(Адрес, ИмяУровня) 
	
	Если (РаботаСАдресамиКлиентСервер_ЭтоМуниципальныйАдрес(Адрес.addressType) 
		Или РаботаСАдресамиКлиентСервер_ЭтоАдминистративноТерриториальныйАдрес(Адрес.addressType))
		И РаботаСАдресамиКлиентСервер_ЭтоИмяУровняРегиона(ИмяУровня) 
		И ЗначениеЗаполнено(Адрес["areaValue"]) Тогда
			Возврат Адрес["areaValue"];
	КонецЕсли;
		
	Возврат УправлениеКонтактнойИнформациейКлиентСервер_СоединитьНаименованиеИТипАдресногоОбъекта(
			Адрес[ИмяУровня], Адрес[ИмяУровня + "Type"], СтрСравнить(ИмяУровня, "area") = 0);
	
КонецФункции

