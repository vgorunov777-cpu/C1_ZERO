// Обновление информационной базы.

// Устанавливает свойства группы контактной информации.
//
// мПараметры:
//    мПараметры - Структура - содержит структуру с полями:
//        * Код    - Строка   - код вида контактной информации для идентификации элемента.
//        * Наименование - Строка - наименование вида контактной информации.
//        * Имя - Строка - имя предопределенного вида контактной информации;
//        * Используется - Булево - признак использования вида контактной информации. Значение по умолчанию Истина.
//
// Возвращаемое значение:
//   СправочникСсылка.ВидыКонтактнойИнформации - ссылка на группу.
//
&НаСервере 
Функция УправлениеКонтактнойИнформацией_УстановитьСвойстваГруппыВидаКонтактнойИнформации(мПараметры) 
	
	Объект = УправлениеКонтактнойИнформацией_ОбъектВидаКонтактнойИнформации(мПараметры.Имя, Истина);
	
	Объект.ИмяПредопределенногоВида = мПараметры.Имя;
	Объект.Родитель                 = мПараметры.Группа;
	Объект.Используется             = мПараметры.Используется;
	
	Если ПустаяСтрока(Объект.ИмяПредопределенногоВида) Тогда
		Объект.ИмяПредопределенногоВида = Объект.ИмяПредопределенныхДанных;
	КонецЕсли;
	
	УправлениеКонтактнойИнформацией_УстановитьНаименованиеВидаКонтактнойИнформации(Объект, мПараметры.Наименование);
	
	ОбновлениеИнформационнойБазы_ЗаписатьОбъект(Объект);
	
	Возврат Объект.Ссылка;
	
КонецФункции  

