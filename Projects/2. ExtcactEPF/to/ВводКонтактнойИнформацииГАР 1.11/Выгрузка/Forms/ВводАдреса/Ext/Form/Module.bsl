Функция СтрРазделить83(Строка, Разделитель = ",", ВключатьПустые = Истина)
	
	МассивСтрок = Новый Массив;
	Строки = СтрЗаменить(Строка, Разделитель, Символы.ПС);
	
	Для Сч = 1 По СтрЧислоСтрок(Строки) Цикл
		
		ТекущаяСтрока = СокрЛП(СтрПолучитьСтроку(Строки, Сч));
		Если (ТекущаяСтрока = "" И ВключатьПустые) Или Не ТекущаяСтрока = "" Тогда
			МассивСтрок.Добавить(ТекущаяСтрока);
		КонецЕсли;
	
	КонецЦикла;
	
	Возврат МассивСтрок;
	
КонецФункции

