КонецФункции

&НаСервере
Функция АдресныйКлассификаторСлужебный_АдресДляСохраненияВБазе(Адрес, Муниципальный = Истина)

	Результат = АдресныйКлассификаторСлужебный_ОписаниеНовойКонтактнойИнформации();
	ЗаполнитьЗначенияСвойств(Результат, Адрес);

	Для Каждого ПолеАдреса Из Результат Цикл
		Если ПолеАдреса.Значение = Неопределено Тогда
			Результат[ПолеАдреса.Ключ] = "";
		КонецЕсли;
	КонецЦикла;

	Если Муниципальный Тогда
		Результат.addressType = АдресныйКлассификаторСлужебный_МуниципальныйАдрес();
		Результат.value = Адрес.munValueWithPostalCode;
	Иначе
		Результат.addressType = АдресныйКлассификаторСлужебный_АдминистративноТерриториальныйАдрес();
		Результат.value = Адрес.valueWithPostalCode;
	КонецЕсли;

	Результат.houseType = ТРег(Результат.houseType);
	
	// Зависит от версии веб-сервиса
	Если Адрес.Свойство("steadNumber") Тогда
		Результат.stead = Строка(Адрес.steadNumber);
	КонецЕсли;

	Для Каждого Строение Из Результат.buildings Цикл
		Строение.type = ТРег(Строение.type);
	КонецЦикла;

	Для Каждого мПомещение Из Результат.apartments Цикл
		мПомещение.type = ТРег(мПомещение.type);
	КонецЦикла;

	Результат.country = АдресныйКлассификаторСлужебный_ОсновнаяСтрана();

	Возврат Результат;

КонецФункции


&НаСервере
Функция АдресныйКлассификаторСлужебный_ВыполнитьЗапросЧерезВебСервис(СтрокаЗапроса, ВремяОжидания = 60)

	Сервис = АдресныйКлассификаторПовтИсп_СервисКлассификатора1С(ВремяОжидания);

	Результат = АдресныйКлассификаторСлужебный_НовыйОтветИзВебСервиса();

	ТекстURL = АдресныйКлассификаторСлужебный_ПрефиксВерсииЗапроса() + СтрокаЗапроса;
	HTTPЗапрос = Новый HTTPЗапрос(ТекстURL);

	Попытка
		Ответ = Сервис.Получить(HTTPЗапрос);
	Исключение

		АдресныйКлассификаторСлужебный_ОбработатьОшибкуОбращенияКВебСервису(Результат, Ответ, ИнформацияОбОшибке(), ТекстURL);
		Возврат Результат;

	КонецПопытки;

	Результат.Отказ = Ложь;
	Результат.КодСостояния = Ответ.КодСостояния;

	Если Результат.КодСостояния = 200 Тогда

		ПолученныеДанные = Ответ.ПолучитьТелоКакСтроку("UTF-8");
		Если ПустаяСтрока(ПолученныеДанные) Тогда
			Результат.Отказ = Истина;
			Возврат Результат;
		КонецЕсли;
		
		Результат.Данные = АдресныйКлассификаторСлужебный_СтрокуJSONВСтруктуру(ПолученныеДанные);

	Иначе

		АдресныйКлассификаторСлужебный_ОбработатьОшибкуОбращенияКВебСервису(Результат, Ответ, ИнформацияОбОшибке(), ТекстURL);

	КонецЕсли;

	Возврат Результат;

КонецФункции 

