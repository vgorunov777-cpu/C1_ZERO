
&НаКлиенте
Процедура АдресСкладаНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	//тестирование+
	//Если СтрДанные.ТипНомер = 1 Тогда
		ТипКонтактнойИнформации = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес");
	//Иначе
	//	ТипКонтактнойИнформации = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон");
	//КонецЕсли;
	ВидКонтактнойИнформации = мВидКИ(); 
	
	//ЭлементТекстРедактирования = "630029, Новосибирская область, г Новосибирск, ул 3-я Чулымская, з/у 214";
	ЭлементТекстРедактирования = "";
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ВидКонтактнойИнформации", ВидКонтактнойИнформации);
	ПараметрыФормы.Вставить("ТолькоПросмотр", Ложь);
	ПараметрыФормы.Вставить("Значение", "");
	ПараметрыФормы.Вставить("Представление", ЭлементТекстРедактирования);
	ПараметрыФормы.Вставить("Комментарий", "");
	ПараметрыФормы.Вставить("ТипАдреса", "");
	Если ТипКонтактнойИнформации <> Неопределено Тогда
		ПараметрыФормы.Вставить("ТипКонтактнойИнформации", ТипКонтактнойИнформации);
		Если ТипКонтактнойИнформации = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Адрес") Тогда 
			ИмяФормыРедактирования =  "ВводАдреса";
			ПараметрыФормы.Вставить("Страна");
			ПараметрыФормы.Вставить("Регион");
			ПараметрыФормы.Вставить("Индекс");
			ПараметрыФормы.Вставить("ТипПомещения", "Квартира");
		ИначеЕсли ТипКонтактнойИнформации = ПредопределенноеЗначение("Перечисление.ТипыКонтактнойИнформации.Телефон") Тогда
			ИмяФормыРедактирования =  "ВводТелефона";
			ПараметрыФормы.Вставить("КодСтраны");
			ПараметрыФормы.Вставить("КодГорода");
			ПараметрыФормы.Вставить("НомерТелефона");
			ПараметрыФормы.Вставить("Добавочный");
		КонецЕсли;
	КонецЕсли;
	
	Если ТипЗнч(ВидКонтактнойИнформации) = Тип("Структура") И ВидКонтактнойИнформации.Свойство("Наименование") Тогда
		ПараметрыФормы.Вставить("Заголовок", ВидКонтактнойИнформации.Наименование);
	Иначе
		ПараметрыФормы.Вставить("Заголовок", Строка(ВидКонтактнойИнформации));
	КонецЕсли;   
	
	Если ПустаяСтрока(Элемент.ТекстРедактирования) Тогда
		ПараметрыФормы.ТипАдреса = "АдминистративноТерриториальный";
	КонецЕсли;
	
	ПараметрыФормы.Вставить("ОткрытаПоСценарию", Истина);  
	
	СтрДанные = Новый Структура;
	ЗначенияПолей = Новый Структура; 
	ЗначенияПолей.Вставить("Страна","РОССИЯ");
	ЗначенияПолей.Вставить("КодСтраны","643");
	ЗначенияПолей.Вставить("Индекс","105203");
	ЗначенияПолей.Вставить("Регион","Москва г");
	ЗначенияПолей.Вставить("КодРегиона","77");
	ЗначенияПолей.Вставить("РегионСокращение","г");
	//ЗначенияПолей.Вставить("Город","Новосибирск г");
	//ЗначенияПолей.Вставить("ГородСокращение","г");
	ЗначенияПолей.Вставить("Улица","Измайловский пр-кт");
	ЗначенияПолей.Вставить("УлицаСокращение","пр-кт");
	ЗначенияПолей.Вставить("ТипДома","Дом");
	ЗначенияПолей.Вставить("Дом","123/1"); 
	ЗначенияПолей.Вставить("Корпус","1");
	ЗначенияПолей.Вставить("Представление","105203, Город Москва, вн.тер.г. муниципальный округ Восточное Измайлово, пр-кт Измайловский, д. 123/1, к. 1, помещ. 1Н"); 
	СтрДанные.Вставить("Вид",ВидКонтактнойИнформации);
	СтрДанные.Вставить("ЗначенияПолей",ЗначенияПолей);
	СтрДанные.Вставить("ТипНомер",1);
	СтрДанные.Вставить("ТолькоРоссийский",Ложь);
	
	//ИсправлениеСовместимости
	ПараметрыФормы.Вставить("ЗначенияПолей",                СтрДанные.ЗначенияПолей);
	ПараметрыФормы.Вставить("Вид",                          СтрДанные.Вид);
	ПараметрыФормы.Вставить("БылиВнесеныИзменения",         Ложь);
	ПараметрыФормы.Вставить("Представление",                "105203, Город Москва, вн.тер.г. муниципальный округ Восточное Измайлово, пр-кт Измайловский, д. 123/1, к. 1, помещ. 1Н");
	ПараметрыФормы.Вставить("РедактированиеТолькоВДиалоге", Не Элемент.РедактированиеТекста);
	ПараметрыФормы.Вставить("АдресТолькоРоссийский",        СтрДанные.ТолькоРоссийский);

	//тестирование-
	
	ИмяОбработкиСлужебное = "ВводКонтактнойИнформации";
	//Результат = ОткрытьФормуМодально("ВнешняяОбработка." + ИмяОбработкиСлужебное + ".Форма."+ИмяФормыРедактирования, ПараметрыФормы, Элемент);
	Результат = ОткрытьФормуМодально(ИмяФормыРедактирования, ПараметрыФормы, Элемент);

	Если ТипЗнч(Результат) = Тип("Структура") Тогда
		ЭтаФорма[Элемент.Имя]   = Результат.Представление;
		//СтрДанные.ЗначенияПолей = Результат.ЗначенияПолей;
		Модифицированность      = Истина;
	КонецЕсли; 	

КонецПроцедуры


