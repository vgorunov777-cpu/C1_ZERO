&НаКлиенте
Процедура ЗагрузитьКлассификатор(Команда)
	ОткрытьВнешнююОбработкуЗагрузкиАдресногоКлассификатора() ;
КонецПроцедуры 

&НаКлиенте
Процедура ОткрытьВнешнююОбработкуЗагрузкиАдресногоКлассификатора() 
	
	СтруктураОбработкиОтчета = ПодключитьВнешнююОбработкуЗагрузкиАдресногоКлассификатора();		 
	ФормаВнешнегоОтчета = ПолучитьФорму(СтруктураОбработкиОтчета.ВнешняяОбработка,СтруктураОбработкиОтчета.ПараметрыОбработки, , , );
    ФормаВнешнегоОтчета.Открыть();
		
КонецПроцедуры    

&НаСервере
Функция ПодключитьВнешнююОбработкуЗагрузкиАдресногоКлассификатора() 
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВнешняяОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию("Загрузка адресного классификатора ГАР");
	ДвоичныеДанныеОбработки = ВнешняяОбработка.ПолучитьОбъект().ХранилищеОбработки.Получить();
	АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанныеОбработки);
	
	ИмяОбработки = ВнешниеОбработки.Подключить(АдресВоВременномХранилище,, Ложь);
		
	ПараметрыОбработки = Новый Структура("ИдентификаторКоманды,ДополнительнаяОбработкаСсылка");
	ПараметрыОбработки.ИдентификаторКоманды = "1";
	ПараметрыОбработки.ДополнительнаяОбработкаСсылка = ВнешняяОбработка;
	
	Структура = Новый Структура;
	Структура.Вставить("ВнешняяОбработка","ВнешняяОбработка."+ИмяОбработки+".Форма");
	Структура.Вставить("ПараметрыОбработки",ПараметрыОбработки);
	
	Возврат Структура;
	
КонецФункции


