&НаКлиенте
Процедура ТаблицаКомплектацияПометкаПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ТаблицаКомплектация.ТекущиеДанные;
	Если Не ТекущиеДанные.Пометка Или Не ТекущиеДанные.Напечатан Тогда
		Возврат;
	КонецЕсли;
	ТекущиеДанные.Пометка = Ложь;
	
	Если ТекущиеДанные.Напечатан Тогда
		Ответ = Вопрос("Данный заказ уже был напечатан! Перепечатать?", РежимДиалогаВопрос.ДаНет);
		Если Ответ = КодВозвратаДиалога.Да Тогда
			ТекущиеДанные.Пометка = Истина;
		КонецЕсли;
	КонецЕсли;
	
	
КонецПроцедуры


