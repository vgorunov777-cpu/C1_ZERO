Функция ПолучитьВесИОбъемТоваровВУпаковкеWMSПоДокументуТЕСТ(ДокументСсылка) Экспорт
	
	
	СтруктрураВесОбъем = Новый Структура("Вес, Объем, КоличествоПаллет");

	Запрос = Новый Запрос;

			Запрос.Текст = "
		|ВЫБРАТЬ
		|	Товары.Номенклатура,
		|	Товары.Количество
		|ПОМЕСТИТЬ Товары
		|ИЗ
		|	Документ." + ДокументСсылка.Метаданные().Имя + ".Товары КАК Товары
		|ГДЕ
		|	Товары.Ссылка = &ДокументСсылка 
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	УпаковкиНоменклатуры.Владелец,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА УпаковкиНоменклатуры.Наименование = ""паллета""
		|				ТОГДА УпаковкиНоменклатуры.Ссылка
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК УпакПаллета,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА УпаковкиНоменклатуры.Наименование = ""Упаковка WMS""
		|				ТОГДА УпаковкиНоменклатуры.Ссылка
		|			ИНАЧЕ NULL
		|		КОНЕЦ) КАК УпакВМС
		|ПОМЕСТИТЬ Упак
		|ИЗ
		|	Справочник.УпаковкиНоменклатуры КАК УпаковкиНоменклатуры
		|ГДЕ
		|	УпаковкиНоменклатуры.Владелец В
		|			(ВЫБРАТЬ
		|				Товары.Номенклатура
		|			ИЗ
		|				Товары КАК Товары)
		|	И УпаковкиНоменклатуры.Наименование В (""паллета"", ""Упаковка WMS"")
		|
		|СГРУППИРОВАТЬ ПО
		|	УпаковкиНоменклатуры.Владелец
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЕСТЬNULL(ВЫРАЗИТЬ(СУММА(Товары.Количество * ВЫБОР
		|					КОГДА НЕ Упак.УпакВМС ЕСТЬ NULL 
		|						ТОГДА Упак.УпакВМС.Вес / Упак.УпакВМС.Коэффициент
		|					ИНАЧЕ ВЫБОР
		|							КОГДА Товары.Номенклатура.Вес = 0
		|								ТОГДА 0.01
		|							ИНАЧЕ Товары.Номенклатура.Вес
		|						КОНЕЦ
		|				КОНЕЦ) КАК ЧИСЛО(37, 3)), 0) КАК Вес,
		|	ЕСТЬNULL(ВЫРАЗИТЬ(СУММА(Товары.Количество * ВЫБОР
		|					КОГДА НЕ Упак.УпакВМС ЕСТЬ NULL 
		|						ТОГДА Упак.УпакВМС.Высота * Упак.УпакВМС.Глубина * Упак.УпакВМС.Ширина / Упак.УпакВМС.Коэффициент
		|					ИНАЧЕ 0
		|				КОНЕЦ) КАК ЧИСЛО(37, 3)), 0) КАК Объем,
		|	ЕСТЬNULL(ВЫРАЗИТЬ(СУММА(Товары.Количество / ВЫБОР
		|					КОГДА НЕ Упак.УпакПаллета ЕСТЬ NULL 
		|						ТОГДА Упак.УпакПаллета.Коэффициент
		|					ИНАЧЕ 99999999999
		|				КОНЕЦ) КАК ЧИСЛО(37, 3)), 0) КАК КоличествоПаллет
		|ИЗ
		|	Товары КАК Товары
		|		ЛЕВОЕ СОЕДИНЕНИЕ Упак КАК Упак
		|		ПО Товары.Номенклатура = Упак.Владелец
		|";
					
			
	Запрос.УстановитьПараметр("ДокументСсылка", ДокументСсылка);
	
	Результат = Запрос.Выполнить();
	
	Количество = 0;
	
	Если Результат.Пустой() Тогда
		
					Количество = ДокументСсылка.Товары.Итог("Количество") / 1000;
		
		Возврат Новый Структура("Вес, Объем, КоличествоПаллет", Количество, Количество, 0);
	Иначе
		
		Выборка = Результат.Выбрать();                              
		Выборка.Следующий();
		ЗаполнитьЗначенияСвойств(СтруктрураВесОбъем, Выборка);
		Если СтруктрураВесОбъем.Вес = 0 Тогда
			
							Количество = ДокументСсылка.Товары.Итог("Количество") / 1000;
			
			
			СтруктрураВесОбъем.Вес = Количество;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СтруктрураВесОбъем;
	
