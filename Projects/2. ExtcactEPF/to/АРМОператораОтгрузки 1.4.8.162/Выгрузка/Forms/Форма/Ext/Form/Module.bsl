	|	ЗаказКлиента.Контрагент.ИНН,
	|	ЗаказКлиента.Контрагент.КПП,
	|	ЗаказКлиента.Контрагент
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
	|		ПО ЗаказКлиента.Контрагент = СкладыДополнительныеРеквизиты.Значение
	|			И (СкладыДополнительныеРеквизиты.Свойство.Наименование = ""Контрагент склада"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ДополнительныеРеквизиты КАК КонтрагентыДополнительныеРеквизиты
	|		ПО ЗаказКлиента.Контрагент = КонтрагентыДополнительныеРеквизиты.Ссылка
	|			И (КонтрагентыДополнительныеРеквизиты.Свойство.Наименование = ""ОбобщённыйДокумент"")
	|ГДЕ
	|	ЗаказКлиента.Ссылка В(&МассивОбъектов)
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ.Ссылка КАК Ссылка,
	|	ВТ.Номер,
	|	ВТ.ДатаДокумента КАК ДатаДокумента,
	|	ВТ.Проведен КАК Проведен,
	|	ВТ.Организация,
	|	ВТ.Префикс,
	|	ВТ.ГлавныйБухгалтер,
	|	ВТ.РукоВодитель,
	|	ВТ.ДолжностьРуководителя,
	|	ВТ.БанковскийСчетОрганизации,
	|	ВТ.БанковскийСчетПеревозчика,
	|	ВТ.Склад,
	|	ВТ.СкладПолучатель,
	|	ВТ.ОбобщенныйДокумент,
	|	ВТ.КонтрагентИНН,
	|	ВТ.КонтрагентКПП,
	|	ВТ.Контрагент,
	|	СкладыДополнительныеРеквизиты.Значение КАК АдресАлкогольногоСклада
	|ИЗ
	|	ВТ КАК ВТ
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
	|		ПО ВТ.Склад = СкладыДополнительныеРеквизиты.Ссылка
	|			И (СкладыДополнительныеРеквизиты.Свойство = &СвойствоАдресАлкогольногоСклада)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаДокумента,
	|	Ссылка");
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.УстановитьПараметр("СвойствоАдресАлкогольногоСклада", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Адрес алкогольного склада"));
	Шапка = Запрос.Выполнить().Выбрать();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПеремещениеТоваровТовары.Номенклатура КАК Товар,
	|	ПеремещениеТоваровТовары.Номенклатура.НаименованиеПолное КАК ТоварНаименование,
	|	ПеремещениеТоваровТовары.Номенклатура.Код КАК ТоварКод,
	|	ПеремещениеТоваровТовары.Характеристика.НаименованиеПолное КАК Характеристика,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваровТовары.Упаковка <> ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения)
	|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения)
	|	КОНЕЦ КАК БазоваяЕдиницаНаименование,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваровТовары.Упаковка <> ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения.Код
	|		ИНАЧЕ ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения.Код
	|	КОНЕЦ КАК ЕдиницаИзмеренияКодПоОКЕИ,
	|	ПеремещениеТоваровТовары.КоличествоУпаковок КАК Количество,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваровТовары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|			ТОГДА ПеремещениеТоваровТовары.Номенклатура.Вес * ПеремещениеТоваровТовары.Количество / 1000
	|		ИНАЧЕ ПеремещениеТоваровТовары.Упаковка.Вес * ПеремещениеТоваровТовары.КоличествоУпаковок / 1000
	|	КОНЕЦ КАК МассаБрутто,
