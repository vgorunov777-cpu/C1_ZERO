		//		ЖДП = ТекДок.ЖелаемаяДатаОтгрузки;
		//	ИначеЕсли ТипЗнч(ТекДок) = Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
		//		ЖДП = ТекДок.ЗаказКлиента.ЖелаемаяДатаОтгрузки;
		//	Иначе
		//		Если ПустаяСтрока(ТекДок.ЗаказНаПеремещение) Тогда
		//			ЖДП = ТекДок.ДатаРаспоряжения;
		//		Иначе
		//			ЖДП = ТекДок.ЗаказНаПеремещение.ЖелаемаяДатаПоступления;
		//		КонецЕсли; 
		//	КонецЕсли; 
		//КонецЕсли; 
		Если ТипЗнч(ТекДок) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			Для Каждого ТекСтр Из ТекДок.ДатыВыпуска Цикл
				НоваяСтрока = ТаблицаНоменклатурИДатВыработки.Добавить();
				НоваяСтрока.Номенклатура = ТекСтр.Номенклатура;
				НоваяСтрока.ДатаВыпуска = ТекСтр.ДатаВыпуска;
			КонецЦикла; 
		Иначе
			Для Каждого ТекСтр Из ТекДок.Товары Цикл
				МассивНоменклатуры.Добавить(ТекСтр.Номенклатура);
			КонецЦикла;
		КонецЕсли; 
		//КонецЦикла; 
		
		НомерДатаНакладной = НомерДатаНакладной + " от " + Формат(ДатаНакладной, "ДФ=dd.MM.yy");
		//Если ТипПечати = "3" ИЛИ ТипПечати = "4" ИЛИ ТипПечати = "5" Тогда
		//	//НомерДатаНакладной = Формат(ЖДП, "ДФ=dd.MM.yy");
		//	НомерДатаНакладной = Формат(ТекущаяДата(), "ДФ=dd.MM.yy");
		//КонецЕсли; 
		//Если ТипПечати = "1" ИЛИ ТипПечати = "2" Тогда
		НомерДатаНакладной = "Накладная " + Лев(ТекущийМагазин,5) + "  " + Формат(ТекущаяДата(), "ДФ=dd.MM.yy");
		//КонецЕсли; 
		
		//Получаем таблицу дат выработки
		Если ТипЗнч(ТекДок) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ТаблицаИскомыхЗначений = ПолучитьТаблицуДатВыработки(ТаблицаНоменклатурИДатВыработки);
		Иначе	
			ТаблицаИскомыхЗначений = НайтиДокументыПоступленияПоНоменклатуре(МассивНоменклатуры);
		КонецЕсли; 
		
		ОбластьМакетаШапка = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакетаШапка.Параметры.НомерДатаНакладной = НомерДатаНакладной;
		ОбластьМакетаШапка.Параметры.АдресМагазина = ПолучитьАдресМагазина(ТекущийМагазин);
		
		СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ШапкаОрганизация, ДатаНакладной);
		ОрганизацияСтрока = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации, "ПолноеНаименование,ИНН,ЮридическийАдрес,Телефоны");
		ОбластьМакетаШапка.Параметры.Организация = ОрганизацияСтрока;
		ТабДокумент.Вывести(ОбластьМакетаШапка);
		
		ОбластьМакетаШапкаТаблицы = Макет.ПолучитьОбласть("ШапкаТаблицы");
		ТабДокумент.Вывести(ОбластьМакетаШапкаТаблицы);
		
		ОбластьГруппа = Макет.ПолучитьОбласть("Группа");
		ОбластьСтрокТовары = Макет.ПолучитьОбласть("Детали");
		НомерПоПорядку = 1;ИтогоВес = 0; 
		
		// Выборка товаров
		ВыборкаГруппТовары = РезультатТовары.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаГруппТовары.Следующий() Цикл
			
			ОбластьГруппа.Параметры.НоменклатурнаяГруппа = СокрЛП(ВыборкаГруппТовары.Группа);
			//Если ТипПечати = "1" ИЛИ ТипПечати = "2" Тогда
			ОбластьГруппа.Параметры.КолВо 				 = Формат(ВыборкаГруппТовары.Количество, "ЧДЦ=2") + "/" + Формат(ВыборкаГруппТовары.Вес, "ЧДЦ=2");
			ЗаписьЖурналаРегистрации("ВВ",,,, Формат(ВыборкаГруппТовары.Количество, "ЧДЦ=2") + "/" + Формат(ВыборкаГруппТовары.Вес, "ЧДЦ=2"));
			ЗаписьЖурналаРегистрации("ВВ",,,,ОбластьГруппа.Параметры.КолВо);
			Сообщить("***");
			//Иначе
			//	ОбластьГруппа.Параметры.КолВо 				 = Формат(ВыборкаГруппТовары.Количество, "ЧДЦ=2");
			//КонецЕсли;
			ТабДокумент.Вывести(ОбластьГруппа);
			
			ВыборкаСтрокТовары = ВыборкаГруппТовары.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаСтрокТовары.Следующий() Цикл
				ОбластьСтрокТовары.Параметры.Заполнить(ВыборкаСтрокТовары);
				
				ОбластьСтрокТовары.Параметры.Номенклатура	 	= ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати(СокрЛП(ВыборкаСтрокТовары.ТоварНаименование));
				ОбластьСтрокТовары.Параметры.КолВо			 	= Формат(ВыборкаСтрокТовары.Количество, "ЧДЦ=2");
				ИтогоКолВо = ИтогоКолВо +  ВыборкаСтрокТовары.Количество;
				ИтогоВес = ИтогоВес + ВыборкаСтрокТовары.Вес;
				
				СтруктураДат 										= ТаблицаИскомыхЗначений.Найти(ВыборкаСтрокТовары.Номенклатура, "Номенклатура");
				Если НЕ СтруктураДат = Неопределено Тогда
					ОбластьСтрокТовары.Параметры.ДатаВыработки		= "" + Формат(СтруктураДат.ДатаВыработки, "ДФ=dd.MM.yyyy");
				Иначе
					МассивНоменклатура = Новый Массив();
					МассивНоменклатура.Добавить(ВыборкаСтрокТовары.Номенклатура);
					ТаблицаДатПоНоменклатуре	= НайтиДокументыПоступленияПоНоменклатуре(МассивНоменклатура);
					СтруктураДат				= ТаблицаДатПоНоменклатуре.Найти(ВыборкаСтрокТовары.Номенклатура, "Номенклатура");
					ТекстСообщения = ТекстСообщения + "Номенклатура: " + ВыборкаСтрокТовары.Номенклатура + "    Дата выработки: " + Формат(ВыборкаСтрокТовары.ДатаВыпуска, "ДФ=dd.MM.yyyy");
					КоличествоНеНайденых = КоличествоНеНайденых + 1;
					Если ПустаяСтрока(СтруктураДат) Тогда
						ОбластьСтрокТовары.Параметры.ДатаВыработки = "";
					Иначе
						ОбластьСтрокТовары.Параметры.ДатаВыработки = "" + СтруктураДат.ДатаВыработки;
					КонецЕсли; 
				КонецЕсли; 
				
				Если НЕ ПустаяСтрока(СтруктураДат) И НЕ ПустаяСтрока(СтруктураДат.НомерВетСвидетельства) Тогда
					ОбластьСтрокТовары.Параметры.НомерВетСвидетельства = СтруктураДат.НомерВетСвидетельства;
				Иначе
					ОбластьСтрокТовары.Параметры.НомерВетСвидетельства = "";
					
					МассивНоменклатура = Новый Массив();
					МассивНоменклатура.Добавить(ВыборкаСтрокТовары.Номенклатура);
					ТаблицаДатПоНоменклатуре	= НайтиДокументыПоступленияПоНоменклатуре(МассивНоменклатура);
					СтруктураДат				= ТаблицаДатПоНоменклатуре.Найти(ВыборкаСтрокТовары.Номенклатура, "Номенклатура");
					
					Если ПустаяСтрока(СтруктураДат) Тогда
						ОбластьСтрокТовары.Параметры.НомерВетСвидетельства = "";
					Иначе
						ОбластьСтрокТовары.Параметры.НомерВетСвидетельства = СтруктураДат.НомерВетСвидетельства;
					КонецЕсли; 
				КонецЕсли; 
				
				ПроизВодитель			 							= ПолучитьФиксПоставщика(ВыборкаСтрокТовары.Номенклатура);
				Если ПроизВодитель = Неопределено Тогда
					ОбластьСтрокТовары.Параметры.ПроизВодитель		= "";
				Иначе
					ОбластьСтрокТовары.Параметры.ПроизВодитель		= ПроизВодитель;
				КонецЕсли; 
				
				ТабДокумент.Вывести(ОбластьСтрокТовары);
				НомерПоПорядку = НомерПоПорядку + 1;
				
			КонецЦикла;
			
		КонецЦикла;
		
		//Если КоличествоНеНайденых > 0 Тогда
		//	ОтправитьФайлПоПочте(ТекстСообщения);
		//КонецЕсли; 
		
		// Выводим итоги по документу в целом
		ОбластьМакета = Макет.ПолучитьОбласть("Итого");
		ПараметрыПредметаИсчисления = "килограмм, килограмма, килограммов, м, грамм, грамма, граммов, м, 3";
		ФорматнаяСтрока = "Л=ru_RU; ДП=Истина";
		
		ИтогоВесПрописью = ЧислоПрописью(ИтогоВес, ФорматнаяСтрока, ПараметрыПредметаИсчисления);
		
		//Если ТипПечати = "1" ИЛИ ТипПечати = "2" Тогда
		ОбластьМакета.Параметры.ВесНетто = "" + Формат(ИтогоВес , "ЧДЦ=2") + "(" + ИтогоВесПрописью + ")";
		//КонецЕсли; 
		ОбластьМакета.Параметры.ИтогоКолВо = Формат(ИтогоКолВо, "ЧДЦ=2");
		
		ТабДокумент.Вывести(ОбластьМакета);
		
		ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
	КонецЦикла;
	
	//Если ТипПечати = "3" ИЛИ ТипПечати = "4" ИЛИ ТипПечати = "5" Тогда
	//	ОбластьМакета = Макет.ПолучитьОбласть("Подвал");
	//	ТабДокумент.Вывести(ОбластьМакета);
	//КонецЕсли; 
	
	Возврат ТабДокумент;
	
КонецФункции

//**************** ВЕТЕРИНАРКА НОВАЯ
&НаСервере
Функция СформироватьПечатнуюФормуПриложенияДляВетВрачаНов(МассивОбъектов, Макет, КоличествоЭкземпляров, ТипПечати = 1, ТаблицаПФ)
	
	//Если ТипПечати = "1" ИЛИ ТипПечати = "2" Тогда
	//	Макет = ПолучитьМакет("ПФ_MXL_ПриложениеДляВетВрача");
	//ИначеЕсли ТипПечати = "3" ИЛИ ТипПечати = "4" Тогда
	//	Макет = ПолучитьМакет("ПФ_MXL_ПриложениеДляВетВрачаНовосибирск");
	//Иначе
	//	Макет = ПолучитьМакет("ПФ_MXL_ПриложениеДляВетВрачаНовосибирск_Старая");
	//КонецЕсли; 
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_Накладная_Для_ветеренарного_врача";
	
	МассивНоменклатуры = Новый Массив;
	
	// Зададим параметры макета
	ТабДокумент.ПолеСверху = 0;
	ТабДокумент.ПолеСлева  = 0;
	ТабДокумент.ПолеСнизу  = 0;
	ТабДокумент.ПолеСправа = 0;
	ТабДокумент.АвтоМасштаб = Истина;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДокумент.ТолькоПросмотр = Ложь;
	ТабДокумент.КоличествоЭкземпляров = 2;
	
	ИтогоКолВо = 0;
	
	//текстЗапроса
	Если Истина Тогда
		Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	НоменклатураДополнительныеРеквизитыВетГруппа.Значение КАК Группа,
		|	ПеремещениеТоваровДатыВыпуска.Номенклатура КАК Номенклатура,
		|	ПеремещениеТоваровДатыВыпуска.Номенклатура.НаименованиеПолное КАК ТоварНаименование,
		|	ПеремещениеТоваровДатыВыпуска.Номенклатура.Код КАК ТоварКод,
		|	СУММА(ВЫБОР
		|			КОГДА ПеремещениеТоваровДатыВыпуска.Номенклатура.ЕдиницаИзмерения.Код = ""796""
		|				ТОГДА ПеремещениеТоваровДатыВыпуска.Количество
		|			ИНАЧЕ ПеремещениеТоваровДатыВыпуска.Количество * ПеремещениеТоваровДатыВыпуска.Номенклатура.Вес
		|		КОНЕЦ) КАК Количество,
		|	СУММА(ПеремещениеТоваровДатыВыпуска.Количество * ПеремещениеТоваровДатыВыпуска.Номенклатура.Вес) КАК Вес,
		|	ПеремещениеТоваровДатыВыпуска.Номенклатура.ЕдиницаИзмерения КАК ЕдиницаИзмерения,
		|	ПеремещениеТоваровДатыВыпуска.ДатаВыпуска,
		|	ПеремещениеТоваровДатыВыпуска.НомерПартии
		|ИЗ
		|	Документ.ПеремещениеТоваров.ДатыВыпуска КАК ПеремещениеТоваровДатыВыпуска
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизитыВетГруппа
		|		ПО ПеремещениеТоваровДатыВыпуска.Номенклатура = НоменклатураДополнительныеРеквизитыВетГруппа.Ссылка
		|			И (НоменклатураДополнительныеРеквизитыВетГруппа.Свойство.Наименование = ""НоменклатурнаяГруппаДляВетВрача"")
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизитыВетКонтроль
		|		ПО ПеремещениеТоваровДатыВыпуска.Номенклатура = НоменклатураДополнительныеРеквизитыВетКонтроль.Ссылка
		|			И (НоменклатураДополнительныеРеквизитыВетКонтроль.Свойство.Наименование = ""ВетКонтроль"")
		|ГДЕ
		|	ПеремещениеТоваровДатыВыпуска.Ссылка В(&МассивОбъектов)
		|	И НоменклатураДополнительныеРеквизитыВетГруппа.Значение <> &Значение
		|
		|СГРУППИРОВАТЬ ПО
		|	ПеремещениеТоваровДатыВыпуска.Номенклатура,
		|	ПеремещениеТоваровДатыВыпуска.Номенклатура.НаименованиеПолное,
		|	ПеремещениеТоваровДатыВыпуска.Номенклатура.Код,
		|	НоменклатураДополнительныеРеквизитыВетГруппа.Значение,
		|	ПеремещениеТоваровДатыВыпуска.Номенклатура.ЕдиницаИзмерения,
		|	ПеремещениеТоваровДатыВыпуска.ДатаВыпуска,
		|	ПеремещениеТоваровДатыВыпуска.НомерПартии
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НоменклатураДополнительныеРеквизиты_ВетГруппа.Значение,
		|	ЗаказНаПеремещениеТовары.Номенклатура,
		|	ЗаказНаПеремещениеТовары.Номенклатура.НаименованиеПолное,
		|	ЗаказНаПеремещениеТовары.Номенклатура.Код,
		|	СУММА(ВЫБОР
		|			КОГДА ЗаказНаПеремещениеТовары.Номенклатура.ЕдиницаИзмерения.Код = ""796""
		|				ТОГДА ЗаказНаПеремещениеТовары.Количество
		|			ИНАЧЕ ЗаказНаПеремещениеТовары.КоличествоУпаковок * ЗаказНаПеремещениеТовары.Номенклатура.Вес
		|		КОНЕЦ),
		|	СУММА(ЗаказНаПеремещениеТовары.КоличествоУпаковок * ЗаказНаПеремещениеТовары.Номенклатура.Вес),
		|	ЗаказНаПеремещениеТовары.Номенклатура.ЕдиницаИзмерения,
		|	NULL,
		|	NULL
		|ИЗ
		|	Документ.ЗаказНаПеремещение.Товары КАК ЗаказНаПеремещениеТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты_ВетГруппа
		|		ПО ЗаказНаПеремещениеТовары.Номенклатура = НоменклатураДополнительныеРеквизиты_ВетГруппа.Ссылка
		|			И (НоменклатураДополнительныеРеквизиты_ВетГруппа.Свойство.Наименование = ""НоменклатурнаяГруппаДляВетВрача"")
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты_ВетКонтроль
