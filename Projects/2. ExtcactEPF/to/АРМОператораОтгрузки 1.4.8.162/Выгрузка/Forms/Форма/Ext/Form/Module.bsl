&НаКлиенте
Процедура ВыделитьАлкоЗаказы(Команда)
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаЗНО" Тогда	
		ВыделитьАлкоЗаказыНаСервере();
		СвернутьРазвернутьДерево();
	КонецЕсли;
КонецПроцедуры

 &НаСервере
 Процедура ВыделитьАлкоЗаказыНаСервере()
	АлкоСклад = Справочники.Склады.НайтиПоНаименованию("Алкоголь-Основной РЦ(WMS)");
	Если АлкоСклад <> Справочники.Склады.ПустаяСсылка() тогда
		ПолучимДерево = РеквизитФормыВЗначение("ЗНО");	
		Для Каждого запись из получимдерево.Строки Цикл
			Для Каждого запись1 из запись.Строки Цикл
				Если запись1.ДатаВыезда = АлкоСклад тогда
					запись1.Пометка = Истина;
					Запись.Пометка = Истина;
				КонецЕсли;
			КонецЦикла;
		КонецЦикла;
		
		ЗначениеВРеквизитФормы(получимдерево,"ЗНО");
	КонецЕсли;
КонецПроцедуры

