&НаСервере
Процедура РеестрВетСертификатовСервер()

	МассивЗНО = Новый Массив;
	
	СтрокиДерева = ЗНО.ПолучитьЭлементы();
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл	
		
		Если СтрокаДерева.Пометка = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		Если НЕ СтрокаДерева.ЗНО.Статус = Перечисления.СтатусыЗаказовНаОтгрузку.Отгружено Тогда
			Сообщить("" + СтрокаДерева.ЗНО + "находится в статусе " + СтрокаДерева.ЗНО.Статус + ". Формировать ВСД можно только для документво со статусом ОТГРУЖЕНО.");
			Продолжить;
		КонецЕсли;	
		
		МассивЗНО.Добавить(СтрокаДерева.ЗНО);
		
	КонецЦикла;	
	
	МодульВетис = ВетисПовтИсп.ИнициализароватьПодключаемыйМодуль();
	МодульВетис.СформироватьЗаявкиПеремещениеПоЗНО(МассивЗНО);
	
КонецПроцедуры

