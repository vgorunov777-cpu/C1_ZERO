	// ЛВО 4.04.2022+
	ШаблонШтрихкодНакладной = "2#%1#" + "%2";
	//-
	
	Пока Шапка.Следующий() Цикл
		Если НЕ Шапка.Проведен Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ " + Строка(Шапка.Ссылка) + " пропущен, Нельзя печатать не проведенные документы!");
			Продолжить;
		КонецЕсли; 
		
		// ЛВО 4.04.2022+
		ГодДокументов = Формат(Шапка.ДатаДокумента, "ДФ = гг");
		//-
		
		Запрос.УстановитьПараметр("ПеремещениеТоваров", Шапка.Ссылка);
		Запрос.УстановитьПараметр("Период",  Шапка.ДатаДокумента);    
		Запрос.УстановитьПараметр("ВидЦены", ОбщегоНазначения.ПолучитьЗначениеРеквизита(Шапка.СкладПолучатель, "УчетныйВидЦены"));
		Выборка = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		// Выводим общие реквизиты шапки.
		СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Организация, Шапка.ДатаДокумента);
		//СведенияОПокупателе = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Контрагент, Шапка.ДатаДокумента,, Шапка.БанковскийСчетКонтрагента);
		
		ОбластьМакета         = Макет.ПолучитьОбласть("Шапка");
		ОбластьМакета.Параметры.Заполнить(Шапка);
		
		СкладОтправитель = ПолучитьСкладПолучатель(Шапка.Ссылка, "Отправитель");
		ИНН = ПолучитьИННСклада(СкладОтправитель);
		КПП = ПолучитьКППСклада(СкладОтправитель);
		
		// ЛВО 18.08.2020 +  Возможность алкогольного склада
		Если  НЕ ПустаяСтрока(Шапка.АдресАлкогольногоСклада) тогда
			АдресСклада = Шапка.АдресАлкогольногоСклада;
		Иначе
			
			АдресСклада = ПолучитьАдресМагазина(СкладОтправитель);		
		КонецЕсли;
		// -

		
		ПредставлениеОрганизации  = "" + Шапка.Организация + ", ИНН/КПП: " + ИНН + "/" + КПП + "  " + АдресСклада;
		ОбластьМакета.Параметры.ПредставлениеОрганизации = ПредставлениеОрганизации;
		
		ОбластьМакета.Параметры.НомерДокумента           = Шапка.Номер;
		ОбластьМакета.Параметры.ДатаДокумента            = Шапка.ДатаДокумента;
		
		//ЛВО 04.04.2022 +
		ШтрихкодНакладной = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонШтрихкодНакладной
																							, СтрЗаменить(Шапка.номер, "-", "")
																							, ГодДокументов);
		ОбластьМакета.Параметры.ШтрихкодДокумента = ШтрихкодНакладной;
		//ЗаполнитьШтрихКодОбласть(ОбластьМакета, ШтрихкодНакладной);
