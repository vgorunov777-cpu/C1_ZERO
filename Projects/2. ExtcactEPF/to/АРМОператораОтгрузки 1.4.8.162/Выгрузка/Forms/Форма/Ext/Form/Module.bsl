Функция ПолучитьТаблицуДатВыработки(ТаблицаНоменклатурИДатВыработки)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВТ_ВходящиеДанные.Номенклатура,
	|	ВТ_ВходящиеДанные.ДатаВыпуска,
	|	ВТ_ВходящиеДанные.НомерПартии
	|ПОМЕСТИТЬ ВТ_1
	|ИЗ
	|	&ВТ_ВходящиеДанные КАК ВТ_ВходящиеДанные
	|;
	|
	|////////////////////////////////////////////////////////////////////////////////
	|ВЫБРАТЬ
	|	ВТ_1.Номенклатура,
	|	ВЫБОР
	|		КОГДА ПоступлениеТоваровУслугТовары.НомерПаспорта = """"
	|			ТОГДА ВТ_1.ДатаВыпуска
	|		ИНАЧЕ ПоступлениеТоваровУслугТовары.НомерПаспорта
	|	КОНЕЦ КАК ДатаВыработки,
	|	МАКСИМУМ(ПоступлениеТоваровУслугТовары.Сертификат) КАК НомерВетСвидетельства,
	|	ПоступлениеТоваровУслугДатыВыпуска.НомерПартии,
	|	ПоступлениеТоваровУслугДатыВыпуска.Ссылка.Контрагент
	|ИЗ
	|	ВТ_1 КАК ВТ_1
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеТоваровУслуг.ДатыВыпуска КАК ПоступлениеТоваровУслугДатыВыпуска
	|			ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
	|			ПО ПоступлениеТоваровУслугДатыВыпуска.Ссылка = ПоступлениеТоваровУслугТовары.Ссылка
	|				И ПоступлениеТоваровУслугДатыВыпуска.Номенклатура = ПоступлениеТоваровУслугТовары.Номенклатура
	|		ПО ВТ_1.Номенклатура = ПоступлениеТоваровУслугДатыВыпуска.Номенклатура
	|			И ВТ_1.ДатаВыпуска = ПоступлениеТоваровУслугДатыВыпуска.ДатаВыпуска
	|			И ВТ_1.НомерПартии = ПоступлениеТоваровУслугДатыВыпуска.НомерПартии
	|
	|СГРУППИРОВАТЬ ПО
	|	ВТ_1.Номенклатура,
	|	ПоступлениеТоваровУслугДатыВыпуска.НомерПартии,
	|	ПоступлениеТоваровУслугДатыВыпуска.Ссылка.Контрагент,
	|	ВЫБОР
	|		КОГДА ПоступлениеТоваровУслугТовары.НомерПаспорта = """"
	|			ТОГДА ВТ_1.ДатаВыпуска
	|		ИНАЧЕ ПоступлениеТоваровУслугТовары.НомерПаспорта
	|	КОНЕЦ";
	
	Запрос.УстановитьПараметр("ВТ_ВходящиеДанные", ТаблицаНоменклатурИДатВыработки);
	
	Возврат Запрос.Выполнить().Выгрузить();
	
