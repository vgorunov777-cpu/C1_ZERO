Функция СформироватьПечатнуюФормуРеестраМаршрутныхЛистов()
	
	УстановитьПривилегированныйРежим(Истина);
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Макет = Обработка.ПолучитьМакет("РеестрМаршрутныхЛистов");
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_РеестрМаршрутныхЛистов";
	
	// Зададим параметры макета
	ТабДокумент.ПолеСверху = 0;
	ТабДокумент.ПолеСлева  = 0;
	ТабДокумент.ПолеСнизу  = 0;
	ТабДокумент.ПолеСправа = 2;
	ТабДокумент.АвтоМасштаб = Истина;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	ОбластьМакета = Макет.ПолучитьОбласть("Шапка");
	ТабДокумент.Вывести(ОбластьМакета);
	ОбластьМакета = Макет.ПолучитьОбласть("Строка");
	
	Автомобили        = ЗНО;
	СтрокиАвтомобилей = Автомобили.ПолучитьЭлементы();
	Для Каждого Запись из СтрокиАвтомобилей цикл
		// Посчитаем вес для Записи+
		СтрокиМаршрута = Запись.ПолучитьЭлементы();
		вес = 0;
		Объем = 0;
		Для каждого СтрЗаказ из СтрокиМаршрута цикл
			ОтборВес = Новый Структура();
			ОтборВес.Вставить("Заказ",СтрЗаказ.Зно);
			
			НайденнаяСтрока = Запись.ЗНО.ДокументОснование.ЗаказыНаОтгрузку.НайтиСтроки(ОтборВес)[0];  
			Если не НайденнаяСтрока = неопределено тогда
			//ВесОбъем =ПолучитьВесИОбъемТоваровВУпаковкеWMSПоДокументуТЕСТ(СтрЗаказ.ЗНО);
				Объем =Объем+ НайденнаяСтрока.Объем;
				Вес = Вес+НайденнаяСтрока.Вес;
			КонецЕсли;
			
		КонецЦикла;
					//-
		
		ТЗ = Новый ТаблицаЗначений;
		ТЗ.Колонки.Добавить("СкладОтправитель");
		ТЗ.Колонки.Добавить("СкладПолучатель");
		
		СтрокиДокументов = Запись.ПолучитьЭлементы();
		для каждого ТекДок из СтрокиДокументов цикл
			Если ТипЗнч(ТекДок.ЗНО) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
				ИскомыйСклад = ТЗ.НайтиСтроки(Новый Структура("СкладОтправитель, СкладПолучатель", ТекДок.ЗНО.СкладОтправитель, ТекДок.ЗНО.СкладПолучатель));
				Если ИскомыйСклад.Количество() = 0 Тогда
					НоваяСтрока = ТЗ.Добавить();
					НоваяСтрока.СкладОтправитель = ТекДок.ЗНО.СкладОтправитель;
					НоваяСтрока.СкладПолучатель = ТекДок.ЗНО.СкладПолучатель;
				КонецЕсли; 
			Иначе
				ИскомыйСклад = ТЗ.НайтиСтроки(Новый Структура("СкладОтправитель, СкладПолучатель", ТекДок.ЗНО.Склад, ТекДок.ЗНО.Контрагент));
				Если ИскомыйСклад.Количество() = 0 Тогда
					НоваяСтрока = ТЗ.Добавить();
					НоваяСтрока.СкладОтправитель = ТекДок.ЗНО.Склад;
					НоваяСтрока.СкладПолучатель = ТекДок.ЗНО.Контрагент;
				КонецЕсли; 
			КонецЕсли; 
		КонецЦикла;
		
		ТЗ.Сортировать("СкладОтправитель");
		ТЗ.Свернуть("СкладОтправитель, СкладПолучатель");
		СтрокаСкладМагазин = ""; СкладОтправительПред = "";
		Для каждого ТекСтрСклад Из ТЗ Цикл
			Если ПустаяСтрока(СкладОтправительПред) ИЛИ НЕ ТекСтрСклад.СкладОтправитель = СкладОтправительПред Тогда
				Если ПустаяСтрока(СкладОтправительПред) Тогда
					СтрокаСкладМагазин = СтрокаСкладМагазин + ТекСтрСклад.СкладОтправитель + " (";	
				Иначе
					СтрокаСкладМагазин = СтрокаСкладМагазин + "), " + Символы.ПС + ТекСтрСклад.СкладОтправитель + " (";	
				КонецЕсли; 
				СкладОтправительПред = ТекСтрСклад.СкладОтправитель;
			КонецЕсли; 
			СтрокаСкладМагазин = СтрокаСкладМагазин + ТекСтрСклад.СкладПолучатель + ", ";
		КонецЦикла; 
		ОбластьМакета.Параметры.СкладМагазин = СтрокаСкладМагазин + ")";
			//ОбластьМакета.Параметры.Водитель = ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Запись.Водитель);
		ОбластьМакета.Параметры.Водитель1 = Запись.Водитель;
		Если НЕ ПустаяСтрока(Запись.Водитель) Тогда
			Телефон1 = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Запись.Водитель, Справочники.ВидыКонтактнойИнформации.МобильныйТелефонФизическогоЛица);
			ОбластьМакета.Параметры.Водитель1 = Строка(ОбластьМакета.Параметры.Водитель1) + ?(Не Телефон1 = "", " / " + Телефон1, "");
		Иначе
			//ОбластьМакета.Параметры.Водитель = "";
		КонецЕсли; 
		
		ОбластьМакета.Параметры.Водитель2 = Запись.Водитель2;
		Если НЕ ПустаяСтрока(Запись.Водитель2) Тогда
			Телефон2 = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Запись.Водитель2, Справочники.ВидыКонтактнойИнформации.МобильныйТелефонФизическогоЛица);
			ОбластьМакета.Параметры.Водитель2 = Строка(ОбластьМакета.Параметры.Водитель2) + ?(Не Телефон2 = "", " / " + Телефон2, "");
		Иначе
			//ОбластьМакета.Параметры.Водитель2 = "";
		КонецЕсли; 
		
		ОбластьМакета.Параметры.ТС = Строка(Запись.Автомобиль);
		ОбластьМакета.Параметры.Контрагент = Строка(Запись.Перевозчик);
		
		ОбластьМакета.Параметры.Экспедитор = Строка(Запись.Экспедитор);

		ОбластьМакета.Параметры.КоличествоПалет = Запись.КоличествоПалет;
		ОбластьМакета.Параметры.ВремяВыезда = Запись.ДатаВыезда;
		ОбластьМакета.Параметры.ДатаПечати = Формат(Запись.ДатаВыезда, "ДФ=dd.MM.yyyy");
		
		ОбластьМакета.Параметры.ВесОбъем = Строка(Окр(Вес,2))+"/"+Символы.ПС+ Строка(Окр(Объем,2));
		ТабДокумент.Вывести(ОбластьМакета);
		
	КонецЦикла;
	
	Возврат ТабДокумент;
	
КонецФункции // СформироватьПечатнуюФормуРеестраМаршрутныхЛистов()


&НаКлиенте
Процедура УдалитьШК(Команда)
	
	ТекДан = Элементы.ЗНО.ТекущиеДанные;
	Если ТипЗнч(ТекДан.Автомобиль) = Тип("СправочникСсылка.ТранспортныеСредства") Тогда
		Для Каждого Стр Из ТекДан.ПолучитьЭлементы() Цикл
			Если ЗначениеЗаполнено(Стр.Автомобиль) Тогда
				УдалитьШКНаСервере(Стр.Автомобиль);
			КонецЕсли;
		КонецЦикла;
	Иначе
		УдалитьШКНаСервере(ТекДан.Автомобиль);
	КонецЕсли;
	
КонецПроцедуры

Процедура УдалитьШКНаСервере(Перемещение)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДополнительныеСведения.Объект,
	|	ДополнительныеСведения.Свойство,
	|	ДополнительныеСведения.Значение
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК Документ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|		ПО Документ.Ссылка = ДополнительныеСведения.Объект
	|			И (ДополнительныеСведения.Свойство.Наименование = ""Штрихкод документа"")
	|ГДЕ
	|	Документ.Ссылка = &Ссылка
	|
	|ОБЪЕДИНИТЬ
	|
	|ВЫБРАТЬ
	|	ДополнительныеСведения.Объект,
	|	ДополнительныеСведения.Свойство,
	|	ДополнительныеСведения.Значение
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК Документ
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|		ПО Документ.Ссылка = ДополнительныеСведения.Объект
	|			И (ДополнительныеСведения.Свойство.Наименование = ""Штрихкод документа"")
	|ГДЕ
	|	Документ.Ссылка = &Ссылка";
	
	Запрос.УстановитьПараметр("Ссылка", Перемещение);
	
	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		РС          = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
		РС.Объект   = ВыборкаДетальныеЗаписи.Объект;
		РС.Свойство = ВыборкаДетальныеЗаписи.Свойство;
		ШК          = ВыборкаДетальныеЗаписи.Значение;
		РС.Значение = Неопределено;
		Попытка
			ЗаписьЖурналаРегистрации("Создание штрихкода документа", УровеньЖурналаРегистрации.Информация,, ВыборкаДетальныеЗаписи.Объект, "ШтрихКод: " + ШК + " " + "Удалил: " + Строка(ПараметрыСеанса.ТекущийПользователь));
			РС.Удалить();
			//Попытка
			//	РС.Записать();
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
	КонецЕсли;
	
КонецПроцедуры

