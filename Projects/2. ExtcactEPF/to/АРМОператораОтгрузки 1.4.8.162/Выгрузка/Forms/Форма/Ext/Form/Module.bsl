		|	КОНЕЦ,
		|	ВТ_Перемещения.Дата,
		|	СкладыДополнительныеРеквизиты.Значение,
		|	ВЫБОР
		|		КОГДА ВТ_Перемещения.Упаковка <> ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
		|			ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(ВТ_Перемещения.УпаковкаЕдиницаИзмерения)
		|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(ВТ_Перемещения.НоменклатураЕдиницаИзмерения)
		|	КОНЕЦ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Товар
		|ИТОГИ
		|	МАКСИМУМ(Дата),
		|	МАКСИМУМ(АдресАлкогольногоСклада)
		|ПО
		|	Организация,
		|	СкладПолучатель,
		|	СкладОтправитель
		|АВТОУПОРЯДОЧИВАНИЕ";
		
		Запрос.УстановитьПараметр("ТекущийПериод", ТекущаяДата());
		Запрос.УстановитьПараметр("ПеремещениеТоваров", МассивДокументов);
		Запрос.УстановитьПараметр("ТоварКод", ТоварКод);
		Запрос.УстановитьПараметр("СвойствоАдресАлкогольногоСклада",ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Адрес алкогольного склада")); 
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		ШаблонШтрихкодНакладной = "2#%1#" + "%2";//Формат(ТекущаяДата(), "ДФ = гг");
		
		Пока Выборка.Следующий() Цикл
			
			ГодДокументов = Формат(Выборка.Дата, "ДФ = гг");
			
			СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Выборка.Организация, ТекущаяДата());
			ВыборкаМагазинов = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаМагазинов.Следующий() Цикл
				
				ОбщийПолучатель = ВыборкаМагазинов.СкладПолучатель;
				
				ВыборкаПолучателей.Сбросить();
				НомерДокументаСтрока="";
				ОбщийНомер="+";
				Пока ВыборкаПолучателей.НайтиСледующий(Новый структура("СкладПолучатель",ОбщийПолучатель)) Цикл
					// создадим строку номеров
					// выделим номер
					ЧастьНомера="";
					НомерДокумента = ВыборкаПолучателей.номер + " " + "от" + " " + Формат(ВыборкаПолучателей.Дата, "ДЛФ = Д");
					ДлинаНомера = стрдлина(НомерДокумента);
					Для сч = 0 по ДлинаНомера Цикл
						номерсимвола = длинаномера-сч;
						Сим = сред(НомерДокумента,номерсимвола,1);
						Если сим="-" Тогда
							прервать;
						КонецЕсли;
						ЧастьНомера = сим + ЧастьНомера ;
					КонецЦикла;
					// счас уберем левые нули
					Для сч=1 по стрдлина(частьномера) Цикл
						сим = сред(частьномера,сч,1);
						Если сим<>"0" Тогда
							Прервать;
						КонецЕсли;
					КонецЦикла;
					
					Если СокрЛП(частьномера) <> "" Тогда
						общийномер = общийномер + прав(ЧастьНомера,стрдлина(частьномера)-сч+1) + "+";
					КонецЕсли;
					НомерДокументаСтрока = НомерДокументаСтрока + ?(Не НомерДокументаСтрока = "", " / ", "") + НомерДокумента;
					
				КонецЦикла;
				
				ОбластьШапки.Параметры.ПредставлениеОрганизации = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации);
				//Удалить старая версия, Заполняем Штрихкод
				//ЗаполнитьШтрихКодОбласть(ОбластьШапки, ОбщийНомер, ВнешняяКомпонента);
				//Если СтруктураПараметров.ВыводитьШтрихкод Тогда
				ШтрихкодНакладной = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонШтрихкодНакладной
																							, СтрЗаменить(ВыборкаПолучателей.номер, "-", "")
																							, ГодДокументов);
																							
				
				ОбластьШапки.Параметры.ШтрихкодДокумента = ШтрихкодНакладной;
				//ЗаполнитьШтрихКодОбласть(ОбластьШапки, ШтрихкодНакладной);
				//КонецЕсли; 
				ОбластьШапки.Параметры.НомерДокумента = НомерДокументаСтрока;
				ТабДокумент.Вывести(ОбластьШапки);
				
				// начнем 
				ВыборкаСкладов = ВыборкаМагазинов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				ИтогоКоличество  = 0;
				ИтогоМассаБрутто = 0;
				ИтогоМассаНетто  = 0;
				ИтогоСумма       = 0;
				
				Пока ВыборкаСкладов.Следующий() Цикл
					ОбщийОтправитель = ВыборкаСкладов.СкладОтправитель;
					// напечатаем заголовок отгрузки со склада
					// ЛВО 18.08.2020 + возможность алкогольного склада +
					Если Не ПустаяСтрока(ВыборкаСкладов.АдресАлкогольногоСклада) тогда
						ОбластьСклада.параметры.ОтправительПодразделение = ВыборкаСкладов.АдресАлкогольногоСклада;
					Иначе	
						ОбластьСклада.параметры.ОтправительПодразделение = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(ОбщийОтправитель, Справочники.ВидыКонтактнойИнформации.АдресСклада);//ОбщийОтправитель;
					КонецЕсли;	
					ОбластьСклада.параметры.ПолучательПодразделение = ОбщийПолучатель;
					ТабДокумент.Вывести(ОбластьСклада);
					
					выборкаСтрокТовары = выборкаскладов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					КоличествоСтрок = ВыборкаСтрокТовары.Количество();
					
					Если КоличествоСтрок = 1 Тогда
						ПереноситьПоследнююСтроку = 0;
					Иначе
						ЦелыхСтраницСПодвалом     = Цел((СтрокШапки + КоличествоСтрок + СтрокПодвала) / СтрокНаСтранице);
						ЦелыхСтраницБезПодвала    = Цел((СтрокШапки + КоличествоСтрок - 1) / СтрокНаСтранице);
						ПереноситьПоследнююСтроку = ЦелыхСтраницСПодвалом - ЦелыхСтраницБезПодвала;
					КонецЕсли;
					
					// инициализация итогов по странице
					ИтогКоличествоМестПоСтранице = 0;
					ИтогМассаБруттоПоСтранице    = 0;
					ИтогМассыНеттоПоСтранице     = 0;
					ИтогСуммыПоСтранице          = 0;
					
					// инициализация итогов по документу
					
					Ном = 0;
					НомерСтраницы=1;
					ОбластьЗаголовка.Параметры.НомерСтраницы = "Страница " + НомерСтраницы; 
					ТабДокумент.Вывести(ОбластьЗаголовка);
					
					Пока выборкаСтроктовары.Следующий() Цикл
						// будем выводить товары
						Ном = Ном + 1;
						//Начинаем новую страницу, Если предыдущая строка была последней на странице
						//или пора переносить последнюю строку на последнюю страницу с подвалом.
						ЦелаяСтраница = (СтрокШапки + Ном - 1) / СтрокНаСтранице;
						
						Если (ЦелаяСтраница = Цел(ЦелаяСтраница))
							или ((ПереноситьПоследнююСтроку = 1) и (Ном = КоличествоСтрок)) Тогда
							
							ОбластьИтогоПоСтранице.Параметры.ИтогКоличествоМестПоСтранице = ИтогКоличествоМестПоСтранице;
							ОбластьИтогоПоСтранице.Параметры.ИтогМассаБруттоПоСтранице    = ИтогМассаБруттоПоСтранице;
							ОбластьИтогоПоСтранице.Параметры.ИтогМассыНеттоПоСтранице     = ИтогМассыНеттоПоСтранице;
							ОбластьИтогоПоСтранице.Параметры.ИтогСуммыПоСтранице          = ИтогСуммыПоСтранице;
							
							ТабДокумент.Вывести(ОбластьИтогоПоСтранице);
							
							// инициализация итогов по странице
							ИтогКоличествоМестПоСтранице = 0;
							ИтогМассаБруттоПоСтранице    = 0;
							ИтогМассаНеттоПоСтранице     = 0;
							ИтогСуммыПоСтранице          = 0;
							
							НомерСтраницы = НомерСтраницы + 1;
							ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
							ОбластьЗаголовка.Параметры.НомерСтраницы = "Страница " + НомерСтраницы;
							ТабДокумент.Вывести(ОбластьЗаголовка);
							
						КонецЕсли;
						
						ОбластьСтроки.Параметры.Заполнить(ВыборкаСтрокТовары);
						
						КоличествоМест = Формат(ВыборкаСтрокТовары.Количество, "ЧЦ=15; ЧДЦ=3");
						
						ОбластьСтроки.Параметры.КоличествоМест    = КоличествоМест;
						
						ОбластьСтроки.Параметры.ТоварНаименование = ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати(
						СокрЛП(ВыборкаСтрокТовары.ТоварНаименование),
						СокрЛП(ВыборкаСтрокТовары.Характеристика));
						
						Сумма = ВыборкаСтрокТовары.Количество * ВыборкаСтрокТовары.Цена;
						
						ОбластьСтроки.Параметры.Сумма = Сумма;
						
						ТабДокумент.Вывести(ОбластьСтроки);
						
						// Обновим итоги по странице
						ИтогКоличествоМестПоСтранице = ИтогКоличествоМестПоСтранице + ВыборкаСтрокТовары.Количество;
						ИтогМассаБруттоПоСтранице    = ИтогМассаБруттоПоСтранице    + ВыборкаСтрокТовары.МассаБрутто;
						ИтогМассыНеттоПоСтранице     = ИтогМассыНеттоПоСтранице     + ВыборкаСтрокТовары.МассаНетто;
						ИтогСуммыПоСтранице          = ИтогСуммыПоСтранице          + Сумма;
						
						// Обновим итогов по документу
						ИтогоКоличество  = ИтогоКоличество  + ВыборкаСтрокТовары.Количество;
						ИтогоМассаБрутто = ИтогоМассаБрутто + ВыборкаСтрокТовары.МассаБрутто;
						ИтогоМассаНетто  = ИтогоМассаНетто  + ВыборкаСтрокТовары.МассаНетто;
						ИтогоСумма       = ИтогоСумма       + Сумма;
						
					КонецЦикла;
					
				КонецЦикла;		
				// завершим печать накладной
				ОбластьИтогоПоСтранице.Параметры.ИтогКоличествоМестПоСтранице = ИтогКоличествоМестПоСтранице;
				ОбластьИтогоПоСтранице.Параметры.ИтогМассаБруттоПоСтранице    = ИтогМассаБруттоПоСтранице;
				ОбластьИтогоПоСтранице.Параметры.ИтогМассыНеттоПоСтранице     = ИтогМассыНеттоПоСтранице;
				ОбластьИтогоПоСтранице.Параметры.ИтогСуммыПоСтранице          = ИтогСуммыПоСтранице;
				
				ТабДокумент.Вывести(ОбластьИтогоПоСтранице);
				
				// Выводим итоги по документу в целом
				ОбластьМакета = Макет.ПолучитьОбласть("Всего");
				ОбластьМакета.Параметры.ИтогоКоличествоМест = ИтогоКоличество;
				ОбластьМакета.Параметры.ИтогоМассаБрутто    = ИтогоМассаБрутто;
				ОбластьМакета.Параметры.ИтогоМассаНетто     = ИтогоМассаНетто;
				ОбластьМакета.Параметры.ИтогоСумма          = ИтогоСумма;
				
				ТабДокумент.Вывести(ОбластьМакета);
				
				// Выводим подвал документа
				ОбластьМакета  = Макет.ПолучитьОбласть("Подвал");
				//ОбластьМакета.Параметры.Заполнить(Шапка);
				
				ОбластьМакета.Параметры.ДолжностьОтправителя = "Бухгалтер-оператор";
				// 12.05.2020 +
				СтрокаДоверенность = ПараметрыСеанса.ТекущийПользователь.Наименование;
				Запрос = Новый Запрос;
				Запрос.Текст = "ВЫБРАТЬ
				               |	ПользователиДополнительныеРеквизиты.Значение
				               |ИЗ
				               |	Справочник.Пользователи.ДополнительныеРеквизиты КАК ПользователиДополнительныеРеквизиты
				               |ГДЕ
				               |	ПользователиДополнительныеРеквизиты.Ссылка = &Пользователь
				               |	И ПользователиДополнительныеРеквизиты.Свойство.Наименование = &Свойство";
				Запрос.УстановитьПараметр("Пользователь",ПараметрыСеанса.ТекущийПользователь);
				Запрос.УстановитьПараметр("Свойство", "Информация о доверенности");
				РезультатДов = Запрос.Выполнить();
				Если не РезультатДов.Пустой() тогда
					ВыборкаДоверенность = РезультатДов.Выбрать();
					Пока ВыборкаДоверенность.Следующий() цикл
						 Доверенность = ВыборкаДоверенность.Значение;
					 КонецЦикла;
					 СтрокаДоверенность = СтрокаДоверенность + " по доверенности " + Доверенность;
				КонецЕсли;	
				//-
				ОбластьМакета.Параметры.ФИООтправителя       = СтрокаДоверенность;//ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Шапка.КладовщикОтправитель);
				
				ОбластьМакета.Параметры.ДолжностьПолучателя  = "";//Шапка.ДолжностьКладовщикаПолучателя;
				ОбластьМакета.Параметры.ФИОПолучателя        = "";//ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Шапка.КладовщикПолучатель);
				
				//Если ЗначениеЗаполнено(Шапка.УчетныйВидЦеныВалютаЦены) Тогда
				ОбластьМакета.Параметры.ИтогоСуммаПрописью = РаботаСКурсамиВалют.СформироватьСуммуПрописью(Цел(ИтогоСумма),ВалютаЦены, Истина);
				//Иначе
				//	ОбластьМакета.Параметры.ИтогоСуммаПрописью = НСтр("ru = 'Ноль'");
				//КонецЕсли;
				
				ОбластьМакета.Параметры.ИтогоСуммаКоп      = Формат(Цел((ИтогоСумма-Цел(ИтогоСумма))*100), "ЧЦ=2; ЧН=00");
				
				ТабДокумент.Вывести(ОбластьМакета);
				
				ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	СохранитьДанныеОПечати(МассивПечать, "Торг 13", СтрокаМаршрута.ЗНО, ТабДокумент.КоличествоЭкземпляров);
	
	Возврат ТабДокумент;
	
КонецФункции // ПечатьТОРГ13()


Функция СформироватьПечатнуюФормуЗаказПоставщику(МассивОбъектов, ОбъектыПечати = Неопределено, ВыводитьБлокВодитель = Ложь, Водитель = Неопределено)
	
	Тип = "ЗаказПоставщику";
	ОбъектыПечати = Новый СписокЗначений;
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	ИспользоватьРучныеСкидки = ПолучитьФункциональнуюОпцию("ИспользоватьРучныеСкидкиВЗакупках");
	
	Запрос = Новый Запрос();
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказПоставщику.Ссылка КАК Ссылка,
	|	ЗаказПоставщику.Номер КАК Номер,
	|	ЗаказПоставщику.Дата КАК Дата,
	|	ЗаказПоставщику.Организация КАК Организация,
	|	ВЫБОР
	|		КОГДА ЗаказПоставщику.НалогообложениеНДС = ЗНАЧЕНИЕ(Перечисление.ТипыНалогообложенияНДС.ПродажаОблагаетсяНДС)
	|			ТОГДА ИСТИНА
	|		ИНАЧЕ ЛОЖЬ
	|	КОНЕЦ КАК УчитыватьНДС,
	|	ЗаказПоставщику.Организация.Префикс КАК Префикс,
	|	ЗаказПоставщику.Контрагент КАК Контрагент,
	|	ЗаказПоставщику.БанковскийСчет КАК БанковскийСчет,
	|	ЗаказПоставщику.БанковскийСчет.ТекстКорреспондента КАК БанковскийСчетТекстКорреспондента,
	|	ЗаказПоставщику.ЦенаВключаетНДС КАК ЦенаВключаетНДС,
	|	ЗаказПоставщику.Валюта КАК Валюта,
	|	ЗаказПоставщику.Менеджер.ФизическоеЛицо.Наименование КАК Менеджер,
	|	ЗаказПоставщику.ДополнительнаяИнформация КАК ДополнительнаяИнформация,
	|	ЗаказПоставщику.ЭтапыГрафикаОплаты.(
	|		ДатаПлатежа КАК ДатаПлатежа
	|	),
	|	ЗаказПоставщику.Товары.(
	|		НомерСтроки КАК НомерСтроки,
	|		НоменклатураПоставщика.Наименование КАК НаименованиеНоменклатурыПоставщика,
	|		НоменклатураПоставщика.Код КАК КодПоставщика,
	|		НоменклатураПоставщика.Артикул КАК АртикулПоставщика,
	|		Номенклатура КАК Номенклатура,
	|		УсловиеЦеныПоставщика КАК УсловиеЦеныПоставщика,
	|		Номенклатура.Код КАК Код,
	|		Номенклатура.Артикул КАК Артикул,
	|		Номенклатура.НаименованиеПолное КАК НаименованиеПолное,
	|		ВЫБОР
	|			КОГДА ЗаказПоставщику.Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|				ТОГДА ПРЕДСТАВЛЕНИЕ(ЗаказПоставщику.Товары.Номенклатура.ЕдиницаИзмерения)
	|			ИНАЧЕ ПРЕДСТАВЛЕНИЕ(ЗаказПоставщику.Товары.Упаковка.ЕдиницаИзмерения)
	|		КОНЕЦ КАК ЕдиницаИзмерения,
	|		КоличествоУпаковок КАК Количество,
	|		Цена КАК Цена,
	|		СуммаРучнойСкидки КАК СуммаСкидки,
	|		ЗаказПоставщику.Товары.Сумма + ЗаказПоставщику.Товары.СуммаРучнойСкидки КАК СуммаБезСкидки,
	|		Сумма КАК Сумма,
	|		СуммаНДС КАК СуммаНДС,
	|		ДатаПоступления КАК ДатаПоступления,
	|		Характеристика.НаименованиеПолное КАК Характеристика,
	|		Отменено КАК Отменено
	|	),
	|	ВЫБОР
	|		КОГДА ИСТИНА
	|			ТОГДА ЗаказПоставщику.Склад
	|		ИНАЧЕ ЕСТЬNULL(СоответствиеТранзитныхСкладов.СкладТранзит, ЗаказПоставщику.Склад)
	|	КОНЕЦ КАК Склад,
	|	ЗаказПоставщику.ЖелаемаяДатаПоступления КАК ЖДП
	|ИЗ
	|	Документ.ЗаказПоставщику КАК ЗаказПоставщику
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.СоответствиеТранзитныхСкладов КАК СоответствиеТранзитныхСкладов
	|		ПО ЗаказПоставщику.Контрагент = СоответствиеТранзитныхСкладов.Отправитель
	|			И ЗаказПоставщику.Склад = СоответствиеТранзитныхСкладов.СкладПолучатель
	|ГДЕ
	|	ЗаказПоставщику.Ссылка В(&МассивОбъектов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка";
	
	ДанныеПечати = Запрос.Выполнить().Выбрать();
	
	ПервыйДокумент = Истина;
	Обработка = РеквизитФормыВЗначение("Объект");
	Макет = Обработка.ПолучитьМакет("ПФ_MXL_ЗаказПоставщику");
	
	Пока ДанныеПечати.Следующий() Цикл
		
		Если Не ПервыйДокумент Тогда
			ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		
		ПервыйДокумент = Ложь;
		
		НомерСтрокиНачало = ТабличныйДокумент.ВысотаТаблицы + 1;
		
		ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ЗаказПоставщику_ЗаказПоставщику";
		
		ТаблицаТовары = ДанныеПечати.Товары.Выгрузить();
		ТаблицаТовары.Сортировать("НомерСтроки");
		
		ВыводитьУсловиеЦены = Ложь;
		Для Каждого СтрокаТовары Из ТаблицаТовары Цикл
			Если ЗначениеЗаполнено(СтрокаТовары.УсловиеЦеныПоставщика) Тогда
				ВыводитьУсловиеЦены = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		ЕстьСкидки    = ФормированиеПечатныхФорм.НужноВыводитьСкидки(ТаблицаТовары, ИспользоватьРучныеСкидки);
		КолонкаКодов  = ФормированиеПечатныхФорм.ИмяДополнительнойКолонки();
		ВыводитьКоды  = ЗначениеЗаполнено(КолонкаКодов);
		
		Если ЕстьСкидки И ВыводитьУсловиеЦены Тогда
			ОбластьКолонкаТовар = Макет.Область("ТоварСУсловиемСоСкидкой");
		ИначеЕсли ЕстьСкидки Или ВыводитьУсловиеЦены Тогда
			ОбластьКолонкаТовар = Макет.Область("ТоварСУсловиемИлиСоСкидкой");
		Иначе
			ОбластьКолонкаТовар = Макет.Область("Товар");
		КонецЕсли;
		
		Если Не ВыводитьКоды Тогда
			
			Если ЕстьСкидки И ВыводитьУсловиеЦены Тогда
				ОбластьКолонкаТовар.ШиринаКолонки = ОбластьКолонкаТовар.ШиринаКолонки * 1.35;
			ИначеЕсли ЕстьСкидки Или ВыводитьУсловиеЦены Тогда
				ОбластьКолонкаТовар.ШиринаКолонки = ОбластьКолонкаТовар.ШиринаКолонки * 1.2;
			Иначе
				ОбластьКолонкаТовар.ШиринаКолонки = ОбластьКолонкаТовар.ШиринаКолонки * 1.14;
			КонецЕсли;
			
		КонецЕсли;
		
		Если ЕстьСкидки И ВыводитьУсловиеЦены Тогда
			
			ОбластьНомера = Макет.ПолучитьОбласть("ШапкаТаблицыСУсловиемСоСкидкой|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("ШапкаТаблицыСУсловиемСоСкидкой|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("ШапкаТаблицыСУсловиемСоСкидкой|ТоварСУсловиемСоСкидкой");
			ОбластьДанных = Макет.ПолучитьОбласть("ШапкаТаблицыСУсловиемСоСкидкой|ДанныеСУсловиемСоСкидкой");
			
		ИначеЕсли ЕстьСкидки Тогда
			
			ОбластьНомера = Макет.ПолучитьОбласть("ШапкаТаблицыСоСкидкой|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("ШапкаТаблицыСоСкидкой|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("ШапкаТаблицыСоСкидкой|ТоварСУсловиемИлиСоСкидкой");
			ОбластьДанных = Макет.ПолучитьОбласть("ШапкаТаблицыСоСкидкой|ДанныеСУсловиемИлиСоСкидкой");
			
		ИначеЕсли ВыводитьУсловиеЦены Тогда
			
			ОбластьНомера = Макет.ПолучитьОбласть("ШапкаТаблицыСУсловием|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("ШапкаТаблицыСУсловием|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("ШапкаТаблицыСУсловием|ТоварСУсловиемИлиСоСкидкой");
			ОбластьДанных = Макет.ПолучитьОбласть("ШапкаТаблицыСУсловием|ДанныеСУсловиемИлиСоСкидкой");
			
		Иначе
			
			ОбластьНомера = Макет.ПолучитьОбласть("ШапкаТаблицы|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("ШапкаТаблицы|Товар");
			ОбластьДанных = Макет.ПолучитьОбласть("ШапкаТаблицы|Данные");
			
		КонецЕсли;
		
		// Заполнить реквизиты шапки
		
		ОбластьМакета = Макет.ПолучитьОбласть("Заголовок");
		
		ТекстЗаголовка = "Заказ поставщику" + " № " + ДанныеПечати.Номер + " от " + Формат(ДанныеПечати.Дата, "ДФ='дд ММММ гггг'") + " г.";
		
		ОбластьМакета.Параметры.ТекстЗаголовка = ТекстЗаголовка;
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		//+a.buganov@kdvm.ru 04.04.2018
		НомерШК = ДанныеПечати.Номер + "_" + Формат(ДанныеПечати.Дата, "ДФ='гг'");
		//Попытка
		//	ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
		//Исключение
		//КонецПопытки;
		
		ОбластьМакета = Макет.ПолучитьОбласть("ШК");
		//ЗаполнитьШтрихКодОбласть(ОбластьМакета, НомерШК);
		
		Если ВыводитьБлокВодитель Тогда
			Шаблон = "Плановая дата поступления: %1" + Символы.ПС
			+ 		 "Водитель				   : %2" + Символы.ПС
			+		 "Телефон				   : %3" + Символы.ПС;
			
			Телефон	   = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Водитель, Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Телефон",, Справочники.ВидыКонтактнойИнформации.СправочникФизическиеЛица));
			Мобильный = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Водитель, Справочники.ВидыКонтактнойИнформации.МобильныйТелефонФизическогоЛица);
			
			Телефоны = ?(ЗначениеЗаполнено(Телефон), Телефон + ", ", "")
						+ ?(ЗначениеЗаполнено(Мобильный), Мобильный, "");
						
			Если Прав(Телефоны, 2) = ", " Тогда
				Телефоны = Лев(Телефоны, СтрДлина(Телефоны) - 2);
			КонецЕсли;
			
			ТекстДоставка = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон
																					, Формат(ДанныеПечати.ЖДП, "ДЛФ = Д")
																					, ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Водитель)
																					, Телефоны);
			ОбластьМакета.Параметры.Доставка = ТекстДоставка;																					
		КонецЕсли;	
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		//- 
		
		ОбластьМакета = Макет.ПолучитьОбласть("Поставщик");
		
		СведенияОПоставщике = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеПечати.Организация, ДанныеПечати.Дата);
		
		ОбластьМакета.Параметры.ПредставлениеПоставщика = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеПечати.Контрагент, ДанныеПечати.Дата), "ПолноеНаименование,ИНН,КПП,ЮридическийАдрес,Телефоны,");
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета                                   = Макет.ПолучитьОбласть("Покупатель");
		ОбластьМакета.Параметры.ПредставлениеПолучателя = ФормированиеПечатныхФорм.ОписаниеОрганизации(ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ДанныеПечати.Организация, ДанныеПечати.Дата), "ПолноеНаименование,ИНН,КПП,ЮридическийАдрес,Телефоны,");
		ОбластьМакета.Параметры.Склад					= ДанныеПечати.Склад;
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ТабличныйДокумент.Вывести(ОбластьНомера);
		
		Если ВыводитьКоды Тогда
			
			ОбластьКодов.Параметры.ИмяКолонкиКодов = КолонкаКодов;
			ТабличныйДокумент.Присоединить(ОбластьКодов);
			
		КонецЕсли;
		
		ОбластьТовар.Параметры.Товар = НСтр("ru='Товары (работы, услуги)'");
		ТабличныйДокумент.Присоединить(ОбластьТовар);
		ТабличныйДокумент.Присоединить(ОбластьДанных);
		
		Если ЕстьСкидки И ВыводитьУсловиеЦены Тогда
			
			ОбластьНомера = Макет.ПолучитьОбласть("СтрокаТаблицыСУсловиемСоСкидкой|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("СтрокаТаблицыСУсловиемСоСкидкой|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("СтрокаТаблицыСУсловиемСоСкидкой|ТоварСУсловиемСоСкидкой");
			ОбластьДанных = Макет.ПолучитьОбласть("СтрокаТаблицыСУсловиемСоСкидкой|ДанныеСУсловиемСоСкидкой");
			
		ИначеЕсли ЕстьСкидки Тогда
			
			ОбластьНомера = Макет.ПолучитьОбласть("СтрокаТаблицыСоСкидкой|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("СтрокаТаблицыСоСкидкой|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("СтрокаТаблицыСоСкидкой|ТоварСУсловиемИлиСоСкидкой");
			ОбластьДанных = Макет.ПолучитьОбласть("СтрокаТаблицыСоСкидкой|ДанныеСУсловиемИлиСоСкидкой");
			
		ИначеЕсли ВыводитьУсловиеЦены Тогда
			
			ОбластьНомера = Макет.ПолучитьОбласть("СтрокаТаблицыСУсловием|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("СтрокаТаблицыСУсловием|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("СтрокаТаблицыСУсловием|ТоварСУсловиемИлиСоСкидкой");
			ОбластьДанных = Макет.ПолучитьОбласть("СтрокаТаблицыСУсловием|ДанныеСУсловиемИлиСоСкидкой");
			
		Иначе
			
			ОбластьНомера = Макет.ПолучитьОбласть("СтрокаТаблицы|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("СтрокаТаблицы|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("СтрокаТаблицы|Товар");
			ОбластьДанных = Макет.ПолучитьОбласть("СтрокаТаблицы|Данные");
			
		КонецЕсли;
		
		Сумма          = 0;
		СуммаНДС       = 0;
		ВсегоСкидок    = 0;
		ВсегоБезСкидок = 0;
		
		НомерСтроки = 0;
		
		Для Каждого СтрокаТовары Из ТаблицаТовары Цикл
			
			Если СтрокаТовары.Отменено Тогда
				Продолжить;
			КонецЕсли;
			
			НомерСтроки = НомерСтроки + 1;
			
			ОбластьНомера.Параметры.НомерСтроки = НомерСтроки;
			ТабличныйДокумент.Вывести(ОбластьНомера);
			
			Если ВыводитьКоды Тогда
				
				ИмяКолонки = КолонкаКодов;
				Если Тип = "ЗаказПоставщикуПоДаннымПоставщика" Тогда
					ИмяКолонки = ИмяКолонки + "Поставщика";
				КонецЕсли;
				
				ОбластьКодов.Параметры.Артикул = СтрокаТовары[ИмяКолонки];
				ТабличныйДокумент.Присоединить(ОбластьКодов);
				
			КонецЕсли;
			
			Если Тип = "ЗаказПоставщикуПоДаннымПоставщика" Тогда
				ОбластьТовар.Параметры.Товар = СтрокаТовары.НаименованиеНоменклатурыПоставщика;
			Иначе
				ОбластьТовар.Параметры.Товар = ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати(СтрокаТовары.НаименованиеПолное, СтрокаТовары.Характеристика);
			КонецЕсли;
			
			ТабличныйДокумент.Присоединить(ОбластьТовар);
			ОбластьДанных.Параметры.Заполнить(СтрокаТовары);
			ТабличныйДокумент.Присоединить(ОбластьДанных);
			
			Сумма          = Сумма          + СтрокаТовары.Сумма;
			СуммаНДС       = СуммаНДС       + СтрокаТовары.СуммаНДС;
			
			Если ЕстьСкидки Тогда
				ВсегоСкидок    = ВсегоСкидок    + СтрокаТовары.СуммаСкидки;
				ВсегоБезСкидок = ВсегоБезСкидок + СтрокаТовары.СуммаБезСкидки;
			КонецЕсли;
			
		КонецЦикла;
		
		Если ЕстьСкидки И ВыводитьУсловиеЦены Тогда
			
			ОбластьНомера = Макет.ПолучитьОбласть("ПодвалТаблицыСУсловиемСоСкидкой|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("ПодвалТаблицыСУсловиемСоСкидкой|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("ПодвалТаблицыСУсловиемСоСкидкой|ТоварСУсловиемСоСкидкой");
			ОбластьДанных = Макет.ПолучитьОбласть("ПодвалТаблицыСУсловиемСоСкидкой|ДанныеСУсловиемСоСкидкой");
			
		ИначеЕсли ЕстьСкидки Тогда
			
			ОбластьНомера = Макет.ПолучитьОбласть("ПодвалТаблицыСоСкидкой|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("ПодвалТаблицыСоСкидкой|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("ПодвалТаблицыСоСкидкой|ТоварСУсловиемИлиСоСкидкой");
			ОбластьДанных = Макет.ПолучитьОбласть("ПодвалТаблицыСоСкидкой|ДанныеСУсловиемИлиСоСкидкой");
			
		ИначеЕсли ВыводитьУсловиеЦены Тогда
			
			ОбластьНомера = Макет.ПолучитьОбласть("ПодвалТаблицыСУсловием|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("ПодвалТаблицыСУсловием|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("ПодвалТаблицыСУсловием|ТоварСУсловиемИлиСоСкидкой");
			ОбластьДанных = Макет.ПолучитьОбласть("ПодвалТаблицыСУсловием|ДанныеСУсловиемИлиСоСкидкой");
			
		Иначе
			
			ОбластьНомера = Макет.ПолучитьОбласть("ПодвалТаблицы|НомерСтроки");
			ОбластьКодов  = Макет.ПолучитьОбласть("ПодвалТаблицы|КолонкаКодов");
			ОбластьТовар  = Макет.ПолучитьОбласть("ПодвалТаблицы|Товар");
			ОбластьДанных = Макет.ПолучитьОбласть("ПодвалТаблицы|Данные");
			
		КонецЕсли;
		
		ТабличныйДокумент.Вывести(ОбластьНомера);
		
		Если ВыводитьКоды Тогда
			ТабличныйДокумент.Присоединить(ОбластьКодов);
		КонецЕсли;
		
		ТабличныйДокумент.Присоединить(ОбластьТовар);
		
		Если ЕстьСкидки Тогда
			
			ОбластьДанных.Параметры.ВсегоСкидок    = ВсегоСкидок;
			ОбластьДанных.Параметры.ВсегоБезСкидок = ВсегоБезСкидок;
			
		КонецЕсли;
		
		ОбластьДанных.Параметры.Всего = ФормированиеПечатныхФорм.ФорматСумм(Сумма);
		ТабличныйДокумент.Присоединить(ОбластьДанных);
		
		// Вывести ИтогоНДС
		
		Если ДанныеПечати.УчитыватьНДС Тогда
			
			ОбластьНомера      = Макет.ПолучитьОбласть("ПодвалТаблицыНДС|НомерСтроки");
			ОбластьКодов       = Макет.ПолучитьОбласть("ПодвалТаблицыНДС|КолонкаКодов");
			ОбластьТовар       = Макет.ПолучитьОбласть("ПодвалТаблицыНДС|Товар");
			ОбластьДанных      = Макет.ПолучитьОбласть("ПодвалТаблицыНДС|Данные");
			
			ТабличныйДокумент.Вывести(ОбластьНомера);
			
			Если ВыводитьКоды Тогда
				ТабличныйДокумент.Присоединить(ОбластьКодов);
			КонецЕсли;
			
			ТабличныйДокумент.Присоединить(ОбластьТовар);
			
			ОбластьДанных.Параметры.НДС = ?(ДанныеПечати.ЦенаВключаетНДС, НСтр("ru='В том числе НДС:'"), НСтр("ru='Сумма НДС:'"));
			ОбластьДанных.Параметры.ВсегоНДС = ФормированиеПечатныхФорм.ФорматСумм(СуммаНДС);
			ТабличныйДокумент.Присоединить(ОбластьДанных);
			
		КонецЕсли;
		
		// Вывести Сумму прописью
		ОбластьМакета = Макет.ПолучитьОбласть("СуммаПрописью");
		СуммаКПрописи = Сумма + ?(ДанныеПечати.ЦенаВключаетНДС, 0, СуммаНДС);
		
		ИтоговаяСтрока = НСтр("ru='Всего наименований %Количество%, на сумму %Сумма%'");
		ИтоговаяСтрока = СтрЗаменить(ИтоговаяСтрока, "%Количество%", НомерСтроки);
		ИтоговаяСтрока = СтрЗаменить(ИтоговаяСтрока, "%Сумма%",      ФормированиеПечатныхФорм.ФорматСумм(СуммаКПрописи, ДанныеПечати.Валюта));
		
		ОбластьМакета.Параметры.ИтоговаяСтрока = ИтоговаяСтрока;
		
		ОбластьМакета.Параметры.СуммаПрописью = РаботаСКурсамиВалют.СформироватьСуммуПрописью(СуммаКПрописи, ДанныеПечати.Валюта);
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		Если ЗначениеЗаполнено(ДанныеПечати.ДополнительнаяИнформация) Тогда
			
			ОбластьМакета                                    = Макет.ПолучитьОбласть("ДополнительнаяИнформация");
			ОбластьМакета.Параметры.ДополнительнаяИнформация = ДанныеПечати.ДополнительнаяИнформация;
			ТабличныйДокумент.Вывести(ОбластьМакета);
			
		КонецЕсли;
		
		// Вывести подписи
		ОбластьМакета = Макет.ПолучитьОбласть("ПодвалЗаказа");
		ОбластьМакета.Параметры.ФИОМенеджер = ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(ДанныеПечати.Менеджер);
		
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабличныйДокумент, НомерСтрокиНачало, ОбъектыПечати, ДанныеПечати.Ссылка);
		
	КонецЦикла;
	
	ТабличныйДокумент.АвтоМасштаб = Истина;
	
	СохранитьДанныеОПечати(МассивОбъектов, "Заказ поставщику", Неопределено, ТабличныйДокумент.КоличествоЭкземпляров);
	
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФорму()

Функция ПолучитьНакладнуюНаПеремещение(СтрокаМарш, МассивОбъектов = Неопределено, ВыводитьБлокВодитель = Ложь)
	
	Если МассивОбъектов = Неопределено Тогда
		МассивОбъектов = Новый Массив;
		Для Каждого Эл Из СтрокаМарш.Строки Цикл
			Если Эл.Пометка = 1 И ЗначениеЗаполнено(Эл.Автомобиль)  Тогда
				
				Если (Эл.СкладWMS И НеПечататьЛистКомплектацииДляWMS) Тогда
					Продолжить;
				КонецЕсли;
				
				МассивОбъектов.Добавить(Эл.Автомобиль);
				
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
	
	Колонка = ФормированиеПечатныхФорм.ИмяДополнительнойКолонки();
	ВыводитьКоды = ЗначениеЗаполнено(Колонка);
	
	ИспользоватьУпаковкиНоменклатуры = ПолучитьФункциональнуюОпцию("ИспользоватьУпаковкиНоменклатуры");
	
	ТабДокумент = Новый ТабличныйДокумент;
	
	Если ВыводНаПринтер Тогда
		ТабДокумент.ИмяПринтера = ПринтерПоУмолчанию;
	КонецЕсли;
	
	//ТабДокумент.ВерхнийКолонтитул.НачальнаяСтраница = 1;
	//ТабДокумент.РазмерКолонтитулаСверху             = 12;
	//ТабДокумент.ВерхнийКолонтитул.Выводить = Истина;
	//ТабДокумент.ВерхнийКолонтитул.ТекстВЦентре = "[&НомерСтраницы] из [&СтраницВсего]";
	
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_Накладная";
	О = РеквизитФормыВЗначение("Объект");
	Макет = О.ПолучитьМакет("ПФ_MXL_НакладнаяНаПеремещение");
	
	ШиринаДок = 0;                 
	ШиринаТовары = 0;
	ОбластьЗаголовка  = Макет.ПолучитьОбласть("Заголовок");
	ШиринаДок = ШиринаДок + Макет.Области.НомерСтроки.ШиринаКолонки -  Макет.Области.Отступ.ШиринаКолонки;
	
	
	Если ВыводитьКоды Тогда
		ОбластьКодовШапка  = Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаКодов");
		ОбластьКодовШапка.Параметры.ИмяКолонкиКодов = Колонка;
		
		ОбластьКодовСтрока = Макет.ПолучитьОбласть("Строка|КолонкаКодов");
		ОбластьКодовПодвал = Макет.ПолучитьОбласть("Подвал|КолонкаКодов");
		
		ШиринаДок = ШиринаДок + Макет.Области.КолонкаКодов.ШиринаКолонки;
	Иначе
		ОбластьТовары = Макет.Область("Товар");
		ОбластьТовары.ШиринаКолонки = ОбластьТовары.ШиринаКолонки + Макет.Область("КолонкаКодов").ШиринаКолонки;
		
		ШиринаТовары = ОбластьТовары.ШиринаКолонки; 
	КонецЕсли;
	
	Если ИспользоватьУпаковкиНоменклатуры Тогда
		ОбластьУпаковокШапка  =  Макет.ПолучитьОбласть("ШапкаТаблицы|КолонкаУпаковок");
		ОбластьУпаковокСтрока =  Макет.ПолучитьОбласть("Строка|КолонкаУпаковок");
		ОбластьУпаковокПодвал =  Макет.ПолучитьОбласть("Подвал|КолонкаУпаковок");
		ШиринаДок = ШиринаДок + Макет.Области.КолонкаУпаковок.ШиринаКолонки;
	Иначе
		ОбластьТовары = Макет.Область("Товар");
		ОбластьТовары.ШиринаКолонки = ОбластьТовары.ШиринаКолонки 
		+ Макет.Область("КолонкаУпаковокКоличество").ШиринаКолонки
		+ Макет.Область("КолонкаУпаковокПредставление").ШиринаКолонки;
	КонецЕсли;
	
	ШиринаТовары = Макет.Области.Товар.ШиринаКолонки;
	ШиринаДок = ШиринаДок + ШиринаТовары;
	
	ОбластьГруппировкаДокумент = Макет.ПолучитьОбласть("ГруппировкаДокумент");
	Макет.Области.Док.ШиринаКолонки = ШиринаДок;
	ОбластьНомераШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|НомерСтроки");
	ОбластьДанныхШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|Товар");
	ОбластьКонецСтрокиШапка = Макет.ПолучитьОбласть("ШапкаТаблицы|КонецСтроки");
	
	ОбластьНомераСтрока = Макет.ПолучитьОбласть("Строка|НомерСтроки");
	ОбластьДанныхСтрока = Макет.ПолучитьОбласть("Строка|Товар");
	ОбластьКонецСтрокиСтрока = Макет.ПолучитьОбласть("Строка|КонецСтроки");
	
	ОбластьНомераПодвал = Макет.ПолучитьОбласть("Подвал|НомерСтроки");
	ОбластьДанныхПодвал = Макет.ПолучитьОбласть("Подвал|Товар");
	ОбластьКонецСтрокиПодвал = Макет.ПолучитьОбласть("Подвал|КонецСтроки");
	
	ОбластьПодписей = Макет.ПолучитьОбласть("Подписи");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("МассивДокументов", МассивОбъектов);
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПеремещениеТоваров.Номер КАК Номер,
	|	ПеремещениеТоваров.Дата КАК Дата,
	|	ПеремещениеТоваров.Организация.Префикс КАК Префикс,
	|	ПеремещениеТоваров.СкладОтправитель.Наименование КАК ОтправительПредставление,
	|	ПеремещениеТоваров.СкладПолучатель.Наименование КАК ПолучательПредставление,
	|	ПеремещениеТоваров.Организация.НаименованиеСокращенное КАК ОрганизацияПредставление,
	|	ПеремещениеТоваров.Ссылка КАК Ссылка,
	|	ПеремещениеТоваров.Товары.(
	|		Номенклатура КАК Товар,
	|		НомерСтроки КАК НомерСтроки,
	|		Номенклатура.НаименованиеПолное КАК ТоварНаименование,
	|		Номенклатура.Код КАК Код,
	|		Номенклатура.Артикул КАК Артикул,
	|		Характеристика.НаименованиеПолное КАК Характеристика,
	|		ВЫБОР
	|			КОГДА ПеремещениеТоваров.Товары.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
	|				ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(ПеремещениеТоваров.Товары.Номенклатура.ЕдиницаИзмерения)
	|			ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(ПеремещениеТоваров.Товары.Упаковка)
	|		КОНЕЦ КАК ПредставлениеЕдининицыИзмеренияУпаковки,
	|		ПРЕДСТАВЛЕНИЕССЫЛКИ(ПеремещениеТоваров.Товары.Номенклатура.ЕдиницаИзмерения) КАК ПредставлениеБазовойЕдиницыИзмерения,
	|		КоличествоУпаковок КАК КоличествоУпаковок,
	|		Количество КАК Количество
	|	) КАК ТаблицаТовары,
	|	ПеремещениеТоваров.СкладПолучатель КАК СкладПолучатель,
	|	ПеремещениеТоваров.ЗаказНаПеремещение.ЖелаемаяДатаПоступления КАК ЖДП
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
	|ГДЕ
	|	ПеремещениеТоваров.Ссылка В(&МассивДокументов)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата,
	|	Ссылка,
	|	НомерСтроки
	|ИТОГИ
	|	МАКСИМУМ(ОтправительПредставление),
	|	МАКСИМУМ(ПолучательПредставление),
	|	МАКСИМУМ(ОрганизацияПредставление),
	|	МАКСИМУМ(ЖДП)
	|ПО
	|	СкладПолучатель,
	|	Ссылка";
	
	Результат = Запрос.Выполнить();
	
	ВыборкаМагазин = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	ПервыйПроход = Истина;
	Пока ВыборкаМагазин.Следующий() Цикл
		Если Не ПервыйПроход Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		Иначе
			ПервыйПроход = Ложь;
		КонецЕсли;
		
		Ширина = 0;
		
		ОбластьЗаголовка.Параметры.ТекстЗаголовка = "Перемещение на" + " " + СокрЛП(ВыборкаМагазин.СкладПолучатель) + " " + "от" + " " + Формат(СтрокаМарш.ЗНО.ВремяВыезда, "ДФ = дд.ММ.гггг") + " " + "г.";
		ЗаполнитьЗначенияСвойств(ОбластьЗаголовка.Параметры, ВыборкаМагазин);
		
		//+a.buganov@kdvm.ru 04.04.2018
		НомерШК = СтрокаМарш.ЗНО.Номер;
		//Попытка
		//	ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
		//Исключение
		//КонецПопытки;
		
		//ЗаполнитьШтрихКодОбласть(ОбластьЗаголовка, НомерШК);
		
		Если ВыводитьБлокВодитель Тогда
			Шаблон = "Плановая дата поступления: %1" + Символы.ПС
			+ "Водитель						   : %2" + Символы.ПС
			+ "Телефон						   : %3" + Символы.ПС;
			
			Телефон	   = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(СтрокаМарш.Водитель, Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Телефон",, Справочники.ВидыКонтактнойИнформации.СправочникФизическиеЛица));
			Мобильный = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(СтрокаМарш.Водитель, Справочники.ВидыКонтактнойИнформации.МобильныйТелефонФизическогоЛица);
			
			Телефоны = ?(ЗначениеЗаполнено(Телефон), Телефон + ", ", "")
						+ ?(ЗначениеЗаполнено(Мобильный), Мобильный, "");
						
			Если Прав(Телефоны, 2) = ", " Тогда
				Телефоны = Лев(Телефоны, СтрДлина(Телефоны) - 2);
			КонецЕсли;
			
			ТекстДоставка = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон
																					, Формат(ВыборкаМагазин.ЖДП, "ДЛФ = Д")
																					, ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(СтрокаМарш.Водитель)
																					, Телефоны);
			ОбластьЗаголовка.Параметры.Доставка = ТекстДоставка;																					
		КонецЕсли;
		
		ТабДокумент.Вывести(ОбластьЗаголовка);
		
		
		ТабДокумент.Вывести(ОбластьНомераШапка);
		
		//		//+a.buganov@kdvm.ru 04.04.2018
		//НомерШК = СтрокаМарш.ЗНО.Номер;
		//Попытка
		//	ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
		//Исключение
		//КонецПопытки;
		//ОбластьШК = Макет.ПолучитьОбласть("ШК");
		//ЗаполнитьШтрихКодОбласть(ОбластьЗаголовка, НомерШК, ВнешняяКомпонента);
		//ТабДокумент.Вывести(ОбластьШК);
		
		
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКодовШапка);
		КонецЕсли;
		
		ТабДокумент.Присоединить(ОбластьДанныхШапка);
		
		Если ИспользоватьУпаковкиНоменклатуры Тогда
			ТабДокумент.Присоединить(ОбластьУпаковокШапка);
		КонецЕсли;
		
		ТабДокумент.Присоединить(ОбластьКонецСтрокиШапка);
		
		ВыборкаДокумент = ВыборкаМагазин.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаДокумент.Следующий() Цикл
			//ТабДокумент.Вывести(Макет.ПолучитьОбласть("ГруппировкаДокумент|Отступ"));
			ОбластьГруппировкаДокумент.Параметры.Документ = ВыборкаДокумент.Ссылка;
			ТабДокумент.Присоединить(ОбластьГруппировкаДокумент);
			
			ВыборкаДетальныеЗаписи = ВыборкаДокумент.Выбрать();
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				ВыборкаСтрокТовары = ВыборкаДетальныеЗаписи.ТаблицаТовары.Выбрать();
				Пока ВыборкаСтрокТовары.Следующий() Цикл
					
					ОбластьНомераСтрока.Параметры.НомерСтроки = ВыборкаСтрокТовары.НомерСтроки;
					ТабДокумент.Вывести(ОбластьНомераСтрока);
					
					Если ВыводитьКоды Тогда
						ОбластьКодовСтрока.Параметры.Артикул = ВыборкаСтрокТовары[Колонка];
						ТабДокумент.Присоединить(ОбластьКодовСтрока);
					КонецЕсли;
					
					ОбластьДанныхСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
					ОбластьДанныхСтрока.Параметры.Товар = ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати(
					СокрЛП(ВыборкаСтрокТовары.ТоварНаименование),
					СокрЛП(ВыборкаСтрокТовары.Характеристика));
					
					ТабДокумент.Присоединить(ОбластьДанныхСтрока);
					
					Если ИспользоватьУпаковкиНоменклатуры Тогда
						ОбластьУпаковокСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
						ТабДокумент.Присоединить(ОбластьУпаковокСтрока);
					КонецЕсли;
					
					ОбластьКонецСтрокиСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
					ТабДокумент.Присоединить(ОбластьКонецСтрокиСтрока);
					
					Если Не ТабДокумент.ПроверитьВывод(ОбластьКонецСтрокиСтрока) Тогда
						ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
						
						ТабДокумент.Вывести(ОбластьНомераШапка);
						
						Если ВыводитьКоды Тогда
							ТабДокумент.Присоединить(ОбластьКодовШапка);
						КонецЕсли;
						
						ТабДокумент.Присоединить(ОбластьДанныхШапка);
						
						Если ИспользоватьУпаковкиНоменклатуры Тогда
							ТабДокумент.Присоединить(ОбластьУпаковокШапка);
						КонецЕсли;
						
						ТабДокумент.Присоединить(ОбластьКонецСтрокиШапка);
						
						ОбластьГруппировкаДокумент.Параметры.Документ = "" + ОбластьГруппировкаДокумент.Параметры.Документ + " / продолжение";
						ТабДокумент.Вывести(ОбластьГруппировкаДокумент);
						
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЦикла;
		
		ТабДокумент.Вывести(ОбластьНомераПодвал);
		
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКодовПодвал);
		КонецЕсли;
		
		ТабДокумент.Присоединить(ОбластьДанныхПодвал);
		
		Если ИспользоватьУпаковкиНоменклатуры Тогда
			ТабДокумент.Присоединить(ОбластьУпаковокПодвал);
		КонецЕсли;
		
		ТабДокумент.Присоединить(ОбластьКонецСтрокиПодвал);
		
		// Вывести подписи.
		ТабДокумент.Вывести(ОбластьПодписей);
		
	КонецЦикла;
	
	СохранитьДанныеОПечати(МассивОбъектов, "Накладная на перемещение", СтрокаМарш.ЗНО, ТабДокумент.КоличествоЭкземпляров);
	
	Возврат ТабДокумент;
	
	
	
	Шапка = Запрос.Выполнить().Выбрать();
	ПервыйДокумент = Истина;
	
	Пока Шапка.Следующий() Цикл
		
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		Если Не ПервыйДокумент Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		КонецЕсли;
		ПервыйДокумент = Ложь;
		
		// Выводим шапку накладной
		ОбластьЗаголовка.Параметры.ТекстЗаголовка = ФормированиеПечатныхФорм.СформироватьЗаголовокДокумента(Шапка, "Накладная на перемещение");
		ОбластьЗаголовка.Параметры.Заполнить(Шапка);
		ТабДокумент.Вывести(ОбластьЗаголовка);
		
		ТабДокумент.Вывести(ОбластьНомераШапка);
		
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКодовШапка);
		КонецЕсли;
		
		ТабДокумент.Присоединить(ОбластьДанныхШапка);
		
		Если ИспользоватьУпаковкиНоменклатуры Тогда
			ТабДокумент.Присоединить(ОбластьУпаковокШапка);
		КонецЕсли;
		
		ТабДокумент.Присоединить(ОбластьКонецСтрокиШапка);
		
		// Выборка товаров
		ВыборкаСтрокТовары = Шапка.ТаблицаТовары.Выбрать();
		Пока ВыборкаСтрокТовары.Следующий() Цикл
			
			ОбластьНомераСтрока.Параметры.НомерСтроки = ВыборкаСтрокТовары.НомерСтроки;
			ТабДокумент.Вывести(ОбластьНомераСтрока);
			
			Если ВыводитьКоды Тогда
				ОбластьКодовСтрока.Параметры.Артикул = ВыборкаСтрокТовары[Колонка];
				ТабДокумент.Присоединить(ОбластьКодовСтрока);
			КонецЕсли;
			
			ОбластьДанныхСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
			ОбластьДанныхСтрока.Параметры.Товар = ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати(
			СокрЛП(ВыборкаСтрокТовары.ТоварНаименование),
			СокрЛП(ВыборкаСтрокТовары.Характеристика));
			
			ТабДокумент.Присоединить(ОбластьДанныхСтрока);
			
			Если ИспользоватьУпаковкиНоменклатуры Тогда
				ОбластьУпаковокСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
				ТабДокумент.Присоединить(ОбластьУпаковокСтрока);
			КонецЕсли;
			
			ОбластьКонецСтрокиСтрока.Параметры.Заполнить(ВыборкаСтрокТовары);
			ТабДокумент.Присоединить(ОбластьКонецСтрокиСтрока);
			
		КонецЦикла;
		
		ТабДокумент.Вывести(ОбластьНомераПодвал);
		
		Если ВыводитьКоды Тогда
			ТабДокумент.Присоединить(ОбластьКодовПодвал);
		КонецЕсли;
		
		ТабДокумент.Присоединить(ОбластьДанныхПодвал);
		
		Если ИспользоватьУпаковкиНоменклатуры Тогда
			ТабДокумент.Присоединить(ОбластьУпаковокПодвал);
		КонецЕсли;
		
		ТабДокумент.Присоединить(ОбластьКонецСтрокиПодвал);
		
		// Вывести подписи.
		ТабДокумент.Вывести(ОбластьПодписей);
		
		//УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);
		
	КонецЦикла;
	
	ТабДокумент.АвтоМасштаб = Истина;
	
	СохранитьДанныеОПечати(МассивОбъектов, "Накладная на перемещение", СтрокаМарш.ЗНО, ТабДокумент.КоличествоЭкземпляров);
	
	Возврат ТабДокумент;
	
	
КонецФункции

//печать алко
&НаСервере
Функция СформироватьПечатнуюФормуСправкаНаЭтиловыйСпирт(СтрокаМаршрута)
	
	МассивДокументов = Новый Массив;
	МассивСкладов = Новый Массив;
	
	Для Каждого СтрЗаказ Из СтрокаМаршрута.Строки Цикл
		Если (ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.ПеремещениеТоваров") 
			ИЛИ  ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.РеализацияТоваровУслуг"))
			И (ЗначениеЗаполнено(СтрЗаказ.Автомобиль)) И Не СтрЗаказ.Пометка = 0 Тогда
			
			ТекПеремещение = СтрЗаказ.Автомобиль;
			
			Если НЕ ЭтоАлкоДокумент(ТекПеремещение) Тогда
				Продолжить;
			КонецЕсли; 
			
			МассивДокументов.Добавить(ТекПеремещение);
			СкладПолучатель = ПолучитьСкладПолучатель(ТекПеремещение);
			Если МассивСкладов.Найти(СкладПолучатель) = Неопределено Тогда
				МассивСкладов.Добавить(СкладПолучатель);
			КонецЕсли;
			
		
		КонецЕсли;
	КонецЦикла; 
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	Для Каждого ТекСклад Из МассивСкладов Цикл
		ВремМассивДокументов = Новый Массив;
		
		Для Каждого ТекДок Из МассивДокументов Цикл
			СкладПолучатель = ПолучитьСкладПолучатель(ТекДок);
			Если НЕ СкладПолучатель = ТекСклад Тогда
				Продолжить;
			КонецЕсли; 
			ВремМассивДокументов.Добавить(ТекДок);
		КонецЦикла; 
		
		ВремТабДок = ПолучитьПечатнуюФорму1_Т(ВремМассивДокументов);
		ТабДок.Вывести(ВремТабДок);
		
		// ЛВО 22.03.2021 +
		//ВремТабДок = ПолучитьПечатнуюФормуСправкаНаЭтиловыйСпирт(ВремМассивДокументов);
		//ТабДок.Вывести(ВремТабДок);
		//-
		СохранитьДанныеОПечати(ВремМассивДокументов, "Справка на этиловый спирт", СтрокаМаршрута.ЗНО, ТабДок.КоличествоЭкземпляров);
		
	КонецЦикла; 
	
	Возврат ТабДок;
	
КонецФункции

&НаСервере
Функция ПолучитьПечатнуюФормуСправкаНаЭтиловыйСпирт(МассивОбъектов)
	
	ТоварКод = "Код";
	Обработка = РеквизитФормыВЗначение("Объект");
	Макет = Обработка.ПолучитьМакет("ПФ_MXL_СправкаНаЭтиловыйСпирт");
	МакетИмпорт = Обработка.ПолучитьМакет("ПФ_MXL_СправкаНаЭтиловыйСпиртИмпорт");
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_СправкаНаАлкоголь";
	
	// Зададим параметры Макета
	ТабДокумент.ПолеСверху = 5;
	ТабДокумент.ПолеСлева  = 5;
	ТабДокумент.ПолеСнизу  = 5;
	ТабДокумент.ПолеСправа = 5;
	ТабДокумент.АвтоМасштаб = Истина;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Перемещение.Ссылка КАК Ссылка,
	|	Перемещение.Номер КАК Номер,
	|	Перемещение.Дата КАК ДатаДокумента,
	|	ВЫБОР
	|		КОГДА Перемещение.ЗаказНаПеремещение = НЕОПРЕДЕЛЕНО
	|			ТОГДА """"
	|		ИНАЧЕ Перемещение.ЗаказНаПеремещение.Номер
	|	КОНЕЦ КАК НомерЗаказа,
	|	Перемещение.Организация КАК Организация,
	|	Перемещение.Организация.Префикс КАК Префикс,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Перемещение.СкладОтправитель) КАК ОтправительПодразделение,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(Перемещение.СкладПолучатель) КАК ПолучательПодразделение,
	|	Перемещение.СкладОтправитель.ТекущийОтветственный КАК КладовщикОтправитель,
	|	Перемещение.СкладОтправитель.ТекущаяДолжностьОтветственного КАК ДолжностьКладовщикаОтправителя,
	|	Перемещение.СкладПолучатель.ТекущийОтветственный КАК КладовщикПолучатель,
	|	Перемещение.СкладПолучатель.ТекущаяДолжностьОтветственного КАК ДолжностьКладовщикаПолучателя,
	|	Перемещение.ВидЦены КАК УчетныйВидЦены,
	|	Перемещение.ВидЦены.ВалютаЦены КАК УчетныйВидЦеныВалютаЦены
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК Перемещение
	|ГДЕ
	|	Перемещение.Ссылка В(&МассивПеремещений)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка,
	|	РеализацияТоваровУслуг.Номер,
	|	РеализацияТоваровУслуг.Дата,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.ЗаказКлиента = НЕОПРЕДЕЛЕНО
	|			ТОГДА """"
	|		ИНАЧЕ РеализацияТоваровУслуг.ЗаказКлиента.Номер
	|	КОНЕЦ,
	|	РеализацияТоваровУслуг.Организация,
	|	РеализацияТоваровУслуг.Организация.Префикс,
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(РеализацияТоваровУслуг.Склад),
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(СкладыДополнительныеРеквизиты.Ссылка),
	|	ПРЕДСТАВЛЕНИЕССЫЛКИ(РеализацияТоваровУслуг.Склад.ТекущийОтветственный),
	|	ПРЕДСТАВЛЕНИЕ(РеализацияТоваровУслуг.Склад.ТекущаяДолжностьОтветственного),
	|	NULL,
	|	NULL,
	|	РеализацияТоваровУслуг.Соглашение.ВидЦен,
	|	РеализацияТоваровУслуг.Валюта
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
	|		ПО РеализацияТоваровУслуг.Контрагент = СкладыДополнительныеРеквизиты.Значение
	|			И (СкладыДополнительныеРеквизиты.Свойство.Наименование = ""Контрагент склада"")
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка В(&МассивПеремещений)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаДокумента,
	|	Ссылка");
	Запрос.УстановитьПараметр("МассивПеремещений", МассивОбъектов);
	Шапка = Запрос.Выполнить().Выбрать();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПеремещениеТоваровДатыВыпуска.Номенклатура КАК Товар,
	|	ПеремещениеТоваровДатыВыпуска.Номенклатура.НаименованиеПолное КАК ТоварНаименование,
	|	ПеремещениеТоваровДатыВыпуска.ДатаВыпуска,
	|	СУММА(ПеремещениеТоваровДатыВыпуска.Количество) КАК Количество,
	|	ПеремещениеТоваровДатыВыпуска.НомерПартии,
	|	ПеремещениеТоваровДатыВыпуска.Ссылка.Дата КАК ДатаОтгрузки,
	|	ПеремещениеТоваровДатыВыпуска.Ссылка.Номер КАК НомерОтгрузки,
	|	ЕСТЬNULL(астСправкиАиБ_ЕГАИС.ЭтоПомарочныйУчет, ЛОЖЬ) КАК ЭтоПомарочныйУчет
	|ИЗ
	|	Документ.ПеремещениеТоваров.ДатыВыпуска КАК ПеремещениеТоваровДатыВыпуска
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|				&ДатаДокумента,
	|				(Номенклатура, ВидЦены) В
	|					(ВЫБРАТЬ
	|						Т.Номенклатура,
	|						&УчетныйВидЦены
	|					ИЗ
	|						Документ.ПеремещениеТоваров.Товары КАК Т
	|					ГДЕ
	|						Т.Ссылка = &ПеремещениеТоваров)) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО ПеремещениеТоваровДатыВыпуска.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.астСправкиАиБ_ЕГАИС КАК астСправкиАиБ_ЕГАИС
	|		ПО ПеремещениеТоваровДатыВыпуска.НомерПартии = астСправкиАиБ_ЕГАИС.Код
	|ГДЕ
	|	ПеремещениеТоваровДатыВыпуска.Ссылка = &ПеремещениеТоваров
	|	И ЕСТЬNULL(астСправкиАиБ_ЕГАИС.ЭтоПомарочныйУчет, ЛОЖЬ) = ЛОЖЬ
	|
	|СГРУППИРОВАТЬ ПО
	|	ПеремещениеТоваровДатыВыпуска.Номенклатура,
	|	ПеремещениеТоваровДатыВыпуска.ДатаВыпуска,
	|	ПеремещениеТоваровДатыВыпуска.НомерПартии,
	|	ПеремещениеТоваровДатыВыпуска.Номенклатура.НаименованиеПолное,
	|	ПеремещениеТоваровДатыВыпуска.Ссылка.Дата,
	|	ПеремещениеТоваровДатыВыпуска.Ссылка.Номер,
	|	ЕСТЬNULL(астСправкиАиБ_ЕГАИС.ЭтоПомарочныйУчет, ЛОЖЬ)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслугДатыВыпуска.Номенклатура,
	|	РеализацияТоваровУслугДатыВыпуска.Номенклатура.НаименованиеПолное,
	|	РеализацияТоваровУслугДатыВыпуска.ДатаВыпуска,
	|	СУММА(РеализацияТоваровУслугДатыВыпуска.Количество),
	|	РеализацияТоваровУслугДатыВыпуска.НомерПартии,
	|	NULL,
	|	NULL,
	|	ЕСТЬNULL(астСправкиАиБ_ЕГАИС.ЭтоПомарочныйУчет, ЛОЖЬ)
	|ИЗ
	|	Документ.РеализацияТоваровУслуг.ДатыВыпуска КАК РеализацияТоваровУслугДатыВыпуска
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	|				&ДатаДокумента,
	|				(Номенклатура, ВидЦены) В
	|					(ВЫБРАТЬ
	|						Т.Номенклатура,
	|						&УчетныйВидЦены
	|					ИЗ
	|						Документ.РеализацияТоваровУслуг.Товары КАК Т
	|					ГДЕ
	|						Т.Ссылка = &ПеремещениеТоваров)) КАК ЦеныНоменклатурыСрезПоследних
	|		ПО РеализацияТоваровУслугДатыВыпуска.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.астСправкиАиБ_ЕГАИС КАК астСправкиАиБ_ЕГАИС
	|		ПО РеализацияТоваровУслугДатыВыпуска.НомерПартии = астСправкиАиБ_ЕГАИС.Код
	|ГДЕ
	|	РеализацияТоваровУслугДатыВыпуска.Ссылка = &ПеремещениеТоваров
	|	И ЕСТЬNULL(астСправкиАиБ_ЕГАИС.ЭтоПомарочныйУчет, ЛОЖЬ) = ЛОЖЬ
	|
	|СГРУППИРОВАТЬ ПО
	|	РеализацияТоваровУслугДатыВыпуска.Номенклатура,
	|	РеализацияТоваровУслугДатыВыпуска.ДатаВыпуска,
	|	РеализацияТоваровУслугДатыВыпуска.НомерПартии,
	|	РеализацияТоваровУслугДатыВыпуска.Номенклатура.НаименованиеПолное,
	|	ЕСТЬNULL(астСправкиАиБ_ЕГАИС.ЭтоПомарочныйУчет, ЛОЖЬ)
	|
	|УПОРЯДОЧИТЬ ПО
	|	Товар
	|АВТОУПОРЯДОЧИВАНИЕ");
	Запрос.УстановитьПараметр("ТоварКод", ТоварКод);
	
	Пока Шапка.Следующий() Цикл
		//Соловьев И.В. Не печатаем не проведенные документы
		Если НЕ Шапка.Ссылка.Проведен Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + Шапка.Ссылка + ". Нельзя печатать не проведенные документы!");
			Продолжить;
		КонецЕсли; 
		//Соловеьв И.В.
		
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		
		Запрос.УстановитьПараметр("ПеремещениеТоваров", Шапка.Ссылка);
		Запрос.УстановитьПараметр("ДатаДокумента", Шапка.ДатаДокумента);
		Запрос.УстановитьПараметр("УчетныйВидЦены", Шапка.УчетныйВидЦены);
		
		ВыборкаСтрокТовары = Запрос.Выполнить().Выбрать();
		
		// Выводим многострочную часть докмента
		
		ОбластьМакетаРоссия = Макет.ПолучитьОбласть("Основная");
		ОбластьМакетаИмпорт = МакетИмпорт.ПолучитьОбласть("Основная");
		Пока ВыборкаСтрокТовары.Следующий() Цикл
			
			ОбъемДал = ПолучитьОбъемДал(ВыборкаСтрокТовары.Товар);
			Если ОбъемДал = 0 Тогда
				Продолжить;
			КонецЕсли; 
			
			ВидПродукции = ПолучитьВидПродукции(ВыборкаСтрокТовары.Товар);
			Если ВидПродукции = 500 ИЛИ ВидПродукции = 510 ИЛИ ВидПродукции = 520 Или ВидПродукции = 261 Или ВидПродукции = 262 Или ВидПродукции = 263  Тогда
				Продолжить;
			КонецЕсли; 
			
			//умножим объем в ДАЛ на количество бутылок
			ОбъемДал = ОбъемДал*ВыборкаСтрокТовары.Количество;			
			
			//Вывести предыдущих поставщиков
			ЕстьРазделА = Ложь;
			ВывестиПредыдущихПоставщиков(ТабДокумент, ВыборкаСтрокТовары.Товар, ВыборкаСтрокТовары.ДатаВыпуска, ВыборкаСтрокТовары.НомерПартии, ЕстьРазделА);
			
			Если ЕстьРазделА Тогда
				ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				
				СтруктураОтвет = ПолучитьПринадлежностьАлкогольнойПродукции(ВыборкаСтрокТовары.Товар, ВыборкаСтрокТовары.ДатаВыпуска, ВыборкаСтрокТовары.НомерПартии);
				Если СтруктураОтвет.Импортный Тогда
					ОбластьМакета = ОбластьМакетаИмпорт;
				Иначе
					ОбластьМакета = ОбластьМакетаРоссия;
				КонецЕсли; 
				
				//Сторона склада
				СкладОтправитель= ПолучитьСкладПолучатель(Шапка.Ссылка, "Отправитель");
				// ЛВО 18.08.2020 +
				
				ЗапросАлкогольныйСклад =  Новый Запрос;
				ЗапросАлкогольныйСклад.Текст = "ВЫБРАТЬ
				               |	СкладыДополнительныеРеквизиты.Значение
				               |ИЗ
				               |	Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
				               |ГДЕ
				               |	СкладыДополнительныеРеквизиты.Ссылка = &Склад
				               |	И СкладыДополнительныеРеквизиты.Свойство = &СвойствоАдресАлкогольногоСклада";
				ЗапросАлкогольныйСклад.УстановитьПараметр("Склад",СкладОтправитель);
				ЗапросАлкогольныйСклад.УстановитьПараметр("СвойствоАдресАлкогольногоСклада",ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Адрес алкогольного склада"));
				РезультатАд = ЗапросАлкогольныйСклад.Выполнить();
				Если РезультатАд.Пустой() тогда
					АдресСклада = ПолучитьАдресМагазина(СкладОтправитель);
				Иначе
					ВыборкаАд = РезультатАд.Выбрать();
					Пока ВыборкаАд.Следующий() цикл
						АдресСклада = ВыборкаАд.Значение;
					КонецЦикла;					
				КонецЕсли;	
				//-	
				
				ОбластьМакета.Параметры.НаименованиеСклада	= АдресСклада;
				ОбластьМакета.Параметры.АдресСклада			= АдресСклада;
				ИНН = ПолучитьИННСклада(СкладОтправитель);
				КПП = ПолучитьКППСклада(СкладОтправитель);
				ОбластьМакета.Параметры.ИННКППСклада = ИНН +"/" + КПП;
				ОбластьМакета.Параметры.ЛицензияСкладаОтправитель = ПолучитьАлкогольнуюЛицензиюСклада(СкладОтправитель);
				
				//Сторона Магазина
				СкладПолучатель = ПолучитьСкладПолучатель(Шапка.Ссылка);
				ОбластьМакета.Параметры.НаименованиеМагазина = СкладПолучатель;
				АдресМагазина = ПолучитьАдресМагазина(СкладПолучатель);
				ОбластьМакета.Параметры.АдресМагазина = АдресМагазина;
				ИНН = ПолучитьИННСклада(СкладПолучатель);
				КПП = ПолучитьКППСклада(СкладПолучатель);
				ОбластьМакета.Параметры.ИННКПП = ИНН +"/" + КПП;
				ОбластьМакета.Параметры.ТоварНаименование = ВыборкаСтрокТовары.ТоварНаименование;
				ОбластьМакета.Параметры.ОбъемДал = ОбъемДал;
				ОбластьМакета.Параметры.Количество = ВыборкаСтрокТовары.Количество;
				Если СтруктураОтвет.Импортный Тогда
					ОбластьМакета.Параметры.ДатаВвоза = Формат(СтруктураОтвет.ДатаВвоза, "ДЛФ=DD");
					ОбластьМакета.Параметры.КодСтраны = СтруктураОтвет.КодСтраны;
					ОбластьМакета.Параметры.НомерСправкиКТД = СтруктураОтвет.НомерСправкиКТД;
				Иначе
					ОбластьМакета.Параметры.ДатаОтгрузки = Формат(ВыборкаСтрокТовары.ДатаОтгрузки, "ДЛФ=DD");
					ОбластьМакета.Параметры.НомерДокумента = ВыборкаСтрокТовары.НомерОтгрузки;
				КонецЕсли; 
				ОбластьМакета.Параметры.ЛицензияСклада = ПолучитьАлкогольнуюЛицензиюСклада(СкладПолучатель);
				ТабДокумент.Вывести(ОбластьМакета);
				ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			КонецЕсли;	
			
		КонецЦикла;
	КонецЦикла;
	
	Возврат ТабДокумент;
	
КонецФункции	

&НаСервере
Функция ЭтоАлкоДокумент(ТекДок)
	
	Если ТипЗнч(ТекДок) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		Если ТекДок.ЗаказНаПеремещение.УчетВЕГАИС Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли; 
	Иначе
		Если ТекДок.ЗаказКлиента.УчетВЕГАИС Тогда
			Возврат Истина;
		Иначе
			Возврат Ложь;
		КонецЕсли; 
	КонецЕсли; 
	
КонецФункции 

&НаСервере
Функция ПолучитьОбъемДал(Ссылка)
	
