&НаСервере
Функция ПолучитьСтруктуруУполномоченногоЛицаПеревозчика(Знач Партнер, ДатаДокумента)
	
	СтруктураУполномоченногоЛица = Неопределено;
	
	Если ТипЗнч(Партнер) = Тип("СправочникСсылка.Контрагенты") Тогда
		Партнер = ОбщегоНазначения.ПолучитьЗначениеРеквизита(Партнер, "Партнер");
	КонецЕсли;
	
	Если ТипЗнч(Партнер) = Тип("СправочникСсылка.Партнеры") И ЗначениеЗаполнено(Партнер) Тогда 
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Владелец", 	   		 Партнер);
		Запрос.УстановитьПараметр("ДатаДокумента", 		 ДатаДокумента);
		Запрос.УстановитьПараметр("РольКонтактногоЛица", Справочники.РолиКонтактныхЛицПартнеров.НайтиПоНаименованию("Генеральный директор"));
		Запрос.Текст = "ВЫБРАТЬ
		|	КонтактныеЛицаПартнеров.Ссылка КАК Ссылка,
		|	КонтактныеЛицаПартнеров.ДатаРегистрацииСвязи
		|ПОМЕСТИТЬ втКонтактныеЛица
		|ИЗ
		|	Справочник.КонтактныеЛицаПартнеров КАК КонтактныеЛицаПартнеров
		|ГДЕ
		|	КонтактныеЛицаПартнеров.Владелец = &Владелец
		|	И КонтактныеЛицаПартнеров.ПометкаУдаления = ЛОЖЬ
		|	И (КонтактныеЛицаПартнеров.ДатаПрекращенияСвязи = ДАТАВРЕМЯ(1, 1, 1)
		|			ИЛИ КонтактныеЛицаПартнеров.ДатаПрекращенияСвязи > &ДатаДокумента)
		|	И (КонтактныеЛицаПартнеров.ДатаРегистрацииСвязи = ДАТАВРЕМЯ(1, 1, 1)
		|			ИЛИ КонтактныеЛицаПартнеров.ДатаРегистрацииСвязи <= &ДатаДокумента)
		|
		|ИНДЕКСИРОВАТЬ ПО
		|	Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	втКонтактныеЛица.Ссылка КАК УполномоченноеЛицо,
		|	КонтактныеЛицаПартнеровРолиКонтактногоЛица.РольКонтактногоЛица КАК РольУполномоченногоЛица
		|ИЗ
		|	втКонтактныеЛица КАК втКонтактныеЛица
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.КонтактныеЛицаПартнеров.РолиКонтактногоЛица КАК КонтактныеЛицаПартнеровРолиКонтактногоЛица
		|		ПО втКонтактныеЛица.Ссылка = КонтактныеЛицаПартнеровРолиКонтактногоЛица.Ссылка
		|
		|УПОРЯДОЧИТЬ ПО
		|	ДатаРегистрацииСвязи УБЫВ";
		
		Результат = Запрос.Выполнить();
		Если Не Результат.Пустой() Тогда
			
			Выборка = Результат.Выбрать();
			Выборка.Следующий();
			
			СтруктураУполномоченногоЛица = Новый Структура;
			СтруктураУполномоченногоЛица.Вставить("УполномоченноеЛицо", 	 Выборка.УполномоченноеЛицо);
			СтруктураУполномоченногоЛица.Вставить("РольУполномоченногоЛица", Выборка.РольУполномоченногоЛица);
			
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат СтруктураУполномоченногоЛица;
	
КонецФункции

