		Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Адрес склада", ,Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Контактная информация справочника ""Склады""")));
		ТелефонПунктРазгрузки = УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(Шапка.СкладПолучатель, 
		Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Телефон склада", ,Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Контактная информация справочника ""Склады""")));
		
		ОбластьМакета.Параметры.ПунктРазгрузки	 = АдресПунктРазгрузки + " ; " + ТелефонПунктРазгрузки;
		
		//ОбластьМакета.Параметры.ПунктРазгрузки	 = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОЗаказчикеПеревозок, 
		//"ФактическийАдрес");
		
		
		////////////
		ТабличныйДокумент.Вывести(ОбластьМакета);
		ОбластьМакета = Макет.ПолучитьОбласть("СведенияОГрузе");
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		ОбластьМакета = Макет.ПолучитьОбласть("ПодвалСведенийОГрузе");
		ТабличныйДокумент.Вывести(ОбластьМакета);
		ОбластьМакета = Макет.ПолучитьОбласть("ПогрузочныеОперации");
		ТабличныйДокумент.Вывести(ОбластьМакета);
		ОбластьМакета = Макет.ПолучитьОбласть("ПрочиеСведения");
		ТабличныйДокумент.Вывести(ОбластьМакета);	
		
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
	КонецЦикла;	
	
	Возврат ТабличныйДокумент;
	
КонецФункции

&НаСервере
Функция ПолучитьИННСклада(Склад)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДополнительныеСведения.Значение
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|ГДЕ
	|	ДополнительныеСведения.Объект = &Объект
	|	И ДополнительныеСведения.Свойство.Наименование = ""ИНН""";
	
	Запрос.УстановитьПараметр("Объект", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Значение;
	КонецЦикла;
	
КонецФункции

&НаСервере
Функция ПолучитьКППСклада(Склад)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ДополнительныеСведения.Значение
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|ГДЕ
	|	ДополнительныеСведения.Объект = &Объект
	|	И ДополнительныеСведения.Свойство.Наименование = ""КПП""";
	
	Запрос.УстановитьПараметр("Объект", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Значение;
	КонецЦикла;
	
КонецФункции
