	|ГДЕ
	|	ЗаказТовары.Отменено = ЛОЖЬ
	|	И ЗаказТовары.Ссылка.ЖелаемаяДатаПоступления = &ДатаОтгрузки
	|{ГДЕ
	|	ЗаказТовары.Ссылка.Склад.*,
	|	ЗаказТовары.Ссылка.Контрагент.*}
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказТовары.Ссылка.СкладПолучатель,
	|	ТИПЗНАЧЕНИЯ(ЗаказТовары.Ссылка),
	|	ЗаказТовары.Ссылка.СкладОтправитель,
	|	ЗаказТовары.НомерСтроки,
	|	ЗаказТовары.Номенклатура.Артикул,
	|	ЗаказТовары.Номенклатура.Наименование,
	|	ЗаказТовары.Количество,
	|	УпаковкиНоменклатуры.Коэффициент,
	|	ВЫБОР
	|		КОГДА УпаковкиНоменклатуры.Коэффициент ЕСТЬ NULL 
	|			ТОГДА 0
	|		ИНАЧЕ ВЫРАЗИТЬ(ЗаказТовары.Количество / УпаковкиНоменклатуры.Коэффициент КАК ЧИСЛО(10, 0))
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА УпаковкиНоменклатуры.Коэффициент ЕСТЬ NULL 
	|			ТОГДА ЗаказТовары.Количество
	|		ИНАЧЕ ЗаказТовары.Количество - (ВЫРАЗИТЬ(ЗаказТовары.Количество / УпаковкиНоменклатуры.Коэффициент КАК ЧИСЛО(10, 0))) * УпаковкиНоменклатуры.Коэффициент
	|	КОНЕЦ,
	|	ЗаказТовары.Ссылка
	|ИЗ
	|	Документ.ЗаказНаПеремещение.Товары КАК ЗаказТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиНоменклатуры КАК УпаковкиНоменклатуры
	|		ПО (УпаковкиНоменклатуры.Наименование = ""Упаковка WMS"")
	|			И ЗаказТовары.Номенклатура = УпаковкиНоменклатуры.Владелец
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗаказНаПеремещение.Ссылка КАК Ссылка
	|		ИЗ
	|			Документ.ЗаказНаПеремещение КАК ЗаказНаПеремещение
	|		ГДЕ
	|			ЗаказНаПеремещение.Ссылка В(&СписокЗаказов)
	|			И ЗаказНаПеремещение.ЖелаемаяДатаПоступления = &ДатаОтгрузки) КАК ВложенныйЗапрос
	|		ПО ЗаказТовары.Ссылка = ВложенныйЗапрос.Ссылка
	|ГДЕ
	|	ЗаказТовары.Отменено = ЛОЖЬ
	|	И ЗаказТовары.Ссылка.ЖелаемаяДатаПоступления = &ДатаОтгрузки
	|{ГДЕ
	|	ЗаказТовары.Ссылка.СкладОтправитель.*,
	|	ЗаказТовары.Ссылка.СкладПолучатель.*}
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиентаТовары.Ссылка.Контрагент,
	|	ТИПЗНАЧЕНИЯ(ЗаказКлиентаТовары.Ссылка),
	|	ЗаказКлиентаТовары.Ссылка.Склад,
	|	ЗаказКлиентаТовары.НомерСтроки,
	|	ЗаказКлиентаТовары.Номенклатура.Артикул,
	|	ЗаказКлиентаТовары.Номенклатура.Наименование,
	|	ЗаказКлиентаТовары.Количество,
	|	УпаковкиНоменклатуры.Коэффициент,
	|	ВЫБОР
	|		КОГДА УпаковкиНоменклатуры.Коэффициент ЕСТЬ NULL 
	|			ТОГДА 0
	|		ИНАЧЕ ВЫРАЗИТЬ(ЗаказКлиентаТовары.Количество / УпаковкиНоменклатуры.Коэффициент КАК ЧИСЛО(10, 0))
	|	КОНЕЦ,
	|	ВЫБОР
