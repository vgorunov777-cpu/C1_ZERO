Функция ПолучитьТипВладенияТСПеревозчика(Перевозчик)
	
	ТипВладенияТС = УправлениеСвойствамиПовтИсп.ЗначениеДополнительногоРеквизитаПоНаименованию(Перевозчик, "Тип владения ТС (для перевозчика)");
	Если ТипВладенияТС = Неопределено Тогда
		ТипВладенияТС = "";
	КонецЕсли;
	
	Возврат Строка(ТипВладенияТС);
	
КонецФункции

&НаСервере
Функция ПолучитьВодительскоеУдостоверениеВодителя(Период, Водитель)
	
	ВодительскоеУдостоверение = "";
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Период",  Период);
	Запрос.УстановитьПараметр("Физлицо", Водитель);
	Запрос.Текст = "ВЫБРАТЬ
	               |	ДокументыФизическихЛицСрезПоследних.Серия,
	               |	ДокументыФизическихЛицСрезПоследних.Номер
	               |ИЗ
	               |	РегистрСведений.ДокументыФизическихЛиц.СрезПоследних(
	               |			&Период,
	               |			Физлицо = &Физлицо
	               |				И ВидДокумента = ЗНАЧЕНИЕ(Справочник.ВидыДокументовФизическихЛиц.ВодительскоеУдостоверение)) КАК ДокументыФизическихЛицСрезПоследних";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ВодительскоеУдостоверение = СтрШаблон("ВУ %1 %2", Выборка.Серия, Выборка.Номер);
	КонецЕсли;
	
	Возврат ВодительскоеУдостоверение; 
	
КонецФункции

//печать внут перемещение
&НаСервере
Функция СформироватьПечатнуюФормуПриложениеКВнутренемуПеремещению(СтрокаМаршрута)
	
	УстановитьПривилегированныйРежим(Истина);
	
	МассивДокументов = Новый Массив;
	Для Каждого СтрЗаказ Из СтрокаМаршрута.Строки Цикл
		Если ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.ПеремещениеТоваров") И МассивДокументов.Найти(СтрЗаказ.Автомобиль)=Неопределено И Не СтрЗаказ.Пометка = 0 Тогда
			МассивДокументов.Добавить(СтрЗаказ.Автомобиль);
		КонецЕсли;	
	КонецЦикла;	
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Макет = Обработка.ПолучитьМакет("ПФ_MXL_ВнутренееПеремещение");
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_ПриложениеКВнутренемуПеремещению";
	
	// Зададим параметры Макета
	ТабДокумент.ПолеСверху = 0;
	ТабДокумент.ПолеСлева  = 0;
	ТабДокумент.ПолеСнизу  = 0;
	ТабДокумент.ПолеСправа = 0;
	ТабДокумент.АвтоМасштаб = Истина;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Перемещение.Ссылка КАК Документ,
	|	Перемещение.Номер КАК НомерДокумента,
	|	Перемещение.Дата КАК ДатаДокумента,
	|	Перемещение.Организация КАК Организация
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК Перемещение
	|ГДЕ
	|	Перемещение.Ссылка В(&МассивПеремещений)
	|
	|УПОРЯДОЧИТЬ ПО
	|	ДатаДокумента,
	|	Документ");
	
	Запрос.УстановитьПараметр("МассивПеремещений", МассивДокументов);
	Шапка = Запрос.Выполнить().Выбрать();
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПеремещениеТоваров.Номенклатура КАК Номенклатура
	|ИЗ
	|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваров
	|ГДЕ
	|	ПеремещениеТоваров.Ссылка = &ПеремещениеТоваров
	|
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура
	|АВТОУПОРЯДОЧИВАНИЕ");
	
	Пока Шапка.Следующий() Цикл
		НПП = 1;
		Если НЕ Шапка.Документ.Проведен Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нельзя печатать не проведенные документы!");
			Продолжить;
		КонецЕсли; 
		
		Запрос.УстановитьПараметр("ПеремещениеТоваров", Шапка.Документ);
		ВыборкаСтрокТовары = Запрос.Выполнить().Выбрать();
		
		НомерСтрокиНачало = ТабДокумент.ВысотаТаблицы + 1;
		
		// Выводим общие реквизиты шапки.
		ОбластьМакета         = Макет.ПолучитьОбласть("Шапка");
		СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Шапка.Организация, Шапка.ДатаДокумента);
		ОбластьМакета.Параметры.Заполнить(Шапка);
		ОбластьМакета.Параметры.Организация		= ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации);
		ОбластьМакета.Параметры.НомерДокумента	= ПрефиксацияОбъектовКлиентСервер.ПолучитьНомерНаПечать(Шапка.НомерДокумента, Ложь, Истина);
		ОбластьМакета.Параметры.ДатаДокумента	= Шапка.ДатаДокумента;
		ТабДокумент.Вывести(ОбластьМакета);
		
		// Выводим заголовок таблицы
		ЗаголовокТаблицы = Макет.ПолучитьОбласть("ЗаголовокТаблицы");
		ТабДокумент.Вывести(ЗаголовокТаблицы);
		
		ОбластьМакета = Макет.ПолучитьОбласть("Строка");
		Пока ВыборкаСтрокТовары.Следующий() Цикл
			ОбластьМакета.Параметры.Заполнить(ВыборкаСтрокТовары);
			ОбластьМакета.Параметры.Номенклатура = ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати(СокрЛП(ВыборкаСтрокТовары.Номенклатура));
			
			ОбластьМакета.Параметры.НПП = НПП;
			СтруктураХарактеристик = ПолучитьСтруктуруДополнительныхХарактеристик(ВыборкаСтрокТовары.Номенклатура);
			ОбластьМакета.Параметры.Изготовитель = СтруктураХарактеристик.Изготовитель;
			ОбластьМакета.Параметры.РегистрационныйНомер = СтруктураХарактеристик.РегистрационныйНомер;
			ОбластьМакета.Параметры.ОрганСертификации = СтруктураХарактеристик.ОрганСертификации;
			
			ОбластьМакета.Параметры.ДатаВыдачиСертификата = СтруктураХарактеристик.ДатаВыдачиСертификата;
			ОбластьМакета.Параметры.ДатаОкончанияСертификата = СтруктураХарактеристик.ДатаОкончанияСертификата;
			
			ТабДокумент.Вывести(ОбластьМакета);
			НПП = НПП + 1;
		КонецЦикла; 
		
		// Выводим подвал документа
		ОбластьМакета  = Макет.ПолучитьОбласть("Подвал");
		ТабДокумент.Вывести(ОбластьМакета);
		
		//УправлениеПечатью.ЗадатьОбластьПечатиДокумента(ТабДокумент, НомерСтрокиНачало, ОбъектыПечати, Шапка.Ссылка);
		
	КонецЦикла;
	
	Возврат ТабДокумент;
	
КонецФункции

&НаСервере
Функция ПолучитьСтруктуруДополнительныхХарактеристик(Номенклатура)
	
	СтруктураРекизитов = Новый Структура("Изготовитель, РегистрационныйНомер, ОрганСертификации, ДатаВыдачиСертификата, ДатаОкончанияСертификата");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	НоменклатураДополнительныеРеквизиты.Значение,
	|	НоменклатураДополнительныеРеквизиты.Ссылка
	|ИЗ
	|	Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
	|ГДЕ
	|	НоменклатураДополнительныеРеквизиты.Ссылка = &Номенклатура";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	
	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	
	ОбъектДокумент = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
	Для Каждого ТекСтр Из ОбъектДокумент.ДополнительныеРеквизиты Цикл
		Если ТекСтр.Свойство.Наименование = "ДатаВыдачиСертификата"  Тогда
			СтруктураРекизитов.ДатаВыдачиСертификата = Формат(ТекСтр.Значение, "ДФ=dd.MM.yy");
		ИначеЕсли ТекСтр.Свойство.Наименование = "ДатаОкончанияСертификата" Тогда
			СтруктураРекизитов.ДатаОкончанияСертификата = Формат(ТекСтр.Значение, "ДФ=dd.MM.yy");
		ИначеЕсли ТекСтр.Свойство.Наименование = "Регистрационный номер сертификата" Тогда
			СтруктураРекизитов.РегистрационныйНомер = ТекСтр.Значение;
		ИначеЕсли ТекСтр.Свойство.Наименование = "Наименование органа сертификации" Тогда
			СтруктураРекизитов.ОрганСертификации = ТекСтр.Значение;
		ИначеЕсли ТекСтр.Свойство.Наименование = "Основной произВодитель" Тогда
			СтруктураРекизитов.Изготовитель = ТекСтр.Значение;
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат СтруктураРекизитов;
КонецФункции 
//конец печать внут перемещение 

//печать торг12
&НаСервере 
Функция СформироватьПечатнуюФормуТОРГ12(МассивДокументов, СтруктураПараметров)
	
	ОбъектыПечати = Новый СписокЗначений;
	Для Каждого ТекСтр Из МассивДокументов Цикл
		ОбъектыПечати.Добавить(ТекСтр);
	КонецЦикла; 
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	
	// ЛВО + 31.07.2019
	//ДанныеДляПечати = ПолучитьДанныеДляПечатнойФормыТОРГ12(Новый Структура("ВыводитьУслуги", Ложь), МассивДокументов);
	Если СтруктураПараметров.ПечатьПоРеализации тогда
		  ДокументыРеализации = ПолучитьРеализацииПоЗаказамКлиента(МассивДокументов);
		  
		  Если ДокументыРеализации.Количество() = 0 тогда
			  ДанныеДляПечати = ПолучитьДанныеДляПечатнойФормыТОРГ12(Новый Структура("ВыводитьУслуги", Ложь), МассивДокументов);
		  Иначе
			  ДанныеДляПечати = ПолучитьДанныеДляПечатнойФормыТОРГ12_Осн(Новый Структура("ВыводитьУслуги", Ложь), ДокументыРеализации);
		  КонецЕсли;	  
	Иначе
		  ДанныеДляПечати = ПолучитьДанныеДляПечатнойФормыТОРГ12(Новый Структура("ВыводитьУслуги", Ложь), МассивДокументов);
	КонецЕсли;
	//-
	ЗаполнитьТабличныйДокументТОРГ12(ТабличныйДокумент, ДанныеДляПечати, ОбъектыПечати);
	
	ДанныеДляПечати = Неопределено;
	
	//+a.buganov@kdvm.ru 03.05.2018
	КоличествоЭкземпляров = 0;
	Если ТабличныйДокумент.КоличествоЭкземпляров = 0 Тогда
		СтрПФ = НастройкаПечати.НайтиСтроки(Новый Структура("ДокументПечати", "ТОРГ-12"));
		Если СтрПФ.Количество() > 0 Тогда
			КоличествоЭкземпляров = СтрПФ[0].Количество;
		Иначе
			КоличествоЭкземпляров = Неопределено;
		КонецЕсли;
	Иначе
		КоличествоЭкземпляров = ТабличныйДокумент.КоличествоЭкземпляров;
	КонецЕсли;
	Попытка
		СохранитьДанныеОПечати(МассивДокументов, "ТОРГ 12", СтруктураПараметров.ЗНО, КоличествоЭкземпляров);
	Исключение
	КонецПопытки;
	//- 
	
	Возврат ТабличныйДокумент;
	
КонецФункции // СформироватьПечатнуюФормуТОРГ12()

// Функция получает данные для формирования печатной формы ТОРГ - 12.
//
Функция ПолучитьДанныеДляПечатнойФормыТОРГ12(ПараметрыПечати, МассивОбъектов) Экспорт 
	
	УстановитьПривилегированныйРежим(Истина);

	КолонкаКодов = ФормированиеПечатныхФорм.ИмяДополнительнойКолонки();
	Если Не ЗначениеЗаполнено(КолонкаКодов) Тогда
		КолонкаКодов = "Код";
	КонецЕсли;
	
	Запрос = Новый Запрос("
	|////////////////////////////////////////////////////////////////////////////
	|// ВРЕМЕННАЯ ТАБЛИЦА
	|ВЫБРАТЬ
	|	*
	|ПОМЕСТИТЬ ВТ_ТаблицаКорректировок
	|ИЗ 
