&НаСервере
Процедура ЗаполнитьДеревоНаСервере()
	
	ТабРеестров = РеквизитФормыВЗначение("РО");
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Документ",ТабРеестров.ВыгрузитьКолонку("РеестрОтгрузки"));
	
	Запрос.Текст = "ВЫБРАТЬ
	               |	ВЫБОР
	               |		КОГДА (ВЫРАЗИТЬ(ЕСТЬNULL(ДопИдентификатор.Значение, """") КАК СТРОКА(50))) = """"
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК СкладWMS,
	               |	ЗаказНаОтгрузкуЗаказы.Ссылка КАК ЗаказНаОтгрузку,
	               |	ЗаказНаОтгрузкуЗаказы.Ссылка.Автомобиль КАК Автомобиль,
	               |	ЗаказНаОтгрузкуЗаказы.Ссылка.Водитель КАК Водитель,
	               |	ЗаказНаОтгрузкуЗаказы.Ссылка.ВремяВыезда КАК ДатаВыезда,
	               |	ЗаказНаОтгрузкуЗаказы.Заказ,
	               |	ЗаказНаОтгрузкуЗаказы.Перемещение,
	               |	ЗаказНаОтгрузкуЗаказы.Склад,
	               |	ЗаказНаОтгрузкуЗаказы.Получатель КАК Магазин,
	               |	ВЫБОР
	               |		КОГДА ЗаказНаОтгрузкуЗаказы.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовНаОтгрузку.Отгружено)
	               |				ИЛИ ЗаказНаОтгрузкуЗаказы.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовНаОтгрузку.ВОтгрузке)
	               |				ИЛИ (ВЫРАЗИТЬ(ЕСТЬNULL(ДопИдентификатор.Значение, """") КАК СТРОКА(50))) = """"
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ЛОЖЬ
	               |	КОНЕЦ КАК пАх,
	               |	ВЫБОР
	               |		КОГДА ЗаказНаОтгрузкуЗаказы.Заказ ССЫЛКА Документ.ЗаказПоставщику
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ВЫБОР
	               |				КОГДА ЗаказНаОтгрузкуЗаказы.Заказ.СкладОтправитель = &СкладыQP5
	               |					ТОГДА ИСТИНА
	               |				КОГДА ЗаказНаОтгрузкуЗаказы.Перемещение ССЫЛКА Документ.ПеремещениеТоваров
	               |						И ЗаказНаОтгрузкуЗаказы.Перемещение <> ЗНАЧЕНИЕ(Документ.ПеремещениеТоваров.ПустаяСсылка)
	               |						И (ЗаказНаОтгрузкуЗаказы.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовНаОтгрузку.ВОтгрузке)
	               |							ИЛИ ЗаказНаОтгрузкуЗаказы.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовНаОтгрузку.Отгружено))
	               |						И (ЗаказНаОтгрузкуЗаказы.СкладскойСтатус = ЗНАЧЕНИЕ(Перечисление.СкладскиеСтатусы.Погрузка)
	               |								И ЗаказНаОтгрузкуЗаказы.СтатусЗаказа = ЗНАЧЕНИЕ(Перечисление.СтатусыОтгружаемыхЗаказов.Скомплектован)
	               |							ИЛИ ЗаказНаОтгрузкуЗаказы.СкладскойСтатус = ЗНАЧЕНИЕ(Перечисление.СкладскиеСтатусы.Отгружен)
	               |								И ЗаказНаОтгрузкуЗаказы.СтатусЗаказа = ЗНАЧЕНИЕ(Перечисление.СтатусыОтгружаемыхЗаказов.Завершено)
	               |							ИЛИ ЗаказНаОтгрузкуЗаказы.СкладскойСтатус = ЗНАЧЕНИЕ(Перечисление.СкладскиеСтатусы.Отменен)
	               |								И ЗаказНаОтгрузкуЗаказы.СтатусЗаказа = ЗНАЧЕНИЕ(Перечисление.СтатусыОтгружаемыхЗаказов.Скомплектован)
	               |							ИЛИ ЗаказНаОтгрузкуЗаказы.СкладскойСтатус = ЗНАЧЕНИЕ(Перечисление.СкладскиеСтатусы.Отменен)
	               |								И ЗаказНаОтгрузкуЗаказы.СтатусЗаказа = ЗНАЧЕНИЕ(Перечисление.СтатусыОтгружаемыхЗаказов.Отменен))
	               |					ТОГДА ИСТИНА
	               |				КОГДА ЗаказНаОтгрузкуЗаказы.Перемещение ССЫЛКА Документ.РеализацияТоваровУслуг
	               |							И ЗаказНаОтгрузкуЗаказы.Перемещение <> ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)
	               |							И (ЗаказНаОтгрузкуЗаказы.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовНаОтгрузку.ВОтгрузке)
	               |								ИЛИ ЗаказНаОтгрузкуЗаказы.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовНаОтгрузку.Отгружено))
	               |							И (ЗаказНаОтгрузкуЗаказы.СкладскойСтатус = ЗНАЧЕНИЕ(Перечисление.СкладскиеСтатусы.Погрузка)
	               |									И ЗаказНаОтгрузкуЗаказы.СтатусЗаказа = ЗНАЧЕНИЕ(Перечисление.СтатусыОтгружаемыхЗаказов.Скомплектован)
	               |								ИЛИ ЗаказНаОтгрузкуЗаказы.СкладскойСтатус = ЗНАЧЕНИЕ(Перечисление.СкладскиеСтатусы.Отгружен)
	               |									И ЗаказНаОтгрузкуЗаказы.СтатусЗаказа = ЗНАЧЕНИЕ(Перечисление.СтатусыОтгружаемыхЗаказов.Завершено)
	               |								ИЛИ ЗаказНаОтгрузкуЗаказы.СкладскойСтатус = ЗНАЧЕНИЕ(Перечисление.СкладскиеСтатусы.Отменен)
	               |									И ЗаказНаОтгрузкуЗаказы.СтатусЗаказа = ЗНАЧЕНИЕ(Перечисление.СтатусыОтгружаемыхЗаказов.Скомплектован)
	               |								ИЛИ ЗаказНаОтгрузкуЗаказы.СкладскойСтатус = ЗНАЧЕНИЕ(Перечисление.СкладскиеСтатусы.Отменен)
	               |									И ЗаказНаОтгрузкуЗаказы.СтатусЗаказа = ЗНАЧЕНИЕ(Перечисление.СтатусыОтгружаемыхЗаказов.Отменен))
	               |						ИЛИ ВложенныйЗапрос.ОбобщенныйДокумент
	               |					ТОГДА ИСТИНА
	               |				ИНАЧЕ ЛОЖЬ
	               |			КОНЕЦ
	               |	КОНЕЦ КАК п1С,
	               |	ДополнительныеСведенияШК.Значение КАК НомерМЛ,
	               |	ВЫБОР
	               |		КОГДА ЕСТЬNULL(ДополнительныеСведенияШК.Значение, """") = """"
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК Напечатано,
	               |	ВЫБОР
	               |		КОГДА НЕ ЗаказНаОтгрузкуЗаказы.Ссылка.Перевозчик = ЗНАЧЕНИЕ(Справочник.Контрагенты.ПустаяСсылка)
	               |			ТОГДА ЗаказНаОтгрузкуЗаказы.Ссылка.Перевозчик
	               |		ИНАЧЕ ЕСТЬNULL(ВЫРАЗИТЬ(ДополнительныеСведенияПеревозчик.Значение КАК Справочник.Контрагенты).Наименование, """")
	               |	КОНЕЦ КАК Перевозчик,
	               |	ЗаказНаОтгрузкуЗаказы.Ссылка.Экспедитор КАК Экспедитор,
	               |	ЕСТЬNULL(ДополнительныеСведенияКоличествоПаллет.Значение, """") КАК КоличествоПалет,
	               |	ВЫРАЗИТЬ(ЗаказНаОтгрузкуЗаказы.Получатель.Наименование КАК СТРОКА(4)) КАК ПолучательПредставление,
	               |	ЗаказНаОтгрузкуЗаказы.Ссылка.Водитель2,
	               |	ВЫБОР
	               |		КОГДА ЗаказНаОтгрузкуЗаказы.Ссылка.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовНаОтгрузку.Отгружено)
	               |			ТОГДА ИСТИНА
	               |		ИНАЧЕ ЛОЖЬ
	               |	КОНЕЦ КАК Отгружен,
	               |	ВложенныйЗапрос.ОбобщенныйДокумент
	               |ИЗ
	               |	Документ.ЗаказНаОтгрузку.Заказы КАК ЗаказНаОтгрузкуЗаказы
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДопИдентификатор
	               |		ПО ЗаказНаОтгрузкуЗаказы.Склад = ДопИдентификатор.Объект
	               |			И (ДопИдентификатор.Свойство.Наименование = ""ИдентификаторСинхронизации"")
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведенияШК
	               |		ПО (ДополнительныеСведенияШК.Свойство.Наименование = ""Штрихкод документа"")
	               |			И ЗаказНаОтгрузкуЗаказы.Перемещение = ДополнительныеСведенияШК.Объект
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведенияПеревозчик
	               |		ПО ((ВЫРАЗИТЬ(ДополнительныеСведенияПеревозчик.Объект КАК Справочник.ТранспортныеСредства)) = ЗаказНаОтгрузкуЗаказы.Ссылка.Автомобиль)
	               |			И (ДополнительныеСведенияПеревозчик.Свойство.Наименование = ""Контрагент"")
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведенияКоличествоПаллет
	               |		ПО ((ВЫРАЗИТЬ(ДополнительныеСведенияКоличествоПаллет.Объект КАК Справочник.ТранспортныеСредства)) = ЗаказНаОтгрузкуЗаказы.Ссылка.Автомобиль)
	               |			И (ДополнительныеСведенияКоличествоПаллет.Свойство.Наименование = ""КоличествоПалет"")
	               |		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	               |			ЗаказНаПеремещение.Ссылка КАК Заказ,
	               |			МАКСИМУМ(ВЫБОР
	               |					КОГДА НЕ ЗаказНаПеремещениеТовары.Отменено
	               |						ТОГДА ИСТИНА
	               |					ИНАЧЕ ЛОЖЬ
	               |				КОНЕЦ) КАК неОтменено,
	               |			ЛОЖЬ КАК ОбобщенныйДокумент
	               |		ИЗ
	               |			Документ.РеестрОтгрузки.ЗаказыНаОтгрузку КАК РеестрОтгрузкиЗаказыНаОтгрузку
	               |				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаПеремещение КАК ЗаказНаПеремещение
	               |					ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказНаПеремещение.Товары КАК ЗаказНаПеремещениеТовары
	               |					ПО (ЗаказНаПеремещениеТовары.Ссылка = ЗаказНаПеремещение.Ссылка)
	               |						И (ЗаказНаПеремещениеТовары.Отменено = ЛОЖЬ)
	               |				ПО (ЗаказНаПеремещение.Ссылка = РеестрОтгрузкиЗаказыНаОтгрузку.Заказ)
	               |		ГДЕ
	               |			РеестрОтгрузкиЗаказыНаОтгрузку.Ссылка В(&Документ)
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			ЗаказНаПеремещение.Ссылка
	               |		
	               |		ОБЪЕДИНИТЬ ВСЕ
	               |		
	               |		ВЫБРАТЬ
	               |			ЗаказКлиента.Ссылка,
	               |			МАКСИМУМ(ВЫБОР
	               |					КОГДА НЕ ЗаказКлиентаТовары.Отменено
	               |						ТОГДА ИСТИНА
	               |					ИНАЧЕ ЛОЖЬ
	               |				КОНЕЦ),
	               |			ЕСТЬNULL(ВЫРАЗИТЬ(КонтрагентыДополнительныеРеквизиты.Значение КАК БУЛЕВО), ЛОЖЬ)
	               |		ИЗ
	               |			Документ.РеестрОтгрузки.ЗаказыНаОтгрузку КАК РеестрОтгрузкиЗаказыНаОтгрузку
	               |				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ЗаказКлиента
	               |					ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	               |					ПО (ЗаказКлиентаТовары.Ссылка = ЗаказКлиента.Ссылка)
	               |						И (ЗаказКлиентаТовары.Отменено = ЛОЖЬ)
	               |					ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.ДополнительныеРеквизиты КАК КонтрагентыДополнительныеРеквизиты
	               |					ПО ЗаказКлиента.Контрагент = КонтрагентыДополнительныеРеквизиты.Ссылка
	               |						И (КонтрагентыДополнительныеРеквизиты.Свойство.Наименование = ""ОбобщённыйДокумент"")
	               |				ПО (ЗаказКлиента.Ссылка = РеестрОтгрузкиЗаказыНаОтгрузку.Заказ)
	               |		ГДЕ
	               |			РеестрОтгрузкиЗаказыНаОтгрузку.Ссылка В(&Документ)
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			ЗаказКлиента.Ссылка,
	               |			ЕСТЬNULL(ВЫРАЗИТЬ(КонтрагентыДополнительныеРеквизиты.Значение КАК БУЛЕВО), ЛОЖЬ)
	               |		
	               |		ОБЪЕДИНИТЬ ВСЕ
	               |		
	               |		ВЫБРАТЬ
	               |			ЗаказПоставщику.Ссылка,
	               |			МАКСИМУМ(ВЫБОР
	               |					КОГДА НЕ ЗаказПоставщикуТовары.Отменено
	               |						ТОГДА ИСТИНА
	               |					ИНАЧЕ ЛОЖЬ
	               |				КОНЕЦ),
	               |			ЛОЖЬ
	               |		ИЗ
	               |			Документ.РеестрОтгрузки.ЗаказыНаОтгрузку КАК РеестрОтгрузкиЗаказыНаОтгрузку
	               |				ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
	               |					ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику.Товары КАК ЗаказПоставщикуТовары
	               |					ПО (ЗаказПоставщикуТовары.Ссылка = ЗаказПоставщику.Ссылка)
	               |						И (ЗаказПоставщикуТовары.Отменено = ЛОЖЬ)
	               |				ПО (ЗаказПоставщику.Ссылка = РеестрОтгрузкиЗаказыНаОтгрузку.Заказ)
	               |		ГДЕ
	               |			РеестрОтгрузкиЗаказыНаОтгрузку.Ссылка В(&Документ)
	               |		
	               |		СГРУППИРОВАТЬ ПО
	               |			ЗаказПоставщику.Ссылка) КАК ВложенныйЗапрос
	               |		ПО ЗаказНаОтгрузкуЗаказы.Заказ = ВложенныйЗапрос.Заказ
	               |ГДЕ
	               |	ЗаказНаОтгрузкуЗаказы.Ссылка В
	               |			(ВЫБРАТЬ
	               |				РеестрОтгрузкиЗаказыНаОтгрузку.ЗаказНаОтгрузку
	               |			ИЗ
	               |				Документ.РеестрОтгрузки.ЗаказыНаОтгрузку КАК РеестрОтгрузкиЗаказыНаОтгрузку
	               |			ГДЕ
	               |				РеестрОтгрузкиЗаказыНаОтгрузку.Ссылка В (&Документ))
	               |	И НЕ ЗаказНаОтгрузкуЗаказы.СкладскойСтатус = ЗНАЧЕНИЕ(Перечисление.СкладскиеСтатусы.Отменен)
	               |	И ЕСТЬNULL(ВложенныйЗапрос.неОтменено, ЛОЖЬ) = ИСТИНА
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	ДатаВыезда,
	               |	ПолучательПредставление
	               |ИТОГИ
	               |	МАКСИМУМ(Автомобиль),
	               |	МАКСИМУМ(Водитель),
	               |	МАКСИМУМ(ДатаВыезда),
	               |	МИНИМУМ(пАх),
	               |	МИНИМУМ(п1С),
	               |	МАКСИМУМ(НомерМЛ),
	               |	МИНИМУМ(Напечатано),
	               |	МАКСИМУМ(Перевозчик),
	               |	МАКСИМУМ(Экспедитор),
	               |	МАКСИМУМ(КоличествоПалет),
	               |	МАКСИМУМ(Отгружен)
	               |ПО
	               |	ЗаказНаОтгрузку";
	
				   
	Запрос.УстановитьПараметр("СкладыQP5", Справочники.Склады.НайтиПоНаименованию("КроссДокинг QP5 О005 Омск"));
	Рез = Запрос.Выполнить();
	
	Дерево = РеквизитФормыВЗначение("ЗНО");
	Дерево.Строки.Очистить();
	
	Выб1 = Рез.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам,"ЗаказНаОтгрузку");
	Пока Выб1.Следующий() Цикл
		
		Стр1 = Дерево.Строки.Добавить();
		Стр1.пАх = Выб1.пАх;
		Стр1.п1С = Выб1.п1С;
		Стр1.Отгружен = Выб1.Отгружен;
		Стр1.ЗНО = Выб1.ЗаказНаОтгрузку;
		Стр1.Автомобиль = Выб1.Автомобиль;
		Стр1.Водитель = Выб1.Водитель;
		Стр1.Водитель2 = Выб1.Водитель2;
		Стр1.ДатаВыезда = Выб1.ДатаВыезда;
		Стр1.Напечатано = Выб1.Напечатано;
		Стр1.Перевозчик = Выб1.Перевозчик;
		Стр1.Экспедитор = Выб1.Экспедитор;
		Стр1.КоличествоПалет = Выб1.КоличествоПалет;
		Стр1.НомерМЛ = Выб1.НомерМЛ;
		Стр1.Ответственный = ПараметрыСеанса.ТекущийПользователь;
		
		//Стр1.НомерМЛ = Выб1.НомерМЛ;
		
		Выб2 = Выб1.Выбрать();
		Пока Выб2.Следующий() Цикл
			
			Стр2 = Стр1.Строки.Добавить();
			Стр2.пАх        = Выб2.пАх;
			Стр2.п1С        = Выб2.п1С;
			Стр2.ЗНО        = Выб2.Заказ;
			Стр2.Автомобиль = Выб2.Перемещение;
			Стр2.Водитель   = Выб2.Магазин;
			Стр2.ДатаВыезда = Выб2.Склад;
			Стр2.Уровень    = 1;
			Стр2.Напечатано = Выб2.Напечатано;
			Стр2.НомерМЛ	 = Выб2.НомерМЛ;
			Стр2.СкладWMS	 = Выб2.СкладWMS;
			Стр2.Перевозчик = Выб2.Перевозчик;
			Стр2.Экспедитор = Выб2.Экспедитор;
			Стр2.КоличествоПалет = Выб2.КоличествоПалет;
			Стр2.обобщенныйДокумент = Выб2.обобщенныйДокумент;
			
		КонецЦикла;
		
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(Дерево, "ЗНО");
	
КонецПроцедуры	

&НаКлиенте
Процедура СвернутьРазвернутьДерево()
	
	СкрытьНапечатанное = Элементы.ЗНОКомандаСкрытьНапечатанное.Пометка;
	
	Если НЕ СкрытьНапечатанное Тогда
		Возврат;
	КонецЕсли;	
	
	
	СтрокиДерева = ЗНО.ПолучитьЭлементы();
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.Напечатано Тогда
			Этаформа.Элементы.ЗНО.Свернуть(СтрокаДерева.ПолучитьИдентификатор());
		Иначе
			Этаформа.Элементы.ЗНО.Развернуть(СтрокаДерева.ПолучитьИдентификатор());
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Функция ПроверкаВозможностиПечати(Сообщение)
	
	Отказ = Ложь;
	Если Не ЗначениеЗаполнено(ПринтерПоУмолчанию) И ВыводНаПринтер Тогда 
		Элементы.ЗНО.КоманднаяПанель.ПодчиненныеЭлементы.ЗНОКомандаПоказатьНастройки.Пометка = Ложь;
		УправлениеВидимостью();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не задан принтер!",, "ПринтерПоУмолчанию");
		//Сообщение = Сообщение + "Не задан принтер!";
		Отказ = Истина;
	КонецЕсли;
	
	ЕстьСтрокиКПечати = Ложь;
	
	КэшАдресовМагазинов = Новый Соответствие;
	
	СтрокиДерева = ЗНО.ПолучитьЭлементы();
	Для Каждого СтрокаДерева Из СтрокиДерева Цикл
		Если СтрокаДерева.Пометка = 0 Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьСтрокиКПечати = Истина;
		
		//закомментировано до лучших времен
		//Если НЕ СтрокаДерева.пАх ИЛИ НЕ СтрокаДерева.п1С Тогда
		Если Ложь И (НЕ СтрокаДерева.пАх Или Не СтрокаДерева.п1С)  Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ " + СтрокаДерева.ЗНО + ", не завершился процесс погрузки!",, "ЗНО[0].Пометка");
			//Сообщение = Сообщение + ?(Не Сообщение = "", Символы.ПС, "") + "Документ " + СтрокаДерева.ЗНО + ", не завершился процесс погрузки!";
			Отказ = Истина;
		КонецЕсли;	
		
		//Если СтрокаДерева.Напечатано Тогда
		//	//ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ " + СтрокаДерева.ЗНО + ", документы на отгрузку уже были напечатаны!",, "ЗНО[0].Пометка");
		//	//Сообщение = Сообщение + ?(Не Сообщение = "", Символы.ПС, "") +  "Документ " + СтрокаДерева.ЗНО + ", документы на отгрузку уже были напечатаны!";
		//	//Отказ = Истина;
		//КонецЕсли;
		ВыбСклады = СтрокаДерева.ПолучитьЭлементы();
		Для Каждого ВыбСклад Из ВыбСклады Цикл
			
			Если Не ЗначениеЗаполнено(ВыбСклад.ДатаВыезда) Тогда
				Продолжить;
			КонецЕсли;
			
			Адрес = КэшАдресовМагазинов[ВыбСклад.ДатаВыезда];
			Если Адрес = Неопределено Тогда
				Адрес = ПолучитьАдресМагазина(ВыбСклад.ДатаВыезда);
				КэшАдресовМагазинов.Вставить(ВыбСклад.ДатаВыезда, Адрес);
			КонецЕсли;
			
			Если ПустаяСтрока(Адрес) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Документ " + СтрокаДерева.ЗНО + ", " + ВыбСклад.ДатаВыезда + " не заполнен адрес склада!");
			КонецЕсли;
			
		КонецЦикла;	
		
	КонецЦикла;	
	
	Если НЕ ЕстьСтрокиКПечати Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбран заказ на отгрузку!",, "ЗНО[0].Пометка");
	КонецЕсли;	
	
	Возврат Отказ;
	
КонецФункции	

&НаСервере
Функция ПечатьНаСервере()
	
	ТабПФ = НастройкаПечати.Выгрузить();//НастройкаПечати.Выгрузить();//РеквизитФормыВЗначение("НастройкаПечати");
	
	ТабПФИтоговая = ТабПФ.Скопировать();
	ТабПФИтоговая.Очистить();
	
	Для Каждого СтрПФ Из ТабПФ Цикл
		Если СтрПФ.Количество > 0 Тогда
			Элем = СписокПечатныхФорм.НайтиПоЗначению(СтрПФ.ДокументПечатиИД);
			Если Элем<>Неопределено И Элем.Пометка Тогда
				Стр = ТабПФИтоговая.Добавить();
				ЗаполнитьЗначенияСвойств(Стр,СтрПФ);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;	
	
	ТабПФИтоговая.Сортировать("Порядок");
	
	СтрокиМаршрутов = РеквизитФормыВЗначение("ЗНО");
	
	ДокументыКПечати = Новый Массив;
	
	ТаблицаВетВрача = Новый ТаблицаЗначений;
	ТаблицаВетВрача.Колонки.Добавить("ТД");
	ТаблицаВетВрача.Колонки.Добавить("Код");
	МассивЗНО = Новый Массив; //ЛВО  08.12.2020
	ИтоговыйТабДокТранспортнаяНакладная2020 = Новый ТабличныйДокумент;
	ИтоговыйТабДокТранспортнаяНакладная2022 = Новый ТабличныйДокумент;
	
	//КопияДерева = СтрокиМаршрутов.Скопировать();
	Если СортировкаПоВодителю тогда
		СтрокиМаршрутов.Строки.Сортировать("Водитель");
	КонецЕсли;
	
	
	Для Каждого СтрокаМарш Из СтрокиМаршрутов.Строки Цикл
		Если НЕ СтрокаМарш.Пометка Тогда
			Продолжить;
		КонецЕсли;
		
		Для Каждого СтрПФ ИЗ ТабПФИтоговая Цикл
			
			ИмяМакета = СтрПФ.ДокументПечатиИД;
			
			Если ИмяМакета = "МаршрутныйЛист" Тогда
				
				Если НЕ СтрокаМарш.Напечатано Или Истина Тогда
					//МассивТД = Новый Массив;
					//МассивТД.Добавить(СформироватьПечатнуюФормуМаршрутногоЛиста(СтрокаМарш));
					//МассивТД.Добавить(СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту(СтрокаМарш));
					
					ТабДок = Новый Массив;
					ТабДок.Добавить(СформироватьПечатнуюФормуМаршрутногоЛиста(СтрокаМарш));
					//ТабДок.Добавить(СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту(СтрокаМарш));					
				Иначе
					Продолжить;
				КонецЕсли;
				
			ИначеЕсли ИмяМакета = "ТОРГ13" Тогда
				
				ТабДок = ПолучитьГрупповоеПеремещение(СтрокаМарш);
				
			ИначеЕсли ВРЕГ(ИмяМакета) = "ТОРГ13ОПТ" Тогда
				
				ТабДок = ПолучитьГрупповоеПеремещениеОПТ(СтрокаМарш);
				
			ИначеЕсли ИмяМакета = "ОбъединенныйМаршрутныйЛист" Тогда
				//+a.buganov@kdvm.ru 02.04.2018
				ТабДок = СформироватьПечатнуюФормуОбъединенныйМаршрутныйЛист(СтрокаМарш);
				//- 
			ИначеЕсли ИмяМакета = "ПФ_MXL_СправкаНаЭтиловыйСпирт" Тогда
				
				ТабДок = Новый Массив;
				ТабДок.Добавить(СформироватьПечатнуюФормуСправкаНаЭтиловыйСпирт(СтрокаМарш));
				//ТабДок.Добавить(СформироватьТТНЕГАИС(СтрокаМарш));
				//ТабДок = СформироватьПечатнуюФормуСправкаНаЭтиловыйСпирт(СтрокаМарш);
				//ТД = СформироватьТТНЕГАИС(СтрокаМарш);
				
				
				
			ИначеЕсли ИмяМакета = "ПриложениеКМаршрутномуЛисту" Тогда
				
				ТабДок = СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту(СтрокаМарш);
				
			ИначеЕсли ИмяМакета = "ПФ_MXL_ТТН" Тогда
				
				ТабДок = СформироватьПечатнуюФорму1_Т(СтрокаМарш);
				
			ИначеЕсли ИмяМакета = "ПФ_MXL_ЗаказПоставщику" Тогда
				
				МассивОбъектов = Новый Массив;
				Для Каждого Заказы Из СтрокаМарш.Строки Цикл
					Если ТипЗНЧ(Заказы.ЗНО) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
						МассивОбъектов.Добавить(Заказы.ЗНО); 
					КонецЕсли;
				КонецЦикла;	
				
				Если Не МассивОбъектов.Количество() = 0 ТОгда
					ТабДок = СформироватьПечатнуюФормуЗаказПоставщику(МассивОбъектов);
				КонецЕсли;
				
				СохранитьДанныеОПечати(МассивОбъектов, "Заказ поставщику", СтрокаМарш.ЗНО, СтрПФ.Количество);
				
			ИначеЕсли ИмяМакета = "ТранспортнаяНакладная" Или ИмяМакета = "ТранспортнаяНакладнаяСПустымЭкспедитором" Или ИмяМакета = "ТранспортнаяНакладнаяСПустымПеревозчиком" Тогда
				
				//n.chernyshov печать новой формы
				//ТабДок = ПолучитьТранспортнуюНакладную(СтрокаМарш);
				//ТабДок = ПолучитьТранспортнуюНакладную2022(СтрокаМарш);
				//разное заполнение по перевозчикам
				
				ПараметрыФормированияТН = ПолучитьПараметрыФормированияТН();
				
				Если ИмяМакета = "ТранспортнаяНакладнаяСПустымЭкспедитором" Тогда
					ПараметрыФормированияТН.ОчиститьЭкспедитора = Истина;
				КонецЕсли;
				
				Если ИмяМакета = "ТранспортнаяНакладнаяСПустымПеревозчиком" Тогда
					ПараметрыФормированияТН.ОчиститьПеревозчика = Истина;
				КонецЕсли;

				ТабДок = ПолучитьТранспортнуюНакладную_01082023(СтрокаМарш, ПараметрыФормированияТН);
				
				Если СтрокаМарш.Перевозчик = "Бриджтаун фудс ЗАО" тогда
					ТабДок.КоличествоЭкземпляров = 1;
				Иначе	
					ТабДок.КоличествоЭкземпляров = СтрПФ.Количество + 1;
				КонецЕсли;
				
				//ЛВО 8.12.2020 +
				//Если НЕ СтрокаМарш.ЗНО.Статус = Перечисления.СтатусыЗаказовНаОтгрузку.Отгружено Тогда
				//	Сообщить("" + СтрокаМарш.ЗНО + "находится в статусе " + СтрокаМарш.ЗНО.Статус + ". Формировать ВСД можно только для документво со статусом ОТГРУЖЕНО.");
				//Иначе
					МассивЗНО.Добавить(СтрокаМарш.ЗНО);
				//КонецЕсли;			
				//-
			ИначеЕсли ИмяМакета = "ТранспортнаяНакладная2020" Тогда
				
				ТабДок = Новый ТабличныйДокумент;
				ТабДокТранспортнаяНакладная2020 = ПолучитьТранспортнуюНакладную2020(СтрокаМарш);
				ИтоговыйТабДокТранспортнаяНакладная2020.Вывести(ТабДокТранспортнаяНакладная2020);
				ИтоговыйТабДокТранспортнаяНакладная2020.ВывестиГоризонтальныйРазделительСтраниц();
				Если СтрокаМарш.Перевозчик = "Бриджтаун фудс ЗАО" тогда
					ИтоговыйТабДокТранспортнаяНакладная2020.КоличествоЭкземпляров = 1;
				Иначе	
					ИтоговыйТабДокТранспортнаяНакладная2020.КоличествоЭкземпляров = СтрПФ.Количество + 1;
				КонецЕсли;
				
			ИначеЕсли ИмяМакета = "ТранспортнаяНакладная2022" Тогда
				
				ТабДок = Новый ТабличныйДокумент;
				ТабДокТранспортнаяНакладная2022 = ПолучитьТранспортнуюНакладную2022(СтрокаМарш);
				ИтоговыйТабДокТранспортнаяНакладная2022.Вывести(ТабДокТранспортнаяНакладная2022);
				ИтоговыйТабДокТранспортнаяНакладная2022.ВывестиГоризонтальныйРазделительСтраниц();
				Если СтрокаМарш.Перевозчик = "Бриджтаун фудс ЗАО" тогда
					ИтоговыйТабДокТранспортнаяНакладная2022.КоличествоЭкземпляров = 1;
				Иначе	
					ИтоговыйТабДокТранспортнаяНакладная2022.КоличествоЭкземпляров = СтрПФ.Количество + 1;
				КонецЕсли;

			ИначеЕсли ИмяМакета = "ПФ_MXL_НакладнаяНаПеремещение" Тогда
				
				ТабДок = ПолучитьНакладнуюНаПеремещение(СтрокаМарш);
				
			ИначеЕсли ИмяМакета = "ПФ_MXL_ВнутренееПеремещение" Тогда
				
				ТабДок = СформироватьПечатнуюФормуПриложениеКВнутренемуПеремещению(СтрокаМарш);
				
			ИначеЕсли ИмяМакета = "ПФ_MXL_ТОРГ12" Тогда
				
				МассивДокументов = Новый Массив;
				СтруктураПараметров = Новый Структура("Водитель, Автомобиль, ЗНО", СтрокаМарш.Водитель, СтрокаМарш.Автомобиль, СтрокаМарш.ЗНО);
				//ЛВО 31.07.2019 +
					ПечатьПоРеализации = Ложь;
					Если СтрокаМарш.Пометка = 1 тогда
						 ПечатьпоРеализации = Истина;
					 КонецЕсли;
					 СтруктураПараметров.Вставить("ПечатьПоРеализации",ПечатьПоРеализации);
				//-
				Для Каждого ТекСтр Из СтрокаМарш.Строки Цикл
					Если Не ЗначениеЗаполнено(ТекСтр.Автомобиль) И ТекСтр.Пометка = 1 И ТипЗнч(ТекСтр.ЗНО) = Тип("ДокументСсылка.ЗаказКлиента") И ТекСтр.ОбобщенныйДокумент Тогда
						
						МассивДокументов.Добавить(ТекСтр.ЗНО);

					ИначеЕсли Не ЗначениеЗаполнено(ТекСтр.Автомобиль) Или Не ТекСтр.Пометка = 1 Тогда
						Продолжить;
					КонецЕсли; 
					
					Если ТипЗнч(ТекСтр.Автомобиль) <> Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
						Продолжить;
					КонецЕсли; 
					МассивДокументов.Добавить(ТекСтр.Автомобиль);
				КонецЦикла; 
				
				ТабДокумент = СформироватьПечатнуюФормуТОРГ12(МассивДокументов, СтруктураПараметров);
				ТабДокумент.РазборПоКопиям = Истина;
				Если ТабДокумент.КоличествоЭкземпляров = 0 Тогда
					ТабДокумент.КоличествоЭкземпляров = СтрПФ.Количество;
				КонецЕсли;
				
				ДокументыКПечати.Добавить(ТабДокумент);
				
				Продолжить;
				
			ИначеЕсли ИмяМакета = "ПФ_MXL_СчетФактура1137" Тогда
				
				МассивДокументов = Новый Массив;
				СтруктураПараметров = Новый Структура("Водитель, Автомобиль, ЗНО", СтрокаМарш.Водитель, СтрокаМарш.Автомобиль, СтрокаМарш.ЗНО);
				
				//ЛВО 31.07.2019 +
					ПечатьПоРеализации = Ложь;
					Если СтрокаМарш.Пометка = 1 тогда
						 ПечатьпоРеализации = Истина;
					 КонецЕсли;
					 СтруктураПараметров.Вставить("ПечатьПоРеализации",ПечатьПоРеализации);
				//-

				Для Каждого ТекСтр Из СтрокаМарш.Строки Цикл
					
					Если Не ЗначениеЗаполнено(ТекСтр.Автомобиль) И ТекСтр.Пометка = 1 И ТипЗнч(ТекСтр.ЗНО) = Тип("ДокументСсылка.ЗаказКлиента") И ТекСтр.ОбобщенныйДокумент Тогда
						
						МассивДокументов.Добавить(ТекСтр.ЗНО);

					ИначеЕсли Не ЗначениеЗаполнено(ТекСтр.Автомобиль) Или Не ТекСтр.Пометка = 1 Тогда
						Продолжить;
					КонецЕсли; 
					
					Если ТипЗнч(ТекСтр.Автомобиль) <> Тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
						Продолжить;
					КонецЕсли; 
					МассивДокументов.Добавить(ТекСтр.Автомобиль);
				КонецЦикла; 
				
				ТабДокумент = СформироватьПечатнуюФормуСчетФактура(МассивДокументов, СтруктураПараметров);
				ТабДокумент.РазборПоКопиям = Истина;
				Если ТабДокумент.КоличествоЭкземпляров = 0 Тогда
					ТабДокумент.КоличествоЭкземпляров = СтрПФ.Количество;
				КонецЕсли;
				
				ДокументыКПечати.Добавить(ТабДокумент);
				
				Продолжить;
				
			ИначеЕсли ИмяМакета = "ПФ_MXL_ПриложениеДляВетВрача" Тогда
				
				ТипПечати = ?(СтрПФ.ДокументПечати = "Приложение для ветврача", "1", "2");
				ТабДок = СформироватьПечатнуюФормуПриложенияДляВетВрача(СтрокаМарш, СтрПФ.Количество, ТипПечати, ТаблицаВетВрача);
				Продолжить;
			ИначеЕсли ИмяМакета = "ТТНЕГАИС" Тогда
				
				ТабДок = СформироватьТТНЕГАИС(СтрокаМарш);
				
			ИначеЕсли ИмяМакета = "ЛистКомплектации" Тогда
				
				ТабДок = ПолучитьЛистКомплектации(СтрокаМарш, 0);
				
			ИначеЕсли ИмяМакета = "ОбъединенныйЛистКомплектации" Тогда
				
				ТабДок = ПолучитьЛистКомплектации(СтрокаМарш, 1);
				
			ИначеЕсли ИмяМакета = "ЛистКомплектацииМагазин" Тогда
				
				ТабДок = ПолучитьЛистКомплектации(СтрокаМарш, 2);
			ИначеЕсли  ИмяМакета = "КомплектДокументовЗаказпоставщикуНакладнаяНаПеремещение" Тогда
				
				СоответствиеСкладов = Новый Соответствие;
				Для Каждого Стр Из СтрокаМарш.Строки Цикл
					Если Не Стр.Пометка = 1 Тогда
						Продолжить;
					КонецЕсли;
					
					Если ЗначениеЗаполнено(Стр.Водитель) И (ТипЗнч(Стр.ЗНО) = Тип("ДокументСсылка.ЗаказНаПеремещение") И ЗначениеЗаполнено(Стр.Автомобиль)) Или ТипЗнч(Стр.ЗНО) = Тип("ДокументСсылка.ЗаказПоставщику")
						Тогда
						
						МассивСтрок = СоответствиеСкладов.Получить(Стр.Водитель);
						Если МассивСтрок = Неопределено Тогда
							
							Массив = Новый Массив;
							Массив.Добавить(Стр);
							СоответствиеСкладов.Вставить(Стр.Водитель, Массив);
							
						Иначе
							
							МассивСтрок.Добавить(Стр);
							
						КонецЕсли;
					КонецЕсли;	
				КонецЦикла;
				
				МассивТД = Новый Массив;
				Для Каждого КлючЗначение Из СоответствиеСкладов Цикл
					
					//+Заказы поставщикам
					МассивОбъектов = Новый Массив;
					МассивПеремещений = Новый Массив;
					Для Каждого Заказы Из КлючЗначение.Значение Цикл
						Если ТипЗНЧ(Заказы.ЗНО) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
							
							МассивОбъектов.Добавить(Заказы.ЗНО); 
							
						ИначеЕсли ТипЗНЧ(Заказы.ЗНО) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
							
							Если Заказы.СкладWMS И НеПечататьЛистКомплектацииДляWMS Тогда
								Продолжить;
							КонецЕсли;
							
							МассивПеремещений.Добавить(Заказы.Автомобиль);
							
						 КонецЕсли;
						 
					КонецЦикла;	
					        
					Если Не МассивОбъектов.Количество() = 0 ТОгда
						ТабДок = СформироватьПечатнуюФормуЗаказПоставщику(МассивОбъектов, Неопределено, Истина, СтрокаМарш.Водитель);
						МассивТД.Добавить(ТабДок);
					КонецЕсли;
					
					Если Не МассивПеремещений.Количество() = 0 Тогда
						ТабДок = ПолучитьНакладнуюНаПеремещение(СтрокаМарш, МассивПеремещений, Истина);
						МассивТД.Добавить(ТабДок);
					КонецЕсли;
					
				КонецЦикла;
				
				Для Каждого Т Из МассивТД Цикл
					Т.КоличествоЭкземпляров = 1;
				КонецЦикла;
				
				ТабДок = МассивТД;
				
			КонецЕсли;	
			
			
			Если ТипЗнч(ТабДок) = Тип("ТабличныйДокумент") Тогда
				МассивТД = Новый Массив;
				МассивТД.Добавить(ТабДок);
			ИначеЕсли ТипЗнч(ТабДок) = Тип("Массив") Тогда
				МассивТД = ТабДок;
			КонецЕсли;
			
			Для Каждого ТабДок Из МассивТД Цикл
				ТабДок.РазборПоКопиям = Истина;
				//Сообщить("" + ТабДок.КоличествоЭкземпляров);
				Если ТабДок.КоличествоЭкземпляров = 0 Тогда // ЛВО 16.10.2019
					ТабДок.КоличествоЭкземпляров = СтрПФ.Количество;
				КонецЕсли;
				//	Сообщить("" + ТабДок.КоличествоЭкземпляров + Символы.Пс + СтрПФ.Количество+ "***");
				ДокументыКПечати.Добавить(ТабДок);
			КонецЦикла;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если СортировкаПоВодителю тогда
		СтрокиМаршрутов.Строки.Сортировать("ДатаВыезда");
	КонецЕсли;
	
	
	Если ИтоговыйТабДокТранспортнаяНакладная2020.Области.Количество() > 0 тогда
		 ДокументыКПечати.Добавить(ИтоговыйТабДокТранспортнаяНакладная2020);
	КонецЕсли;
	 
	Если ИтоговыйТабДокТранспортнаяНакладная2022.Области.Количество() > 0 тогда
		 ДокументыКПечати.Добавить(ИтоговыйТабДокТранспортнаяНакладная2022);
	КонецЕсли;
	
	ЗначениеВРеквизитФормы(СтрокиМаршрутов,"ЗНО");
	
	ТаблицаВетВрача.Сортировать("Код");
	Для Каждого ТабДок Из ТаблицаВетВрача Цикл
		ДокументыКПечати.Добавить(ТабДок.ТД);
	КонецЦикла;
	
	// ЛВО 08.12.2020 +
	Если не РольДоступна("ПолныеПрава") и  МассивЗНО.Количество()>0 тогда
		МодульВетис = ВетисПовтИсп.ИнициализароватьПодключаемыйМодуль();
		МодульВетис.СформироватьЗаявкиПеремещениеПоЗНО(МассивЗНО);
	КонецЕсли;
	// +
	
	Возврат ДокументыКПечати;
	
КонецФункции	

&НаСервере
Процедура СохранитьСписокПечатныхФормНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ХранилищеДополнительнойИнформации.Наименование,
	|	ХранилищеДополнительнойИнформации.Хранилище,
	|	ХранилищеДополнительнойИнформации.Дата КАК Дата,
	|	ХранилищеДополнительнойИнформации.Ссылка
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации КАК ХранилищеДополнительнойИнформации
	|ГДЕ
	|	ХранилищеДополнительнойИнформации.ВидДанных = 18
	|	И ХранилищеДополнительнойИнформации.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		ХранОбъект = Выборка.Ссылка.ПолучитьОбъект();
	Иначе
		ХранОбъект = Справочники.ХранилищеДополнительнойИнформации.СоздатьЭлемент();
	КонецЕсли;
	
	ТЗ = НастройкаПечати.Выгрузить();//НастройкаПечати.Выгрузить();//РеквизитФормыВЗначение("НастройкаПечати");
	
	ХранОбъект.Дата 			= ТекущаяДата();
	ХранОбъект.ВидДанных 		= 18; // отдельный вид для настоен
	ХранОбъект.Комментарий 	    = "Настройки печати маршрутов";
	ХранОбъект.Наименование 	= "Настройки печати маршрутов";
	ХранОбъект.Ответственный 	= ПараметрыСеанса.ТекущийПользователь;
	ХранОбъект.Хранилище 		= Новый ХранилищеЗначения(ТЗ);
	ХранОбъект.Записать();
	
КонецПроцедуры	

&НаСервере
Процедура ВосстановитьСписокПечатныхФормНаСервере()
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	|	ХранилищеДополнительнойИнформации.Наименование,
	|	ХранилищеДополнительнойИнформации.Хранилище,
	|	ХранилищеДополнительнойИнформации.Дата КАК Дата,
	|	ХранилищеДополнительнойИнформации.Ссылка
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации КАК ХранилищеДополнительнойИнформации
	|ГДЕ
	|	ХранилищеДополнительнойИнформации.ВидДанных = 18
	|	И ХранилищеДополнительнойИнформации.ПометкаУдаления = ЛОЖЬ
	|
	|УПОРЯДОЧИТЬ ПО
	|	Дата УБЫВ";
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Если Выборка.Следующий() Тогда
		ТЗ = Выборка.Хранилище.Получить();
		ЗначениеВРеквизитФормы(ТЗ,"НастройкаПечати");
		ЗаполнитьСписокПечатныхФорм();
	Иначе
		ЗаполнитьСписокПечатныхФорм();
	КонецЕсли;	
	
КонецПроцедуры	


