&НаСервере
Процедура ВывестиПредыдущихПоставщиков(ТабДок, Товар, ДатаВыпуска, НомерПартии, ЕстьРазделА)
	
	МассивАдресов = ПолучитьИзДопХранилища(Товар, ДатаВыпуска, НомерПартии);
	
	Для Каждого АдресВоВременномХранилище Из МассивАдресов Цикл
		НачальноеПоложениеКартинки = ТабДок.ВысотаТаблицы + 1;
		КонечноеПоложениеКартинки = ТабДок.ВысотаТаблицы + 90;  //90 165
		
		ТабДок.ВывестиГоризонтальныйРазделительСтраниц();
		
		Если Не ПустаяСтрока(АдресВоВременномХранилище) Тогда
			ДвоичныеДанныеКартинки = ПолучитьИзВременногоХранилища(АдресВоВременномХранилище);
			Если ДвоичныеДанныеКартинки = Неопределено Тогда
				Продолжить;
			КонецЕсли; 
			Попытка
				ДДКартинки = Новый Картинка (ДвоичныеДанныеКартинки);
			Исключение
				ТекстОшибки = "Не удалось вывести Раздел А Для "+ Символы.ПС + "Товар: "+СокрЛП(Товар)+ Символы.ПС + "Выпуск: "+ДатаВыпуска + Символы.ПС + "Партия: "+ НомерПартии;
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
				Продолжить;
			КонецПопытки;
		КонецЕсли; 
		
		Попытка
			
			Рисунок = ТабДок.Рисунки.Добавить(ТипРисункаТабличногоДокумента.Картинка);
			Рисунок.ГраницаСверху = Ложь;
			Рисунок.ГраницаСлева = Ложь;
			Рисунок.ГраницаСнизу = Ложь;
			Рисунок.ГраницаСправа = Ложь;
			Индекс = ТабДок.Рисунки.Индекс(Рисунок);
			ТабДок.Рисунки[Индекс].Картинка = ДДКартинки;
			ТабДок.Рисунки[Индекс].Расположить(ТабДок.Область("R" + Формат(НачальноеПоложениеКартинки,"ЧГ=0") + "C1:R" + Формат(КонечноеПоложениеКартинки, "ЧГ=0") + "C19"));  //57
			
			ЕстьРазделА = Истина;
			
		Исключение
			ТекстОшибки = "Не удалось вывести Раздел А Для: "+СокрЛП(Товар)+" выпуск "+ДатаВыпуска+" " + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		КонецПопытки;	
	КонецЦикла; 
	
КонецПроцедуры

&НаСервере
Функция ПолучитьПринадлежностьАлкогольнойПродукции(Ссылка, ДатаВыпуска, НомерПартии)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Номенклатура,
	|	ЕСТЬNULL(ДопРеквизиты_Импортный.Значение, ЛОЖЬ) КАК Импортный,
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.Комментарий КАК НомерСправкиКТД,
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопДата КАК ДатаВвоза,
	|	ДополнительныеСведения.Значение КАК СтранаПроизВодитель
	|ИЗ
	|	(ВЫБРАТЬ
	|		СпрНоменклатура.Ссылка КАК Номенклатура
	|	ИЗ
	|		Справочник.Номенклатура КАК СпрНоменклатура
	|	ГДЕ
	|		СпрНоменклатура.Ссылка = &Ссылка) КАК ВложенныйЗапрос
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК ДопРеквизиты_Импортный
	|		ПО ВложенныйЗапрос.Номенклатура = ДопРеквизиты_Импортный.Ссылка
	|			И (ДопРеквизиты_Импортный.Свойство.Наименование = ""ИмпортныйАлкоголь"")
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ХранилищеДополнительнойИнформации.ДополнительныеСведения КАК ХранилищеДополнительнойИнформацииДополнительныеСведения
	|		ПО ВложенныйЗапрос.Номенклатура = ХранилищеДополнительнойИнформацииДополнительныеСведения.Объект
	|			И (ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.ВидДанных = 0)
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|		ПО ВложенныйЗапрос.Номенклатура = ДополнительныеСведения.Объект
	|			И (ДополнительныеСведения.Свойство.Наименование = ""СтранаПроисхождения"")
	|ГДЕ
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.Дата = &ДатаВыпуска
	|	И ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер1 = """"
	|	И ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер = &КодСправкиА";
	
	
	Запрос.УстановитьПараметр("Ссылка", Ссылка);
	Запрос.УстановитьПараметр("ДатаВыпуска", ДатаВыпуска);
	КодСправкиА = ПолучитьКодСправкиА(Ссылка, ДатаВыпуска, НомерПартии);
	Если ТипЗнч(КодСправкиА) = Тип("Строка") Тогда
		Запрос.УстановитьПараметр("КодСправкиА", КодСправкиА);
	Иначе
		Запрос.УстановитьПараметр("КодСправкиА", КодСправкиА.Код);
	КонецЕсли; 
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Новый Структура("Импортный, КодСтраны, НомерСправкиКТД, ДатаВвоза", Ложь);
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если НЕ ПустаяСтрока(ВыборкаДетальныеЗаписи.СтранаПроизВодитель) Тогда
			СтранаПроизВодительКодАльфа2 = ВыборкаДетальныеЗаписи.СтранаПроизВодитель.КодАльфа2;
		Иначе
			СтранаПроизВодительКодАльфа2 = "";
		КонецЕсли; 
		
		Возврат Новый Структура("Импортный, КодСтраны, НомерСправкиКТД, ДатаВвоза", 
		ВыборкаДетальныеЗаписи.Импортный, СтранаПроизВодительКодАльфа2, ВыборкаДетальныеЗаписи.НомерСправкиКТД, ВыборкаДетальныеЗаписи.ДатаВвоза);
	КонецЦикла;
	
КонецФункции

&НаСервере
Функция ПолучитьСкладПолучатель(ДокументПеремещение, ТипСклада = "Получатель")
	
	Если ТипЗнч(ДокументПеремещение) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		Если ТипСклада = "Получатель" Тогда
			Возврат ДокументПеремещение.СкладПолучатель;
		Иначе
			Возврат ДокументПеремещение.СкладОтправитель;
		КонецЕсли; 
	Иначе
		Возврат НайтиСкладКонтрагента(ДокументПеремещение.Контрагент);
	КонецЕсли; 
	
КонецФункции

