КонецПроцедуры

Процедура ЗаполнитьТаблицуЗаказовККомплектации()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ОрганизацияДоставкиПоЗаказам.Регистратор КАК Заказ
	|ИЗ
	|	РегистрНакопления.ОрганизацияДоставкиПоЗаказам КАК ОрганизацияДоставкиПоЗаказам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента КАК ЗаказКлиента
	|		ПО ОрганизацияДоставкиПоЗаказам.Регистратор = ЗаказКлиента.Ссылка
	|ГДЕ
	|	ОрганизацияДоставкиПоЗаказам.ВидДвижения = &ВидДвижения
	|	И ОрганизацияДоставкиПоЗаказам.СкладОтправитель = &СкладОтправитель
	|	И ЗаказКлиента.ЖелаемаяДатаОтгрузки = &ДатаОтгрузки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОрганизацияДоставкиПоЗаказам.Регистратор
	|ИЗ
	|	РегистрНакопления.ОрганизацияДоставкиПоЗаказам КАК ОрганизацияДоставкиПоЗаказам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказНаПеремещение КАК ЗаказНаПеремещение
	|		ПО ОрганизацияДоставкиПоЗаказам.Регистратор = ЗаказНаПеремещение.Ссылка
	|ГДЕ
	|	ОрганизацияДоставкиПоЗаказам.ВидДвижения = &ВидДвижения
	|	И ОрганизацияДоставкиПоЗаказам.СкладОтправитель = &СкладОтправитель
	|	И ЗаказНаПеремещение.ЖелаемаяДатаПоступления = &ДатаОтгрузки
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ОрганизацияДоставкиПоЗаказам.Регистратор
	|ИЗ
	|	РегистрНакопления.ОрганизацияДоставкиПоЗаказам КАК ОрганизацияДоставкиПоЗаказам
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ЗаказПоставщику КАК ЗаказПоставщику
	|		ПО ОрганизацияДоставкиПоЗаказам.Регистратор = ЗаказПоставщику.Ссылка
	|ГДЕ
	|	ОрганизацияДоставкиПоЗаказам.ВидДвижения = &ВидДвижения
	|	И ОрганизацияДоставкиПоЗаказам.СкладОтправитель = &СкладОтправитель
	|	И ЗаказПоставщику.ЖелаемаяДатаПоступления = &ДатаОтгрузки";
	
	Запрос.УстановитьПараметр("ВидДвижения", ВидДвиженияНакопления.Приход);
	Запрос.УстановитьПараметр("СкладОтправитель", СкладТранзит);
	Запрос.УстановитьПараметр("ДатаОтгрузки", ДатаОтгрузки);
	
	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаКомплектация.Добавить(), ВыборкаДетальныеЗаписи);
	КонецЦикла;
	
КонецПроцедуры

Процедура НайтиСтрокиПоДаннымФормыДерево(НайденнаяСтрока, КоллекцияЭлементов = Неопределено, СтруктураПоиска, ПрекратитьПоиск, ИскатьВПодчиненных = Ложь)
	Если КоллекцияЭлементов = Неопределено Тогда
		КоллекцияЭлементовДерева = ЗНО.ПолучитьЭлементы();
	КонецЕсли;
	Для Каждого СтрокаДерева ИЗ КоллекцияЭлементовДерева Цикл
		
		Если ПрекратитьПоиск Тогда
			Возврат;
		КонецЕсли;
		
		КлючСоответствует = Истина;
		Для Каждого Параметр Из СтруктураПоиска Цикл
			Если Не СтрокаДерева[Параметр.Ключ] = Параметр.Значение Тогда
				КлючСоответствует = Ложь;
			КонецЕсли;
		КонецЦикла;
		
		Если КлючСоответствует Тогда
			
			НайденнаяСтрока = СтрокаДерева;
			
			ПрекратитьПоиск = Истина;
			
			Возврат;
			
		КонецЕсли;
		
		Если Не ИскатьВПодчиненных Тогда
			Продолжить;
		КонецЕсли;
		
		КоллекцияЭлементов = СтрокаДерева.ПолучитьЭлементы();
		
		Если КоллекцияЭлементов.Количество() > 0 Тогда
			
			НайтиСтрокиПоДаннымФормыДерево(НайденнаяСтрока, КоллекцияЭлементов, СтруктураПоиска, ПрекратитьПоиск, ИскатьВПодчиненных);
			
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

Функция УстановитьБезопасныйРежимСервер()
	Пока БезопасныйРежим() Цикл
		УстановитьБезопасныйРежим(Ложь);
	КонецЦикла;
	
КонецФункции

&НаКлиенте
Процедура УстановитьФлажки(Команда)
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаЗНО" Тогда
		
		УстановитьФлажкиНаСервере(Истина);
		СвернутьРазвернутьДерево();
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаКомплектация" Тогда
		
		ПечататьВсе = Ложь;
		
		Ответ = Вопрос("Пометить напечатанные заказы?", РежимДиалогаВопрос.ДаНет);
		Если Ответ = КодВозвратаДиалога.Да Тогда
			ПечататьВсе = Истина;
		КонецЕсли;
		
		
		Для Каждого Стр Из ТаблицаКомплектация Цикл
			Если Не Стр.Напечатан Или ПечататьВсе Тогда
				Стр.Пометка = Истина;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура УбратьФлажки(Команда)
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаЗНО" Тогда
		
		УстановитьФлажкиНаСервере(Ложь);
		СвернутьРазвернутьДерево();
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаКомплектация" Тогда
		Для Каждого Стр Из ТаблицаКомплектация Цикл
			Стр.Пометка = Ложь;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаСкрытьНапечатанное(Команда)
	
	Элементы.ЗНОКомандаСкрытьНапечатанное.Пометка = НЕ Элементы.ЗНОКомандаСкрытьНапечатанное.Пометка;
	
	СвернутьРазвернутьДерево();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаПечатьОбщая(Команда)
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаЗНО" Тогда
		
		СтруктураЗНО = Новый Структура("ЗНО", ?(Не Элементы.ЗНО.ТекущиеДанные = Неопределено, 
			?(ТипЗнч(Элементы.ЗНО.ТекущиеДанные.ЗНО) = Тип("ДокументСсылка.ЗаказНаОтгрузку"), Элементы.ЗНО.ТекущиеДанные.ЗНО, Элементы.ЗНО.ТекущиеДанные.ПолучитьРодителя().ЗНО), 
			Неопределено));
			
		Если Не СтруктураЗНО.Зно = Неопределено Тогда
			ИндексТекущейСтроки = Элементы.ЗНО.ТекущиеДанные.ПолучитьИдентификатор();//Элементы.ЗНО.ТекущаяСтрока;//ЗНО.ПолучитьЭлементы().Индекс(Элементы.ЗНО.ТекущиеДанные);
		КонецЕсли;
		
		Сообщение = "";
		Если Отладка тогда
			Отказ = ЛОжь;
		ИНаче	
			Отказ = ПроверкаВозможностиПечати(Сообщение);
		КонецЕсли;	
		Если Отказ И Не Отладка Тогда
			Возврат;
		КонецЕсли;
		
		ПодготовитьСписокПечатныхФорм();
		
		Если СписокПечатныхФорм.ОтметитьЭлементы("Печатать") Тогда
			
			Если СписокПечатныхФорм.Количество() = 0 Тогда
				Возврат;
			КонецЕсли;
			
			РазрешитьПечатьНапечатанных = Истина;
			Для Каждого ПФ Из СписокПечатныхФорм Цикл
				
				Если ПФ.Пометка И Не ПФ.Представление = "Документы на алкоголь" И Найти(ПФ.Представление, "Приложение для ветврача") = 0 И Не (ПФ.Представление = "Транспортная наклдная" Или ПФ.Представление = "Транспортная накладная") И Не Сообщение = "" Тогда
					Если Не Отладка Тогда
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Сообщение,, "ЗНО[0]");
						Возврат;
					КонецЕсли;
				КонецЕсли;
				
			КонецЦикла;
			
			ДокументыКПечати = ПечатьНаСервере();
			//
			//Для Каждого Док Из ДокументыКПечати Цикл
			//	Если Док.ВысотаТаблицы>0   Тогда
			//		Если Не ВыводНаПринтер Тогда
			//			Док.Показать();
			//		Иначе
			//			Если ЗначениеЗаполнено(ПринтерПоУмолчанию) Тогда
			//				Док.ИмяПринтера = ПринтерПоУмолчанию;
			//			Иначе
			//				//Док.ИмяПринтера = ОбщегоНазначенияКлиент.ПолучитьПринтерПоУмолчанию();
			//			КонецЕсли;
			//			
			//			Док.Напечатать(Истина);
			//		КонецЕсли;
			//	КонецЕсли;	
			//	
			//КонецЦикла;	
			
		КонецЕсли;	
		
		Если Не СтруктураЗНО.Зно = Неопределено Тогда
			
			Для Каждого СтрокаЗНО Из ЗНО.ПолучитьЭлементы() Цикл
				Если СтрокаЗНО.ЗНО = СтруктураЗНО.ЗНО Тогда
					
					Элементы.ЗНО.ТекущаяСтрока = СтрокаЗНО.ПолучитьИдентификатор();//ИндексТекущейСтроки;
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаКомплектация" Тогда
		
		Если ТаблицаКомплектация.НайтиСтроки(Новый Структура("Пометка", Истина)).Количество() = 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не выбрано ни одного заказа!");
			Возврат;
		КонецЕсли;
		
		ТабДок = СформироватьПечатнуюФормуКомплектация();
		ДокументыКПечати = Новый Массив;
		ДокументыКПечати.Добавить(ТабДок);
		
	КонецЕсли;
	
	Если ДокументыКПечати = Неопределено Или ТипЗнч(ДокументыКПечати) = Тип("Массив") И ДокументыКПечати.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нет данных для печати");
		Возврат;
	КонецЕсли;
	
	Для Каждого Док Из ДокументыКПечати Цикл
		Если Док.ВысотаТаблицы>0   Тогда
			Док.ПолеСлева = 5;
			Док.ПолеСправа = 5;
			Док.Автомасштаб = Истина;
			Если Не ВыводНаПринтер Тогда
				Док.Показать();
			Иначе
				Если ЗначениеЗаполнено(ПринтерПоУмолчанию) Тогда
					Док.ИмяПринтера = ПринтерПоУмолчанию;
				Иначе
					//Док.ИмяПринтера = ОбщегоНазначенияКлиент.ПолучитьПринтерПоУмолчанию();
				КонецЕсли;
				
				Док.Напечатать(Истина);
			КонецЕсли;
		КонецЕсли;	
		
	КонецЦикла;	
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаКомплектация" Тогда
		
		МассивЗаказов = Новый Массив;
		Заказы = ТаблицаКомплектация.НайтиСтроки(Новый Структура("Пометка", Истина));
		Для Каждого Стр Из Заказы Цикл
			МассивЗаказов.Добавить(Стр.Заказ);
		КонецЦикла;
		
		ЗаписатьДанныеОПечати(МассивЗаказов);
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура  ЗаписатьДанныеОПечати(Заказы)
	
	ДопКонстанты = ОбщегоНазначенияСерверПовтИсп.ПолучитьЗначениеДопКонстант();
	
	Для Каждого Заказ Из Заказы Цикл
		
		РС = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
		РС.Объект = Заказ;
		РС.Свойство = ?(ДопКонстанты.Свойство("СвойствоНапечатан"), ДопКонстанты.СвойствоНапечатан, ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Напечатан"));
		Если Не ЗначениеЗаполнено(РС.Свойство) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не удается найти свойство напечатан! Данные о печати не будут добавлены!");
			Прервать;
		КонецЕсли;
		
		РС.Значение = Истина;
		
		Попытка
			РС.Записать();
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
		КонецПопытки;
		
	КонецЦикла;	
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаСохранитьСписокПечатныхФорм(Команда)
	
	СохранитьСписокПечатныхФормНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура КомандаОбновитьСписокПечатныхФорм(Команда)
	
	НастройкаПечати.Очистить();
	ЗаполнитьСписокПечатныхФорм();
	//ВосстановитьСписокПечатныхФормНаСервере();
	
КонецПроцедуры


