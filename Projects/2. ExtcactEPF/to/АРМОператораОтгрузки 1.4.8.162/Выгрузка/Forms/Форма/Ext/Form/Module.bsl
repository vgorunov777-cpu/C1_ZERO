&НаСервере
Функция ИнициализироватьИсточникКНКД(СхемаКомпоновкиДанных, Запрос = "")
	
	ИсточникДанных = СхемаКомпоновкиДанных.ИсточникиДанных.Добавить(); 
	ИсточникДанных.Имя                = "ИсточникДанных";
	ИсточникДанных.ТипИсточникаДанных = "Local";
	
	НаборДанных = СхемаКомпоновкиДанных.НаборыДанных.Добавить(Тип("НаборДанныхЗапросСхемыКомпоновкиДанных"));
	//НаборДанных.АвтоЗаполнениеДоступныхПолей = Истина;
	
	//НаборДанных.Запрос 			= ПолучитьТекстЗапросаДляНастройкиКомпоновкиДанных(ПоЗаказам);
	НаборДанных.Запрос 			= Запрос;
	НаборДанных.Имя            	= "НаборДанных";
	НаборДанных.ИсточникДанных 	= "ИсточникДанных";
	
	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных);
	ИсточникНастроек 		   = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных);
	
	Возврат ИсточникНастроек;
	
КонецФункции

&НаСервере
Функция ВыполнитьЗапросВКНКД(ИсточникНастроек, НастройкиКомпоновкиДанных, СхемаКомпоновкиДанных)
	
	ТаблицаЗначениеРезультат = Новый ТаблицаЗначений;	
	
	КНКД = Новый КомпоновщикНастроекКомпоновкиДанных;
	КНКД.Инициализировать(ИсточникНастроек);
	КНКД.ЗагрузитьНастройки(НастройкиКомпоновкиДанных);
	//
	ГруппировкаКНКД = КНКД.Настройки.Структура.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	ГруппировкаКНКД.Использование = Истина;
	
	Для Каждого Поле Из ГруппировкаКНКД.Выбор.ДоступныеПоляВыбора.Элементы Цикл
		Если Не Поле.Папка Тогда
			ДобавитьПолеВКНКД(ГруппировкаКНКД.Выбор.Элементы, Поле.Заголовок);//"Склад");
		КонецЕсли;
	КонецЦикла;
	
	КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
	МакетКомпоновки   = КомпоновщикМакета.Выполнить(СхемаКомпоновкиДанных, КНКД.Настройки,,, Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновки.Инициализировать(МакетКомпоновки,,,);
	
	ПроцессорВывода = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВывода.УстановитьОбъект(ТаблицаЗначениеРезультат);
	
	ПроцессорВывода.Вывести(ПроцессорКомпоновки);
	
	Возврат ТаблицаЗначениеРезультат;
	
КонецФункции	

&НаСервере
Процедура ДобавитьПолеВКНКД(ВыбранныеЭлементы, Поле)
	
	Элемент = ВыбранныеЭлементы.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
