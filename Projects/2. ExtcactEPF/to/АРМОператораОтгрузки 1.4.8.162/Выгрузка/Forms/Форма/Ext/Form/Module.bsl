Функция ПолучитьПоследнийШтрихкодПоСвойству()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПОДСТРОКА(ВЫРАЗИТЬ(ДополнительныеСведения.Значение КАК СТРОКА(150)), 1, 11) КАК Значение
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|ГДЕ
	|	ДополнительныеСведения.Свойство.Наименование = ""Штрихкод документа""
	|
	|УПОРЯДОЧИТЬ ПО
	|	Значение УБЫВ";
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		//Будем кодировать документы 
		Возврат "0"; 
	КонецЕсли; 
	ТаблицаДетальныеЗаписи = РезультатЗапроса.Выгрузить();
	
	Возврат ТаблицаДетальныеЗаписи[0].Значение;
