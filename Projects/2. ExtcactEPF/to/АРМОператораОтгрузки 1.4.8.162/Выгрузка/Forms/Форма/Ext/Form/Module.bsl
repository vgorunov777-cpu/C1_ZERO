Функция ПолучитьАдресСклада(МассивОбъектов)
	ТаблицаСкладов = Новый ТаблицаЗначений;
	ТаблицаСкладов.Колонки.Добавить("Склад");
	
	Для каждого ТекСтр Из МассивОбъектов Цикл
		Если ТипЗнч(ТекСтр) = Тип("ДокументСсылка.ЗаказНаПеремещение") ИЛИ ТипЗнч(ТекСтр) = Тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ТекущийМагазин = ТекСтр.СкладОтправитель;
		Иначе
			ТекущийМагазин = ТекСтр.Склад;
		КонецЕсли; 
		
		НоваяСтрока = ТаблицаСкладов.Добавить();
		НоваяСтрока.Склад = ТекущийМагазин;
	КонецЦикла; 
	
	ТаблицаСкладов.Свернуть("Склад");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	СкладыКонтактнаяИнформация.Представление
	|ИЗ
	|	Справочник.Склады.КонтактнаяИнформация КАК СкладыКонтактнаяИнформация
	|ГДЕ
	|	СкладыКонтактнаяИнформация.Ссылка В(&Ссылка)
	|	И СкладыКонтактнаяИнформация.Вид = &Вид
	|
	|СГРУППИРОВАТЬ ПО
	|	СкладыКонтактнаяИнформация.Представление";
	
	Запрос.УстановитьПараметр("Ссылка", ТаблицаСкладов.ВыгрузитьКолонку("Склад"));
	Запрос.УстановитьПараметр("вид", справочники.ВидыКонтактнойИнформации.АдресСклада);
	
	ВыборкаАдресов = Запрос.Выполнить().Выгрузить();
	
	СтрокаАдресов = "";
	Для каждого ТекСтр Из ВыборкаАдресов Цикл
		
		СтрокаАдресов = СтрокаАдресов + ТекСтр.Представление + ", ";
		
	КонецЦикла; 
	
	Возврат СтрокаАдресов;
	
