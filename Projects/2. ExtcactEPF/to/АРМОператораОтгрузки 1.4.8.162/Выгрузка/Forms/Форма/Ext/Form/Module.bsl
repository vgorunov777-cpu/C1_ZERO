	|			ТОГДА ЗаказКлиентаТовары.Количество
	|		ИНАЧЕ ЗаказКлиентаТовары.Количество - (ВЫРАЗИТЬ(ЗаказКлиентаТовары.Количество / УпаковкиНоменклатуры.Коэффициент КАК ЧИСЛО(10, 0))) * УпаковкиНоменклатуры.Коэффициент
	|	КОНЕЦ,
	|	ЗаказКлиентаТовары.Ссылка
	|ИЗ
	|	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.УпаковкиНоменклатуры КАК УпаковкиНоменклатуры
	|		ПО (УпаковкиНоменклатуры.Наименование = ""Упаковка WMS"")
	|			И ЗаказКлиентаТовары.Номенклатура = УпаковкиНоменклатуры.Владелец
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			ЗаказКлиента.Ссылка КАК Ссылка
	|		ИЗ
	|			Документ.ЗаказКлиента КАК ЗаказКлиента
	|		ГДЕ
	|			ЗаказКлиента.Ссылка В(&СписокЗаказов)
	|			И ЗаказКлиента.ЖелаемаяДатаОтгрузки = &ДатаОтгрузки) КАК ВложенныйЗапрос
	|		ПО ЗаказКлиентаТовары.Ссылка = ВложенныйЗапрос.Ссылка
	|ГДЕ
	|	ЗаказКлиентаТовары.Отменено = ЛОЖЬ
	|ИТОГИ
	|	МАКСИМУМ(ПоставщикСклад)
	|ПО
	|	Магазин,
	|	Заказ";
	
	Запрос.УстановитьПараметр("ДатаОтгрузки", ДатаОтгрузки);
	Запрос.УстановитьПараметр("СписокЗаказов", СписокЗаказов);
	
	Результат = Запрос.Выполнить();
	
	ВремяВыполнения  = ВремяВыполнения + Символы.ПС + "Время выполнения Запроса:" + " " + (ТекущаяДата() - К);
	К = ТекущаяДата();
	
	ВремяВыполнения  = ВремяВыполнения + Символы.ПС + "Начало формирования ТД:" + " " + ТекущаяДата();
	Область = Макет.ПолучитьОбласть("Шапка");
	ТабДокумент.Вывести(Область);
	
	ВыборкаПолучатель = Результат.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаПолучатель.Следующий() Цикл
		
		Область = Макет.ПолучитьОбласть("СтрокаМагазин");
		ЗаполнитьЗначенияСвойств(Область.Параметры, ВыборкаПолучатель);
		ТабДокумент.Вывести(Область);
		
		ВыборкаЗаказ = ВыборкаПолучатель.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		Пока ВыборкаЗаказ.Следующий() Цикл
			
			Область = Макет.ПолучитьОбласть("СтрокаДокумент");
			Область.Параметры.ТипДокумента   = ВыборкаЗаказ.Заказ;
			Область.Параметры.ПоставщикСклад = ВыборкаЗаказ.ПоставщикСклад;
			ТабДокумент.Вывести(Область);
			
			ВыборкаДетальныеЗаписи = ВыборкаЗаказ.Выбрать();
			
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				
				Если Не ВыборкаДетальныеЗаписи.КоличествоУпаковок = 0  Тогда
					
					Область = Макет.ПолучитьОбласть("СтрокаДанные");
					ЗаполнитьЗначенияСвойств(Область.Параметры, ВыборкаДетальныеЗаписи,, "Количество");
					Область.Области.СтрокаДанные.ЦветФона = WebЦвета.СветлоСерый;
					ТабДокумент.Вывести(Область);
					
				КонецЕсли;
				
				Если Не ВыборкаДетальныеЗаписи.Количество = 0  Тогда
					
					Область = Макет.ПолучитьОбласть("СтрокаДанные");
					ЗаполнитьЗначенияСвойств(Область.Параметры, ВыборкаДетальныеЗаписи,, "КоличествоУпаковок");
					ТабДокумент.Вывести(Область);
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
	КонецЦикла;
	
	Область = Макет.ПолучитьОбласть("Подвал");
	ЗаполнитьЗначенияСвойств(Область.Параметры, ВыборкаПолучатель);
	ТабДокумент.Вывести(Область);
	
	ВремяВыполнения  = ВремяВыполнения + Символы.ПС + "Завершение формирвоания ТД:" + " " + (ТекущаяДата() - К);
	
	Если Отладка Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ВремяВыполнения);
	КонецЕсли;
	
	Возврат ТабДокумент;
	
КонецФункции

&НаСервере
Функция ПолучитьМассивУзловДляДокумента(ДокументСсылка)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ОбменУправлениеТорговлей_11_0_РозничнаяТорговля_1_0.Ссылка
	|ИЗ
	|	ПланОбмена.ОбменУправлениеТорговлей_11_0_РозничнаяТорговля_1_0 КАК ОбменУправлениеТорговлей_11_0_РозничнаяТорговля_1_0
	|ГДЕ
	|	ОбменУправлениеТорговлей_11_0_РозничнаяТорговля_1_0.Склады.Склад = &Склад";
	
	Если ТипЗнч(ДокументСсылка) = тип("ДокументСсылка.ПеремещениеТоваров") Тогда
		Запрос.УстановитьПараметр("Склад", ДокументСсылка.СкладПолучатель);
	Иначе
		Возврат Неопределено;
	КонецЕсли; 
	
	РезультатЗапроса = Запрос.Выполнить().Выгрузить();
	
	Возврат РезультатЗапроса.ВыгрузитьКолонку("Ссылка");
КонецФункции 

&НаСервере
Функция ПолучитьСправочникКоробок(ТекДок);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ХранилищеДополнительнойИнформации.Ссылка
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации КАК ХранилищеДополнительнойИнформации
	|ГДЕ
	|	ХранилищеДополнительнойИнформации.ВидДанных = 5
	|	И ХранилищеДополнительнойИнформации.Объект = &Объект";
	
	Запрос.УстановитьПараметр("Объект", ТекДок);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Выборка.Следующий();
	
	Возврат Выборка.Ссылка;
	
КонецФункции 

&НаСервере
Функция НайтиСкладКонтрагента(Контрагент)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СкладыДополнительныеРеквизиты.Ссылка
	|ИЗ
	|	Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
	|ГДЕ
	|	СкладыДополнительныеРеквизиты.Свойство.Наименование = ""Контрагент склада""
	|	И СкладыДополнительныеРеквизиты.Значение = &Значение";
	
	Запрос.УстановитьПараметр("Значение", Контрагент);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	
	Возврат ВыборкаДетальныеЗаписи.Ссылка;
КонецФункции 

&НаСервере
Функция ПолучитьАдресМагазина(Склад)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СкладыКонтактнаяИнформация.Представление
	|ИЗ
	|	Справочник.Склады.КонтактнаяИнформация КАК СкладыКонтактнаяИнформация
	|ГДЕ
	|	СкладыКонтактнаяИнформация.Ссылка = &Ссылка
	|	И СкладыКонтактнаяИнформация.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес)";
	
	Запрос.УстановитьПараметр("Ссылка", Склад);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли; 
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.Представление;
	КонецЦикла;
	
КонецФункции

&НаСервере
Функция ПолучитьКодМагазинаСклада(СкладПолучатель)
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Ссылка",   СкладПолучатель);
	Запрос.УстановитьПараметр("Свойство", УправлениеСвойствамиПовтИсп.ПолучитьДополнительноеСвойствоПВХПоНаименованию("КодМагазинаСклада"));
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЕСТЬNULL(СкладыДополнительныеРеквизиты.Значение, """") КАК КодМагазинаСклада
	               |ИЗ
	               |	Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
	               |ГДЕ
	               |	СкладыДополнительныеРеквизиты.Ссылка = &Ссылка
	               |	И СкладыДополнительныеРеквизиты.Свойство = &Свойство";
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.КодМагазинаСклада;
	КонецЕсли;
	
	Возврат "";
	
КонецФункции

&НаСервере
Процедура СохранитьДанныеОПечати(МассивДокументов, ПФ, ЗНО = Неопределено, КоличествоЭкземпляров = 0)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Для Каждого Док Из МассивДокументов Цикл
		
		РС = РегистрыСведений.ИсторияПечатиДокументов.СоздатьМенеджерЗаписи();
		ЗаполнитьЗначенияСвойств(РС, Новый Структура("Документ, Дата, Пользователь, ПечатнаяФорма, ДопАналитика, КоличествоЭкземпляров"
		, Док
		, ТекущаяДата()
		, ПараметрыСеанса.ТекущийПользователь
		, ПФ
		, ЗНО
		, КоличествоЭкземпляров));
		Попытка
			РС.Записать();
		Исключение
			ЗаписьЖурналаРегистрации("История печати документов", УровеньЖурналаРегистрации.Ошибка,, Док, "Печать из АРМ:" + " " + ПараметрыСеанса.ТекущийПользователь); 
		КонецПопытки;
		
	КонецЦикла;
	
КонецПроцедуры

