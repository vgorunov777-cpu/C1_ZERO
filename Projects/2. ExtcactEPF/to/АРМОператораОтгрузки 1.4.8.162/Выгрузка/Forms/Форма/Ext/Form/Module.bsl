					Область = Макет.ПолучитьОбласть("СтрокаДанные");
					ЗаполнитьЗначенияСвойств(Область.Параметры, ВыборкаДетальныеЗаписи,, "Количество, КоличествоУпаковок");
					Область.Параметры.Количество = Количество;
					Область.Параметры.НПП = НПП;
					ТабДокумент.Вывести(Область);
					
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
		Если РежимПечати = 2 Тогда
			ТабДокумент.Вывести(ОбластьПодвал);
		КонецЕсли;
		
	КонецЦикла;
	
	Область = Макет.ПолучитьОбласть("Подвал");
	ЗаполнитьЗначенияСвойств(Область.Параметры, ВыборкаПолучатель);
	Если Не РежимПечати = 2 Тогда
		ТабДокумент.Вывести(Область);
	КонецЕсли;
	
	ВремяВыполнения  = ВремяВыполнения + Символы.ПС + "Завершение формирвоания ТД:" + " " + (ТекущаяДата() - К);
	
	Если Отладка Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ВремяВыполнения);
	КонецЕсли;
	
	Возврат ТабДокумент;
	
	
КонецФункции

