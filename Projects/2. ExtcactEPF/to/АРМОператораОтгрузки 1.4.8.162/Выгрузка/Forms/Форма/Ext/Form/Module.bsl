Функция СформироватьПечатнуюФормуТранспортнаяНакладнаяОбщая()
		
	УстановитьПривилегированныйРежим(Истина);
	 СтрокиМаршрутов = РеквизитФормыВЗначение("ЗНО");
	 Зно1="";
	 МассивДокументов = Новый Массив;
	 Для Каждого СтрокаМаршрута Из СтрокиМаршрутов.Строки Цикл
		Если НЕ СтрокаМаршрута.Пометка Тогда
			Продолжить;
		КонецЕсли;
	  
	  Если ПустаяСтрока(Зно1) тогда
		Зно1 = СтрокаМаршрута.Зно;
		Перевозчик1 = СтрокаМаршрута.Перевозчик;
	  КонецЕсли;

	
	Для Каждого СтрЗаказ Из СтрокаМаршрута.Строки Цикл
		Если (ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.ПеремещениеТоваров") 
			ИЛИ  ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.РеализацияТоваровУслуг"))
			И (ЗначениеЗаполнено(СтрЗаказ.Автомобиль)) И Не СтрЗаказ.Пометка = 0 Тогда
			МассивДокументов.Добавить(СтрЗаказ.Автомобиль);
		ИначеЕсли Не ЗначениеЗаполнено(СтрЗаказ.Автомобиль) И ТипЗнч(СтрЗаказ.ЗНО)=Тип("ДокументСсылка.ЗаказКлиента") И СтрЗаказ.ОбобщенныйДокумент И СтрЗаказ.Пометка = 1 Тогда
			МассивДокументов.Добавить(СтрЗаказ.ЗНО);
		КонецЕсли;	
	КонецЦикла;	
	
	
	МассивСкладов = Новый Массив;
	
	СоответствиеОбобщенных = Новый Соответствие;
	Для Каждого ТекДок из МассивДокументов Цикл
		Если ТипЗнч(ТекДок) = тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ИскомыйСклад = МассивСкладов.Найти(ТекДок.СкладПолучатель);
			Если ПустаяСтрока(ИскомыйСклад) Тогда
				МассивСкладов.Добавить(ТекДок.СкладПолучатель);
			КонецЕсли; 
		Иначе
			
			СкладКонтрагента = НайтиСкладКонтрагента(ТекДок.Контрагент);
			Если Не ЗначениеЗаполнено(СкладКонтрагента) Тогда
				
				КонтрагентСОбобщеннымиДокументами = СоответствиеОбобщенных.Получить(ТекДок.Контрагент); 
				Если КонтрагентСОбобщеннымиДокументами = Неопределено Тогда
					КонтрагентСОбобщеннымиДокументами = КонтрагентСОбобщеннымиДокументами(ТекДок.Контрагент) = Истина;
					СоответствиеОбобщенных.Вставить(ТекДок.Контрагент, КонтрагентСОбобщеннымиДокументами); 
				КонецЕсли;
				
				Если КонтрагентСОбобщеннымиДокументами Тогда
					
					Если МассивСкладов.Найти(ТекДок.Контрагент) = Неопределено ТОгда
						
						МассивСкладов.Добавить(ТекДок.Контрагент);
						
					КонецЕсли;
					
				КонецЕсли;
				
			Иначе
				
				ИскомыйСклад = МассивСкладов.Найти(СкладКонтрагента);
				Если ПустаяСтрока(ИскомыйСклад) Тогда
					МассивСкладов.Добавить(СкладКонтрагента);
				КонецЕсли; 
				
			КонецЕсли; 
			
		КонецЕсли;
		
	КонецЦикла;
	КонецЦикла;
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ПолеСверху = 0;
	ТабДокумент.ПолеСлева  = 0;
	ТабДокумент.ПолеСнизу  = 0;
	ТабДокумент.ПолеСправа = 0;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДокумент.КоличествоЭкземпляров = 1;
	ТабДокумент.АвтоМасштаб = Истина;
	
	Обработка = РеквизитФормыВЗначение("Объект");		
	Макет = Обработка.ПолучитьМакет("ТранспортнаяНакладная");
	Область1 = Макет.ПолучитьОбласть("лицеваясторона1");
	Область2 = Макет.ПолучитьОбласть("лицеваясторона2");
	Область3 = Макет.ПолучитьОбласть("лицеваясторона3");
	Область4 = Макет.ПолучитьОбласть("ГоризонтальнаяОборотнаяСторона");
	// теперь напечатаем ТТН-ку общую на все документы
	// получим список документов на которые печатаем ТТН
	
	// получим данные Для печати ТТН 
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ПеремещениеТоваров.Ссылка КАК Ссылка,
	|	ПеремещениеТоваров.Номер КАК Номер,
	|	ПеремещениеТоваров.Дата КАК Дата,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваров.ЗаказНаПеремещение = НЕОПРЕДЕЛЕНО
	|			ТОГДА """"
	|		ИНАЧЕ ПеремещениеТоваров.ЗаказНаПеремещение.Номер
	|	КОНЕЦ КАК НомерЗаказа,
	|	ВЫБОР
	|		КОГДА ПеремещениеТоваров.ЗаказНаПеремещение = НЕОПРЕДЕЛЕНО
	|			ТОГДА """"
	|		ИНАЧЕ ПеремещениеТоваров.ЗаказНаПеремещение.Дата
	|	КОНЕЦ КАК ДатаЗаказа,
	|	ПеремещениеТоваров.Организация КАК Организация,
	|	ПеремещениеТоваров.Организация КАК Грузополучатель,
	|	ПеремещениеТоваров.Организация КАК Грузоотправитель,
	|	ПеремещениеТоваров.Организация КАК Контрагент,
	|	ПеремещениеТоваров.Организация КАК ЗаказчикПеревозок,
	|	ПеремещениеТоваров.Организация.Префикс КАК Префикс,
	|	ПеремещениеТоваров.СкладОтправитель.ТекущийОтветственный КАК Кладовщик,
	|	ПеремещениеТоваров.СкладОтправитель.ТекущаяДолжностьОтветственного КАК ДолжностьКладовщика,
	|	ПеремещениеТоваров.Организация.ТекущийРукоВодитель КАК РукоВодитель,
	|	ПеремещениеТоваров.Организация.ТекущаяДолжностьРуководителя КАК ДолжностьРуководителя,
	|	ПеремещениеТоваров.Организация.ТекущийГлавныйБухгалтер КАК ГлавныйБухгалтер,
	|	ПеремещениеТоваров.Перевозчик КАК Перевозчик,
	|	ПеремещениеТоваров.Водитель КАК Водитель,
	|	СкладыКонтактнаяОтправитель.Представление КАК ПунктПогрузки,
	|	СкладыКонтактнаяПолучатель.Представление КАК ПунктРазгрузки,
	|	ПеремещениеТоваров.СрокДоставки КАК СрокДоставки,
	|	ВложенныйЗапрос.ВесНетто КАК ВесНетто,
	|	ПеремещениеТоваров.Автомобиль КАК Автомобиль
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.КонтактнаяИнформация КАК СкладыКонтактнаяПолучатель
	|		ПО ПеремещениеТоваров.СкладПолучатель = СкладыКонтактнаяПолучатель.Ссылка
	|			И (СкладыКонтактнаяПолучатель.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресСклада))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.КонтактнаяИнформация КАК СкладыКонтактнаяОтправитель
	|		ПО ПеремещениеТоваров.СкладОтправитель = СкладыКонтактнаяОтправитель.Ссылка
	|			И (СкладыКонтактнаяОтправитель.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресСклада))
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СУММА((ВЫРАЗИТЬ(ВЫБОР
	|						КОГДА НоменклатураДополнительныеРеквизиты.Значение ЕСТЬ NULL 
	|								ИЛИ НоменклатураДополнительныеРеквизиты.Значение = 0
	|							ТОГДА ПеремещениеТоваровТовары.Номенклатура.Вес
	|						ИНАЧЕ НоменклатураДополнительныеРеквизиты.Значение
	|					КОНЕЦ КАК ЧИСЛО(15, 3))) * ПеремещениеТоваровТовары.Количество) КАК ВесНетто,
	|			ПеремещениеТоваровТовары.Ссылка КАК Ссылка
	|		ИЗ
	|			Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
	|				ПО ПеремещениеТоваровТовары.Номенклатура = НоменклатураДополнительныеРеквизиты.Ссылка
	|					И (НоменклатураДополнительныеРеквизиты.Свойство.Наименование = ""Вес брутто"")
	|		ГДЕ
	|			ПеремещениеТоваровТовары.Ссылка В(&МассивДокументов)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ПеремещениеТоваровТовары.Ссылка) КАК ВложенныйЗапрос
	|		ПО ПеремещениеТоваров.Ссылка = ВложенныйЗапрос.Ссылка
	|ГДЕ
	|	ПеремещениеТоваров.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиента.Ссылка,
	|	ЗаказКлиента.Номер,
	|	ЗаказКлиента.Дата,
	|	ЗаказКлиента.Номер,
	|	ЗаказКлиента.Дата,
