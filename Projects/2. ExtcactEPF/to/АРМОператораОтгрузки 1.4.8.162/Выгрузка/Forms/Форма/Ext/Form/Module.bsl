&НаСервере
Функция ПолучитьИзДопХранилища(Номенклатура, ДатаВыпуска = Неопределено, НомерПартии = Неопределено)
	МассивАдресов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.Дата КАК ДатаРозлива,
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.ХранилищеВСтроке КАК АдресВоВременномХранилище,
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер1 КАК КодСправкиБ,
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер КАК КодСправкиА
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации.ДополнительныеСведения КАК ХранилищеДополнительнойИнформацииДополнительныеСведения
	|ГДЕ
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.Объект = &Объект
	|	И НАЧАЛОПЕРИОДА(ХранилищеДополнительнойИнформацииДополнительныеСведения.Дата, ДЕНЬ) = &Дата
	|	И НЕ ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.ПометкаУдаления
	|	И ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.ВидДанных = 0
	|	И ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер1 = &НомерПартии";
	
	Запрос.УстановитьПараметр("Объект", Номенклатура);
	
	Если ДатаВыпуска = Неопределено Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И НАЧАЛОПЕРИОДА(ХранилищеДополнительнойИнформацииДополнительныеСведения.Дата, ДЕНЬ) = &Дата", "");
	Иначе
		Запрос.УстановитьПараметр("Дата", НачалоДня(ДатаВыпуска));
	КонецЕсли; 
	Если НомерПартии = Неопределено ИЛИ НомерПартии = "#$888" Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер1 = &НомерПартии", "");
	Иначе
		Запрос.УстановитьПараметр("НомерПартии", НомерПартии);
	КонецЕсли; 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() И ЗначениеЗаполнено(ДатаВыпуска) Тогда
		
		Если НомерПартии = "#$888" Тогда
			ТекстСообщения = "Не найдено справки на: '" + Номенклатура + "', по дате розлива: " + Формат(ДатаВыпуска, "ДФ=dd.MM.yyyy");
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат ПолучитьИзДопХранилища(Номенклатура);	
		Иначе
			ТекстСообщения = "Не найдено справки на: '" + Номенклатура + "', по дате розлива: " + Формат(ДатаВыпуска, "ДФ=dd.MM.yyyy") + " и № партии: " + НомерПартии;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			Возврат ПолучитьИзДопХранилища(Номенклатура, ДатаВыпуска, "#$888");	
		КонецЕсли; 
		
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ПолучилСправкуА = Ложь;
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		Попытка
			Если НЕ ПолучилСправкуА И НЕ ПустаяСтрока(ВыборкаДетальныеЗаписи.КодСправкиА) Тогда
				МассивСправокА = ПолучитьСправкуА(Номенклатура, ДатаВыпуска, ВыборкаДетальныеЗаписи.КодСправкиА);
				Для Каждого ТекСтр Из МассивСправокА Цикл
					АдресВоВременномХранилище_СправкиА = ПоместитьВоВременноеХранилище(ТекСтр.Получить());
					МассивАдресов.Добавить(АдресВоВременномХранилище_СправкиА);
				КонецЦикла; 
				ПолучилСправкуА = Истина;
			КонецЕсли; 
			
			АдресВоВременномХранилище =  ПоместитьВоВременноеХранилище(ВыборкаДетальныеЗаписи.АдресВоВременномХранилище.Получить());
			МассивАдресов.Добавить(АдресВоВременномХранилище);
		Исключение
			ТекстСообщения = "Нет справок Для " + Номенклатура;
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
			
			ТекстСообщения = ТекстСообщения + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ЗаписьЖурналаРегистрации("Ошибка получения справки по алкоголю", УровеньЖурналаРегистрации.Ошибка,,,ТекстСообщения);
		КонецПопытки;		
		
	КонецЦикла;
	
	Возврат МассивАдресов;
КонецФункции

&НаСервере
Функция ПолучитьСправкуА(Номенклатура, ДатаВыпуска, КодСправкиА)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.ХранилищеВСтроке КАК АдресВоВременномХранилище
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации.ДополнительныеСведения КАК ХранилищеДополнительнойИнформацииДополнительныеСведения
	|ГДЕ
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.Объект = &Объект
	|	И НАЧАЛОПЕРИОДА(ХранилищеДополнительнойИнформацииДополнительныеСведения.Дата, ДЕНЬ) = &Дата
	|	И НЕ ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.ПометкаУдаления
	|	И ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.ВидДанных = 0
	|	И ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер = &НомерПартии
	|	И ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер1 = &ДопНомер1";
	
	Запрос.УстановитьПараметр("Объект", Номенклатура);
	Запрос.УстановитьПараметр("Дата", НачалоДня(ДатаВыпуска));
	Если ТипЗнч(КодСправкиА) = Тип("Строка") Тогда
		Запрос.УстановитьПараметр("НомерПартии", КодСправкиА);
	иначе
		Запрос.УстановитьПараметр("НомерПартии", КодСправкиА.Код);
	КонецЕсли; 
	Запрос.УстановитьПараметр("ДопНомер1",  "");
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	МассивСправок = Новый массив;
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивСправок.Добавить(ВыборкаДетальныеЗаписи.АдресВоВременномХранилище);
	КонецЦикла;
	
	Возврат МассивСправок;
КонецФункции 

&НаСервере
Функция ПолучитьКодСправкиА(Номенклатура, ДатаВыпуска, НомерПартии)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер КАК КодСправкиА
	|ИЗ
	|	Справочник.ХранилищеДополнительнойИнформации.ДополнительныеСведения КАК ХранилищеДополнительнойИнформацииДополнительныеСведения
	|ГДЕ
	|	ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.Объект = &Объект
	|	И НАЧАЛОПЕРИОДА(ХранилищеДополнительнойИнформацииДополнительныеСведения.Дата, ДЕНЬ) = &Дата
	|	И НЕ ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.ПометкаУдаления
	|	И ХранилищеДополнительнойИнформацииДополнительныеСведения.Ссылка.ВидДанных = 0
	|	И ХранилищеДополнительнойИнформацииДополнительныеСведения.ДопНомер1 = &НомерПартии";
	
	Запрос.УстановитьПараметр("Объект", Номенклатура);
	Запрос.УстановитьПараметр("Дата", НачалоДня(ДатаВыпуска));
	Запрос.УстановитьПараметр("НомерПартии", НомерПартии);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "";
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	
	Возврат ВыборкаДетальныеЗаписи.КодСправкиА;
КонецФункции 

//конец печать алко

//печать приложение МЛ
&НаСервере 
Функция СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту(СтрокаМаршрута)
	
	УстановитьПривилегированныйРежим(Истина);
	
	МассивОбъектов = Новый Массив;
	Для Каждого СтрЗаказ Из СтрокаМаршрута.Строки Цикл
		Если (ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.ПеремещениеТоваров") 
			ИЛИ  ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.РеализацияТоваровУслуг"))
			И (МассивОбъектов.Найти(СтрЗаказ.Автомобиль)=Неопределено) И Не СтрЗаказ.Пометка = 0 Тогда
			МассивОбъектов.Добавить(СтрЗаказ.Автомобиль);
		КонецЕсли;	
	КонецЦикла;	
	
	//ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Макет = Обработка.ПолучитьМакет("ПриложениеКМаршрутномуЛисту");
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_ПриложениеКМаршрутномуЛисту";
	
	// Зададим параметры Макета
	ТабДокумент.ПолеСверху = 0;
	ТабДокумент.ПолеСлева  = 0;
	ТабДокумент.ПолеСнизу  = 0;
	ТабДокумент.ПолеСправа = 2;
	ТабДокумент.АвтоМасштаб = Истина;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	//ТабДокумент.КоличествоЭкземпляров = МассивСкладов.Количество();
	//ТабДокумент.КоличествоЭкземпляров = 1;
	ШтрихкодНакладной = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаМаршрута.ЗНО, "Номер");	
	Если Ложь Тогда //МЛ печатается в Ах
		ТаблицаШтрихкодовДокументов = НайтиШтрихкодДокументов(МассивОбъектов);
		Если ТаблицаШтрихкодовДокументов = Неопределено Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Печать приложения не возможна! Сначала необходимо напечатать маршрутный лист!");
			Возврат ТабДокумент;
		КонецЕсли; 
		ШтрихкодНакладной = ТаблицаШтрихкодовДокументов[0]; 
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
		|	ПеремещениеТоваров.СкладОтправитель КАК СкладОтправитель,
		|	ПеремещениеТоваров.СкладПолучатель КАК СкладПолучатель,
		|	ПеремещениеТоваров.СкладПолучатель.РозничныйВидЦены КАК СкладПолучательРозничныйВидЦены,
		|	ПеремещениеТоваров.Организация КАК Организация,
		|	ПеремещениеТоваров.Водитель КАК Водитель,
		|	ПеремещениеТоваров.Автомобиль КАК Автомобиль,
		|	ПеремещениеТоваров.Ссылка КАК Ссылка,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту.ВТ_ПеремещенияШапки}}"" КАК Метка
		|ПОМЕСТИТЬ ВТ_ПеремещенияШапки
		|ИЗ
		|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
		|ГДЕ
		|	ПеремещениеТоваров.Ссылка В(&Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПеремещениеТоваровТовары.Ссылка,
		|	ПеремещениеТоваровТовары.Номенклатура,
		|	ПеремещениеТоваровТовары.Номенклатура.Код,
		|	ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения,
		|	ПеремещениеТоваровТовары.Количество,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту.ВТ_ПеремещенияВсеТовары}}"" КАК Метка
		|ПОМЕСТИТЬ ВТ_ПеремещенияВсеТовары
		|ИЗ
		|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|ГДЕ
		|	ПеремещениеТоваровТовары.Ссылка В(&Ссылка)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ПеремещенияВсеТовары.Ссылка,
		|	ВТ_ПеремещенияВсеТовары.Номенклатура,
		|	ВТ_ПеремещенияВсеТовары.НоменклатураКод,
		|	ВТ_ПеремещенияВсеТовары.НоменклатураЕдиницаИзмерения,
		|	ВТ_ПеремещенияВсеТовары.Количество,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту.ВТ_ПеремещенияТовары}}"" КАК Метка
		|ПОМЕСТИТЬ ВТ_ПеремещенияТовары
		|ИЗ
		|	ВТ_ПеремещенияВсеТовары КАК ВТ_ПеремещенияВсеТовары
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
		|		ПО (НоменклатураСегмента.Сегмент = &Сегмент)
		|			И ВТ_ПеремещенияВсеТовары.Номенклатура = НоменклатураСегмента.Номенклатура
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ПеремещенияШапки.Ссылка,
		|	ВТ_ПеремещенияШапки.СкладПолучатель,
		|	ВТ_ПеремещенияШапки.СкладПолучательРозничныйВидЦены,
		|	ВТ_ПеремещенияШапки.Организация,
		|	ВТ_ПеремещенияШапки.Водитель,
		|	ВТ_ПеремещенияШапки.Автомобиль,
		|	ВТ_ПеремещенияТовары.Номенклатура,
		|	ВТ_ПеремещенияТовары.Количество,
		|	ВТ_ПеремещенияТовары.НоменклатураКод,
		|	ВТ_ПеремещенияТовары.НоменклатураЕдиницаИзмерения,
		|	ЛОЖЬ КАК ХозТовары,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту.ВТ_Перемещения}}"" КАК Метка
		|ПОМЕСТИТЬ ВТ_Перемещения
		|ИЗ
		|	ВТ_ПеремещенияШапки КАК ВТ_ПеремещенияШапки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПеремещенияТовары КАК ВТ_ПеремещенияТовары
		|		ПО ВТ_ПеремещенияШапки.Ссылка = ВТ_ПеремещенияТовары.Ссылка
		|
		|ОБЪЕДИНИТЬ ВСЕ
		| 
		|ВЫБРАТЬ
		|	ВТ_ПеремещенияШапки.Ссылка,
		|	ВТ_ПеремещенияШапки.СкладПолучатель,
		|	ВТ_ПеремещенияШапки.СкладПолучательРозничныйВидЦены,
		|	ВТ_ПеремещенияШапки.Организация,
		|	ВТ_ПеремещенияШапки.Водитель,
		|	ВТ_ПеремещенияШапки.Автомобиль,
		|	ВТ_ПеремещенияВсеТовары.Номенклатура,
		|	ВТ_ПеремещенияВсеТовары.Количество,
		|	ВТ_ПеремещенияВсеТовары.НоменклатураКод,
		|	ВТ_ПеремещенияВсеТовары.НоменклатураЕдиницаИзмерения,
		|	ИСТИНА КАК ХозТовары,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту.ВТ_Перемещения}}"" КАК Метка
		|ИЗ
		|	ВТ_ПеремещенияВсеТовары КАК ВТ_ПеремещенияВсеТовары 
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПеремещенияШапки КАК ВТ_ПеремещенияШапки
		|		ПО ВТ_ПеремещенияШапки.Ссылка = ВТ_ПеремещенияВсеТовары.Ссылка
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
		|		ПО (НоменклатураСегмента.Сегмент = &Сегмент)
		|			И ВТ_ПеремещенияВсеТовары.Номенклатура = НоменклатураСегмента.Номенклатура
		|ГДЕ 
		|	ВТ_ПеремещенияШапки.СкладОтправитель = &СкладХозТовары
		|	И НоменклатураСегмента.Номенклатура ЕСТЬ NULL	
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Перемещения.СкладПолучатель КАК СкладПолучатель,
		|	ВТ_Перемещения.Номенклатура КАК Номенклатура,
		|	ВТ_Перемещения.Количество КАК Количество,
		|	ВТ_Перемещения.Организация КАК Организация,
		|	ВТ_Перемещения.Водитель КАК Водитель,
		|	ВТ_Перемещения.Автомобиль КАК Автомобиль,
		|	ВТ_Перемещения.Ссылка КАК Ссылка,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
		|	ЦеныНоменклатурыСрезПоследних.Цена * ВТ_Перемещения.Количество КАК Сумма,
		|	ВТ_Перемещения.НоменклатураКод,
		|	ВТ_Перемещения.НоменклатураЕдиницаИзмерения,
		|	ВТ_Перемещения.ХозТовары,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.СформироватьПечатнуюФормуПриложениеКМаршрутномуЛисту.Результат}}"" КАК Метка
		|ИЗ
		|	ВТ_Перемещения КАК ВТ_Перемещения
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних КАК ЦеныНоменклатурыСрезПоследних
		|		ПО ВТ_Перемещения.СкладПолучательРозничныйВидЦены = ЦеныНоменклатурыСрезПоследних.ВидЦены
		|			И ВТ_Перемещения.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
		|
		|УПОРЯДОЧИТЬ ПО
		|	СкладПолучатель,
		|	Номенклатура
		|ИТОГИ
		|	СУММА(Количество),
		|	МАКСИМУМ(Организация),
		|	МАКСИМУМ(Водитель),
		|	МАКСИМУМ(Автомобиль),
		|	МАКСИМУМ(Ссылка),
		|	СУММА(Цена),
		|	СУММА(Сумма)
		|ПО
		|	СкладПолучатель,
		|	ХозТовары,
		|	Номенклатура ИЕРАРХИЯ
		|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("Период", ТекущаяДата());
	Запрос.УстановитьПараметр("Ссылка", МассивОбъектов);
	Запрос.УстановитьПараметр("СкладХозТовары", Справочники.Склады.НайтиПоНаименованию("НСК Хоз. товары (WMS) - ТЛМ2"));
	Запрос.УстановитьПараметр("Сегмент", Справочники.СегментыНоменклатуры.НайтиПоКоду("01-00000727"));
	
	ГруппаТара = Справочники.Номенклатура.НайтиПоКоду("99-00000114");
	ГруппаХозТовары = Справочники.Номенклатура.НайтиПоКоду("01-00010827"); 
	
	РезультатЗапроса = Запрос.Выполнить();
	
	ВыборкаСкладПолучатель = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	
	Пока ВыборкаСкладПолучатель.Следующий() Цикл
		
		ВыборкаХозТовары = ВыборкаСкладПолучатель.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаХозТовары.Следующий() Цикл
			
			ОбластьМакета         = Макет.ПолучитьОбласть("Шапка");
			СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ВыборкаХозТовары.Организация, ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВыборкаХозТовары.Ссылка, "Дата"));
			ОбластьМакета.Параметры.Организация					= ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации);
			ОбластьМакета.Параметры.Приложение					= "Приложение к Маршрутному листу №" + Лев(ШтрихкодНакладной,11);
			ОбластьМакета.Параметры.Склад						= "В магазин " + ВыборкаХозТовары.СкладПолучатель;
			ОбластьМакета.Параметры.ШтрихкодМаршрутногоЛиста	= ШтрихкодНакладной;
			ОбластьМакета.Параметры.ФИОВодителя					= ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(СтрокаМаршрута.Водитель)
				+ ?(ЗначениеЗаполнено(СтрокаМаршрута.Водитель2), " / " + Символы.ПС + ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(СтрокаМаршрута.Водитель2), "");
			ОбластьМакета.Параметры.ГосНомерТС					= СтрокаМаршрута.Автомобиль.Код;
			//ЗаполнитьШтрихКодОбласть(ОбластьМакета, ШтрихкодНакладной);
			ОбластьМакета.Параметры.ХозТовары = ?(ВыборкаХозТовары.ХозТовары, "(хоз. товары)", "");
			ТабДокумент.Вывести(ОбластьМакета);
			
			ОбластьСтрока = Макет.ПолучитьОбласть("Строка");
			ОбластьГруппа = Макет.ПолучитьОбласть("Группа");
			ОбластьИтог = Макет.ПолучитьОбласть("Итог");
			
			ВыборкаНоменклатура = ВыборкаХозТовары.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			КоличествоВГруппе = 0;
			ВывестиИтог = Ложь;
			
			Если ВыборкаХозТовары.ХозТовары Тогда
				НПП = 1;
			КонецЕсли;
			
			Пока ВыборкаНоменклатура.Следующий() Цикл
				Если Не ВыборкаХозТовары.ХозТовары И ((ВыборкаНоменклатура.Уровень() = 3 и Не ОбщегоНазначения.ПолучитьЗначениеРеквизита(ВыборкаНоменклатура.Номенклатура, "Родитель") = ГруппаТара) Или ВыборкаНоменклатура.Номенклатура = ГруппаТара) Тогда
					Если ВывестиИтог тогда
						
						ОбластьИтог.Параметры.ИтогКоличество = КоличествоВГруппе;
						ТабДокумент.Вывести(ОбластьИтог);
						КоличествоВГруппе = 0;
						ВывестиИтог = Ложь;
					КонецЕсли;
					
					НПП = 1;
					ОбластьГруппа.Параметры.Группа = ВыборкаНоменклатура.Номенклатура;
					ТабДокумент.Вывести(ОбластьГруппа);
				ИначеЕсли НЕ ВыборкаНоменклатура.Номенклатура.ЭтоГруппа Тогда
					ОбластьСтрока.Параметры.НПП = НПП;
					ОбластьСтрока.Параметры.Заполнить(ВыборкаНоменклатура);
					ТабДокумент.Вывести(ОбластьСтрока);
					НПП = НПП + 1;
					
					КоличествовГруппе = КоличествоВГруппе+ВыборкаНоменклатура.Количество;
					ВывестиИтог = Истина;
				КонецЕсли; 
			КонецЦикла;
				
			ОбластьИтог.Параметры.ИтогКоличество = КоличествоВГруппе;
			ТабДокумент.Вывести(ОбластьИтог);
			
			ОбластьМакета = Макет.ПолучитьОбласть("Подвал");
			ТабДокумент.Вывести(ОбластьМакета);
			
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат ТабДокумент;
	
КонецФункции
//конец печать приложение МЛ

//печать ТТН
&НаСервере
Функция СформироватьПечатнуюФорму1_Т(СтрокаМаршрута)
	
	МассивДокументов = Новый Массив;
	МассивСкладов = Новый Массив;
	
	Для Каждого СтрЗаказ Из СтрокаМаршрута.Строки Цикл
		Если (ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.ПеремещениеТоваров") 
			ИЛИ  ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.РеализацияТоваровУслуг"))
			И (ЗначениеЗаполнено(СтрЗаказ.Автомобиль)) И Не СтрЗаказ.Пометка = 0 Тогда
			
			ТекПеремещение = СтрЗаказ.Автомобиль;
			
			Если НЕ ЭтоАлкоДокумент(ТекПеремещение) Тогда
				Продолжить;
			КонецЕсли; 
			
			МассивДокументов.Добавить(ТекПеремещение);
			СкладПолучатель = ПолучитьСкладПолучатель(ТекПеремещение);
			Если МассивСкладов.Найти(СкладПолучатель) = Неопределено Тогда
				МассивСкладов.Добавить(СкладПолучатель);
			КонецЕсли;
			
		ИначеЕсли Не ЗначениеЗаполнено(СтрЗаказ.Автомобиль) И ТипЗнч(СтрЗаказ.ЗНО)=Тип("ДокументСсылка.ЗаказКлиента") И СтрЗаказ.ОбобщенныйДокумент = Истина И СтрЗаказ.Пометка = 1 Тогда
			МассивДокументов.Добавить(СтрЗаказ.ЗНО);
			СкладПолучатель = ПолучитьСкладПолучатель(СтрЗаказ.ЗНО);
			Если МассивСкладов.Найти(СкладПолучатель) = Неопределено Тогда
				МассивСкладов.Добавить(СкладПолучатель);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла; 
	
	ТабДок = Новый ТабличныйДокумент;
	ТабДок.АвтоМасштаб = Истина;
	ТабДок.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	
	Для Каждого ТекСклад Из МассивСкладов Цикл
		ВремМассивДокументов = Новый Массив;
		
		Для Каждого ТекДок Из МассивДокументов Цикл
			СкладПолучатель = ПолучитьСкладПолучатель(ТекДок);
			Если НЕ СкладПолучатель = ТекСклад Тогда
				Продолжить;
			КонецЕсли; 
			ВремМассивДокументов.Добавить(ТекДок);
		КонецЦикла; 
		
		
		ВремТабДок = ПолучитьПечатнуюФорму1_Т(ВремМассивДокументов);
		ТабДок.Вывести(ВремТабДок);
		
	КонецЦикла; 
	
	СохранитьДанныеОПечати(МассивДокументов, "ТТН", СтрокаМаршрута.ЗНО, ТабДок.КоличествоЭкземпляров);
	
	Возврат ТабДок;
	
КонецФункции

&НаСервере
Функция ПолучитьПечатнуюФорму1_Т(МассивОбъектов) Экспорт
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	ТабличныйДокумент.ПолеСверху = 0;
	ТабличныйДокумент.ПолеСлева = 5;
	ТабличныйДокумент.ПолеСнизу = 0;
	ТабличныйДокумент.ПолеСправа = 5;
	ТабличныйДокумент.РазмерКолонтитулаСверху = 0;
	ТабличныйДокумент.РазмерКолонтитулаСнизу = 0;
	ТабличныйДокумент.АвтоМасштаб = Истина;
	ТабличныйДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	// ЛВО 4.04.2022+
	//ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();	
	//-

	
	ТабличныйДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ТТН";
	Обработка = РеквизитФормыВЗначение("Объект");		
	Макет = Обработка.ПолучитьМакет("ПФ_MXL_ТТН");
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	ПеремещениеТоваров.Ссылка КАК Ссылка,
	|	ПеремещениеТоваров.Номер КАК Номер,
	|	ПеремещениеТоваров.Дата КАК ДатаДокумента,
	|	ПеремещениеТоваров.Проведен КАК Проведен,
	|	ПеремещениеТоваров.Организация КАК Организация,
	|	ПеремещениеТоваров.Организация.Префикс КАК Префикс,
	|	ПеремещениеТоваров.Организация.ТекущийГлавныйБухгалтер КАК ГлавныйБухгалтер,
	|	ПеремещениеТоваров.Организация.ТекущийРуководитель КАК РукоВодитель,
	|	ПеремещениеТоваров.Организация.ТекущаяДолжностьРуководителя КАК ДолжностьРуководителя,
	|	ПеремещениеТоваров.БанковскийСчетОрганизации,
	|	ПеремещениеТоваров.БанковскийСчетПеревозчика,
	|	ПеремещениеТоваров.СкладОтправитель КАК Склад,
	|	ПеремещениеТоваров.СкладПолучатель,
	|	ЛОЖЬ КАК ОбобщенныйДокумент,
	|	NULL КАК КонтрагентИНН,
	|	NULL КАК КонтрагентКПП,
	|	NULL КАК Контрагент
	|ПОМЕСТИТЬ ВТ
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
	|ГДЕ
	|	ПеремещениеТоваров.Ссылка В(&МассивОбъектов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка,
	|	РеализацияТоваровУслуг.Номер,
	|	РеализацияТоваровУслуг.Дата,
	|	РеализацияТоваровУслуг.Проведен,
	|	РеализацияТоваровУслуг.Организация,
	|	РеализацияТоваровУслуг.Организация.Префикс,
	|	РеализацияТоваровУслуг.Организация.ТекущийГлавныйБухгалтер,
	|	РеализацияТоваровУслуг.Организация.ТекущийРуководитель,
	|	РеализацияТоваровУслуг.Организация.ТекущаяДолжностьРуководителя,
	|	РеализацияТоваровУслуг.БанковскийСчетОрганизации,
	|	РеализацияТоваровУслуг.БанковскийСчетПеревозчика,
	|	РеализацияТоваровУслуг.Склад,
	|	СкладыДополнительныеРеквизиты.Ссылка,
	|	ЛОЖЬ,
	|	NULL,
	|	NULL,
	|	NULL
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
	|		ПО РеализацияТоваровУслуг.Контрагент = СкладыДополнительныеРеквизиты.Значение
	|			И (СкладыДополнительныеРеквизиты.Свойство.Наименование = ""Контрагент склада"")
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка В(&МассивОбъектов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	ЗаказКлиента.Ссылка,
	|	ЗаказКлиента.Номер,
	|	ЗаказКлиента.Дата,
	|	ЗаказКлиента.Проведен,
	|	ЗаказКлиента.Организация,
	|	ЗаказКлиента.Организация.Префикс,
	|	ЗаказКлиента.Организация.ТекущийГлавныйБухгалтер,
	|	ЗаказКлиента.Организация.ТекущийРуководитель,
	|	ЗаказКлиента.Организация.ТекущаяДолжностьРуководителя,
	|	ЗаказКлиента.БанковскийСчет,
	|	НЕОПРЕДЕЛЕНО,
	|	ЗаказКлиента.Склад,
	|	ЕСТЬNULL(СкладыДополнительныеРеквизиты.Ссылка, ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)),
