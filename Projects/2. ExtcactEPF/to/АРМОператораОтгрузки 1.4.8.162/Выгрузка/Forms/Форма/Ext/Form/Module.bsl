&НаСервере
Процедура ЗаполнитьСписокПечатныхФорм(ТекущаяСтраница = "")
	
	МассивПФКомплектация = ПолучитьМассивПФКомплектация();
	
	ТЗПФ = НастройкаПечати.Выгрузить();//РеквизитФормыВЗначение("НастройкаПечати");
	
	СписокПечатныхФорм.Очистить();
	
	СпВыб = Элементы.НастройкаПечатиДокументПечатиИД.СписокВыбора;
	СпВыб.Очистить();
	
	ПерезаполнятьТЗ = Истина;//(ТЗПФ.Количество()=0) Или Не ТекущаяСтраница = "";
	
	МДМакеты = РеквизитФормыВЗначение("Объект").Метаданные().Макеты;
	
	Для Каждого М Из МДМакеты Цикл
		
		Если ТекущаяСтраница = "ГруппаКомплектация" И МассивПФКомплектация.Найти(М.Имя) = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если М.Имя = "ПФ_MXL_СправкаНаЭтиловыйСпиртИмпорт" Тогда
			Продолжить;
		КонецЕсли;
		
		Если М.Имя = "ПФ_MXL_СчетФактура981" Тогда
			Продолжить;
		КонецЕсли;
		
		Если М.Имя = "ЛистКомплектации" Тогда
			//Продолжить;
		КонецЕсли;
		
		Если М.Имя = "РеестрМаршрутныхЛистов" Тогда
			Продолжить;
		КонецЕсли;
		
		Если М.ТипМакета = Метаданные.СвойстваОбъектов.ТипМакета.СхемаКомпоновкиДанных Тогда
			Продолжить;
		КонецЕсли;
		
		СпВыб.Добавить(М.Имя,М.Синоним);
		СписокПечатныхФорм.Добавить(М.Имя,М.Синоним);
		
		Если М.Имя = "ТранспортнаяНакладная" Тогда
			
			Имя = "ТранспортнаяНакладнаяСПустымЭкспедитором";
			Синоним = "Транспортная накладная (с пустым экспедитором)";
			
			СпВыб.Добавить(Имя, Синоним);
			СписокПечатныхФорм.Добавить(Имя, Синоним);
			
			Имя = "ТранспортнаяНакладнаяСПустымПеревозчиком";
			Синоним = "Транспортная накладная (с пустым перевозчиком)";
			
			СпВыб.Добавить(Имя, Синоним);
			СписокПечатныхФорм.Добавить(Имя, Синоним);
			
		КонецЕсли;
		
		Если ПерезаполнятьТЗ Тогда
			
			Стр = ТЗПФ.Добавить();
			Стр.ДокументПечатиИД = М.Имя;
			Стр.ДокументПечати = М.Синоним;
			
			Если М.Синоним = "Приложение для ветврача" Тогда
				Стр = ТЗПФ.Добавить();
				Стр.ДокументПечатиИД = М.Имя;
				Стр.ДокументПечати = М.Синоним + "(только корма)";
			КонецЕсли;
			
			Если М.Имя = "ТранспортнаяНакладная" Тогда
				
				Имя = "ТранспортнаяНакладнаяСПустымЭкспедитором";
				Синоним = "Транспортная накладная (с пустым экспедитором)";
				
				Стр = ТЗПФ.Добавить();
				Стр.ДокументПечатиИД = Имя;
				Стр.ДокументПечати   = Синоним;
				
				Имя = "ТранспортнаяНакладнаяСПустымПеревозчиком";
				Синоним = "Транспортная накладная (с пустым перевозчиком)";
				
				Стр = ТЗПФ.Добавить();
				Стр.ДокументПечатиИД = Имя;
				Стр.ДокументПечати   = Синоним;
				
			КонецЕсли;
			
		КонецЕсли;
		
		
		
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(ТЗПФ,"НастройкаПечати");
	
КонецПроцедуры	

&НаСервере
Процедура УстановитьДоступностьСпискаПечатныхФорм()
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СоставГруппПользователей.ГруппаПользователей,
	|	СоставГруппПользователей.Пользователь
	|ИЗ
	|	РегистрСведений.СоставГруппПользователей КАК СоставГруппПользователей
	|ГДЕ
	|	СоставГруппПользователей.Пользователь = &Пользователь
	|	И СоставГруппПользователей.ГруппаПользователей = &ГруппаПользователей";
	
	Запрос.УстановитьПараметр("ГруппаПользователей", Справочники.ГруппыПользователей.НайтиПоНаименованию("Администраторы"));
	Запрос.УстановитьПараметр("Пользователь", ПараметрыСеанса.ТекущийПользователь);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		//	Элементы.НастройкаПечати.ТолькоПросмотр = Истина;
		//	Элементы.НастройкаПечатиКомандаСохранитьСписокПечатныхФорм.Доступность = Ложь;
		//Иначе	
		//	Элементы.НастройкаПечати.ТолькоПросмотр = Ложь;
		//	Элементы.НастройкаПечатиКомандаСохранитьСписокПечатныхФорм.Доступность = Истина;
	КонецЕсли; 
	
КонецПроцедуры	

&НаСервере
Процедура ПодготовитьСписокПечатныхФорм()
	
	ТЗПФ = НастройкаПечати.Выгрузить();//РеквизитФормыВЗначение("НастройкаПечати");
	ТЗПФ.Сортировать("Порядок");
	
	СписокПечатныхФорм.Очистить();
	
	Для Каждого СтрПФ Из ТЗПФ Цикл
		Если СтрПФ.Количество<>0 Тогда
			СписокПечатныхФорм.Добавить(СтрПФ.ДокументПечатиИД,СтрПФ.ДокументПечати, Истина);
		КонецЕсли;
	КонецЦикла;	
	
КонецПроцедуры	

///////////////////////////////////////////////////////////////////////////////
// ФУНКЦИИ ЗАПОЛНЕНИЯ ТАБЛИЧНЫХ ДОКУМЕНТОВ ПЕЧАТНЫХ ФОРМ

//печать МЛ
&НаСервере 
Функция СформироватьПечатнуюФормуМаршрутногоЛиста(СтрокаМаршрута)
	
	УстановитьПривилегированныйРежим(Истина);
	//Попытка
	//	ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
	//Исключение
	//КонецПопытки;
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Макет = Обработка.ПолучитьМакет("МаршрутныйЛист");
	
	МассивОбъектов = Новый Массив;
	Для Каждого СтрЗаказ Из СтрокаМаршрута.Строки Цикл
		
		Если ТипЗнч(СтрЗаказ.ЗНО) = Тип("ДокументСсылка.ЗаказКлиента") Или ТипЗнч(СтрЗаказ.ЗНО) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
			ЭтоАлкашка = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрЗаказ.ЗНО, "УчетВЕГАИС");
		Иначе
			ЭтоАлкашка = Ложь;
		КонецЕсли;
		
		Если (ТипЗнч(СтрЗаказ.Автомобиль) = Тип("ДокументСсылка.ПеремещениеТоваров") ИЛИ  ТипЗнч(СтрЗаказ.Автомобиль) = Тип("ДокументСсылка.РеализацияТоваровУслуг"))
			И (МассивОбъектов.Найти(СтрЗаказ.Автомобиль) = Неопределено) и Не СтрЗаказ.Пометка = 0 Тогда
			//Если СтрЗаказ.СкладWMS = ЛОЖЬ И Не ЭтоАлкашка Тогда
			//	Продолжить;
			//КонецЕсли; 
			МассивОбъектов.Добавить(СтрЗаказ.Автомобиль);
		КонецЕсли;
		
		Если ТипЗнч(СтрЗаказ.ЗНО) = Тип("ДокументСсылка.ЗаказПоставщику") И ЗначениеЗаполнено(СтрЗаказ.Водитель) И ТипЗнч(СтрЗаказ.Водитель) = Тип("СправочникСсылка.Склады") 
			И ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрЗаказ.Водитель, "ТипСклада") = Перечисления.ТипыСкладов.ОптовыйСклад Тогда
			МассивОбъектов.Добавить(СтрЗаказ.ЗНО);
		КонецЕсли;
			
	КонецЦикла;	
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_МаршрутныйЛист";
	
	// Зададим параметры Макета
	ТабДокумент.ПолеСверху = 5;
	ТабДокумент.ПолеСлева  = 5;
	ТабДокумент.ПолеСнизу  = 5;
	ТабДокумент.ПолеСправа = 5;
	ТабДокумент.АвтоМасштаб = Истина;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Ландшафт;
	
	МассивСкладов = Новый Массив;
	Для Каждого ТекДок из МассивОбъектов Цикл
		
		//Зарегистрировать документы Для обмена !!!!Более нет необходимости регистрировать!!!
		//МассивУзлов = ПолучитьМассивУзловДляДокумента(ТекДок);
		//Если МассивУзлов <> Неопределено Тогда
		//	ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, ТекДок);
		//КонецЕсли;
		
		//Зарегистрировать коробки этого документа
		//ТекСпр = ПолучитьСправочникКоробок(ТекДок);
		//Если ТекСпр <> Неопределено Тогда
		//	ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, ТекСпр);
		//КонецЕсли; 
		
		Если ТипЗнч(ТекДок) = тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ИскомыйСклад = МассивСкладов.Найти(ТекДок.СкладПолучатель);
			Если ИскомыйСклад = Неопределено Тогда
				МассивСкладов.Добавить(ТекДок.СкладПолучатель);
			КонецЕсли; 
		ИначеЕсли ТипЗнч(ТекДок) = тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			СкладКонтрагента = НайтиСкладКонтрагента(ТекДок.Контрагент);
			ИскомыйСклад = МассивСкладов.Найти(СкладКонтрагента);
			Если  ИскомыйСклад = Неопределено Тогда
				Если СкладКонтрагента <> Неопределено тогда
					МассивСкладов.Добавить(СкладКонтрагента);
				Иначе
					МассивСкладов.Добавить(ТекДок.Контрагент);
				КонецЕсли;
			КонецЕсли;
		ИначеЕсли ТипЗнч(ТекДок) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			КонтрагентЗаказа = ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТекДок, "Контрагент");
			Если МассивСкладов.Найти(КонтрагентЗаказа) = Неопределено Тогда
				МассивСкладов.Добавить(КонтрагентЗаказа);
			КонецЕсли;
		КонецЕсли; 
		
		//Если уже записан так же Автомобиль и Водитель, не записывать
		Организация = ТекДок.Организация;
		ДатаДокумента = ТекДок.Дата;
		
		//Если ТекДок.Водитель = СтруктураПараметров.Водитель И ТекДок.Автомобиль = СтруктураПараметров.Автомобиль Тогда
		//	Продолжить;
		//КонецЕсли; 
		//ДокументОбъект = ТекДок.ПолучитьОбъект();
		//ДокументОбъект.Автомобиль = СтруктураПараметров.Автомобиль;
		//ДокументОбъект.Водитель = СтруктураПараметров.Водитель;
		//ДокументОбъект.Записать(РежимЗаписиДокумента.Запись);
	КонецЦикла;
	
	ШтрихкодНакладной = СоздатьШтрихкодНакладнойПоНомеруЗНО(МассивОбъектов, ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаМаршрута.ЗНО, "Номер"));
	//ШтрихкодНакладной = СоздатьШтрихкодНакладной(МассивОбъектов);
	//Если ШтрихкодНакладной = Неопределено Тогда
	//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Печать прервана! Маршрутный лист уже был напечатан!");
	//	Возврат ТабДокумент;
	//КонецЕсли; 
	
	ОбластьМакета         = Макет.ПолучитьОбласть("Шапка");
	СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Организация, ДатаДокумента);
	
	//************    Согласно логики консультанта-аналитика Котлячковой брать склад-отправитель - первый из ЗНО
	Если Истина Тогда
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(ЗаказНаОтгрузкуЗаказы.Склад) КАК Склад
		|ИЗ
		|	Документ.ЗаказНаОтгрузку.Заказы КАК ЗаказНаОтгрузкуЗаказы
		|ГДЕ
		|	ЗаказНаОтгрузкуЗаказы.Ссылка = &ЗНО";
		
		Запрос.УстановитьПараметр("ЗНО", СтрокаМаршрута.ЗНО);
		Рез = Запрос.Выполнить().Выбрать();
		Рез.Следующий();
		Если ЗначениеЗаполнено(Рез.Склад) Тогда
			СкладОтправитель = Рез.Склад;
		КонецЕсли;
	Иначе
		
		КодУзла = ВнешнийМодульРаботаСWebПолучениеДанных.ПолучитьКодТекущегоУзла();
		Если КодУзла = "000" Тогда
			СкладОтправитель = Справочники.Склады.НайтиПоНаименованию("Основной РЦ (WMS)");
		Иначе
			СкладОтправитель = Справочники.Склады.НайтиПоНаименованию("Обх Основной (WMS)");
		КонецЕсли; 
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаОтгрузкуЗаказы.НомерСтроки
		|ИЗ
		|	Документ.ЗаказНаОтгрузку.Заказы КАК ЗаказНаОтгрузкуЗаказы
		|ГДЕ
		|	ЗаказНаОтгрузкуЗаказы.Ссылка = &ЗНО
		|	И ЗаказНаОтгрузкуЗаказы.Склад.Наименование = &СкладНаименованиеТЛМ";
		
		Запрос.УстановитьПараметр("ЗНО", СтрокаМаршрута.ЗНО);
		Запрос.УстановитьПараметр("СкладНаименованиеТЛМ", "ТЛМ Основной РЦ (WMS)");
		
		Результат = Запрос.Выполнить();
		Если Не Результат.Пустой() Тогда
			СкладОтправитель = Справочники.Склады.НайтиПоНаименованию("ТЛМ Основной РЦ (WMS)");
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаОтгрузкуЗаказы.НомерСтроки
		|ИЗ
		|	Документ.ЗаказНаОтгрузку.Заказы КАК ЗаказНаОтгрузкуЗаказы
		|ГДЕ
		|	ЗаказНаОтгрузкуЗаказы.Ссылка = &ЗНО
		|	И ЗаказНаОтгрузкуЗаказы.Склад.Наименование = &СкладНаименованиеЗорька";
		
		Запрос.УстановитьПараметр("ЗНО", СтрокаМаршрута.ЗНО);
		Запрос.УстановитьПараметр("СкладНаименованиеЗорька", "ТСК Основной РЦ (WMS)");
		
		Результат = Запрос.Выполнить();
		Если Не Результат.Пустой() Тогда
			СкладОтправитель = Справочники.Склады.НайтиПоНаименованию("ТСК Основной РЦ (WMS)");
		КонецЕсли;
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказНаОтгрузкуЗаказы.НомерСтроки
		|ИЗ
		|	Документ.ЗаказНаОтгрузку.Заказы КАК ЗаказНаОтгрузкуЗаказы
		|ГДЕ
		|	ЗаказНаОтгрузкуЗаказы.Ссылка = &ЗНО
		|	И ЗаказНаОтгрузкуЗаказы.Склад.Наименование = &СкладНаименованиеЗорька";
		
		Запрос.УстановитьПараметр("ЗНО", СтрокаМаршрута.ЗНО);
		Запрос.УстановитьПараметр("СкладНаименованиеЗорька", "НКЗ Заморозка (WMS)");
		
		Результат = Запрос.Выполнить();
		Если Не Результат.Пустой() Тогда
			СкладОтправитель = Справочники.Склады.НайтиПоНаименованию("НКЗ Заморозка (WMS)");
		КонецЕсли;
		
	КонецЕсли;
	
	АдресГрузоОтправителя =УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(СкладОтправитель, Справочники.ВидыКонтактнойИнформации.АдресСклада);
	//АдресГрузоОтправителя = ПолучитьАдресМагазина(СкладОтправитель);
	
	ОбластьМакета.Параметры.Организация					= ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации);
	ОбластьМакета.Параметры.ШтрихкодМаршрутногоЛиста	= Лев(ШтрихкодНакладной, 11);
	ОбластьМакета.Параметры.ШтрихкодДокумента			= ШтрихкодНакладной;
	ОбластьМакета.Параметры.ДатаПечати					= СтрокаМаршрута.ЗНО.ВремяВыезда;//, "ДЛФ=D");
	ОбластьМакета.Параметры.ФИОВодителя					= ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(СтрокаМаршрута.Водитель)  
	+ ?(ЗначениеЗаполнено(СтрокаМаршрута.Водитель2), " / " + Символы.ПС + ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(СтрокаМаршрута.Водитель2), "");
	ОбластьМакета.Параметры.ТелефонВодителя				= УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(СтрокаМаршрута.Водитель, Справочники.ВидыКонтактнойИнформации.МобильныйТелефонФизическогоЛица);
	
	ОбластьМакета.Параметры.ГосНомерТС					= СтрокаМаршрута.Автомобиль.Код;
	ОбластьМакета.Параметры.Грузоотправильетль			= АдресГрузоОтправителя;
	//ЗаполнитьШтрихКодОбласть(ОбластьМакета, ШтрихкодНакладной);
	ТабДокумент.Вывести(ОбластьМакета);
	
	ОбластьМакета = Макет.ПолучитьОбласть("Строка");
	НПП = 1;
	Для Каждого ТекСтр Из МассивСкладов Цикл
		// ЛВО 19.09.2019 +
		Если ТипЗнч(ТекСтр) = Тип("СправочникСсылка.Контрагенты") тогда
			ВидКИ = Справочники.ВидыКонтактнойИнформации.ФактАдресКонтрагента;
		Иначе
			ВидКИ = Справочники.ВидыКонтактнойИнформации.ТелефонСклада;
		КонецЕсли;
		//-
		
		ОбластьМакета.Параметры.Склад = "" + ТекСтр + 
		//";" + УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(ТекСтр, Справочники.ВидыКонтактнойИнформации.АдресСклада) + 
		";" + УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(ТекСтр,ВидКИ); // Справочники.ВидыКонтактнойИнформации.ТелефонСклада);  ЛВО
		ОбластьМакета.Параметры.НПП = НПП;
		НПП = НПП + 1;
		СтруктураОтвет = ПолучитьИнформациюОМагазине(ТекСтр);
		ОбластьМакета.Параметры.РежимРаботыГрузчиков = СтруктураОтвет.РежимРаботыГрузчиков;
		ОбластьМакета.Параметры.ТипРазгрузки = СтруктураОтвет.ТипРазгрузки;
		ТабДокумент.Вывести(ОбластьМакета);
	КонецЦикла; 
	
	ОбластьМакета = Макет.ПолучитьОбласть("Подвал");
	ТабДокумент.Вывести(ОбластьМакета);
	
	ТабДокумент.КоличествоЭкземпляров = МассивСкладов.Количество() + 1;
	
	//Если Константы.ЗаголовокСистемы.Получить()="ООО «Камелот – А» [Новосибирск РЦ]" Тогда
	//	ТабДокумент.КоличествоЭкземпляров = МассивСкладов.Количество();
	//Иначе 	
	//   ТабДокумент.КоличествоЭкземпляров = МассивСкладов.Количество() + 1;
	//КонецЕсли;
   
	//Зарегистрировать документы Для отправки на кассу
	//Для Каждого ТекДок Из МассивОбъектов Цикл
	//	МассивУзлов = ПолучитьМассивУзловДляДокумента(ТекДок);
	//	Если МассивУзлов <> Неопределено Тогда
	//		ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, ТекДок);
	//	КонецЕсли;
	//	
	//	//Зарегистрировать коробки этого документа
	//	ТекСпр = ПолучитьСправочникКоробок(ТекДок);
	//	Если ТекСпр <> Неопределено Тогда
	//		ПланыОбмена.ЗарегистрироватьИзменения(МассивУзлов, ТекСпр);
	//	КонецЕсли; 
	//КонецЦикла; 
	
	СтрокаМаршрута.Напечатано = Истина;
	СтрокаМаршрута.НомерМЛ = ШтрихкодНакладной;
	СтрокаМаршрута.Ответственный = ПараметрыСеанса.ТекущийПользователь;
	
	//СтруктураПараметров = Новый Структура("Водитель, Автомобиль, Статус, УдаленныйШтрихкод",СтрокаМаршрута.Водитель, СтрокаМаршрута.Автомобиль, 1, ШтрихкодНакладной);
	//СохранитьДанныеОПечати(СтруктураПараметров);
	
	СохранитьДанныеОПечати(МассивОбъектов, "Маршрутный лист", СтрокаМаршрута.ЗНО, ТабДокумент.КоличествоЭкземпляров);	
		
	Возврат ТабДокумент;
	
КонецФункции

Функция СформироватьПечатнуюФормуОбъединенныйМаршрутныйЛист(СтрокаМаршрута)
	
	УстановитьПривилегированныйРежим(Истина);
	//Попытка
	//	ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
	//Исключение
	//КонецПопытки;
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Макет = Обработка.ПолучитьМакет("ОбъединенныйМаршрутныйЛист");
	
	МассивОбъектов = Новый Массив;
	Для Каждого СтрЗаказ Из СтрокаМаршрута.Строки Цикл
		
		Если Не СтрЗаказ.Пометка Тогда 
			Продолжить; 
		КонецЕсли;
		
		Если ТипЗнч(СтрЗаказ.ЗНО) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
			МассивОбъектов.Добавить(СтрЗаказ.ЗНО);
		Иначе
			
			ЭтоАлкашка = ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрЗаказ.ЗНО, "УчетВЕГАИС");
			Если (ТипЗнч(СтрЗаказ.Автомобиль) = Тип("ДокументСсылка.ПеремещениеТоваров") ИЛИ  ТипЗнч(СтрЗаказ.Автомобиль) = Тип("ДокументСсылка.РеализацияТоваровУслуг"))
				И (МассивОбъектов.Найти(СтрЗаказ.Автомобиль) = Неопределено) и Не СтрЗаказ.Пометка = 0 Тогда
				//Если СтрЗаказ.СкладWMS = ЛОЖЬ И Не ЭтоАлкашка Тогда
				//	Продолжить;
				//КонецЕсли; 
				МассивОбъектов.Добавить(СтрЗаказ.Автомобиль);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;	
	
	ТабДокумент = Новый ТабличныйДокумент;
	//ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_МаршрутныйЛист";
	
	// Зададим параметры Макета
	ТабДокумент.ПолеСверху = 5;
	ТабДокумент.ПолеСлева  = 5;
	ТабДокумент.ПолеСнизу  = 5;
	ТабДокумент.ПолеСправа = 5;
	ТабДокумент.АвтоМасштаб = Истина;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДокумент.КоличествоЭкземпляров = 1;
	
	МассивСкладов = Новый Массив;
	Для Каждого ТекДок из МассивОбъектов Цикл
		
		ЭтоЗаказПоставщику = ТипЗнч(ТекДок) = тип("ДокументСсылка.ЗаказПоставщику");
		
		Если ТипЗнч(ТекДок) = тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ИскомыйСклад = МассивСкладов.Найти(ТекДок.СкладПолучатель);
			Если ИскомыйСклад = Неопределено Тогда
				МассивСкладов.Добавить(ТекДок.СкладПолучатель);
			КонецЕсли; 
		ИначеЕсли ТипЗнч(ТекДок) = тип("ДокументСсылка.РеализацияТоваровУслуг") Тогда
			СкладКонтрагента = НайтиСкладКонтрагента(ТекДок.Контрагент);
			ИскомыйСклад = МассивСкладов.Найти(СкладКонтрагента);
			Если  ИскомыйСклад = Неопределено Тогда
				МассивСкладов.Добавить(СкладКонтрагента);
			КонецЕсли; 
		ИначеЕсли ЭтоЗаказПоставщику Тогда
			МассивСкладов.Добавить(ОбщегоНазначения.ПолучитьЗначениеРеквизита(ТекДок, "Склад"));
		КонецЕсли; 
		
		//Если уже записан так же Автомобиль и Водитель, не записывать
		Организация = ТекДок.Организация;
		ДатаДокумента = ТекДок.Дата;
		
	КонецЦикла;
	
	ШтрихкодНакладной = СоздатьШтрихкодНакладнойПоНомеруЗНО(МассивОбъектов, ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаМаршрута.ЗНО, "Номер"));
	//ШтрихкодНакладной = СоздатьШтрихкодНакладной(МассивОбъектов);
	//Если ШтрихкодНакладной = Неопределено Тогда
	//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Печать прервана! Маршрутный лист уже был напечатан!");
	//	Возврат ТабДокумент;
	//КонецЕсли; 
	
	ОбластьМакета         = Макет.ПолучитьОбласть("Шапка");
	ОбластьШапкаТаблицы   = Макет.ПолучитьОбласть("ШапкаТаблицы");
	СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Организация, ДатаДокумента);
	КодУзла = ВнешнийМодульРаботаСWebПолучениеДанных.ПолучитьКодТекущегоУзла();
	Если ЭтоЗаказПоставщику Тогда
		РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ТекДок, "Контрагент, Склад");
		СкладОтправитель = ПолучитьСкладТранзит(Новый Структура("Отправитель, СкладПолучатель", РеквизитыЗаказа.Контрагент, РеквизитыЗаказа.Склад));
		
		Если СкладОтправитель = Неопределено Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не указан склад транзит для связки" + Символы.ПС 
			+ "Контрагент:" + " " + РеквизитыЗаказа.Контрагент
			+ "Склад:"		+ " " + РеквизитыЗаказа.Склад);
			Возврат ТабДокумент 
		КонецЕсли;
		
	ИначеЕсли КодУзла = "000" Тогда
		СкладОтправитель = Справочники.Склады.НайтиПоНаименованию("Основной РЦ (WMS)");
	Иначе
		СкладОтправитель = Справочники.Склады.НайтиПоНаименованию("Обх Основной (WMS)");
	КонецЕсли; 
	АдресГрузоОтправителя = ПолучитьАдресМагазина(СкладОтправитель);
	
	Водитель											= ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(СтрокаМаршрута.Водитель)  
	+ ?(ЗначениеЗаполнено(СтрокаМаршрута.Водитель2), " / " + Символы.ПС + ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(СтрокаМаршрута.Водитель2), "");
	ОбластьМакета.Параметры.Водитель					= Водитель;	
	
	ДатаНомерЗНО = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтрокаМаршрута.ЗНО, "Дата, Номер");
	
	ОбластьМакета.Параметры.ДатаЗНО						= ДатаНомерЗНО.Дата;
	ОбластьМакета.Параметры.НомерЗНО					= ДатаНомерЗНО.Номер;
	//ОбластьМакета.Параметры.ГосНомерТС					= СтрокаМаршрута.Автомобиль.Код;
	//ОбластьМакета.Параметры.Грузоотправильетль			= АдресГрузоОтправителя;
	//ЗаполнитьШтрихКодОбласть(ОбластьМакета, ШтрихкодНакладной);
	ТабДокумент.Вывести(ОбластьМакета);
	
	Дерево = РеквизитФормыВЗначение("ЗНО");
	
	ОбластьМакетаГруппировкаМагазина = Макет.ПолучитьОбласть("ГруппировкаМагазин");
	ОбластьМакетаСтрока				 = Макет.ПолучитьОбласть("ДанныеСтрока");
	НПП = 1;
	ВсегоВес   = 0;
	ВсегоОбъем = 0;
	ВсегоСумма = 0;
	МассивСкладовРазличные = Новый Массив;
	ОбщегоНазначения.ЗаполнитьМассивУникальнымиЗначениями(МассивСкладовРазличные, МассивСкладов);
	
	Для Каждого ТекСтр Из МассивСкладовРазличные Цикл
		
		КодМагазина = СтрПолучитьСтроку(СтрЗаменить(Строка(ТекСтр), " ", Символы.ПС), 1);
		ОбластьМакетаГруппировкаМагазина.Параметры.КодМагазина   = КодМагазина;
		ОбластьМакетаГруппировкаМагазина.Параметры.АдресМагазина = СтрЗаменить(Строка(ТекСтр), КодМагазина + " " , "");//УправлениеКонтактнойИнформацией.ПолучитьКонтактнуюИнформацияОбъекта(ТекСтр, Справочники.ВидыКонтактнойИнформации.АдресСклада);//СтрЗаменить(Строка(ТекСтр), КодМагазина + " ", "");
		
		Если Не ТабДокумент.ПроверитьВывод(ОбластьМакетаГруппировкаМагазина) Тогда
			ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
			ТабДокумент.Вывести(ОбластьШапкаТаблицы);
		КонецЕсли;
		
		ТабДокумент.Вывести(ОбластьМакетаГруппировкаМагазина);
		
		Заказы = Дерево.Строки.НайтиСтроки(Новый Структура("Водитель, Пометка", ТекСтр, 1), Истина);
		
		Для Каждого СтрокаЗаказ Из Заказы Цикл
			Если ТипЗнч(СтрокаЗаказ.ЗНО) = Тип("ДокументСсылка.ЗаказПоставщику") Тогда
				ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтрокаЗаказ.ЗНО, "Номер, Контрагент, СуммаДокумента");
				ОбластьМакетаСтрока.Параметры.НомерДокумента = ДанныеЗаказа.Номер;
				ОбластьМакетаСтрока.Параметры.СкладПоставщик = ДанныеЗаказа.Контрагент;
				ОбластьМакетаСтрока.Параметры.Сумма = ДанныеЗаказа.СуммаДокумента;
				Сумма = ДанныеЗаказа.СуммаДокумента;
			ИначеЕсли ТипЗнч(СтрокаЗаказ.ЗНО) = Тип("ДокументСсылка.ЗаказНаПеремещение") Тогда
				ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтрокаЗаказ.ЗНО, "Номер, СкладОтправитель");
				ОбластьМакетаСтрока.Параметры.НомерДокумента = ДанныеЗаказа.Номер;
				ОбластьМакетаСтрока.Параметры.СкладПоставщик = ДанныеЗаказа.СкладОтправитель;
				Сумма = 0;
			КонецЕсли;
			
			ВесОбъем = ОбработкаТабличнойЧастиСервер.ПолучитьВесИОбъемТоваровВУпаковкеWMSПоДокументу(СтрокаЗаказ.ЗНО);
			ОбластьМакетаСтрока.Параметры.Вес   = Окр(ВесОбъем.Вес);
			ОбластьМакетаСтрока.Параметры.Объем = ВесОбъем.Объем;
			ВсегоВес   = ВсегоВес   + ВесОбъем.Вес;
			ВсегоОбъем = ВсегоОбъем + ВесОбъем.Объем;
			ВсегоСумма = ВсегоСумма + Сумма;
			Если Не ТабДокумент.ПроверитьВывод(ОбластьМакетаСтрока) Тогда
				ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				ТабДокумент.Вывести(ОбластьШапкаТаблицы);
			КонецЕсли;
			
			ТабДокумент.Вывести(ОбластьМакетаСтрока);	
		КонецЦикла;
		
	КонецЦикла; 
	
	ОбластьМакета = Макет.ПолучитьОбласть("Итоги");
	ОбластьМакета.Параметры.ВесИтого   = Окр(ВсегоВес);
	ОбластьМакета.Параметры.ОбъемИтого = ВсегоОбъем;
	ОбластьМакета.Параметры.СуммаИтого = ВсегоСумма;
	ТабДокумент.Вывести(ОбластьМакета);
	
	ОбластьМакета = Макет.ПолучитьОбласть("Подвал");
	ТабДокумент.Вывести(ОбластьМакета);
	
	//ТабДокумент.КоличествоЭкземпляров = МассивСкладов.Количество() + 1;
	
	СтрокаМаршрута.Напечатано = Истина;
	СтрокаМаршрута.НомерМЛ = ШтрихкодНакладной;
	СтрокаМаршрута.Ответственный = ПараметрыСеанса.ТекущийПользователь;
	//
	//СтруктураПараметров = Новый Структура("Водитель, Автомобиль, Статус, УдаленныйШтрихкод",СтрокаМаршрута.Водитель, СтрокаМаршрута.Автомобиль, 1, ШтрихкодНакладной);
	//СохранитьДанныеОПечати(мХранилищеДополнительнойИнформации, СтруктураПараметров);
	
	СохранитьДанныеОПечати(МассивОбъектов, "Объединенный маршрутный лист", СтрокаМаршрута.ЗНО, ТабДокумент.КоличествоЭкземпляров);		
		
	Возврат ТабДокумент;
	
	
КонецФункции

Функция ПолучитьСкладТранзит(ПараметрыТранзит);
	
	Отправитель 	= ПараметрыТранзит.Отправитель; 
	СкладПолучатель = ПараметрыТранзит.СкладПолучатель;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	?(ТипЗнч(Отправитель) = Тип("СправочникСсылка.Контрагенты"),
	"ВЫБРАТЬ
	|	СоответствиеТранзитныхСкладов.СкладТранзит
	|ИЗ
	|	РегистрСведений.СоответствиеТранзитныхСкладов КАК СоответствиеТранзитныхСкладов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Таблица
	|		ПО СоответствиеТранзитныхСкладов.Отправитель = Таблица.Ссылка
	|ГДЕ
	|	СоответствиеТранзитныхСкладов.Отправитель = &Отправитель
	|	И СоответствиеТранзитныхСкладов.СкладПолучатель = &СкладПолучатель
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СоответствиеТранзитныхСкладов.СкладТранзит
	|ИЗ
	|	РегистрСведений.СоответствиеТранзитныхСкладов КАК СоответствиеТранзитныхСкладов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Контрагенты КАК Таблица
	|		ПО СоответствиеТранзитныхСкладов.Отправитель = Таблица.Ссылка
	|ГДЕ
	|	СоответствиеТранзитныхСкладов.Отправитель = &Отправитель
	|	И СоответствиеТранзитныхСкладов.СкладПолучатель = ВЫРАЗИТЬ(&СкладПолучатель КАК Справочник.Склады).Родитель"
	, 
	"ВЫБРАТЬ		
	|	СоответствиеТранзитныхСкладов.СкладТранзит
	|ИЗ
	|	РегистрСведений.СоответствиеТранзитныхСкладов КАК СоответствиеТранзитныхСкладов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК Таблица
	|		ПО СоответствиеТранзитныхСкладов.Отправитель = Таблица.Ссылка
	|ГДЕ
	|	СоответствиеТранзитныхСкладов.Отправитель = &Отправитель
	|	И СоответствиеТранзитныхСкладов.СкладПолучатель = &СкладПолучатель
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СоответствиеТранзитныхСкладов.СкладТранзит
	|ИЗ
	|	РегистрСведений.СоответствиеТранзитныхСкладов КАК СоответствиеТранзитныхСкладов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК Таблица
	|		ПО СоответствиеТранзитныхСкладов.Отправитель = Таблица.Ссылка
	|ГДЕ
	|	СоответствиеТранзитныхСкладов.Отправитель = ВЫРАЗИТЬ(&Отправитель КАК Справочник.Склады).Родитель
	|	И СоответствиеТранзитныхСкладов.СкладПолучатель = &СкладПолучатель
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	СоответствиеТранзитныхСкладов.СкладТранзит
	|ИЗ
	|	РегистрСведений.СоответствиеТранзитныхСкладов КАК СоответствиеТранзитныхСкладов
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Склады КАК Таблица
	|		ПО СоответствиеТранзитныхСкладов.Отправитель = Таблица.Ссылка
	|ГДЕ
	|	СоответствиеТранзитныхСкладов.Отправитель = &Отправитель
	|	И СоответствиеТранзитныхСкладов.СкладПолучатель = ВЫРАЗИТЬ(&СкладПолучатель КАК Справочник.Склады).Родитель");
	
	Запрос.УстановитьПараметр("Отправитель"	   , Отправитель);
	Запрос.УстановитьПараметр("СкладПолучатель", СкладПолучатель);
	
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда 
		Возврат Неопределено;
	КонецЕсли;
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.СкладТранзит;
	КонецЦикла;
	
КонецФункции

Функция ПолучитьЛистКомплектации(СтрокаМаршрута, РежимПечати)
	
	
	ВремяВыполнения = "";
	ВремяВыполнения = "Старт:" + " " + ТекущаяДата();
	
	УстановитьПривилегированныйРежим(Истина);
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Если РежимПечати = 0 Тогда
		Макет = Обработка.ПолучитьМакет("ЛистКомплектации");
	ИначеЕсли РежимПечати = 1 Тогда
		Макет = Обработка.ПолучитьМакет("ОбъединенныйЛистКомплектации");
	ИначеЕсли РежимПечати = 2 Тогда
		Макет = Обработка.ПолучитьМакет("ЛистКомплектацииМагазин");
	КонецЕсли;
	
	Водитель   = СокрЛП(СтрокаМаршрута.Водитель);
	Автомобиль = СокрЛП(СтрокаМаршрута.Автомобиль);
	
	СписокЗаказов = Новый Массив;
	Строки = СтрокаМаршрута.Строки.НайтиСтроки(Новый Структура("Пометка", 1));
	Для Каждого Строка Из Строки Цикл
		
		Если Строка.СкладWMS И НеПечататьЛистКомплектацииДляWMS Тогда
			Продолжить;
		КонецЕсли;
		
		Если Не ЗначениеЗаполнено(Строка.Автомобиль) Тогда
