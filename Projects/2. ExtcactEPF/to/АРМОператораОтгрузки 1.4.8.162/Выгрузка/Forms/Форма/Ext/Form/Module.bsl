
&НаСервере
Перем мХранилищеДополнительнойИнформации;

///////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ ФОРМЫ

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Обработка = РеквизитФормыВЗначение("Объект");
	
	Если Параметры.Свойство("ДополнительнаяОбработкаСсылка") Тогда
		Объект.ДополнительнаяОбработкаСсылка = Параметры.ДополнительнаяОбработкаСсылка;
	КонецЕсли;
	
	ВосстановитьСписокПечатныхФормНаСервере();
	
	УстановитьДоступностьСпискаПечатныхФорм();
	
	Элементы.Отладка.Видимость = РольДоступна("ПолныеПрава");
	
	ТекстОтбораДляЗП     =	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказПоставщику.Контрагент Как Поставщик,
	|	ЗаказПоставщику.Склад Как Магазин
	|ИЗ
	|	Документ.ЗаказПоставщику КАК ЗаказПоставщику";			  
	
	
	ИнициализироватьКНКД(НастройкиЗП , ТекстОтбораДляЗП);
	ИнициализироватьКНКД(НастройкиЗнП, "Выбрать Значение(Справочник.Склады.ПустаяСсылка) Как СкладОтправитель, Значение(Справочник.Склады.ПустаяСсылка) Как СкладПолучатель");
	
	//ИмяВнешнейКомпонентыПечати = "КартинкаШтрихкода";
	//ВнешняяКомпонентаШК = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
	
КонецПроцедуры

&НаСервере
Процедура ИнициализироватьКНКД(ПолеОтбора, ТекстЗапроса)
	
	Обработка 		= РеквизитФормыВЗначение("Объект");
	ТекстЗапроса 	= ТекстЗапроса;
	
	СхемаКомпоновкиДанных = Новый СхемаКомпоновкиДанных;
	ИсточникДанных = СхемаКомпоновкиДанных.ИсточникиДанных.Добавить(); 
	ИсточникДанных.Имя                = "ИсточникДанных";
	ИсточникДанных.ТипИсточникаДанных = "Local";
	
	НаборДанных = СхемаКомпоновкиДанных.НаборыДанных.Добавить(Тип("НаборДанныхЗапросСхемыКомпоновкиДанных"));
	НаборДанных.АвтоЗаполнениеДоступныхПолей = Истина;
	
	НаборДанных.Запрос = ТекстЗапроса;
	НаборДанных.Имя            = "НаборДанных";
	НаборДанных.ИсточникДанных = "ИсточникДанных";
	
	АдресСхемыКомпоновкиДанных = ПоместитьВоВременноеХранилище(СхемаКомпоновкиДанных, ЭтаФорма.УникальныйИдентификатор);
	ИсточникНастроек 		   = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресСхемыКомпоновкиДанных);
	
	ПолеОтбора.Инициализировать(ИсточникНастроек);
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	
	Элементы.ЗНОКомандаИгнорироватьПометку1С.Пометка = Ложь;
	
	ПолучитьЗаголовокФормы();
	
	Принт =  Новый COMОбъект("WScript.Network");
	prn =  Принт.EnumPrinterConnections();
	i = 0;
	Пока i < prn.Count()-1 Цикл
		Элементы.ПринтерПоУмолчанию.СписокВыбора.Добавить(prn.Item(i+1));
		i = i + 2;
	КонецЦикла;
	
	
	Настройки = ПолучитьНастройкиПечатиПоУмолчаниюКлиент();
	Если Не Настройки = Неопределено Тогда 
		ЗаполнитьЗначенияСвойств(ЭтаФорма, Настройки);
	КонецЕсли; 
	
	ВидимостьНастроек = Истина;
	УправлениеВидимостью();
	
КонецПроцедуры

Функция ПолучитьНастройкиПечатиПоУмолчаниюКлиент()
	Возврат ПолучитьНастройкиПечатиПоУмолчанию();
КонецФункции

Функция ПолучитьНастройкиПечатиПоУмолчанию()
	
	
	ТЗ = "ВЫБРАТЬ
	|	ВариантыОтчетов.Наименование,
	|	ВариантыОтчетов.ХранилищеЗначений,
	|	ВариантыОтчетов.Ссылка
	|ИЗ
	|	Справочник.ВариантыОтчетов КАК ВариантыОтчетов
	|ГДЕ
	|	ВариантыОтчетов.Наименование = &КлючВарианта
	|	И ВариантыОтчетов.Администратор = &Пользователь";
	
	Запрос = Новый Запрос(ТЗ);
	Запрос.УстановитьПараметр("Пользователь", ПараметрыСеанса.ТекущийПользователь);
	Запрос.УстановитьПараметр("КлючВарианта", "НастройкиПечатиАРМОператораОтгрузки");
	
	УстановитьПривилегированныйРежим(Истина);
	
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		//ОписаниеНастроек.Представление = Выборка.Наименование;
		Настройки = Выборка.ХранилищеЗначений.Получить();
		Если ТипЗнч(Настройки) = Тип("Структура") Тогда
			Настройки.Вставить("Ссылка", Выборка.Ссылка);
		КонецЕсли;
	КонецЕсли;
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Настройки;
	
КонецФункции

Процедура СохранитьНастройкиПечатиПоУмолчанию()
	
	СтруктураНастроек = Новый Структура("ПринтерПоУмолчанию, ВыводНаПринтер");
	ЗаполнитьЗначенияСвойств(СтруктураНастроек, ЭтаФорма);
	
	Настройки = ПолучитьНастройкиПечатиПоУмолчанию();
	Если ТипЗнч(Настройки) = Тип("Структура") Тогда
		
		Если Настройки.ПринтерПоУмолчанию = ПринтерПоУмолчанию И Настройки.ВыводНаПринтер = ВыводНаПринтер Тогда
			Возврат;
		КонецЕсли;
		
		ВариантОбъект = Настройки.Ссылка.Получитьобъект();
		
	Иначе
		
		ВариантОбъект = Справочники.ВариантыОтчетов.СоздатьЭлемент();
		ВариантОбъект.Наименование = "НастройкиПечатиАРМОператораОтгрузки";
		ВариантОбъект.КлючОбъекта  = "ВнешняяОбработка.АРМОператораОтгрузки";
		ВариантОбъект.Администратор = ПараметрыСеанса.ТекущийПользователь;
	КонецЕсли;
	
	ВариантОбъект.ХранилищеЗначений = Новый ХранилищеЗначения(СтруктураНастроек, Новый СжатиеДанных());
	Попытка
		ВариантОбъект.Записать();
	Исключение
		Сообщить(ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

///////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ОБРАБОТЧИКИ СОБЫТИЙ РЕКВИЗИТОВ

&НаКлиенте
Процедура НастройкаПечатиДокументПечатиОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	
	СпВыб = Элементы.НастройкаПечатиДокументПечатиИД.СписокВыбора;
	Элем = СпВыб.НайтиПоЗначению(ВыбранноеЗначение);
	
	ТекДанные = Элементы.НастройкаПечати.ТекущиеДанные;
	
	Если Элем<>Неопределено Тогда
		ТекДанные.ДокументПечати = Элем.Представление;
	КонецЕсли;	 
	
КонецПроцедуры

////////////////////////////////////////////////////////////////////////////////
// ПРОЦЕДУРЫ - ДЕЙСТВИЯ КОМАНДНЫХ ПАНЕЛЕЙ ФОРМЫ

&НаКлиенте
Процедура КомандаЗаполнитьЗНО(Команда)
	
	//ВремяНачала = ОценкаПроизВодительностиКлиентСервер.НачатьЗамерВремени();
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаЗНО" Тогда
		
		СтруктураЗНО = Новый Структура("ЗНО", ?(Не Элементы.ЗНО.ТекущиеДанные = Неопределено, 
		?(ТипЗнч(Элементы.ЗНО.ТекущиеДанные.ЗНО) = Тип("ДокументСсылка.ЗаказНаОтгрузку"), Элементы.ЗНО.ТекущиеДанные.ЗНО, Элементы.ЗНО.ТекущиеДанные.ПолучитьРодителя().ЗНО) 
		, Неопределено));
		Если Не СтруктураЗНО.Зно = Неопределено Тогда
			ИндексТекущейСтроки = Элементы.ЗНО.ТекущиеДанные.ПолучитьИдентификатор();//Элементы.ЗНО.ТекущаяСтрока;//ЗНО.ПолучитьЭлементы().Индекс(Элементы.ЗНО.ТекущиеДанные);
		КонецЕсли;
		Попытка
			УстановитьБезопасныйРежимСервер();
		Исключение
		КонецПопытки;
		//ЗаполнитьДеревоНаСервере();
		ОбновитьЗНО();
		ЗаполнитьДеревоНаСервере();
		
		Если Не СтруктураЗНО.Зно = Неопределено Тогда
			
			Для Каждого СтрокаЗНО Из ЗНО.ПолучитьЭлементы() Цикл
				Если СтрокаЗНО.ЗНО = СтруктураЗНО.ЗНО Тогда
					
					Элементы.ЗНО.ТекущаяСтрока = СтрокаЗНО.ПолучитьИдентификатор();//ИндексТекущейСтроки;
				КонецЕсли;	
			КонецЦикла;
		КонецЕсли;  
		//СвернутьРазвернутьДерево();
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаКомплектация" Тогда
		
		ТаблицаКомплектация.Очистить();
		
		//ЗаполнитьОтборПоЗП();
		//ЗаполнитьОтборПоЗнП();
		ТаблицаКомплектация.Очистить();
		ПараметрыДанных = Новый Структура("ВидДвижения, ДатаОтгрузки, СкладТранзит", ВидДвиженияНакопления.Приход, ДатаОтгрузки, СкладТранзит);
		ВыполнитьЗапросСКД("ПолучениеДанныхКомплектацииЗП" , ПараметрыДанных, НастройкиЗП.Настройки.Отбор);
		ВыполнитьЗапросСКД("ПолучениеДанныхКомплектацииЗнП", ПараметрыДанных, НастройкиЗнП.Настройки.Отбор);
		
	КонецЕсли;
	
	//ОценкаПроизВодительностиКлиентСервер.ЗакончитьЗамерВремени(ПредопределенноеЗначение("Справочник.КлючевыеОперации.ОбновлениеСпискаМаршрутовВАрмОператораОтгрузки"), ВремяНачала);
	
КонецПроцедуры

Процедура ВыполнитьЗапросСКД(ИмяМакета, ПараметрыСКД, Знач Отбор);
	
	Обработка = РеквизитФормыВЗначение("Объект");
	ОСКД = Обработка.ПолучитьМакет(ИмяМакета);
	
	НастройкиОСКД = ОСКД.НастройкиПоУмолчанию;
	
	Для Каждого ЭлементОТбора Из НастройкиОСКД.Отбор.Элементы Цикл
		Для Каждого ЭлементНастройки Из Отбор.Элементы Цикл
			Если ЭлементОТбора.ЛевоеЗначение = ЭлементНастройки.ЛевоеЗначение Тогда
				ЗаполнитьЗначенияСвойств(ЭлементОТбора, ЭлементНастройки);
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	
	//НастройкиОСКД = КомпоновщикНастроек.ПолучитьНастройкиОСКД();
	
	ПараметрыДанныхОСКД = НастройкиОСКД.ПараметрыДанных.Элементы;
	
	Для Каждого КлючЗначение Из ПараметрыСКД Цикл
		ПараметрДанных = ПараметрыДанныхОСКД.Найти(КлючЗначение.Ключ);
		ПараметрДанных.Использование = Истина;
		ПараметрДанных.Значение = КлючЗначение.Значение;
	КонецЦикла;
	
	
	
	
	//ПараметрДанных = ПараметрыДанныхОСКД.Найти("ВидДвижения");
	//ПараметрДанных.Использование = Истина;
	//ПараметрДанных.Значение = ВидДвиженияНакопления.Приход;
	//
	//ПараметрДанных = ПараметрыДанныхОСКД.Найти("ДатаОтгрузки");
	//ПараметрДанных.Использование = Истина;
	//ПараметрДанных.Значение = ДатаОтгрузки;
	//
	//ПараметрДанных = ПараметрыДанныхОСКД.Найти("СкладТранзит");
	//ПараметрДанных.Использование = Истина;
	//ПараметрДанных.Значение = СкладТранзит;
	
	КомпоновщикМакетаОСКД = Новый КомпоновщикМакетаКомпоновкиДанных;
	Макет = КомпоновщикМакетаОСКД.Выполнить(ОСКД, НастройкиОСКД,,,Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
	
	ПроцессорКомпоновкиОСКД = Новый ПроцессорКомпоновкиДанных;
	ПроцессорКомпоновкиОСКД.Инициализировать(Макет);
	
	ТЗ = Новый ТаблицаЗначений;
	ПроцессорВыводаОСКД = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
	ПроцессорВыводаОСКД.УстановитьОбъект(ТЗ);
	ПроцессорВыводаОСКД.Вывести(ПроцессорКомпоновкиОСКД);
	
	Для Каждого Строка Из ТЗ Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаКомплектация.Добавить(), Строка);
	КонецЦикла;
	
КонецПроцедуры


Процедура ЗаполнитьОтборПоЗП()
	
	ТекстЗапроса = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ЗаказПоставщику.Контрагент,
	|	ЗаказПоставщику.Склад
	|ИЗ
	|	Документ.ЗаказПоставщику КАК ЗаказПоставщику";
	СхемаКомпоновкиДанных = Новый СхемаКомпоновкиДанных;
	
	ИсточникНастроек = ИнициализироватьИсточникКНКД(СхемаКомпоновкиДанных, ТекстЗапроса);
	
	ЕстьАктивноеУсловие = Ложь;
	Для Каждого ЭлементОтбора Из НастройкиЗП.ПолучитьНастройки().Отбор.Элементы Цикл
		Если ЭлементОтбора.Использование Тогда
			ЕстьАктивноеУсловие = Истина;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Не ЕстьАктивноеУсловие Тогда
		Возврат;
	КонецЕсли;	
	
	ОтборЗП.Загрузить(ВыполнитьЗапросВКНКД(ИсточникНастроек, НастройкиЗП.ПолучитьНастройки(), СхемаКомпоновкиДанных));
	
КонецПроцедуры

Процедура ВыполнитьСКД()
	
	СхемаКомпоновкиДанных = Новый СхемаКомпоновкиДанных;
	
	ВариантыНастроекКомпоновкиДанных = СхемаКомпоновкиДанных.ВариантыНастроек;
	ВариантыНастроекКомпоновкиДанных.Очистить();
	ВариантНастроекКомпоновкиДанных = ВариантыНастроекКомпоновкиДанных.Добавить();
	ВариантНастроекКомпоновкиДанных.Имя = "Основной";
	
	НастройкиКомпоновкиДанных = ВариантНастроекКомпоновкиДанных.Настройки;
	ВыбранныеПоляКомпоновкиДанных = НастройкиКомпоновкиДанных.Выбор;
	КоллекцияВыбранныхПолейКомпоновкиДанных = ВыбранныеПоляКомпоновкиДанных.Элементы;
	ВыбранноеПолеКомпоновкиДанных = КоллекцияВыбранныхПолейКомпоновкиДанных.Добавить(Тип("ВыбранноеПолеКомпоновкиДанных"));
	ВыбранноеПолеКомпоновкиДанных.Поле = Новый ПолеКомпоновкиДанных("Заказ");
	ОтборКомпоновкиДанных = НастройкиЗП.Настройки.Отбор;//НастройкиКомпоновкиДанных.Отбор;
	КоллекцияЭлементовОтбораКомпоновкиДанных = ОтборКомпоновкиДанных.Элементы;
	ЭлементОтбораКомпоновкиДанных = КоллекцияЭлементовОтбораКомпоновкиДанных.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбораКомпоновкиДанных.Использование = Ложь;
	ЭлементОтбораКомпоновкиДанных.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Заказ.Контрагент");
	ЭлементОтбораКомпоновкиДанных = КоллекцияЭлементовОтбораКомпоновкиДанных.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
	ЭлементОтбораКомпоновкиДанных.ЛевоеЗначение = Новый ПолеКомпоновкиДанных("Заказ.Склад");
	КоллекцияЭлементовСтруктурыНастроекКомпоновкиДанных = НастройкиКомпоновкиДанных.Структура;
	ГруппировкаКомпоновкиДанных = КоллекцияЭлементовСтруктурыНастроекКомпоновкиДанных.Добавить(Тип("ГруппировкаКомпоновкиДанных"));
	ВыбранныеПоляКомпоновкиДанных = ГруппировкаКомпоновкиДанных.Выбор;
	КоллекцияВыбранныхПолейКомпоновкиДанных = ВыбранныеПоляКомпоновкиДанных.Элементы;
	КоллекцияВыбранныхПолейКомпоновкиДанных.Добавить(Тип("АвтоВыбранноеПолеКомпоновкиДанных"));
	ПорядокКомпоновкиДанных = ГруппировкаКомпоновкиДанных.Порядок;
	КоллекцияЭлементовПорядкаКомпоновкиДанных = ПорядокКомпоновкиДанных.Элементы;
	КоллекцияЭлементовПорядкаКомпоновкиДанных.Добавить(Тип("АвтоЭлементПорядкаКомпоновкиДанных"));
	ВариантНастроекКомпоновкиДанных.Представление = "Основной";
	ИсточникиДанныхСхемыКомпоновкиДанных = СхемаКомпоновкиДанных.ИсточникиДанных;
	ИсточникДанныхСхемыКомпоновкиДанных = ИсточникиДанныхСхемыКомпоновкиДанных.Добавить();
	ИсточникДанныхСхемыКомпоновкиДанных.Имя = "ИсточникДанных1";
	ИсточникДанныхСхемыКомпоновкиДанных.ТипИсточникаДанных = "Local";
	НаборыДанныхСхемыКомпоновкиДанных = СхемаКомпоновкиДанных.НаборыДанных;
	НаборДанныхЗапросСхемыКомпоновкиДанных = НаборыДанныхСхемыКомпоновкиДанных.Добавить(Тип("НаборДанныхЗапросСхемыКомпоновкиДанных"));
	
	НаборДанныхЗапросСхемыКомпоновкиДанных.Запрос = "ВЫБРАТЬ
	|ОрганизацияДоставкиПоЗаказам.Регистратор Как Заказ
	|ИЗ
	|РегистрНакопления.ОрганизацияДоставкиПоЗаказам КАК ОрганизацияДоставкиПоЗаказам
