&НаКлиенте
Процедура ЗНОПометкаПриИзменении(Элемент)
	ТекущиеДанные = Элементы.ЗНО.ТекущиеДанные;
	ЭтоВерхнийУровень = ТипЗнч(ТекущиеДанные.ЗНО) = Тип("ДокументСсылка.ЗаказНаОтгрузку");
	
	//Если Не ТекущиеДанные.пАх Или Не ТекущиеДанные.п1С Тогда
	Если Не ТекущиеДанные.п1С И Не ЭтоВерхнийУровень И ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Не завершился процесс погрузки!",, "ЗНО[0].Пометка");
		ТекущиеДанные.Пометка = 0;
		Возврат;
	КонецЕсли;
	
	Если Не ЭтоВерхнийУровень И ТекущиеДанные.Пометка = 2 Тогда 
		ТекущиеДанные.Пометка = 0;
	КонецЕсли;
	
	//ТекущиеДанные.Пометка = ?(ТекущиеДанные.Пометка = 1 Или ТекущиеДанные.Пометка = 2, ТекущиеДанные.Пометка = 0, ТекущиеДанные.Пометка = 1);
	
	Попытка
		ЕстьЗаполненные = Ложь;
		ТекущиеДанные.ПолучитьРодителя().Пометка = 1;
		Для Каждого ЭлементДерева Из ТекущиеДанные.ПолучитьРодителя().ПолучитьЭлементы() Цикл
			Если ЭлементДерева.Пометка = 0 Тогда 
				ТекущиеДанные.ПолучитьРодителя().Пометка = 2;
			ИначеЕсли ЭлементДерева.Пометка = 1 Тогда 
				ЕстьЗаполненные = Истина;
			КонецЕсли;
		КонецЦикла;
		Если ТекущиеДанные.ПолучитьРодителя().Пометка = 2 И Не ЕстьЗаполненные Тогда
			ТекущиеДанные.ПолучитьРодителя().Пометка = 0;
		КонецЕсли;
	Исключение
	КонецПопытки;
	
	ИгнорироватьПометку1С = Элементы.ЗНОКомандаИгнорироватьПометку1С.Пометка;
	ЕстьЗаполненные = Ложь;
	Для Каждого ЭлементДерева Из ТекущиеДанные.ПолучитьЭлементы() Цикл
		// 2025.06.23 v.nagaycev@kdvm.ru попросили убрать проверку пометки 1С, добавил команду
		Если ЭлементДерева.пАх и (ЭлементДерева.п1С Или ИгнорироватьПометку1С) Тогда 
			Если ЭтоВерхнийУровень И ТекущиеДанные.Пометка = 2 Тогда 
				ЭлементДерева.Пометка = 0;
			Иначе
				ЕстьЗаполненные = Истина;
				ЭлементДерева.Пометка = Элементы.ЗНО.ТекущиеДанные.Пометка;
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Если ЭтоВерхнийУровень И Не ЕстьЗаполненные Тогда
		ТекущиеДанные.Пометка = 0;
	КонецЕсли;
	
КонецПроцедуры

