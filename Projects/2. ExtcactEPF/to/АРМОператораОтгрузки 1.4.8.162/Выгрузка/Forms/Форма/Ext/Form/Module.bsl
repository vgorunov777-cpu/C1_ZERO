&НаСервере
Функция ПолучитьДействующееСоглашениеСПоставщиком(мКонтрагент)
	
	Если мКонтрагент <> Неопределено и ТипЗнч(мКонтрагент) = Тип("СправочникСсылка.Контрагенты") и мКонтрагент <> Справочники.Контрагенты.ПустаяСсылка() Тогда   
	
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	МАКСИМУМ(СоглашенияСПоставщиками.Ссылка) КАК Ссылка
		|ИЗ
		|	Справочник.СоглашенияСПоставщиками КАК СоглашенияСПоставщиками
		|ГДЕ
		|	СоглашенияСПоставщиками.Контрагент = &Контрагент
		|	И СоглашенияСПоставщиками.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСПоставщиками.Действует)
		|	И СоглашенияСПоставщиками.ПометкаУдаления <> ИСТИНА";
		Запрос.УстановитьПараметр("Контрагент",мКонтрагент);
		Результат = Запрос.Выполнить().Выбрать();
		Если Результат.Следующий() Тогда
			Возврат Результат.Ссылка;
		Иначе  
			мПартнер = мКонтрагент.Партнер;
			
			Если мПартнер <> Неопределено и ТипЗнч(мПартнер) = Тип("СправочникСсылка.Партнеры") и мПартнер <> Справочники.Партнеры.ПустаяСсылка() Тогда
				Запрос = Новый Запрос;
				Запрос.Текст = 
				"ВЫБРАТЬ
				|	МАКСИМУМ(СоглашенияСПоставщиками.Ссылка) КАК Ссылка
				|ИЗ
				|	Справочник.СоглашенияСПоставщиками КАК СоглашенияСПоставщиками
				|ГДЕ
				|	СоглашенияСПоставщиками.Партнер = &Партнер
				|	И СоглашенияСПоставщиками.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыСоглашенийСПоставщиками.Действует)
				|	И СоглашенияСПоставщиками.ПометкаУдаления <> ИСТИНА";
				Запрос.УстановитьПараметр("Партнер",мПартнер);
				Результат = Запрос.Выполнить().Выбрать();
				Если Результат.Следующий() Тогда
					Возврат Результат.Ссылка;
	            КонецЕсли;
			КонецЕсли;
				
		КонецЕсли; 
		
		Возврат Справочники.СоглашенияСПоставщиками.ПустаяСсылка();
	Иначе
		
		Возврат Справочники.СоглашенияСПоставщиками.ПустаяСсылка();
		
	КонецЕсли;
	
КонецФункции

