Процедура УправлениеВидимостью()
	
	Элементы.ЗНО.КоманднаяПанель.ПодчиненныеЭлементы.ЗНОКомандаПоказатьНастройки.Пометка = ВидимостьНастроек;
	Элементы.ТаблицаКомплектация.КоманднаяПанель.ПодчиненныеЭлементы.ТаблицаКомплектацияКомандаПоказатьНастройки.Пометка = ВидимостьНастроек;	
	
	Если ВидимостьНастроек Тогда
		Элементы.ГруппаНастройки.Видимость = Истина;
		Элементы.ЗНО.КоманднаяПанель.ПодчиненныеЭлементы.ЗНОКомандаПоказатьНастройки.Заголовок = "Скрыть настройки";
		Элементы.ЗНО.КоманднаяПанель.ПодчиненныеЭлементы.ЗНОКомандаПоказатьНастройки.Картинка  = БиблиотекаКартинок.ПерейтиНаСледующийЭтапСделки;
		Элементы.ТаблицаКомплектация.КоманднаяПанель.ПодчиненныеЭлементы.ТаблицаКомплектацияКомандаПоказатьНастройки.Заголовок = "Скрыть настройки";
		Элементы.ТаблицаКомплектация.КоманднаяПанель.ПодчиненныеЭлементы.ТаблицаКомплектацияКомандаПоказатьНастройки.Картинка  = БиблиотекаКартинок.ПерейтиНаСледующийЭтапСделки;
	Иначе
		Элементы.ГруппаНастройки.Видимость = Ложь;
		Элементы.ЗНО.КоманднаяПанель.ПодчиненныеЭлементы.ЗНОКомандаПоказатьНастройки.Заголовок = "Показать настройки";
		Элементы.ЗНО.КоманднаяПанель.ПодчиненныеЭлементы.ЗНОКомандаПоказатьНастройки.Картинка  = БиблиотекаКартинок.ПерейтиНаПредыдущийЭтапСделки;
		Элементы.ТаблицаКомплектация.КоманднаяПанель.ПодчиненныеЭлементы.ТаблицаКомплектацияКомандаПоказатьНастройки.Заголовок = "Показать настройки";
		Элементы.ТаблицаКомплектация.КоманднаяПанель.ПодчиненныеЭлементы.ТаблицаКомплектацияКомандаПоказатьНастройки.Картинка  = БиблиотекаКартинок.ПерейтиНаПредыдущийЭтапСделки;		
	КонецЕсли;
	
	Отладка = Ложь;
	
	Если Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаЗНО" Тогда
		
		Элементы.ГруппаРО.Видимость				   = Истина;
		Элементы.ГруппаОтборКомплектация.Видимость = Не Элементы.ГруппаРО.Видимость;
		Элементы.ГруппаПФ.Видимость				   = Элементы.ГруппаРО.Видимость;
		
	ИначеЕсли Элементы.ГруппаСтраницы.ТекущаяСтраница.Имя = "ГруппаКомплектация" Тогда
		
		Элементы.ГруппаРО.Видимость				   = Ложь;
		Элементы.ГруппаОтборКомплектация.Видимость = Не Элементы.ГруппаРО.Видимость;
		Элементы.ГруппаПФ.Видимость				   = Элементы.ГруппаРО.Видимость;
	КонецЕсли;
	
	Элементы.НастройкаПечати.КоманднаяПанель.ПодчиненныеЭлементы.НастройкаПечатиНеПечататьЛистКомплектацииДляWMS.Пометка = НеПечататьЛистКомплектацииДляWMS;
