		|	ВТ_ПеремещенияТовары.ХарактеристикаНаименованиеПолное,
		|	ВТ_ПеремещенияТовары.Упаковка,
		|	ВТ_ПеремещенияТовары.НоменклатураЕдиницаИзмерения,
		|	ВТ_ПеремещенияТовары.УпаковкаЕдиницаИзмерения,
		|	ВТ_ПеремещенияТовары.УпаковкаЕдиницаИзмеренияКод,
		|	ВТ_ПеремещенияТовары.НоменклатураЕдиницаИзмеренияКод,
		|	ВТ_ПеремещенияТовары.КоличествоУпаковок,
		|	ВТ_ПеремещенияТовары.УпаковкаКоэффициент,
		|	ВТ_ПеремещенияТовары.НоменклатураВес,
		|	ВТ_ПеремещенияТовары.Количество,
		|	ВТ_ПеремещенияШапки.СкладПолучательРозничныйВидЦены,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.ПолучитьГрупповоеПеремещение.ВТ_Перемещения}}"" КАК Метка
		|ПОМЕСТИТЬ ВТ_Перемещения
		|ИЗ
		|	ВТ_ПеремещенияШапки КАК ВТ_ПеремещенияШапки
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ПеремещенияТовары КАК ВТ_ПеремещенияТовары
		|		ПО ВТ_ПеремещенияШапки.Ссылка = ВТ_ПеремещенияТовары.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_Перемещения.Номенклатура КАК Товар,
		|	ВТ_Перемещения.НоменклатураНаименованиеПолное КАК ТоварНаименование,
		|	ВЫБОР
		|		КОГДА &ТоварКод = ""Код""
		|			ТОГДА ВТ_Перемещения.НоменклатураКод
		|		ИНАЧЕ ВТ_Перемещения.НоменклатураАртикул
		|	КОНЕЦ КАК ТоварКод,
		|	ВТ_Перемещения.ХарактеристикаНаименованиеПолное КАК Характеристика,
		|	ВЫБОР
		|		КОГДА ВТ_Перемещения.Упаковка <> ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
		|			ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(ВТ_Перемещения.УпаковкаЕдиницаИзмерения)
		|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(ВТ_Перемещения.НоменклатураЕдиницаИзмерения)
		|	КОНЕЦ КАК ЕдиницаИзмеренияНаименование,
		|	ВЫБОР
		|		КОГДА ВТ_Перемещения.Упаковка <> ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
		|			ТОГДА ВТ_Перемещения.УпаковкаЕдиницаИзмеренияКод
		|		ИНАЧЕ ВТ_Перемещения.НоменклатураЕдиницаИзмеренияКод
		|	КОНЕЦ КАК ЕдиницаИзмеренияКодПоОКЕИ,
		|	СУММА(ВТ_Перемещения.КоличествоУпаковок) КАК Количество,
		|	СУММА((ВЫРАЗИТЬ(ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 1) * ЕСТЬNULL(ВТ_Перемещения.УпаковкаКоэффициент, 1) КАК ЧИСЛО(15, 2))) * ВТ_Перемещения.КоличествоУпаковок) КАК Сумма,
		|	ВЫРАЗИТЬ(ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 1) * ЕСТЬNULL(ВТ_Перемещения.УпаковкаКоэффициент, 1) КАК ЧИСЛО(15, 2)) КАК Цена,
		|	СУММА(ВЫБОР
		|			КОГДА ВТ_Перемещения.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
		|				ТОГДА (ВЫРАЗИТЬ(ВЫБОР
		|							КОГДА НоменклатураДополнительныеРеквизиты.Значение ЕСТЬ NULL
		|									ИЛИ НоменклатураДополнительныеРеквизиты.Значение = 0
		|								ТОГДА ВТ_Перемещения.НоменклатураВес
		|							ИНАЧЕ ЕСТЬNULL(НоменклатураДополнительныеРеквизиты.Значение, 0)
		|						КОНЕЦ КАК ЧИСЛО(15, 3))) * ВТ_Перемещения.Количество
		|			ИНАЧЕ (ВЫРАЗИТЬ(ВЫБОР
		|						КОГДА НоменклатураДополнительныеРеквизиты.Значение ЕСТЬ NULL
		|								ИЛИ НоменклатураДополнительныеРеквизиты.Значение = 0
		|							ТОГДА ВТ_Перемещения.НоменклатураВес
		|						ИНАЧЕ ЕСТЬNULL(НоменклатураДополнительныеРеквизиты.Значение, 0)
		|					КОНЕЦ КАК ЧИСЛО(15, 3))) * ВТ_Перемещения.КоличествоУпаковок
		|		КОНЕЦ) КАК МассаБрутто,
		|	СУММА(ВТ_Перемещения.НоменклатураВес * ВТ_Перемещения.Количество) КАК МассаНетто,
		|	ВТ_Перемещения.СкладОтправитель КАК СкладОтправитель,
		|	ВТ_Перемещения.СкладПолучатель КАК СкладПолучатель,
		|	ВТ_Перемещения.Организация КАК Организация,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.ПолучитьГрупповоеПеремещение.Результат}}"" КАК Метка
		|ИЗ
		|	ВТ_Перемещения КАК ВТ_Перемещения
		|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ТекущийПериод, ) КАК ЦеныНоменклатурыСрезПоследних
		|		ПО ВТ_Перемещения.СкладПолучательРозничныйВидЦены = ЦеныНоменклатурыСрезПоследних.ВидЦены
		|			И ВТ_Перемещения.Номенклатура = ЦеныНоменклатурыСрезПоследних.Номенклатура
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
		|		ПО ВТ_Перемещения.Номенклатура = НоменклатураДополнительныеРеквизиты.Ссылка
		|			И (НоменклатураДополнительныеРеквизиты.Свойство.Наименование = ""вес брутто"")
		|
		|СГРУППИРОВАТЬ ПО
		|	ВТ_Перемещения.Номенклатура,
		|	ВТ_Перемещения.ХарактеристикаНаименованиеПолное,
		|	ВЫБОР
		|		КОГДА ВТ_Перемещения.Упаковка <> ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
		|			ТОГДА ВТ_Перемещения.УпаковкаЕдиницаИзмеренияКод
		|		ИНАЧЕ ВТ_Перемещения.НоменклатураЕдиницаИзмеренияКод
		|	КОНЕЦ,
		|	ВТ_Перемещения.СкладОтправитель,
		|	ВТ_Перемещения.СкладПолучатель,
		|	ВТ_Перемещения.Организация,
		|	ВЫРАЗИТЬ(ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) / ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Упаковка.Коэффициент, 1) * ЕСТЬNULL(ВТ_Перемещения.УпаковкаКоэффициент, 1) КАК ЧИСЛО(15, 2)),
		|	ВТ_Перемещения.НоменклатураНаименованиеПолное,
		|	ВЫБОР
		|		КОГДА &ТоварКод = ""Код""
		|			ТОГДА ВТ_Перемещения.НоменклатураКод
		|		ИНАЧЕ ВТ_Перемещения.НоменклатураАртикул
		|	КОНЕЦ,
		|	ВЫБОР
		|		КОГДА ВТ_Перемещения.Упаковка <> ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
		|			ТОГДА ПРЕДСТАВЛЕНИЕССЫЛКИ(ВТ_Перемещения.УпаковкаЕдиницаИзмерения)
		|		ИНАЧЕ ПРЕДСТАВЛЕНИЕССЫЛКИ(ВТ_Перемещения.НоменклатураЕдиницаИзмерения)
		|	КОНЕЦ
		|
		|УПОРЯДОЧИТЬ ПО
		|	Товар
		|ИТОГИ ПО
		|	Организация,
		|	СкладПолучатель,
		|	СкладОтправитель
		|АВТОУПОРЯДОЧИВАНИЕ";
		
		Запрос.УстановитьПараметр("ТекущийПериод", ТекущаяДата());
		Запрос.УстановитьПараметр("ПеремещениеТоваров", МассивДокументов);
		Запрос.УстановитьПараметр("ТоварКод", ТоварКод);
		
		РезультатЗапроса = Запрос.Выполнить();
		Выборка = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		
		ШтрихкодНакладной = СоздатьШтрихкодНакладнойПоНомеруЗНО(МассивДокументов, ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрокаМаршрута.ЗНО, "Номер"));
		//ШтрихкодНакладной = СоздатьШтрихкодНакладной(МассивДокументов);
		Если ШтрихкодНакладной = Неопределено Тогда
			//Сообщить("Печать прервана! Маршрутный лист уже был напечатан!");
			//Возврат ТабДокумент;
		КонецЕсли; 
		
		Пока Выборка.Следующий() Цикл
			
			СведенияОбОрганизации = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(Выборка.Организация, ТекущаяДата());
			ВыборкаМагазинов = Выборка.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаМагазинов.Следующий() Цикл
				
				ОбщийПолучатель = ВыборкаМагазинов.СкладПолучатель;
				
				ВыборкаПолучателей.Сбросить();
				НомерДокументаСтрока="";
				ОбщийНомер="+";
				Пока ВыборкаПолучателей.НайтиСледующий(Новый структура("СкладПолучатель",ОбщийПолучатель)) Цикл
					// создадим строку номеров
					// выделим номер
					ЧастьНомера="";
					НомерДокумента = ВыборкаПолучателей.номер + " " + "от" + " " + Формат(ВыборкаПолучателей.Дата, "ДЛФ = Д");
					ДлинаНомера = стрдлина(НомерДокумента);
					Для сч = 0 по ДлинаНомера Цикл
						номерсимвола = длинаномера-сч;
						Сим = сред(НомерДокумента,номерсимвола,1);
						Если сим="-" Тогда
							прервать;
						КонецЕсли;
						ЧастьНомера = сим + ЧастьНомера ;
					КонецЦикла;
					// счас уберем левые нули
					Для сч=1 по стрдлина(частьномера) Цикл
						сим = сред(частьномера,сч,1);
						Если сим<>"0" Тогда
							Прервать;
						КонецЕсли;
					КонецЦикла;
					
					Если СокрЛП(частьномера) <> "" Тогда
						общийномер = общийномер + прав(ЧастьНомера,стрдлина(частьномера)-сч+1) + "+";
					КонецЕсли;
					НомерДокументаСтрока = НомерДокументаСтрока + НомерДокумента+"/";
					
				КонецЦикла;
				
				ОбластьШапки.Параметры.ПредставлениеОрганизации = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОбОрганизации);
				//Удалить старая версия, Заполняем Штрихкод
				//ЗаполнитьШтрихКодОбласть(ОбластьШапки, ОбщийНомер, ВнешняяКомпонента);
				//Если СтруктураПараметров.ВыводитьШтрихкод Тогда
				ОбластьШапки.Параметры.ШтрихкодДокумента = ШтрихкодНакладной;
				//ЗаполнитьШтрихКодОбласть(ОбластьШапки, ШтрихкодНакладной);
				//КонецЕсли; 
				ОбластьШапки.Параметры.НомерДокумента = НомерДокументаСтрока;
				ТабДокумент.Вывести(ОбластьШапки);
				
				// начнем 
				ВыборкаСкладов = ВыборкаМагазинов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				ИтогоКоличество  = 0;
				ИтогоМассаБрутто = 0;
				ИтогоМассаНетто  = 0;
				ИтогоСумма       = 0;
				
				Пока ВыборкаСкладов.Следующий() Цикл
					ОбщийОтправитель = ВыборкаСкладов.СкладОтправитель;
					// напечатаем заголовок отгрузки со склада
					ОбластьСклада.параметры.ОтправительПодразделение = ОбщийОтправитель;
					ОбластьСклада.параметры.ПолучательПодразделение = ОбщийПолучатель;
					ТабДокумент.Вывести(ОбластьСклада);
					
					выборкаСтрокТовары = выборкаскладов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
					КоличествоСтрок = ВыборкаСтрокТовары.Количество();
					
					Если КоличествоСтрок = 1 Тогда
						ПереноситьПоследнююСтроку = 0;
					Иначе
						ЦелыхСтраницСПодвалом     = Цел((СтрокШапки + КоличествоСтрок + СтрокПодвала) / СтрокНаСтранице);
						ЦелыхСтраницБезПодвала    = Цел((СтрокШапки + КоличествоСтрок - 1) / СтрокНаСтранице);
						ПереноситьПоследнююСтроку = ЦелыхСтраницСПодвалом - ЦелыхСтраницБезПодвала;
					КонецЕсли;
					
					// инициализация итогов по странице
					ИтогКоличествоМестПоСтранице = 0;
					ИтогМассаБруттоПоСтранице    = 0;
					ИтогМассаНеттоПоСтранице     = 0;
					ИтогСуммыПоСтранице          = 0;
					
					// инициализация итогов по документу
					
					Ном = 0;
					НомерСтраницы=1;
					ОбластьЗаголовка.Параметры.НомерСтраницы = "Страница " + НомерСтраницы; 
					ТабДокумент.Вывести(ОбластьЗаголовка);
					
					Пока выборкаСтроктовары.Следующий() Цикл
						// будем выводить товары
						Ном = Ном + 1;
						//Начинаем новую страницу, Если предыдущая строка была последней на странице
						//или пора переносить последнюю строку на последнюю страницу с подвалом.
						ЦелаяСтраница = (СтрокШапки + Ном - 1) / СтрокНаСтранице;
						
						Если (ЦелаяСтраница = Цел(ЦелаяСтраница))
							или ((ПереноситьПоследнююСтроку = 1) и (Ном = КоличествоСтрок)) Тогда
							
							ОбластьИтогоПоСтранице.Параметры.ИтогКоличествоМестПоСтранице = ИтогКоличествоМестПоСтранице;
							ОбластьИтогоПоСтранице.Параметры.ИтогМассаБруттоПоСтранице    = ИтогМассаБруттоПоСтранице;
							ОбластьИтогоПоСтранице.Параметры.ИтогМассаНеттоПоСтранице     = ИтогМассаНеттоПоСтранице;
							ОбластьИтогоПоСтранице.Параметры.ИтогСуммыПоСтранице          = ИтогСуммыПоСтранице;
							
							ТабДокумент.Вывести(ОбластьИтогоПоСтранице);
							
							// инициализация итогов по странице
							ИтогКоличествоМестПоСтранице = 0;
							ИтогМассаБруттоПоСтранице    = 0;
							ИтогМассаНеттоПоСтранице     = 0;
							ИтогСуммыПоСтранице          = 0;
							
							НомерСтраницы = НомерСтраницы + 1;
							ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
							ОбластьЗаголовка.Параметры.НомерСтраницы = "Страница " + НомерСтраницы;
							ТабДокумент.Вывести(ОбластьЗаголовка);
							
						КонецЕсли;
						
						ОбластьСтроки.Параметры.Заполнить(ВыборкаСтрокТовары);
						
						КоличествоМест = Формат(ВыборкаСтрокТовары.Количество, "ЧЦ=15; ЧДЦ=3");
						
						ОбластьСтроки.Параметры.КоличествоМест    = КоличествоМест;
						
						ОбластьСтроки.Параметры.ТоварНаименование = ФормированиеПечатныхФорм.ПолучитьПредставлениеНоменклатурыДляПечати(
						СокрЛП(ВыборкаСтрокТовары.ТоварНаименование),
						СокрЛП(ВыборкаСтрокТовары.Характеристика));
						
						Сумма = ВыборкаСтрокТовары.Количество * ВыборкаСтрокТовары.Цена;
						
						ОбластьСтроки.Параметры.Сумма = Сумма;
						
						ТабДокумент.Вывести(ОбластьСтроки);
						
						// Обновим итоги по странице
						ИтогКоличествоМестПоСтранице = ИтогКоличествоМестПоСтранице + ВыборкаСтрокТовары.Количество;
						ИтогМассаБруттоПоСтранице    = ИтогМассаБруттоПоСтранице    + ВыборкаСтрокТовары.МассаБрутто;
						ИтогМассаНеттоПоСтранице     = ИтогМассаНеттоПоСтранице     + ВыборкаСтрокТовары.МассаНетто;
						ИтогСуммыПоСтранице          = ИтогСуммыПоСтранице          + Сумма;
						
						// Обновим итогов по документу
						ИтогоКоличество  = ИтогоКоличество  + ВыборкаСтрокТовары.Количество;
						ИтогоМассаБрутто = ИтогоМассаБрутто + ВыборкаСтрокТовары.МассаБрутто;
						ИтогоМассаНетто  = ИтогоМассаНетто  + ВыборкаСтрокТовары.МассаНетто;
						ИтогоСумма       = ИтогоСумма       + Сумма;
						
					КонецЦикла;
					
				КонецЦикла;		
				// завершим печать накладной
				ОбластьИтогоПоСтранице.Параметры.ИтогКоличествоМестПоСтранице = ИтогКоличествоМестПоСтранице;
				ОбластьИтогоПоСтранице.Параметры.ИтогМассаБруттоПоСтранице    = ИтогМассаБруттоПоСтранице;
				ОбластьИтогоПоСтранице.Параметры.ИтогМассаНеттоПоСтранице     = ИтогМассаНеттоПоСтранице;
				ОбластьИтогоПоСтранице.Параметры.ИтогСуммыПоСтранице          = ИтогСуммыПоСтранице;
				
				ТабДокумент.Вывести(ОбластьИтогоПоСтранице);
				
				// Выводим итоги по документу в целом
				ОбластьМакета = Макет.ПолучитьОбласть("Всего");
				ОбластьМакета.Параметры.ИтогоКоличествоМест = ИтогоКоличество;
				ОбластьМакета.Параметры.ИтогоМассаБрутто    = ИтогоМассаБрутто;
				ОбластьМакета.Параметры.ИтогоМассаНетто     = ИтогоМассаНетто;
				ОбластьМакета.Параметры.ИтогоСумма          = ИтогоСумма;
				
				ТабДокумент.Вывести(ОбластьМакета);
				
				// Выводим подвал документа
				ОбластьМакета  = Макет.ПолучитьОбласть("Подвал");
				//ОбластьМакета.Параметры.Заполнить(Шапка);
				
				ОбластьМакета.Параметры.ДолжностьОтправителя = "";
				ОбластьМакета.Параметры.ФИООтправителя       = "";//ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Шапка.КладовщикОтправитель);
				
				ОбластьМакета.Параметры.ДолжностьПолучателя  = "";//Шапка.ДолжностьКладовщикаПолучателя;
				ОбластьМакета.Параметры.ФИОПолучателя        = "";//ФормированиеПечатныхФорм.ФамилияИнициалыФизЛица(Шапка.КладовщикПолучатель);
				
				//Если ЗначениеЗаполнено(Шапка.УчетныйВидЦеныВалютаЦены) Тогда
				ОбластьМакета.Параметры.ИтогоСуммаПрописью = РаботаСКурсамиВалют.СформироватьСуммуПрописью(Цел(ИтогоСумма),ВалютаЦены, Истина);
				//Иначе
				//	ОбластьМакета.Параметры.ИтогоСуммаПрописью = НСтр("ru = 'Ноль'");
				//КонецЕсли;
				
				ОбластьМакета.Параметры.ИтогоСуммаКоп      = Формат(Цел((ИтогоСумма-Цел(ИтогоСумма))*100), "ЧЦ=2; ЧН=00");
				
				ТабДокумент.Вывести(ОбластьМакета);
				
				ТабДокумент.ВывестиГоризонтальныйРазделительСтраниц();
				
			КонецЦикла;
		КонецЦикла;
	КонецЦикла;
	
	СохранитьДанныеОПечати(МассивПечать, "Торг 13", СтрокаМаршрута.ЗНО, ТабДокумент.КоличествоЭкземпляров);
	
	Возврат ТабДокумент;
	
КонецФункции // ПечатьТОРГ13()
//конец печать ТОРГ13

Функция ПолучитьГрупповоеПеремещениеОПТ(СтрокаМаршрута)
	
	
	МассивОбъектов = Новый Массив;
	Для Каждого Строка Из СтрокаМаршрута.Строки ЦИкл
		
		Если Строка.Пометка И ТипЗнч(Строка.Автомобиль) = Тип("ДокументСсылка.ПеремещениеТоваров") ТОгда
			МассивОбъектов.Добавить(Строка.Автомобиль);
		КонецЕсли;
		
	КонецЦикла;
	
	Возврат СформироватьПечатнуюФормуТОРГ13ОПТ(МассивОбъектов, Новый СписокЗначений);
	
	
КонецФункции // ПечатьТОРГ13()

Процедура ЗадатьПараметрыМакета(ТабДокумент)
	
	ТабДокумент.ПолеСверху = 5;
	ТабДокумент.ПолеСлева  = 5;
	ТабДокумент.ПолеСнизу  = 5;
	ТабДокумент.ПолеСправа = 5;
	ТабДокумент.РазмерКолонтитулаСверху = 0;
	ТабДокумент.РазмерКолонтитулаСнизу = 0;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДокумент.АвтоМасштаб = Истина;
	
КонецПроцедуры

Функция СформироватьПечатнуюФормуТОРГ13ОПТ(МассивОбъектов, ОбъектыПечати)
	
	////Соловьев И.В. Подключаем внешнюю компаненту штрихкода
	//ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
	////Соловьев И.В.
	
	ТоварКод = ФормированиеПечатныхФорм.ИмяДополнительнойКолонки();
	Если Не ЗначениеЗаполнено(ТоварКод) Тогда
		ТоварКод = "Код";
	КонецЕсли;
	
	Макет = РеквизитФормыВЗначение("Объект").ПолучитьМакет("Торг13ОПТ");
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_ТОРГ13";
	
	ЗадатьПараметрыМакета(ТабДокумент);
	
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Перемещение.Ссылка                                          КАК Ссылка,
	|	Перемещение.Номер                                           КАК Номер,
	|	Перемещение.Дата                                            КАК ДатаДокумента,
	|	ВЫБОР
	|		КОГДА Перемещение.ЗаказНаПеремещение = Неопределено
	|		ТОГДА """"
