&НаСервере
Функция ПолучитьТранспортнуюНакладнуюИнойПеревозчикЧерезКаргомарт(СтрокаМаршрута, ПараметрыФормированияТН)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ДляНалоговой = ПараметрыФормированияТН.ДляНалоговой;
	ОчиститьЭкспедитора = ПараметрыФормированияТН.ОчиститьЭкспедитора;
	ОчиститьПеревозчика = ПараметрыФормированияТН.ОчиститьПеревозчика;
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ПолеСверху = 0;
	ТабДокумент.ПолеСлева  = 0;
	ТабДокумент.ПолеСнизу  = 0;
	ТабДокумент.ПолеСправа = 0;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет; 
	Если ДвусторонняяПечатьТранспортнойНакладной тогда
		ТабДокумент.ДвусторонняяПечать = ТипДвустороннейПечати.ПереворотВлево;
	КонецЕсли;	
		//ТабДокумент.КоличествоЭкземпляров = 1;
	ТабДокумент.АвтоМасштаб = Истина;
	
	Обработка = РеквизитФормыВЗначение("Объект");		
	Макет = Обработка.ПолучитьМакет("ТранспортнаяНакладная2022");
	Область1 = Макет.ПолучитьОбласть("Область1");
	Область2 = Макет.ПолучитьОбласть("Область2");
	Область3 = Макет.ПолучитьОбласть("Область3");
	
	РеквизитыЗНО = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(СтрокаМаршрута.ЗНО, "Дата, Номер, ДатаОтгрузки, Перевозчик");
	
	МассивДокументов = Новый Массив;
	Для Каждого СтрЗаказ Из СтрокаМаршрута.Строки Цикл
		Если (ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.ПеремещениеТоваров") 
			ИЛИ  ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.РеализацияТоваровУслуг"))
			И (ЗначениеЗаполнено(СтрЗаказ.Автомобиль)) И Не СтрЗаказ.Пометка = 0 Тогда
			МассивДокументов.Добавить(СтрЗаказ.Автомобиль);
		ИначеЕсли Не ЗначениеЗаполнено(СтрЗаказ.Автомобиль) И ТипЗнч(СтрЗаказ.ЗНО)=Тип("ДокументСсылка.ЗаказКлиента") И СтрЗаказ.ОбобщенныйДокумент И СтрЗаказ.Пометка = 1 Тогда
			МассивДокументов.Добавить(СтрЗаказ.ЗНО);
		ИначеЕсли Не ЗначениеЗаполнено(СтрЗаказ.Автомобиль) И ТипЗнч(СтрЗаказ.ЗНО)=Тип("ДокументСсылка.ЗаказПоставщику") И СтрЗаказ.Пометка = 1 И ЗначениеЗаполнено(СтрЗаказ.Водитель)
			И ТипЗнч(СтрЗаказ.Водитель) = Тип("СправочникСсылка.Склады") И ОбщегоНазначения.ПолучитьЗначениеРеквизита(СтрЗаказ.Водитель, "ТИпСклада") = Перечисления.ТипыСкладов.ОптовыйСклад Тогда
			МассивДокументов.Добавить(СтрЗаказ.ЗНО);
		КонецЕсли;	
	КонецЦикла;
	
	ШтрихкодНакладной = СоздатьШтрихкодНакладнойПоНомеруЗНО(МассивДокументов, РеквизитыЗНО.Номер);
	
	МассивСкладов = Новый Массив;	
	СоответствиеОбобщенных = Новый Соответствие;
	Для Каждого ТекДок из МассивДокументов Цикл
		Если ТипЗнч(ТекДок) = тип("ДокументСсылка.ПеремещениеТоваров") Тогда
			ИскомыйСклад = МассивСкладов.Найти(ТекДок.СкладПолучатель);
			Если ПустаяСтрока(ИскомыйСклад) Тогда
				МассивСкладов.Добавить(ТекДок.СкладПолучатель);
			КонецЕсли; 
		Иначе	
			СкладКонтрагента = НайтиСкладКонтрагента(ТекДок.Контрагент);
			Если Не ЗначениеЗаполнено(СкладКонтрагента) Тогда
				
				КонтрагентСОбобщеннымиДокументами = СоответствиеОбобщенных.Получить(ТекДок.Контрагент); 
				Если КонтрагентСОбобщеннымиДокументами = Неопределено Тогда
					КонтрагентСОбобщеннымиДокументами = КонтрагентСОбобщеннымиДокументами(ТекДок.Контрагент) = Истина;
					СоответствиеОбобщенных.Вставить(ТекДок.Контрагент, КонтрагентСОбобщеннымиДокументами); 
				КонецЕсли;
				
				Если КонтрагентСОбобщеннымиДокументами Тогда	
					Если МассивСкладов.Найти(ТекДок.Контрагент) = Неопределено ТОгда	
						МассивСкладов.Добавить(ТекДок.Контрагент);	
					КонецЕсли;	
				КонецЕсли;
				
			Иначе
				
				ИскомыйСклад = МассивСкладов.Найти(СкладКонтрагента);
				Если ПустаяСтрока(ИскомыйСклад) Тогда
					МассивСкладов.Добавить(СкладКонтрагента);
				КонецЕсли; 
				
			КонецЕсли; 	
		КонецЕсли;	
	КонецЦикла;
		
	// теперь напечатаем ТТН-ку общую на все документы
	// получим список документов на которые печатаем ТТН
	
	// это самый верхний уровень - по машинкам
