		//	"ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны,НомерСчета,Банк,БИК,КоррСчет");
		
		СкладПолучатель = ПолучитьСкладПолучатель(Шапка.Ссылка);
		АдресСклада = ПолучитьАдресМагазина(СкладПолучатель);
		КодМагазинаСклада = ПолучитьКодМагазинаСклада(СкладПолучатель);
		Если Не ПустаяСтрока(КодМагазинаСклада) Тогда
			КодМагазинаСклада = СтрШаблон(" (%1)", КодМагазинаСклада);
