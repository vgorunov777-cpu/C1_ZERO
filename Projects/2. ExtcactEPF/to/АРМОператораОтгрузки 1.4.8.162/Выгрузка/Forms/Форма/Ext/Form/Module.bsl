			ОбластьМакета.Параметры.МассаГрузаНеттоПрописью = ЧислоПрописью(Окр(ИтогоМассаНетто*1000),"НП=Ложь",",,,,,,,,0")+ " кг.";
		КонецЕсли;
		
		ОбластьМакета.Параметры.КоличествоПорядковыхНомеровЗаписейПрописью = ЧислоПрописью(КоличествоНаименований, ,",,,,,,,,0");
		ОбластьМакета.Параметры.ВсегоНаименованийПрописью = ЧислоПрописью(КоличествоНаименований, ,",,,,,,,,0");
		ОбластьМакета.Параметры.СуммаПрописью = РаботаСКурсамиВалют.СформироватьСуммуПрописью(ИтогоСумма, Константы.ВалютаРегламентированногоУчета.Получить());
		ТабличныйДокумент.Вывести(ОбластьМакета);
		
		//Транспортный раздел
		ТабличныйДокумент.ВывестиГоризонтальныйРазделительСтраниц();
		
		ОбластьМакета = Макет.ПолучитьОбласть("ТранспортныйРаздел");
		///////
		
