&НаСервере
Функция ПолучитьГрупповоеПеремещение(СтрокаМаршрута)
	
	УстановитьПривилегированныйРежим(Истина);
	
	СкладОтправитель1 = Справочники.Склады.НайтиПоНаименованию("Склад Хозяйственные товары");
	СкладОтправитель2 = Справочники.Склады.НайтиПоНаименованию("Обх Склад Хозяйственные товары");
	СкладОтправитель3 = Справочники.Склады.НайтиПоНаименованию("Склад оборудования");
	СкладОтправитель4 = Справочники.Склады.НайтиПоНаименованию("Обх Склад оборудования");
	СкладОтправитель5 = Справочники.Склады.НайтиПоНаименованию("Склад IT");
	СкладОтправитель6 = Справочники.Склады.НайтиПоНаименованию("Обх Склад IT");
	
	//+Буганов
	СкладОтправитель7 = Справочники.Склады.НайтиПоНаименованию("Обх Склад охлажденка");
	СкладОтправитель8 = Справочники.Склады.НайтиПоНаименованию("Склад охлажденка");
	
	МассивХозТоваров		= Новый Массив;
	МассивОборудования		= Новый Массив;
	МассивДокументовДляIT	= Новый Массив;
	//+Буганов
	МассивДокументовАлкоголь= Новый Массив;
	//-
	
	МассивПечать = Новый Массив;
	Для Каждого СтрЗаказ Из СтрокаМаршрута.Строки Цикл
		Если ТипЗнч(СтрЗаказ.Автомобиль)=Тип("ДокументСсылка.ПеремещениеТоваров") И ЗначениеЗаполнено(СтрЗаказ.Автомобиль) И Не СтрЗаказ.Пометка = 0 Тогда
			
			ТекПеремещение = СтрЗаказ.Автомобиль;
			
			Если НЕ ТекПеремещение.Проведен Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Нельзя печатать не проведенные документы!");
				Продолжить;
			КонецЕсли; 
			
			//+Буганов
			Если ТекПеремещение.ЗаказНаПеремещение.УчетВЕГАИС И Ложь Тогда
				МассивДокументовАлкоголь.Добавить(ТекПеремещение); 
				МассивПечать.Добавить(ТекПеремещение);
				//-
			ИначеЕсли ТекПеремещение.СкладОтправитель = СкладОтправитель1
				ИЛИ ТекПеремещение.СкладОтправитель = СкладОтправитель2
				ИЛИ ТекПеремещение.СкладОтправитель = СкладОтправитель7
				ИЛИ ТекПеремещение.СкладОтправитель = СкладОтправитель8
				Тогда
				МассивХозТоваров.Добавить(ТекПеремещение);
				МассивПечать.Добавить(ТекПеремещение);
			ИначеЕсли ТекПеремещение.СкладОтправитель = СкладОтправитель3
				ИЛИ ТекПеремещение.СкладОтправитель = СкладОтправитель4 Тогда
				МассивОборудования.Добавить(ТекПеремещение);
				МассивПечать.Добавить(ТекПеремещение);
			ИначеЕсли ТекПеремещение.СкладОтправитель = СкладОтправитель5
				ИЛИ ТекПеремещение.СкладОтправитель = СкладОтправитель6 Тогда
				МассивДокументовДляIT.Добавить(ТекПеремещение); 
				МассивПечать.Добавить(ТекПеремещение);
			КонецЕсли; 
		КонецЕсли; 
	КонецЦикла; 
	
	МД = Новый Массив;
	МД.Добавить(МассивХозТоваров);
	МД.Добавить(МассивОборудования);
	МД.Добавить(МассивДокументовДляIT);
	МД.Добавить(МассивДокументовАлкоголь);
	//
	////Соловьев И.В. Подключаем внешнюю компаненту штрихкода
	//ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
	////Соловьев И.В.
	Обработка = РеквизитФормывЗначение("Объект");
	ТоварКод = ФормированиеПечатныхФорм.ИмяДополнительнойКолонки();
	
	Если Не ЗначениеЗаполнено(ТоварКод) Тогда
		ТоварКод = "Код";
	КонецЕсли;
	
	Макет = Обработка.ПолучитьМакет("ТОРГ13");
	
	ТабДокумент = Новый ТабличныйДокумент;
	ТабДокумент.ИмяПараметровПечати = "ПАРАМЕТРЫ_ПЕЧАТИ_ПеремещениеТоваров_ТОРГ13";
	ВалютаЦены = Справочники.Валюты.НайтиПоКоду("810");
	// Зададим параметры Макета
	ТабДокумент.ПолеСверху = 0;
	ТабДокумент.ПолеСлева  = 0;
	ТабДокумент.ПолеСнизу  = 0;
	ТабДокумент.ПолеСправа = 0;
	ТабДокумент.ОриентацияСтраницы = ОриентацияСтраницы.Портрет;
	ТабДокумент.АвтоМасштаб = Истина;
	
	// получим области
	ОбластьШапки         = Макет.ПолучитьОбласть("Шапка");
	//Если СтруктураПараметров.ВыводитьШтрихкод  Тогда
	//	ОбластьШапки         = Макет.ПолучитьОбласть("Шапка");
	//Иначе
	//	ОбластьШапки         = Макет.ПолучитьОбласть("ШапкаБезШК");
	//КонецЕсли; 
	
	ОбластьСклада =           Макет.ПолучитьОбласть("ЗаголовокСклада");
	ОбластьЗаголовка =        Макет.ПолучитьОбласть("ЗаголовокТаблицы");
	ОбластьСтроки =           Макет.ПолучитьОбласть("Строка");
	ОбластьИтогоПоСтранице =  Макет.ПолучитьОбласть("ИтогиПоСтранице");
	ОбластьВсего =            Макет.ПолучитьОбласть("Всего");
	ОбластьПодвал =           Макет.ПолучитьОбласть("Подвал");
	СтрокНаСтранице = 70;  //23
	СтрокШапки      = 10;
	СтрокПодвала    = 9;
	НомерСтраницы   = 1;
	
	
	Для Каждого МассивДокументов Из МД Цикл
		
		// на каждый маршрут - один документ перемещения
		НомерДокументаСтрока="";
		
		// надо получить данные по магазинам... Для печати накладных
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		|	ПеремещениеТоваров.Номер,
		|	ПеремещениеТоваров.Дата,
		|	ПеремещениеТоваров.СкладПолучатель
		|ИЗ
		|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
		|ГДЕ
		|	ПеремещениеТоваров.Ссылка В(&Ссылка)";
		
		Запрос.УстановитьПараметр("Ссылка", МассивДокументов);
		
		РезультатЗапроса = Запрос.Выполнить();
		ВыборкаПолучателей = РезультатЗапроса.Выбрать();
		
		// счас получим Запросом состав документов, сгруппируем по складу отправителю, складу получателю...
		// еще и цену надо получить в Запросе
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ
		|	ПеремещениеТоваров.СкладОтправитель,
		|	ПеремещениеТоваров.СкладПолучатель,
		|	ПеремещениеТоваров.Организация,
		|	ПеремещениеТоваров.Дата,
		|	ПеремещениеТоваров.Ссылка,
		|	ПеремещениеТоваров.СкладПолучатель.РозничныйВидЦены,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.ПолучитьГрупповоеПеремещение.ВТ_ПеремещенияШапки}}"" КАК Метка
		|ПОМЕСТИТЬ ВТ_ПеремещенияШапки
		|ИЗ
		|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
		|ГДЕ
		|	ПеремещениеТоваров.Ссылка В(&ПеремещениеТоваров)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ПеремещениеТоваровТовары.Ссылка,
		|	ПеремещениеТоваровТовары.Номенклатура,
		|	ПеремещениеТоваровТовары.Номенклатура.НаименованиеПолное,
		|	ПеремещениеТоваровТовары.Номенклатура.Код,
		|	ПеремещениеТоваровТовары.Номенклатура.Артикул,
		|	ПеремещениеТоваровТовары.Характеристика.НаименованиеПолное,
		|	ПеремещениеТоваровТовары.Упаковка,
		|	ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения,
		|	ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения,
		|	ПеремещениеТоваровТовары.Упаковка.ЕдиницаИзмерения.Код,
		|	ПеремещениеТоваровТовары.Номенклатура.ЕдиницаИзмерения.Код,
		|	ПеремещениеТоваровТовары.КоличествоУпаковок,
		|	ПеремещениеТоваровТовары.Упаковка.Коэффициент,
		|	ПеремещениеТоваровТовары.Номенклатура.Вес,
		|	ПеремещениеТоваровТовары.Количество,
		|	""{{ВнешняяОбработка.АРМОператораОтгрузки.Форма.ПолучитьГрупповоеПеремещение.ВТ_ПеремещенияТовары}}"" КАК Метка
		|ПОМЕСТИТЬ ВТ_ПеремещенияТовары
		|ИЗ
		|	Документ.ПеремещениеТоваров.Товары КАК ПеремещениеТоваровТовары
		|ГДЕ
		|	ПеремещениеТоваровТовары.Ссылка В(&ПеремещениеТоваров)
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ВТ_ПеремещенияШапки.СкладОтправитель,
		|	ВТ_ПеремещенияШапки.СкладПолучатель,
		|	ВТ_ПеремещенияШапки.Организация,
		|	ВТ_ПеремещенияШапки.Дата,
