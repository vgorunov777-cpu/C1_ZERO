&НаСервере
Функция СоздатьШтрихкодНакладной(МассивДокументов)
	
	Попытка
		НачатьТранзакцию();
		
		Запрос = Новый Запрос;
		Запрос.УстановитьПараметр("Объект", МассивДокументов);
		Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ ДополнительныеСведения.Значение КАК Значение
		|ИЗ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		|ГДЕ ДополнительныеСведения.Свойство.Наименование = ""Штрихкод документа""
		|	И ДополнительныеСведения.Объект В(&Объект)
		|СГРУППИРОВАТЬ ПО
		|	ДополнительныеСведения.Значение";
		
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			
			Запрос = Новый Запрос;
			Запрос.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1
			|	ПОДСТРОКА(ВЫРАЗИТЬ(ДополнительныеСведения.Значение КАК СТРОКА(150)), 1, 11) КАК Значение
			|ИЗ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
			|ГДЕ ДополнительныеСведения.Свойство.Наименование = ""Штрихкод документа""
			|
			|ДЛЯ ИЗМЕНЕНИЯ РегистрСведений.ДополнительныеСведения
			|
			|УПОРЯДОЧИТЬ ПО
			|	Значение УБЫВ
			|АВТОУПОРЯДОЧИВАНИЕ";
			
			РезультатЗапроса = Запрос.Выполнить();
			Если РезультатЗапроса.Пустой() Тогда
				Возврат "0"; 
			КонецЕсли; 
			ТаблицаДетальныеЗаписи = РезультатЗапроса.Выгрузить();
			ПоследнийНомерМаршрута = ТаблицаДетальныеЗаписи[0].Значение;
			
			//ПоследнийШтрихкод = Формат(Число(ПолучитьПоследнийШтрихкодПоСвойству()) +1, "ЧЦ=11; ЧВН=; ЧГ=0") + "+" + Формат(ТекущаяДата(), "ДФ='dd.MM.yyyy HH:mm'") + "+" + 46;
			ПоследнийШтрихкод = Формат(Число(ПоследнийНомерМаршрута) +1, "ЧЦ=11; ЧВН=; ЧГ=0") + "+" + Формат(ТекущаяДата(), "ДФ='dd.MM.yyyy HH:mm'") + "+" + 46;
		Иначе
			Выборка = РезультатЗапроса.Выбрать();
			Пока Выборка.Следующий() Цикл
				Возврат Выборка.Значение;//ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Выборка.Значение);
			КонецЦикла;
			
			ЗафиксироватьТранзакцию();
			Возврат Неопределено;
		КонецЕсли; 
		
		СвойствоШКДокумента = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Штрихкод документа");
		Для Каждого ТекДок Из МассивДокументов Цикл
			//Если уже записан так же штрихкод, не записывать
			НаборЗаписейДопСв = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
			НаборЗаписейДопСв.Объект = ТекДок;
			НаборЗаписейДопСв.Свойство = СвойствоШКДокумента;
			НаборЗаписейДопСв.Значение = ПоследнийШтрихкод;
			НаборЗаписейДопСв.Записать(Истина);
			ЗаписьЖурналаРегистрации("Создание штрихкода документа", УровеньЖурналаРегистрации.Информация,, ТекДок, "ШтрихКод: " + ПоследнийШтрихкод + " " + "Создал: " + Строка(ПараметрыСеанса.ТекущийПользователь));
		КонецЦикла; 
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
	КонецПопытки;
	
	Возврат ПоследнийШтрихкод;
	
КонецФункции

Функция СоздатьШтрихкодНакладнойПоНомеруЗНО(МассивДокументов, НомерЗНО)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЕСТЬNULL(ДополнительныеСведения.Значение, """") КАК ШК,
	|	ПеремещениеТоваров.Ссылка
	|ИЗ
	|	Документ.ПеремещениеТоваров КАК ПеремещениеТоваров
	|		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|		ПО (ПеремещениеТоваров.Ссылка = (ВЫРАЗИТЬ(ДополнительныеСведения.Объект КАК Документ.ПеремещениеТоваров)))
	|			И (ДополнительныеСведения.Свойство.Наименование = ""Штрихкод документа"")
	|ГДЕ
	|	ПеремещениеТоваров.Ссылка В(&МассивДокументов)
	|	И НЕ ЕСТЬNULL(ВЫРАЗИТЬ(ДополнительныеСведения.Значение КАК СТРОКА), """") ПОДОБНО &НомерЗНО";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	Запрос.УстановитьПараметр("НомерЗНО", НомерЗНО);
	
	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	Штрихкод = НомерЗНО;
	//+БАА убрать транзакцию от дедлоков
	//НачатьТранзакцию();
	СвойствоШКДокумента = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Штрихкод документа");
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		//Если уже записан так же штрихкод, не записывать
		НаборЗаписейДопСв = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
		НаборЗаписейДопСв.Объект = ВыборкаДетальныеЗаписи.Ссылка;
		НаборЗаписейДопСв.Свойство = СвойствоШКДокумента;
		НаборЗаписейДопСв.Значение = Штрихкод;
		Попытка
			НаборЗаписейДопСв.Записать(Истина);
		Исключение
		//	ОтменитьТранзакцию();
		КонецПопытки;
		ЗаписьЖурналаРегистрации("Создание штрихкода документа", УровеньЖурналаРегистрации.Информация,, ВыборкаДетальныеЗаписи.Ссылка, "ШтрихКод: " + Штрихкод + " " + "Создал: " + Строка(ПараметрыСеанса.ТекущийПользователь));
	КонецЦикла;
	
	//ЗафиксироватьТранзакцию();
	
	Возврат Штрихкод;
	
КонецФункции


&НаСервере
Функция НайтиШтрихкодДокументов(МассивДокументов)
	
	УстановитьПривилегированныйРежим(Истина);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ РАЗЛИЧНЫЕ
	|	ДополнительныеСведения.Значение КАК Значение
	|ИЗ
	|	РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	|ГДЕ
	|	ДополнительныеСведения.Свойство.Наименование = ""Штрихкод документа""
	|	И ДополнительныеСведения.Объект В(&Объект)
	|
	|СГРУППИРОВАТЬ ПО
	|	ДополнительныеСведения.Значение
	|
	|//ДЛЯ ИЗМЕНЕНИЯ РегистрСведений.ДополнительныеСведения
	|";
	
	Запрос.УстановитьПараметр("Объект", МассивДокументов);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли; 
	
	Возврат РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Значение");
	
КонецФункции

&НаСервере
Процедура ЗаполнитьШтрихКодОбласть(Область, ЗначениеШтрихкода)
	
	ВнешняяКомпонента = ПолучитьВнешнююКомпонентуПечатиШтрихкода();
	
	Для Каждого Рисунок Из Область.Рисунки Цикл
		Если ВРЕГ(Лев(Рисунок.Имя,8)) = "ШТРИХКОД" Тогда
			
			Если ВнешняяКомпонента = Неопределено Тогда
				ВызватьИсключение НСтр("ru = 'Ошибка подключения внешней компоненты печати штрихкода!'");
			КонецЕсли;
			
			Если ЗначениеЗаполнено(ЗначениеШтрихкода) Тогда
				
				ПараметрыШтрихкода = Новый Структура;
				ПараметрыШтрихкода.Вставить("Ширина",          Рисунок.Ширина);
				ПараметрыШтрихкода.Вставить("Высота",          Рисунок.Высота);
				ПараметрыШтрихкода.Вставить("Штрихкод",        ЗначениеШтрихкода);
				ПараметрыШтрихкода.Вставить("ТипКода",         4); //3 = Code39, 4 = Code128
				ПараметрыШтрихкода.Вставить("ОтображатьТекст", Ложь);
				ПараметрыШтрихкода.Вставить("РазмерШрифта",    6);
				
				Рисунок.Картинка = ПолучитьКартинкуШтрихкода(ВнешняяКомпонента, ПараметрыШтрихкода);
				
			КонецЕсли;
			
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере           
Функция ПолучитьКартинкуШтрихкода(ВнешняяКомпонента, ПараметрыШтрихкода) Экспорт
	
	// Зададим размер картинки
	ВнешняяКомпонента.Ширина = Окр(ПараметрыШтрихкода.Ширина);
	ВнешняяКомпонента.Высота = Окр(ПараметрыШтрихкода.Высота);
	
	// Разрешим компоненте самой определять тип кода
	ВнешняяКомпонента.АвтоТип = Ложь;
	ВнешняяКомпонента.ТипКода         = ПараметрыШтрихкода.ТипКода;
	ВнешняяКомпонента.ОтображатьТекст = ПараметрыШтрихкода.ОтображатьТекст;
	ВнешняяКомпонента.РазмерШрифта    = ПараметрыШтрихкода.РазмерШрифта;
	
	// Или установим код EAN-13
	// ВнешняяКомпонента.ТипКода = 1;
	//
	// Тип смотрим в документации на внешнуюю компоненту
	
	// Если код содержит контрольный символ, обязательно указываем
	ВнешняяКомпонента.СодержитКС = СтрДлина(ПараметрыШтрихкода.Штрихкод) = 13;
	
	// Если отображать контрольный символ не нужно
	// ВнешняяКомпонента.ВидимостьКС = Ложь;
	
	// Формируем картинку штрихкода
	ВнешняяКомпонента.ЗначениеКода = ПараметрыШтрихкода.Штрихкод;
	
	// Если установленная нами ширина меньше минимально допустимой Для этого штрихкода
	Если ВнешняяКомпонента.Ширина < ВнешняяКомпонента.МинимальнаяШиринаКода Тогда
		// Скорректируем ширину
		ВнешняяКомпонента.Ширина = ВнешняяКомпонента.МинимальнаяШиринаКода + 10;
	КонецЕсли;
	
	// Сформируем картинку
	Попытка
		ДвоичныеДанныеКартинки = ВнешняяКомпонента.ПолучитьШтрихкод();
	Исключение
		ДвоичныеДанныеКартинки = Неопределено;
	КонецПопытки;
	
	// Если картинка сформировалась
	Если ДвоичныеДанныеКартинки <> Неопределено Тогда
		// Формируем из двоичных данных
		Возврат Новый Картинка(ДвоичныеДанныеКартинки);
	КонецЕсли;
	
	Возврат Неопределено;
	
КонецФункции

&НаСервере
Функция ПолучитьИнформациюОМагазине(Склад)
	
	СтруктураОтвет = Новый Структура("РежимРаботыГрузчиков, ТипРазгрузки", Неопределено, Неопределено);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	СкладыДополнительныеРеквизиты.Значение,
	|	СкладыДополнительныеРеквизиты.Свойство,
	|	СкладыДополнительныеРеквизиты.Свойство.Наименование КАК СвойствоНаименование
	|ИЗ
	|	Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
	|ГДЕ
	|	(СкладыДополнительныеРеквизиты.Свойство.Наименование = ""РежимРаботыГрузчиков""
	|			ИЛИ СкладыДополнительныеРеквизиты.Свойство.Наименование = ""ТипРазгрузки"")
	|	И СкладыДополнительныеРеквизиты.Ссылка = &Склад";
	
	Запрос.УстановитьПараметр("Склад", Склад);
	
	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если ВыборкаДетальныеЗаписи.СвойствоНаименование = "РежимРаботыГрузчиков" Тогда
			СтруктураОтвет.РежимРаботыГрузчиков = ВыборкаДетальныеЗаписи.Значение;
		Иначе
			СтруктураОтвет.ТипРазгрузки = ВыборкаДетальныеЗаписи.Значение;
		КонецЕсли; 
	КонецЦикла;
	
	Возврат СтруктураОтвет;
