				Если ПустаяСтрока(СтруктураДат) Тогда
					ОбластьСтрокТовары.Параметры.ДатаВыработки = "";
				Иначе
					ОбластьСтрокТовары.Параметры.ДатаВыработки = "" + СтруктураДат.ДатаВыработки;
				КонецЕсли; 
			КонецЕсли; 
			
			Если НЕ ПустаяСтрока(СтруктураДат) И НЕ ПустаяСтрока(СтруктураДат.НомерВетСвидетельства) Тогда
				ОбластьСтрокТовары.Параметры.НомерВетСвидетельства = СтруктураДат.НомерВетСвидетельства;
			Иначе
				ОбластьСтрокТовары.Параметры.НомерВетСвидетельства = "";
				
				МассивНоменклатура = Новый Массив();
				МассивНоменклатура.Добавить(ВыборкаСтрокТовары.Номенклатура);
				ТаблицаДатПоНоменклатуре	= НайтиДокументыПоступленияПоНоменклатуре(МассивНоменклатура);
				СтруктураДат				= ТаблицаДатПоНоменклатуре.Найти(ВыборкаСтрокТовары.Номенклатура, "Номенклатура");
				
				Если ПустаяСтрока(СтруктураДат) Тогда
					ОбластьСтрокТовары.Параметры.НомерВетСвидетельства = "";
				Иначе
					ОбластьСтрокТовары.Параметры.НомерВетСвидетельства = СтруктураДат.НомерВетСвидетельства;
				КонецЕсли; 
			КонецЕсли; 
			
			ГдеБратьПроизводителя = ПолучитьПоставщикаИзПоступления(ВыборкаСтрокТовары.Номенклатура);
			Если ГдеБратьПроизводителя И НЕ ПустаяСтрока(СтруктураДат.Контрагент) Тогда
				ОбластьСтрокТовары.Параметры.ПроизВодитель		= СтруктураДат.Контрагент;
			Иначе	
				ПроизВодитель			 							= ПолучитьФиксПоставщика(ВыборкаСтрокТовары.Номенклатура);
				Если ПроизВодитель = Неопределено Тогда
					ОбластьСтрокТовары.Параметры.ПроизВодитель		= "";
				Иначе
					ОбластьСтрокТовары.Параметры.ПроизВодитель		= ПроизВодитель;
				КонецЕсли; 
			КонецЕсли; 
			
			ТабДокумент.Вывести(ОбластьСтрокТовары);
			НомерПоПорядку = НомерПоПорядку + 1;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Если КоличествоНеНайденых > 0 Тогда
		ОтправитьФайлПоПочте(ТекстСообщения);
	КонецЕсли; 
	
	// Выводим итоги по документу в целом
	ОбластьМакета = Макет.ПолучитьОбласть("Итого");
	ПараметрыПредметаИсчисления = "килограмм, килограмма, килограммов, м, грамм, грамма, граммов, м, 3";
	ФорматнаяСтрока = "Л=ru_RU; ДП=Истина";
	
	ИтогоВесПрописью = ЧислоПрописью(ИтогоВес, ФорматнаяСтрока, ПараметрыПредметаИсчисления);
	
	//Если ТипПечати = "1" ИЛИ ТипПечати = "2" Тогда
	ОбластьМакета.Параметры.ВесНетто = "" + Формат(ИтогоВес , "ЧДЦ=2") + "(" + ИтогоВесПрописью + ")";
	//КонецЕсли; 
	ОбластьМакета.Параметры.ИтогоКолВо = Формат(ИтогоКолВо, "ЧДЦ=2");
	
	ТабДокумент.Вывести(ОбластьМакета);
	
	Если ТипПечати = "3" ИЛИ ТипПечати = "4" ИЛИ ТипПечати = "5" Тогда
		ОбластьМакета = Макет.ПолучитьОбласть("Подвал");
		ТабДокумент.Вывести(ОбластьМакета);
	КонецЕсли; 
	
	Если ЕстьТовары Тогда
		ЗаполнитьЗначенияСвойств(ТаблицаПФ.Добавить(), Новый Структура("ТД, Код", ТабДокумент, Лев(ТекущийМагазин,5)));
	КонецЕсли;
	
	Возврат ТабДокумент;
	
КонецФункции

Функция ПолучитьНомераНакладныхСГруппировкойПоДате(МассивОбъектов, ТипПечати)
	
	Запрос = Новый Запрос(
		"ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Док.Ссылка.Дата, ДЕНЬ) КАК Дата,
		|	Док.Ссылка.Номер КАК Номер
		|ПОМЕСТИТЬ вр
		|ИЗ
		|	Документ.ПеремещениеТоваров.ДатыВыпуска КАК Док
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизитыВетГруппа
		|		ПО Док.Номенклатура = НоменклатураДополнительныеРеквизитыВетГруппа.Ссылка
		|			И (НоменклатураДополнительныеРеквизитыВетГруппа.Свойство.Наименование = ""НоменклатурнаяГруппаДляВетВрача"")
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизитыВетКонтроль
		|		ПО Док.Номенклатура = НоменклатураДополнительныеРеквизитыВетКонтроль.Ссылка
		|			И (НоменклатураДополнительныеРеквизитыВетКонтроль.Свойство.Наименование = ""ВетКонтроль"")
		|ГДЕ
		|	Док.Ссылка В(&МассивОбъектов)
		|	И НоменклатураДополнительныеРеквизитыВетГруппа.Значение <> &Значение
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Док.Ссылка.Дата, ДЕНЬ),
		|	Док.Ссылка.Номер
		|ИЗ
		|	Документ.ЗаказНаПеремещение.Товары КАК Док
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты_ВетГруппа
		|		ПО Док.Номенклатура = НоменклатураДополнительныеРеквизиты_ВетГруппа.Ссылка
		|			И (НоменклатураДополнительныеРеквизиты_ВетГруппа.Свойство.Наименование = ""НоменклатурнаяГруппаДляВетВрача"")
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты_ВетКонтроль
		|		ПО Док.Номенклатура = НоменклатураДополнительныеРеквизиты_ВетКонтроль.Ссылка
		|			И (НоменклатураДополнительныеРеквизиты_ВетКонтроль.Свойство.Наименование = ""ВетКонтроль"")
		|ГДЕ
		|	Док.Ссылка В(&МассивОбъектов)
		|	И НоменклатураДополнительныеРеквизиты_ВетГруппа.Значение <> &Значение
		|	И НЕ Док.Отменено
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Док.Ссылка.Дата, ДЕНЬ),
		|	Док.Ссылка.Номер
		|ИЗ
		|	Документ.ЗаказКлиента.Товары КАК Док
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты_ВетГруппа
		|		ПО Док.Номенклатура = НоменклатураДополнительныеРеквизиты_ВетГруппа.Ссылка
		|			И (НоменклатураДополнительныеРеквизиты_ВетГруппа.Свойство.Наименование = ""НоменклатурнаяГруппаДляВетВрача"")
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты_ВетКонтроль
		|		ПО Док.Номенклатура = НоменклатураДополнительныеРеквизиты_ВетКонтроль.Ссылка
		|			И (НоменклатураДополнительныеРеквизиты_ВетКонтроль.Свойство.Наименование = ""ВетКонтроль"")
		|ГДЕ
		|	Док.Ссылка В(&МассивОбъектов)
		|	И НоменклатураДополнительныеРеквизиты_ВетГруппа.Значение <> &Значение
		|	И НЕ Док.Отменено
		|
		|ОБЪЕДИНИТЬ ВСЕ
		|
		|ВЫБРАТЬ
		|	НАЧАЛОПЕРИОДА(Док.Ссылка.Дата, ДЕНЬ),
		|	Док.Ссылка.Номер
		|ИЗ
		|	Документ.РеализацияТоваровУслуг.Товары КАК Док
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизитыВетГруппа
		|		ПО Док.Номенклатура = НоменклатураДополнительныеРеквизитыВетГруппа.Ссылка
		|			И (НоменклатураДополнительныеРеквизитыВетГруппа.Свойство.Наименование = ""НоменклатурнаяГруппаДляВетВрача"")
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизитыВетКонтроль
		|		ПО Док.Номенклатура = НоменклатураДополнительныеРеквизитыВетКонтроль.Ссылка
		|			И (НоменклатураДополнительныеРеквизитыВетКонтроль.Свойство.Наименование = ""ВетКонтроль"")
		|ГДЕ
		|	Док.Ссылка В(&МассивОбъектов)
		|	И НоменклатураДополнительныеРеквизитыВетГруппа.Значение <> &Значение
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	вр.Дата КАК Дата,
		|	вр.Номер КАК Номер
		|ИЗ
		|	вр КАК вр
		|
		|УПОРЯДОЧИТЬ ПО
		|	Дата
		|ИТОГИ
		|	КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Номер)
		|ПО
		|	Дата");
	
	Запрос.УстановитьПараметр("МассивОбъектов", МассивОбъектов);
	Запрос.УстановитьПараметр("Значение", Справочники.ЗначенияСвойствОбъектов.НайтиПоНаименованию("Корма для непродуктивных животных:"));
	Если ТипПечати = "2" ИЛИ ТипПечати = "4" Тогда
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И НоменклатураДополнительныеРеквизитыВетГруппа.Значение <> &Значение", "И НоменклатураДополнительныеРеквизитыВетГруппа.Значение = &Значение");
		Запрос.Текст = СтрЗаменить(Запрос.Текст, "И НоменклатураДополнительныеРеквизиты_ВетГруппа.Значение <> &Значение", "И НоменклатураДополнительныеРеквизиты_ВетГруппа.Значение = &Значение");
	КонецЕсли;
	
	Рез = Запрос.Выполнить();
	
	ДокументыДаты = "";
	
	ВыборкаДата = Рез.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаДата.Следующий() Цикл
		
		Дата = ВыборкаДата.Дата;
		Номер = "";
		
		ВыборкаНомера = ВыборкаДата.Выбрать();
		Пока ВыборкаНомера.Следующий() Цикл
			Номер = Номер + ?(Номер = "", "", ", ") + ВыборкаНомера.Номер;
		КонецЦикла;
		
		ДокументыДаты = ДокументыДаты + ?(Документы = "", "", Символы.ПС) + Номер + " " + "от" + " " + Формат(Дата, "ДЛФ = Д")
		
	КонецЦикла;
	
	Возврат ДокументыДаты;
	
КонецФункции

Функция НайтиДокументПоступленияСНомеромВетСвидетельства(Номенклатура, Контрагент)
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПоступлениеТоваровУслугТовары.Ссылка,
	|	МАКСИМУМ(ПоступлениеТоваровУслугДополнительныеРеквизиты.Значение) КАК Значение
	|ИЗ
	|	Документ.ПоступлениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеТоваровУслуг.ДополнительныеРеквизиты КАК ПоступлениеТоваровУслугДополнительныеРеквизиты
	|		ПО ПоступлениеТоваровУслугТовары.Ссылка = ПоступлениеТоваровУслугДополнительныеРеквизиты.Ссылка
	|			И (ПоступлениеТоваровУслугДополнительныеРеквизиты.Свойство.Наименование = ""Номер вет свидетельства"")
	|			И (ПоступлениеТоваровУслугТовары.Ссылка.Проведен)
	|ГДЕ
	|	ПоступлениеТоваровУслугТовары.Номенклатура = &Номенклатура
	|	И ПоступлениеТоваровУслугТовары.Ссылка.Контрагент = &Контрагент
	|
	|СГРУППИРОВАТЬ ПО
	|	ПоступлениеТоваровУслугТовары.Ссылка";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	СтруктураДат = Новый Структура("НомерВетСвидетельства");
	ВыборкаДетальныеЗаписи.Следующий();
	
	ОбъектДокумент = ВыборкаДетальныеЗаписи.Ссылка.ПолучитьОбъект();
	Для каждого ТекСтр Из ОбъектДокумент.ДополнительныеРеквизиты Цикл
		Если ТекСтр.Свойство.Наименование = "Номер вет свидетельства" Тогда
			СтруктураДат.НомерВетСвидетельства = ТекСтр.Значение;
		КонецЕсли; 
	КонецЦикла; 
	
	Возврат СтруктураДат;
КонецФункции

Функция НайтиДокументыПоступленияПоНоменклатуре(СписокНоменклатуры)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ВложенныйЗапрос.Дата,
	|	ВложенныйЗапрос.Номенклатура,
	|	ПоступлениеТоваровУслугТовары.Сертификат КАК НомерВетСвидетельства,
	|	ПоступлениеТоваровУслугТовары.НомерПаспорта КАК ДатаВыработки,
	|	ПоступлениеТоваровУслугТовары.Ссылка.Контрагент
	|ИЗ
	|	(ВЫБРАТЬ
	|		МАКСИМУМ(ПоступлениеТоваровУслугТовары.Ссылка.Дата) КАК Дата,
	|		ПоступлениеТоваровУслугТовары.Номенклатура КАК Номенклатура
	|	ИЗ
	|		Документ.ПоступлениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
	|	ГДЕ
	|		ПоступлениеТоваровУслугТовары.Номенклатура В(&Номенклатура)
	|		И НЕ ПоступлениеТоваровУслугТовары.НомерПаспорта = """"
	|	
	|	СГРУППИРОВАТЬ ПО
	|		ПоступлениеТоваровУслугТовары.Номенклатура) КАК ВложенныйЗапрос
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.ПоступлениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
	|		ПО ВложенныйЗапрос.Номенклатура = ПоступлениеТоваровУслугТовары.Номенклатура
	|			И ВложенныйЗапрос.Дата = ПоступлениеТоваровУслугТовары.Ссылка.Дата
	|ГДЕ
	|	ПоступлениеТоваровУслугТовары.Номенклатура В(&Номенклатура)
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("Номенклатура", СписокНоменклатуры);
	
	Возврат Запрос.Выполнить().Выгрузить();
КонецФункции

Функция НайтиДокументПоступления(Номенклатура)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	ПоступлениеТоваровУслугТовары.Ссылка КАК Ссылка,
	|	ПоступлениеТоваровУслугТовары.Сертификат КАК НомерВетСвидетельства,
	|	ПоступлениеТоваровУслугТовары.НомерПаспорта КАК ДатаВыработки
	|ИЗ
	|	Документ.ПоступлениеТоваровУслуг.Товары КАК ПоступлениеТоваровУслугТовары
	|ГДЕ
	|	ПоступлениеТоваровУслугТовары.Номенклатура = &Номенклатура
	|	И НЕ ПоступлениеТоваровУслугТовары.НомерПаспорта = """"
	|	И ПоступлениеТоваровУслугТовары.Ссылка.Дата >= &Дата
	|
	|УПОРЯДОЧИТЬ ПО
	|	Ссылка УБЫВ
	|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("Дата", ДобавитьМесяц(НачалоМесяца(ТекущаяДата()), -6));
	Результат = Запрос.Выполнить();
	
	Если Результат.Пустой() Тогда
		Возврат Неопределено;
	КонецЕсли; 
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	//СтруктураДат = Новый Структура("ДатаВыработкиС, ДатаВыработкиПо, НомерВетСвидетельства");
