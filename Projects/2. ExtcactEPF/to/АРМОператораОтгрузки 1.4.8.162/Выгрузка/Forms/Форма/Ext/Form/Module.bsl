	|	"""",
	|	"""",
	|	ЗаказКлиента.Организация.ТекущийРукоВодитель,
	|	ЗаказКлиента.Организация.ТекущаяДолжностьРуководителя,
	|	ЗаказКлиента.Организация.ТекущийГлавныйБухгалтер,
	|	&Перевозчик,
	|	&Водитель,
	|	СкладыКонтактнаяОтправитель.Представление,
	|	КонтрагентыКонтактнаяИнформация.Представление,
	|	"""",
	|	ВложенныйЗапрос.ВесНетто,
	|	&Автомобиль
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.КонтактнаяИнформация КАК СкладыКонтактнаяОтправитель
	|		ПО (СкладыКонтактнаяОтправитель.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресСклада))
	|			И ЗаказКлиента.Склад = СкладыКонтактнаяОтправитель.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			СУММА((ВЫРАЗИТЬ(ВЫБОР
	|						КОГДА НоменклатураДополнительныеРеквизиты.Значение ЕСТЬ NULL 
	|								ИЛИ НоменклатураДополнительныеРеквизиты.Значение = 0
	|							ТОГДА ЗаказКлиентаТовары.Номенклатура.Вес
	|						ИНАЧЕ НоменклатураДополнительныеРеквизиты.Значение
	|					КОНЕЦ КАК ЧИСЛО(15, 3))) * ЗаказКлиентаТовары.Количество) КАК ВесНетто,
	|			ЗаказКлиентаТовары.Ссылка КАК Ссылка
	|		ИЗ
	|			Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
	|				ПО ЗаказКлиентаТовары.Номенклатура = НоменклатураДополнительныеРеквизиты.Ссылка
	|					И (НоменклатураДополнительныеРеквизиты.Свойство.Наименование = ""Вес брутто"")
	|		ГДЕ
	|			ЗаказКлиентаТовары.Ссылка В(&МассивДокументов)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			ЗаказКлиентаТовары.Ссылка) КАК ВложенныйЗапрос
	|		ПО ЗаказКлиента.Ссылка = ВложенныйЗапрос.Ссылка
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяИнформация
	|		ПО (КонтрагентыКонтактнаяИнформация.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|			И ЗаказКлиента.Контрагент = КонтрагентыКонтактнаяИнформация.Ссылка
	|ГДЕ
	|	ЗаказКлиента.Ссылка В(&МассивДокументов)
	|
	|ОБЪЕДИНИТЬ ВСЕ
	|
	|ВЫБРАТЬ
	|	РеализацияТоваровУслуг.Ссылка,
	|	РеализацияТоваровУслуг.Номер,
	|	РеализацияТоваровУслуг.Дата,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.ЗаказКлиента = НЕОПРЕДЕЛЕНО
	|			ТОГДА """"
	|		ИНАЧЕ РеализацияТоваровУслуг.ЗаказКлиента.Номер
	|	КОНЕЦ,
	|	ВЫБОР
	|		КОГДА РеализацияТоваровУслуг.ЗаказКлиента = НЕОПРЕДЕЛЕНО
	|			ТОГДА """"
	|		ИНАЧЕ РеализацияТоваровУслуг.ЗаказКлиента.Дата
	|	КОНЕЦ,
	|	РеализацияТоваровУслуг.Организация,
	|	РеализацияТоваровУслуг.Контрагент,
	|	РеализацияТоваровУслуг.Организация,
	|	РеализацияТоваровУслуг.Организация,
	|	РеализацияТоваровУслуг.Организация,
	|	РеализацияТоваровУслуг.Организация.Префикс,
	|	РеализацияТоваровУслуг.Склад.ТекущийОтветственный,
	|	РеализацияТоваровУслуг.Склад.ТекущаяДолжностьОтветственного,
	|	РеализацияТоваровУслуг.Организация.ТекущийРукоВодитель,
	|	РеализацияТоваровУслуг.Организация.ТекущаяДолжностьРуководителя,
	|	РеализацияТоваровУслуг.Организация.ТекущийГлавныйБухгалтер,
	|	РеализацияТоваровУслуг.Перевозчик,
	|	РеализацияТоваровУслуг.Водитель,
	|	СкладыКонтактнаяОтправитель.Представление,
	|	КонтрагентыКонтактнаяПолучатель.Представление,
	|	РеализацияТоваровУслуг.СрокДоставки,
	|	ВложенныйЗапрос.ВесНетто,
	|	РеализацияТоваровУслуг.Автомобиль
	|ИЗ
	|	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Контрагенты.КонтактнаяИнформация КАК КонтрагентыКонтактнаяПолучатель
	|		ПО РеализацияТоваровУслуг.Контрагент = КонтрагентыКонтактнаяПолучатель.Ссылка
	|			И (КонтрагентыКонтактнаяПолучатель.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.ФактАдресКонтрагента))
	|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.КонтактнаяИнформация КАК СкладыКонтактнаяОтправитель
	|		ПО РеализацияТоваровУслуг.Склад = СкладыКонтактнаяОтправитель.Ссылка
	|			И (СкладыКонтактнаяОтправитель.Вид = ЗНАЧЕНИЕ(Справочник.ВидыКонтактнойИнформации.АдресСклада))
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			РеализацияТоваровУслугТовары.Ссылка КАК Ссылка,
	|			СУММА((ВЫРАЗИТЬ(ВЫБОР
	|						КОГДА НоменклатураДополнительныеРеквизиты.Значение ЕСТЬ NULL 
	|								ИЛИ НоменклатураДополнительныеРеквизиты.Значение = 0
	|							ТОГДА РеализацияТоваровУслугТовары.Номенклатура.Вес
	|						ИНАЧЕ НоменклатураДополнительныеРеквизиты.Значение
	|					КОНЕЦ КАК ЧИСЛО(15, 3))) * РеализацияТоваровУслугТовары.Количество) КАК ВесНетто
	|		ИЗ
	|			Документ.РеализацияТоваровУслуг.Товары КАК РеализацияТоваровУслугТовары
	|				ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Номенклатура.ДополнительныеРеквизиты КАК НоменклатураДополнительныеРеквизиты
	|				ПО РеализацияТоваровУслугТовары.Номенклатура = НоменклатураДополнительныеРеквизиты.Ссылка
	|					И (НоменклатураДополнительныеРеквизиты.Свойство.Наименование = ""Вес брутто"")
	|		ГДЕ
	|			РеализацияТоваровУслугТовары.Ссылка В(&МассивДокументов)
	|		
	|		СГРУППИРОВАТЬ ПО
	|			РеализацияТоваровУслугТовары.Ссылка) КАК ВложенныйЗапрос
	|		ПО РеализацияТоваровУслуг.Ссылка = ВложенныйЗапрос.Ссылка
	|ГДЕ
	|	РеализацияТоваровУслуг.Ссылка В(&МассивДокументов)
	|ИТОГИ ПО
	|	ПунктРазгрузки";
	
	Запрос.УстановитьПараметр("МассивДокументов", МассивДокументов);
	Запрос.УстановитьПараметр("Перевозчик", Перевозчик1);
	Запрос.УстановитьПараметр("Водитель", Водитель1ПоУмолчанию);
	Запрос.УстановитьПараметр("Автомобиль", АвтомобильПоУмолчанию);

	РезультатЗапроса = Запрос.Выполнить();
	//ТаблицаРезультата = Запрос.Выполнить().Выгрузить();
	//
	ВыборкаПунктов = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	// это самый верхний уровень - по машинкам
	Автомобиль = АвтомобильПоУмолчанию;
	//общийвес = СтрокаМаршрута.вес;
	// Для Строки заказов заведем строку
	СтрокаЗаказов="";
	СтрокаПеремещений="";
	СтрокаПеремещенийДата="";
	СтрокаРеализацийДата = "";
	МассаНетто = 0;//СтруктураПараметров.Вес;
	//ПунктПогрузки = "Новосибирская обл, Новосибирск г, Карьер Мочище мкр, Кубовая ул, дом № 68";
	
	//************    Согласно логики консультанта-аналитика Котлячковой брать склад-отправитель - первая строка из ЗНО
		
		Запрос = Новый Запрос;
		Запрос.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	ЗаказНаОтгрузкуЗаказы.Склад
		|ИЗ
		|	Документ.ЗаказНаОтгрузку.Заказы КАК ЗаказНаОтгрузкуЗаказы
		|ГДЕ
		|	ЗаказНаОтгрузкуЗаказы.Ссылка = &ЗНО";
		
		Запрос.УстановитьПараметр("ЗНО", Зно1);
		Рез = Запрос.Выполнить().Выбрать();
		Пока Рез.Следующий() Цикл
			Если ЗначениеЗаполнено(Рез.Склад) Тогда
				СкладОтправитель = Рез.Склад;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	

	ПунктПогрузки = ПолучитьАдресМагазина(Справочники.Склады.НайтиПоНаименованию("Основной РЦ (WMS)"));
	ПунктРазгрузки = ПолучитьАдресМагазина(Справочники.Склады.НайтиПоНаименованию("НСК Основной РЦ (WMS) - ТЛМ2"));
	//
	ДанныеДляПечати = Новый ТаблицаЗначений;
	ДанныеДляПечати.Колонки.Добавить("ПунктРазгрузки");
	ДанныеДляПечати.Колонки.Добавить("ВесНетто");
	СведенияОПеревозчике      = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(СтрокаМаршрута.ЗНО.Перевозчик, ТекущаяДата());
	
	Пока ВыборкаПунктов.Следующий() Цикл
		ОбщаяВыборка = ВыборкаПунктов.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		НоваяСтрока = ДанныеДляПечати.Добавить();
		НоваяСтрока.ПунктРазгрузки = ВыборкаПунктов.ПунктРазгрузки;
		//НоваяСтрока.ВесНетто = ВыборкаПунктов.ВесНетто;
		ВесПогрузки=0;
		Пока ОбщаяВыборка.Следующий() Цикл
			Если ВесПогрузки = 0 тогда
				Область1.параметры.Пункт0_Номер = "ТН"+ОбщаяВыборка.НомерЗаказа;
				Область1.параметры.Пункт0_Дата = Формат(ТекущаяДата(), "ДЛФ=Д");
			КонецЕсли;
			
			
			// присвоим общие значения Для ТТН
			СтрокаЗаказов = СтрокаЗаказов + ОбщаяВыборка.НомерЗаказа + " от " + формат(ОбщаяВыборка.ДатаЗаказа,"ДФ=dd.MM.yy") + ";";
			СтрокаПеремещений = СтрокаПеремещений + ОбщаяВыборка.номер + ";";
 			Если ТипЗнч(ОбщаяВыборка.Ссылка) = Тип("ДокументСсылка.ПеремещениеТоваров") тогда
				СтрокаПеремещенийДата = СтрокаПеремещенийДата + ОбщаяВыборка.номер + " от " + формат(ОбщаяВыборка.Дата,"ДФ=dd.MM.yy") + ";";
			Иначе
				СтрокаРеализацийДата = СтрокаРеализацийДата + ОбщаяВыборка.номер + " от " + формат(ОбщаяВыборка.Дата,"ДФ=dd.MM.yy") + ";";
			КонецЕсли;
			СведенияОГрузополучателе  = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ОбщаяВыборка.Грузополучатель,  ОбщаяВыборка.Дата);
			СведенияОГрузоотправитель = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ОбщаяВыборка.Грузоотправитель, ОбщаяВыборка.Дата);
			//СведенияОПеревозчике      = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ОбщаяВыборка.Перевозчик, ОбщаяВыборка.Дата);
			
			СведенияОВодителе         = ФормированиеПечатныхФорм.СведенияОЮрФизЛице(ОбщаяВыборка.Водитель, ОбщаяВыборка.Дата);
			ОбщийГрузоотправитель = ОбщаяВыборка.Грузополучатель;
			ОбщийГрузополучатель =  ОбщаяВыборка.Грузополучатель;
			ОбщийПеревозчик =       ОбщаяВыборка.Перевозчик;
			ОбщийВодитель = СтрокаМаршрута.Водитель;
			Если СокрЛП(ПунктПогрузки) = "" Тогда
				ПунктПогрузки = ОбщаяВыборка.ПунктПогрузки;
			КонецЕсли;
			ВесПогрузки = ВесПогрузки + ?(ОбщаяВыборка.ВесНетто = null или ОбщаяВыборка.ВесНетто = 0, 0, ОбщаяВыборка.ВесНетто);
			МассаНетто = МассаНетто + ?(ОбщаяВыборка.ВесНетто = null или ОбщаяВыборка.ВесНетто = 0, 0, ОбщаяВыборка.ВесНетто);
		КонецЦикла;
		НоваяСтрока.ВесНетто = ВесПогрузки;
		
		ПредставлениеГрузоотправителя = "";
		ПредставлениеПеревозчика      = "";
		Перевозчик                    = "";
		Грузоотправитель              = "";
		Если Общийгрузополучатель.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо
			Или ОбщийГрузополучатель.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда
			Область1.Параметры.Пункт2_1 = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОГрузополучателе, 
			"ПолноеНаименование,ИНН,ФактическийАдрес");
		Иначе
			//ОбластьМакета.Параметры.Пункт2_2 = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОГрузополучателе,  //ninch 23.12.2011
			Область1.Параметры.Пункт2_2 = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОГрузополучателе,  //ninch 23.12.2011
			"ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны");
		КонецЕсли;
		
		
		// 18.01.2021 +
		Попытка
			Если общийПеревозчик.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо Или ОбщийПеревозчик.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда
				ПредставлениеПеревозчика = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПеревозчике, 
				"ПолноеНаименование,ФактическийАдрес,Телефоны");
				Перевозчик = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПеревозчике, "ПолноеНаименование");
				
			Иначе
				ПредставлениеПеревозчика = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПеревозчике, 
				"ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны");
				Перевозчик = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПеревозчике, "ПолноеНаименование");
			КонецЕсли;
		Исключение
			ПредставлениеПеревозчика = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПеревозчике, 
			"ПолноеНаименование,ИНН,ФактическийАдрес,Телефоны");
			Перевозчик = ФормированиеПечатныхФорм.ОписаниеОрганизации(СведенияОПеревозчике, "ПолноеНаименование");
		КонецПопытки;
		
		
		Если ОбщийГрузоотправитель.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ФизЛицо
				Или ОбщийГрузоотправитель.ЮрФизЛицо = Перечисления.ЮрФизЛицо.ИндивидуальныйПредприниматель Тогда
