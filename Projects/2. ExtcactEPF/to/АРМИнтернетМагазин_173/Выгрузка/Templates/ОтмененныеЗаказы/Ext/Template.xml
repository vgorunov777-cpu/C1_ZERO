	<calculatedField>
		<dataPath>ПериодДоставки</dataPath>
		<expression>Формат(ВремяДоставкиСЧас, "ЧЦ=2; ЧВН=; ЧН=00") + ":" + Формат(ВремяДоставкиСМинута, "ЧЦ=2; ЧВН=; ЧН=00") + " - " + Формат(ВремяДоставкиПоЧас, "ЧЦ=2; ЧВН=; ЧН=00") + ":" + Формат(ВремяДоставкиПоМинута, "ЧЦ=2; ЧВН=; ЧН=00")</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
