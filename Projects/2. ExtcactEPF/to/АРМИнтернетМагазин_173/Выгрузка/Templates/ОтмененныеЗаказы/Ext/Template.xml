		<query>ВЫБРАТЬ
	ЗаказКлиента.Ссылка КАК Заказ,
	ЗаказКлиента.Склад КАК Склад,
	ЗаказКлиента.ДатаЗаказаНаСайте КАК ДатаЗаказаНаСайте,
	ЗаказКлиента.НомерЗаказаНаСайте КАК НомерЗаказаНаСайте,
	ВЫБОР
		КОГДА ЗаказКлиента.ПредыдущийСтатус = ""
			ТОГДА "Отменен"
		ИНАЧЕ ЗаказКлиента.ПредыдущийСтатус
	КОНЕЦ КАК Статус,
	ЗаказКлиента.СуммаДокумента,
	ЗаказКлиента.ЖелаемаяДатаОтгрузки,
	ЗаказКлиента.ПокупательТелефон,
	ЗаказКлиента.ПокупательEmail,
	ЗаказКлиента.Комплектовщик,
	ЗаказКлиента.ПокупательФИО,
	ЗаказКлиента.ВремяДоставкиПо,
	ЗаказКлиента.ВремяДоставкиС,
	ЗаказКлиента.АдресДоставки,
	ЗаказКлиента.Комментарий,
	ЗаказКлиента.ТрекНомер,
	ЗаказКлиента.ПользовательОтмены,
	ВЫБОР
		КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "USER1CWEB"
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ОтменаМагазином,
	ВЫБОР
		КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "ОбменСайт"
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ОтменаСайтом,
	ВЫБОР
		КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "ОбменPayMob"
			ТОГДА ИСТИНА
		ИНАЧЕ ЛОЖЬ
	КОНЕЦ КАК ОтменаКурьером,
	ВЫБОР
		КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "USER1CWEB"
			ТОГДА ЛОЖЬ
		КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "ОбменСайт"
			ТОГДА ЛОЖЬ
		КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "ОбменPayMob"
			ТОГДА ЛОЖЬ
		ИНАЧЕ ИСТИНА
	КОНЕЦ КАК ОтменаТехподдержкой,
	зкСтроки.КоличествоСтрок,
	ЕСТЬNULL(ПоследниеИзменения.ДатаВерсии, ДАТАВРЕМЯ(1, 1, 1, 0, 0, 0)) КАК ДатаПоследнегоИзменения,
	ЧАС(ЗаказКлиента.ВремяДоставкиС) КАК ВремяДоставкиСЧас,
	МИНУТА(ЗаказКлиента.ВремяДоставкиС) КАК ВремяДоставкиСМинута,
	ЧАС(ЗаказКлиента.ВремяДоставкиПо) КАК ВремяДоставкиПоЧас,
	МИНУТА(ЗаказКлиента.ВремяДоставкиПо) КАК ВремяДоставкиПоМинута
ИЗ
	Документ.ЗаказКлиента КАК ЗаказКлиента
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ЗаказКлиентаТовары.Ссылка КАК Ссылка,
			КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказКлиентаТовары.НомерСтроки) КАК КоличествоСтрок
		ИЗ
			Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
		ГДЕ
			ЗаказКлиентаТовары.ПричинаОтмены.Наименование = "Отказ"
		
		СГРУППИРОВАТЬ ПО
			ЗаказКлиентаТовары.Ссылка) КАК зкСтроки
		ПО ЗаказКлиента.Ссылка = зкСтроки.Ссылка
		ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
			ВерсииОбъектов.Объект КАК Заказ,
			МАКСИМУМ(ВерсииОбъектов.ДатаВерсии) КАК ДатаВерсии
		ИЗ
			РегистрСведений.ВерсииОбъектов КАК ВерсииОбъектов
		
		СГРУППИРОВАТЬ ПО
			ВерсииОбъектов.Объект) КАК ПоследниеИзменения
		ПО ЗаказКлиента.Ссылка = ПоследниеИзменения.Заказ
ГДЕ
	ЗаказКлиента.ИнтернетМагазин
	И НЕ ЗаказКлиента.НомерЗаказаНаСайте = ""
	И ЗаказКлиента.СуммаДокумента = 0
	И ЗаказКлиента.ЖелаемаяДатаОтгрузки МЕЖДУ &amp;ЖелаемаяДатаОтгрузкиНачало И &amp;ЖелаемаяДатаОтгрузкиОкончание
{ГДЕ
	ЗаказКлиента.Склад.*,
	ЗаказКлиента.Ссылка.* КАК Заказ,
	ЗаказКлиента.НомерЗаказаНаСайте,
	ЗаказКлиента.ДатаЗаказаНаСайте,
	ЗаказКлиента.ПользовательОтмены.*,
	(ВЫБОР
			КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "USER1CWEB"
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ) КАК ОтменаМагазином,
	(ВЫБОР
			КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "ОбменСайт"
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ) КАК ОтменаСайтом,
	(ВЫБОР
			КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "ОбменPayMob"
				ТОГДА ИСТИНА
			ИНАЧЕ ЛОЖЬ
		КОНЕЦ) КАК ОтменаКурьером,
	(ВЫБОР
			КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "USER1CWEB"
				ТОГДА ЛОЖЬ
			КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "ОбменСайт"
				ТОГДА ЛОЖЬ
			КОГДА ЗаказКлиента.ПользовательОтмены.Наименование = "ОбменPayMob"
				ТОГДА ЛОЖЬ
			ИНАЧЕ ИСТИНА
		КОНЕЦ) КАК ОтменаТехподдержкой}</query>
