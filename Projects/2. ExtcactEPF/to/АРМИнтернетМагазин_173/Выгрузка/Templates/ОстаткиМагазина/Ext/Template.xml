////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	сНоменклатура.Номенклатура КАК Номенклатура,
	ВЫРАЗИТЬ(ЕСТЬNULL(СвободныеОстаткиОстатки.ВНаличииОстаток, 0) - ЕСТЬNULL(СвободныеОстаткиОстатки.ВРезервеОстаток, 0) - ЕСТЬNULL(ТоварныеОграничения.НормативноеКоличествоЗапаса, 0) * &amp;ПроцентУменьшенияОстаткаНаСайт / 100 КАК ЧИСЛО(10, 0)) КАК ДоступныйОстаток,
	СвободныеОстаткиОстатки.ВНаличииОстаток КАК ВНаличии,
	СвободныеОстаткиОстатки.ВРезервеОстаток КАК ВРезерве,
	ЕСТЬNULL(ДополнительныеСведения.Значение, "&lt;&gt;") КАК СтатусАктивности,
	ТоварныеОграничения.НормативноеКоличествоЗапаса КАК НормативноеКоличествоЗапаса,
	ТоварыКПоступлениюОстатки.КПоступлениюОстаток КАК КПоступлению,
	сНоменклатура.Склад КАК Склад,
	сНоменклатура.Номенклатура.Наименование КАК НаименованиеНоменклатуры
ПОМЕСТИТЬ ВТ_Данные
{ВЫБРАТЬ
	Номенклатура.*,
	Склад.*,
	СтатусАктивности,
	НормативноеКоличествоЗапаса,
	ВНаличии,
	ВРезерве,
	КПоступлению,
	ДоступныйОстаток}
ИЗ
	сНоменклатура КАК сНоменклатура
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СвободныеОстатки.Остатки(
				&amp;ТекущаяДата {(&amp;ТекущаяДата)},
				(Номенклатура, Склад) В
					(ВЫБРАТЬ
						сНоменклатура.Номенклатура,
						сНоменклатура.Склад
					ИЗ
						сНоменклатура КАК сНоменклатура)) КАК СвободныеОстаткиОстатки
		ПО сНоменклатура.Номенклатура = СвободныеОстаткиОстатки.Номенклатура
			И сНоменклатура.Склад = СвободныеОстаткиОстатки.Склад
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		ПО сНоменклатура.Номенклатура = ДополнительныеСведения.Объект
			И (ЕСТЬNULL(ВЫРАЗИТЬ(ДополнительныеСведения.Свойство КАК ПланВидовХарактеристик.ДополнительныеРеквизитыИСведения).Наименование, "") = "СтатусАктивности")
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКПоступлению.Остатки(
				&amp;ТекущаяДата {(&amp;ТекущаяДата)},
				(Номенклатура, Склад) В
					(ВЫБРАТЬ
						сНоменклатура.Номенклатура,
						сНоменклатура.Склад
					ИЗ
						сНоменклатура КАК сНоменклатура)) КАК ТоварыКПоступлениюОстатки
		ПО сНоменклатура.Номенклатура = ТоварыКПоступлениюОстатки.Номенклатура
			И сНоменклатура.Склад = ТоварыКПоступлениюОстатки.Склад
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТоварныеОграничения КАК ТоварныеОграничения
		ПО сНоменклатура.Номенклатура = ТоварныеОграничения.Номенклатура
			И сНоменклатура.Склад = ТоварныеОграничения.Склад
{ГДЕ
	СвободныеОстаткиОстатки.ВНаличииОстаток КАК ВНаличии,
	СвободныеОстаткиОстатки.ВРезервеОстаток КАК ВРезерве,
	ТоварыКПоступлениюОстатки.КПоступлениюОстаток КАК КПоступлению,
	сНоменклатура.Номенклатура.*,
	сНоменклатура.Склад.*,
	сНоменклатура.Номенклатура.Наименование КАК НаименованиеНоменклатуры,
	(ВЫРАЗИТЬ(ЕСТЬNULL(СвободныеОстаткиОстатки.ВНаличииОстаток, 0) - ЕСТЬNULL(СвободныеОстаткиОстатки.ВРезервеОстаток, 0) - ЕСТЬNULL(ТоварныеОграничения.НормативноеКоличествоЗапаса, 0) * &amp;ПроцентУменьшенияОстаткаНаСайт / 100 КАК ЧИСЛО(10, 0))) КАК ДоступныйОстаток}
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Данные.Номенклатура КАК Номенклатура,
	ВТ_Данные.НаименованиеНоменклатуры КАК НаименованиеНоменклатуры,
	ВТ_Данные.НормативноеКоличествоЗапаса КАК НормативноеКоличествоЗапаса,
	ВТ_Данные.СтатусАктивности КАК СтатусАктивности,
	ВТ_Данные.Склад КАК Склад,
	ВТ_Данные.ВНаличии КАК ВНаличии,
	ВТ_Данные.ВРезерве КАК ВРезерве,
	ВТ_Данные.КПоступлению КАК КПоступлению,
	ШтрихкодыНоменклатуры.Штрихкод КАК Штрихкод,
	ВЫБОР
		КОГДА ШтрихкодыНоменклатуры.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
			ТОГДА ""
		ИНАЧЕ ШтрихкодыНоменклатуры.Упаковка.Наименование
	КОНЕЦ КАК Упаковка,
	ВТ_Данные.ДоступныйОстаток КАК ДоступныйОстаток
{ВЫБРАТЬ
	Номенклатура.*,
	НаименованиеНоменклатуры,
	НормативноеКоличествоЗапаса,
	СтатусАктивности.*,
	Склад.*,
	ВНаличии,
	ВРезерве,
	КПоступлению,
	Штрихкод,
	Упаковка,
	ДоступныйОстаток}
ИЗ
	ВТ_Данные КАК ВТ_Данные
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		ПО ВТ_Данные.Номенклатура = ШтрихкодыНоменклатуры.Номенклатура
{ГДЕ
	ВТ_Данные.Номенклатура.*,
	ВТ_Данные.НаименованиеНоменклатуры,
	ВТ_Данные.Склад.*,
	ВТ_Данные.ВНаличии,
	ВТ_Данные.ВРезерве,
	ВТ_Данные.КПоступлению,
	ШтрихкодыНоменклатуры.Штрихкод,
	ШтрихкодыНоменклатуры.Упаковка.*,
	ВТ_Данные.ДоступныйОстаток}</query>
