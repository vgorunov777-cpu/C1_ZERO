		<dataPath>ШтрихкодСУпаковкой</dataPath>
		<expression>ВЫБОР КОГДА Упаковка = "" ТОГДА Штрихкод ИНАЧЕ Штрихкод + "("+Упаковка+")" КОНЕЦ</expression>
