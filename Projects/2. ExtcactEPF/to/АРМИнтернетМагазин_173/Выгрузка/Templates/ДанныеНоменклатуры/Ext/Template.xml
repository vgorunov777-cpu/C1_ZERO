<?xml version="1.0" encoding="UTF-8"?>
<DataCompositionSchema xmlns="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcscom="http://v8.1c.ru/8.1/data-composition-system/common" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<dataSource>
		<name>ИсточникДанных1</name>
		<dataSourceType>Local</dataSourceType>
	</dataSource>
	<dataSet xsi:type="DataSetQuery">
		<name>НаборДанных1</name>
		<field xsi:type="DataSetFieldField">
			<dataPath>Номенклатура</dataPath>
			<field>Номенклатура</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>НормативноеКоличествоЗапаса</dataPath>
			<field>НормативноеКоличествоЗапаса</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Склад</dataPath>
			<field>Склад</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>СтатусАктивности</dataPath>
			<field>СтатусАктивности</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Характеристика</dataPath>
			<field>Характеристика</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ДокументПоступления</dataPath>
			<field>ДокументПоступления</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВНаличии</dataPath>
			<field>ВНаличии</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>ВРезерве</dataPath>
			<field>ВРезерве</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>КПоступлению</dataPath>
			<field>КПоступлению</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Упаковка</dataPath>
			<field>Упаковка</field>
		</field>
		<field xsi:type="DataSetFieldField">
			<dataPath>Штрихкод</dataPath>
			<field>Штрихкод</field>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	спрНоменклатура.Ссылка КАК Номенклатура,
	ВЫРАЗИТЬ(&amp;Склад КАК Справочник.Склады) КАК Склад
ПОМЕСТИТЬ сНоменклатура
ИЗ
	Справочник.Номенклатура КАК спрНоменклатура
ГДЕ
	спрНоменклатура.Ссылка В(&amp;СписокНоменклатуры)
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	сНоменклатура.Номенклатура,
	СвободныеОстаткиОстатки.ВНаличииОстаток КАК ВНаличии,
	СвободныеОстаткиОстатки.ВРезервеОстаток КАК ВРезерве,
	ЕСТЬNULL(ВЫРАЗИТЬ(ДополнительныеСведения.Значение КАК ЧИСЛО(1, 0)), "&lt;&gt;") КАК СтатусАктивности,
	ТоварныеОграничения.НормативноеКоличествоЗапаса,
	ТоварыКПоступлениюОстатки.КПоступлениюОстаток КАК КПоступлению
ПОМЕСТИТЬ ВТ_Данные
ИЗ
	сНоменклатура КАК сНоменклатура
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.СвободныеОстатки.Остатки(
				&amp;ТекущаяДата {(&amp;ТекущаяДата)},
				(Номенклатура, Склад) В
					(ВЫБРАТЬ
						сНоменклатура.Номенклатура,
						сНоменклатура.Склад
					ИЗ
						сНоменклатура КАК сНоменклатура)) КАК СвободныеОстаткиОстатки
		ПО сНоменклатура.Номенклатура = СвободныеОстаткиОстатки.Номенклатура
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
		ПО сНоменклатура.Номенклатура = ДополнительныеСведения.Объект
			И (ДополнительныеСведения.Свойство = &amp;СвойствоСтатусАктивности)
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТоварныеОграничения КАК ТоварныеОграничения
		ПО сНоменклатура.Номенклатура = ТоварныеОграничения.Номенклатура
			И сНоменклатура.Склад = ТоварныеОграничения.Склад
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.ТоварыКПоступлению.Остатки(
				&amp;ТекущаяДата {(&amp;ТекущаяДата)},
				(Номенклатура, Склад) В
					(ВЫБРАТЬ
						сНоменклатура.Номенклатура,
						сНоменклатура.Склад
					ИЗ
						сНоменклатура КАК сНоменклатура)) КАК ТоварыКПоступлениюОстатки
		ПО сНоменклатура.Номенклатура = ТоварыКПоступлениюОстатки.Номенклатура
;

////////////////////////////////////////////////////////////////////////////////
ВЫБРАТЬ
	ВТ_Данные.Номенклатура,
	ВТ_Данные.ВНаличии,
	ВТ_Данные.ВРезерве,
	ВТ_Данные.СтатусАктивности,
	ВТ_Данные.НормативноеКоличествоЗапаса,
	ВТ_Данные.КПоступлению,
	ШтрихкодыНоменклатуры.Штрихкод,
	ВЫБОР
		КОГДА ШтрихкодыНоменклатуры.Упаковка = ЗНАЧЕНИЕ(Справочник.УпаковкиНоменклатуры.ПустаяСсылка)
			ТОГДА ""
		ИНАЧЕ ШтрихкодыНоменклатуры.Упаковка.Наименование
	КОНЕЦ КАК Упаковка
ИЗ
	ВТ_Данные КАК ВТ_Данные
		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		ПО ВТ_Данные.Номенклатура = ШтрихкодыНоменклатуры.Номенклатура</query>
	</dataSet>
	<calculatedField>
		<dataPath>ШтрихкодСУпаковкой</dataPath>
		<expression>ВЫБОР КОГДА Упаковка = "" ТОГДА Штрихкод ИНАЧЕ Штрихкод + "("+Упаковка+")" КОНЕЦ</expression>
		<title xsi:type="v8:LocalStringType">
			<v8:item>
				<v8:lang>ru</v8:lang>
				<v8:content>Штрихкод с упаковкой</v8:content>
			</v8:item>
		</title>
	</calculatedField>
	<totalField>
		<dataPath>ШтрихкодСУпаковкой</dataPath>
		<expression>СоединитьСтроки(ШтрихкодСУпаковкой, ", ")</expression>
		<group>Номенклатура</group>
	</totalField>
