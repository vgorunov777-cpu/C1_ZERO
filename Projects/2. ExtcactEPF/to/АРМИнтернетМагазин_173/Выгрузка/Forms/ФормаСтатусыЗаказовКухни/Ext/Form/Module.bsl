
#Область ОсновныеМетоды

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не Параметры.Свойство("Заказ", Заказ) Тогда
		Отказ = Истина;
	КонецЕсли;
	
	О = РеквизитФормыВЗначение("Объект");
	Заголовок = О.Метаданные().Комментарий + ": " + О.Метаданные().Синоним + ": " + ЭтаФорма.Заголовок;
	ЭтаФорма.Заголовок = Заголовок;
	
	ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(ТаблицаПроизводство, "Документ", Заказ, ВидСравненияКомпоновкиДанных.Равно);
	
	РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Заказ, "НомерЗаказаНаСайте, Склад");
	ЗаказНомер = РеквизитыЗаказа.НомерЗаказаНаСайте;
	СкладЗаказа = РеквизитыЗаказа.Склад;
	
	ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(ТаблицаПроизводство, "Документ", Заказ, ВидСравненияКомпоновкиДанных.Равно);
	ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(ТаблицаПроизводство, "Склад", СкладЗаказа, ВидСравненияКомпоновкиДанных.Равно);
	
	ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(ТаблицаЗаказ, "Документ", Заказ, ВидСравненияКомпоновкиДанных.Равно);
	
	Элементы.ФормаСнятьПризнакТребуетсяОбработка.Доступность = ПолучитьЗначениеТребуетсяОбработка(Заказ);
	
КонецПроцедуры

