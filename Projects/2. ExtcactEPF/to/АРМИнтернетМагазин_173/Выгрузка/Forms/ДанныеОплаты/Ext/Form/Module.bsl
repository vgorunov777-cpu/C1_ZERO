
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	О = РеквизитФормыВЗначение("Объект");
	Заголовок = О.Метаданные().Комментарий + ": " + О.Метаданные().Синоним + ": " + ЭтаФорма.Заголовок;
	ЭтаФорма.Заголовок = Заголовок;
	
	Если Параметры.Свойство("Заказ") Тогда
		Заказы.Добавить(Параметры.Заказ);
	КонецЕсли;
	
	Если Параметры.Свойство("Заказы") Тогда
		Заказы = Параметры.Заказы;
	КонецЕсли;
	
	ЗагрузитьЧекиМагПей();
	
КонецПроцедуры

Функция ЗагрузитьЧекиМагПей() Экспорт
	
	//удаляем с формы существующие данные
	Для Каждого ЭлементСписка Из ИмяГруппыНаФорме Цикл
		НайденныйЭлемент = Элементы.Найти(ЭлементСписка.Значение);
		Если НЕ НайденныйЭлемент = Неопределено Тогда
			Элементы.Удалить(НайденныйЭлемент);
		КонецЕсли;
	КонецЦикла;
	ИмяГруппыНаФорме.Очистить();
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект"); 
	Для Каждого Заказ Из Заказы Цикл
		ОперацииJSON = ОбработкаОбъект.ЗагрузитьОперацииМагПей(Заказ.Значение);
		РазобратьОтвет(ОперацииJSON);
	КонецЦикла;
	
КонецФункции

Функция РазобратьОтвет(Ответ)
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Если ТипЗнч(Ответ) = Тип("Соответствие") Тогда
		
		Если Не Ответ.Получить("data") = Неопределено Тогда 
				
			Для Каждого КЗЗаказ Из Ответ.Получить("data") Цикл
					
				ДанныеЗаказаСтруктура = ОбщегоНазначения.СоответствиеВСтруктуру(КЗЗаказ);
				ВывестиДанные(ДанныеЗаказаСтруктура);

			КонецЦикла;
				
				
		Иначе //Ошибка
				
		КонецЕсли;
		
	КонецЕсли;
	
КонецФункции

Процедура ВывестиДанные(ДанныеЗаказаСтруктура)

	//получаем дополнительные реквизиты для формы
	СтруктураРеквизитовЗаказа = ПолучитьСтруктуруРеквизитовЗаказа(ДанныеЗаказаСтруктура.reference_number);
	
	//формируем корневую группу элементов
	ГруппаЗаказ = ДобавитьГруппу(ДанныеЗаказаСтруктура.reference_number, ЭтаФорма);
	ИмяГруппыНаФорме.Добавить(ГруппаЗаказ.Имя);
	
	Для Каждого РеквизитЗаказа Из СтруктураРеквизитовЗаказа Цикл
		ДобавитьЭлемент(РеквизитЗаказа.Ключ, РеквизитЗаказа.Значение, ГруппаЗаказ);	
	КонецЦикла;
	
	Для Каждого КЗ Из ДанныеЗаказаСтруктура Цикл
		
		Если ТипЗнч(КЗ.Значение) = Тип("Массив") ТОгда
			Продолжить;
		КонецЕсли;
		
		РазобратьЭлемент(КЗ, ГруппаЗаказ);
		
	КонецЦикла;
	
	Для Каждого КЗ Из ДанныеЗаказаСтруктура Цикл
		
		Если Не ТипЗнч(КЗ.Значение) = Тип("Массив") ТОгда
			Продолжить;
		КонецЕсли;
		
		РазобратьЭлемент(КЗ, ГруппаЗаказ);
		
	КонецЦикла;
	
КонецПроцедуры 

Функция ДобавитьГруппу(Имя, Родитель, Заголовок = "", Линия = Ложь, Горизонтальное = Ложь)
	
	УникальноеИмя = СтрЗаменить(Имя + Строка(Новый УникальныйИдентификатор()), "-", "");
	Группа = Элементы.Добавить(
		"Группа" + УникальноеИмя,
		Тип("ГруппаФормы"),
		Родитель);
		
	Группа.Вид = ВидГруппыФормы.ОбычнаяГруппа;
	
	Группа.Заголовок = ?(Заголовок = "", Имя, Заголовок);	
	Группа.Отображение = ?(Линия, ОтображениеОбычнойГруппы.Линия, ОтображениеОбычнойГруппы.РамкаГруппы);
    Группа.Группировка = ?(Горизонтальное, ГруппировкаПодчиненныхЭлементовФормы.Горизонтальная, ГруппировкаПодчиненныхЭлементовФормы.Вертикальная);
	Возврат Группа;
	
КонецФункции

Функция ДобавитьЭлемент(Имя, Знач Значение, родитель)
	
	Значение = УдалитьНедопустимыеСимволыXML(Строка(Значение));
	
	ИмяРеквизита = Имя + СтрЗаменить(Новый УникальныйИдентификатор(), "-", "");
	ДобавляемыеРеквизиты = Новый Массив();
	Реквизит = Новый РеквизитФормы(ИмяРеквизита, ОписаниеТипаСтрока(СтрДлина(СокрЛП(Значение))), , Имя);
	ДобавляемыеРеквизиты.Добавить(Реквизит);
	ЭтаФорма.ИзменитьРеквизиты(ДобавляемыеРеквизиты);
	
	Элемент = ЭтаФорма.Элементы.Добавить(ИмяРеквизита, Тип("ПолеФормы"), Родитель);
	Элемент.Вид = ВидПоляФормы.ПолеВвода;
	Элемент.ПутьКДанным = ИмяРеквизита;
	Элемент.Заголовок = Имя;
	Элемент.РастягиватьПоГоризонтали = Ложь;
	ЭтаФорма[ИмяРеквизита] = Значение;
	
КонецФункции

Функция РазобратьЭлемент(КЗ, Знач Группа)
	
	Если ТипЗнч(КЗ.Значение) = Тип("Массив") Тогда
		ГруппаМ = ДобавитьГруппу(КЗ.Ключ, Группа);
		
		ИндексЭлементаМассива = 0;
		Для Каждого М Из КЗ.Значение Цикл
			
			ИндексЭлементаМассива = ИндексЭлементаМассива + 1;
			
			Если ТипЗнч(М) = Тип("Соответствие") Тогда
				М = ОбщегоНазначения.СоответствиеВСтруктуру(М);
			КонецЕсли;
			
			Если КЗ.Ключ = "items" Тогда
				Ном = СокрЛП(Справочники.Номенклатура.ПолучитьСсылку(М.nomenclature_id));
				ГруппаН = ДобавитьГруппу( "Ном" + СтрЗаменить(Новый УникальныйИдентификатор(), "-", ""), ГруппаМ, Ном, Истина, Истина);
			ИначеЕсли КЗ.Ключ = "operations" Тогда
				ГруппаН = ДобавитьГруппу("" + КЗ.Ключ + "_" + ИндексЭлементаМассива, ГруппаМ, "" + КЗ.Ключ + "_" + ИндексЭлементаМассива, Истина, Ложь);
			Иначе
				ГруппаН = ГруппаМ;
			КонецЕсли;
			
			Если ТипЗнч(М) = Тип("Структура") ИЛИ ТипЗнч(М) = Тип("Массив") Тогда
				Для Каждого КЗм Из М Цикл
					РазобратьЭлемент(КЗм, ГруппаН);
				КонецЦикла;
			Иначе
				ДобавитьЭлемент(КЗ.Ключ, М, ГруппаМ);	
			КонецЕсли;
			
		КонецЦикла;
		
	ИначеЕсли ТипЗнч(КЗ.Значение) = Тип("Соответствие") Тогда
		Данные = ОбщегоНазначения.СоответствиеВСтруктуру(КЗ.Значение);
		Для Каждого КЗп Из Данные Цикл
			ДобавитьЭлемент(КЗп.Ключ, КЗп.Значение, Группа);
		КонецЦикла;
	ИначеЕсли ТипЗнч(КЗ.Значение) = Тип("Структура") Тогда
		
		Группа = ДобавитьГруппу(КЗ.Ключ, Группа, КЗ.Ключ, Ложь, Ложь);
		
		Для Каждого КЗп Из КЗ.Значение Цикл
			РазобратьЭлемент(КЗп, Группа); 
			//ДобавитьЭлемент(КЗп.Ключ, КЗп.Значение, Группа);
		КонецЦикла;
		
	Иначе
		ДобавитьЭлемент(КЗ.Ключ, КЗ.Значение, Группа);
	КонецЕсли;
	
КонецФункции

Функция ОписаниеТипаСтрока(ДлинаСтроки) Экспорт

	Массив = Новый Массив;
	Массив.Добавить(Тип("Строка"));

	КвалификаторСтроки = Новый КвалификаторыСтроки(ДлинаСтроки, ДопустимаяДлина.Переменная);

	Возврат Новый ОписаниеТипов(Массив, , КвалификаторСтроки);

КонецФункции

Функция УдалитьНедопустимыеСимволыXML(Стр)

    Позиция = НайтиНедопустимыеСимволыXML(Стр, , );

    Пока Позиция <> 0 Цикл
        Стр = Лев(Стр, Позиция-1) + Сред(Стр, Позиция+1);
        Позиция = НайтиНедопустимыеСимволыXML(Стр, , );
    КонецЦикла; 

    Возврат Стр;

КонецФункции

Функция ПолучитьСтруктуруРеквизитовЗаказа(НомерЗаказаНаСайте)
	
	СтруктураРеквизитов = новый Структура;
	СтруктураРеквизитов.Вставить("MagPayRef", "");
	//СтруктураРеквизитов.Вставить("MagPayID", "");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиента.MagPayRef,
		|	ЗаказКлиента.MagPayID
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	ЗаказКлиента.НомерЗаказаНаСайте = &НомерЗаказаНаСайте";

	Запрос.УстановитьПараметр("НомерЗаказаНаСайте", НомерЗаказаНаСайте);

	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(СтруктураРеквизитов, ВыборкаДетальныеЗаписи);
	КонецЦикла;

	Возврат СтруктураРеквизитов;
	
КонецФункции

&НаКлиенте
Процедура ЗаказыПриИзменении(Элемент)
	ЗагрузитьЧекиМагПей();
КонецПроцедуры

&НаКлиенте
Процедура Перечитать(Команда)
	ЗагрузитьЧекиМагПей();
КонецПроцедуры

&НаКлиенте
Процедура Заблокировать(Команда)
	ЗаблокироватьРазблокироватьЗаказы(Истина);
	ЗагрузитьЧекиМагПей();
КонецПроцедуры

&НаКлиенте
Процедура Разблокировать(Команда)
	ЗаблокироватьРазблокироватьЗаказы(Ложь);
	ЗагрузитьЧекиМагПей();
КонецПроцедуры

&НаСервере
Процедура ЗаблокироватьРазблокироватьЗаказы(Блокировка)
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект"); 

	Если Блокировка Тогда
		Ресурс = ОбработкаОбъект.РесурсыЗапроса().ЗаблокироватьЗаказы;
	Иначе
		Ресурс = ОбработкаОбъект.РесурсыЗапроса().РазблокироватьЗаказы;
	КонецЕсли;
	
	ОтправляемыеЗаказы = СтруктураСписокЗаказов();
	Сч = 0;
	
	Для Каждого Заказ Из Заказы Цикл
		
		Сч = Сч + 1;
		Если Не Сч%25 Тогда                                                                               
			ОтправитьЗаказыНаБлокировкуРазблокировку(ОтправляемыеЗаказы, Ресурс);
			ОтправляемыеЗаказы = СтруктураСписокЗаказов();
		КонецЕсли;
		
		ОтправляемыеЗаказы.Data.Добавить(Новый Структура("external_id", Строка(Заказ.Значение.УникальныйИдентификатор())));
		
	КонецЦикла;
	
	Если ОтправляемыеЗаказы.Data.Количество() Тогда
		ОтправитьЗаказыНаБлокировкуРазблокировку(ОтправляемыеЗаказы, Ресурс);
	КонецЕсли;
	
	//Если Заказы.Количество() > 0 Тогда
	//	УзелОбменаМагпей = ОбщегоНазначенияСерверПовтИсп.ЗначениеКонстанты("УзелОбменаMagPay");
	//	ПланыОбмена.ЗарегистрироватьИзменения(УзелОбменаМагпей, Заказы.ВыгрузитьЗначения());
	//КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтправитьЗаказыНаБлокировкуРазблокировку(ОтправляемыеЗаказы, Ресурс)
	
	ТекстJSON = JSONСерверВызовСервера.СформироватьСтрокуJSON(ОтправляемыеЗаказы);
	Рез = "";
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Попытка
		Ответ = ОбработкаОбъект.ВыполнитьЗапрос(Ресурс, ТекстJSON, "Заказы", Рез); 
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка отправки запроса: " + Символы.ПС + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция СтруктураСписокЗаказов()
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	Возврат ОбработкаОбъект.СтруктураИзСпискаПолей("data", Новый Массив);
	
КонецФункции

	