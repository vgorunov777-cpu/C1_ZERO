#Область ОтправитьСМС

&НаКлиенте
Процедура ОтправитьСМС(Команда)
	ОтправитьСМСНаСервере();
	Закрыть();
КонецПроцедуры

&НаСервере
Процедура ОтправитьСМСНаСервере();
	
	RegExp=Новый COMОбъект("VBScript.RegExp");
	RegExp.Global = Истина;
	RegExp.IgnoreCase = Истина;
	RegExp.Pattern = "[^0-9]";
	
	СтрокаАбонентов = "";
	Для Каждого СтрокаТаблицы Из ТаблицаПолучателей Цикл
		ТелефонДляОтправки = RegExp.Replace(СтрокаТаблицы.ПокупательТелефон, "");
		Если СтрДлина(ТелефонДляОтправки)>=10 Тогда
			СтрокаАбонентов = СтрокаАбонентов + ?(ПустаяСтрока(СтрокаАбонентов), "", ",") + "7"+Прав(ТелефонДляОтправки,10);
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ПустаяСтрока(СтрокаАбонентов) Тогда
		МассивРезультатовОтправкиСМС = ИнтеграцияСервер.ОтправитьСМС(СтрокаАбонентов, ТекстШаблонаСМС);
		//О = РеквизитФормыВЗначение("Объект");
		//МассивРезультатовОтправкиСМС = О.ОтправитьСМС(СтрокаАбонентов, ТекстШаблонаСМС);
		//ЗначениеВРеквизитФормы(О, "Объект");
		ТекстПисьма = "";
		Для Каждого РезультатОтправкиСМС ИЗ МассивРезультатовОтправкиСМС Цикл
			Если РезультатОтправкиСМС.Результат = ИСТИНА Тогда
				Продолжить;
			КонецЕсли;
			ТекстПисьма = ТекстПисьма + "Абонент " + РезультатОтправкиСМС.Абонент + ": " + РезультатОтправкиСМС.Комментарий;
		КонецЦикла;
		Если СтрДлина(ТекстПисьма)>0 Тогда
			ТекстПисьма = "Ошибки отправки СМС" + Символы.ПС + ТекстПисьма;
			О = РеквизитФормыВЗначение("Объект");
			О.ОтправитьНаПочту("АРМ ИМ", ТекстПисьма);
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ТаблицаПолучателей

&НаКлиенте
Процедура ТаблицаПолучателейВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	Если НЕ Поле.Имя = "ТаблицаПолучателейПокупательТелефон" Тогда
		СтандартнаяОбработка = Ложь; 
		Если ЗначениеЗаполнено(ТаблицаПолучателей[ВыбраннаяСтрока].Заказ) Тогда
			П = Новый Структура("Ключ", ТаблицаПолучателей[ВыбраннаяСтрока].Заказ);
			ФормаДокумента = ПолучитьФорму("Документ.ЗаказКлиента.Форма.ФормаДокумента", П);
			ФормаДокумента.ТолькоПросмотр = Истина;
			ФормаДокумента.Открыть();
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти
