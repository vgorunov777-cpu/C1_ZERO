&НаКлиенте
Процедура ШаблонСМСНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	ОткрытьФормуВыбораШаблона(Элемент, "ПриЗакрытииФормыВыбораШаблона");
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораШаблона(Владелец, ПроцедураПриЗакрытии = Неопределено)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ФиксированныеНастройки",					ПолучитьНастройкиКомпоновкиДляФормыВыбораШаблона());
	ПараметрыФормы.Вставить("РежимВыбора",								Истина);
	ПараметрыФормы.Вставить("МножественныйВыбор",						Ложь);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе",						Истина);
	ПараметрыФормы.Вставить("ОтображениеТаблицы",						ОтображениеТаблицы.Список);
	
	ОткрытьФорму("Справочник.ШаблоныСМС.ФормаВыбора", ПараметрыФормы, Владелец,
		, , , ?(ПроцедураПриЗакрытии = Неопределено, Неопределено, Новый ОписаниеОповещения(ПроцедураПриЗакрытии, ЭтаФорма)));
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьНастройкиКомпоновкиДляФормыВыбораШаблона()
	
	НастройкиКомпоновки = Новый НастройкиКомпоновкиДанных;
	
	МассивВитрин = Новый Массив;
	Для Каждого СтрокаТаблицы Из ТаблицаПолучателей Цикл
		Если НЕ ЗначениеЗаполнено(СтрокаТаблицы.Витрина) Тогда
			Продолжить;
		КонецЕсли;
		Если МассивВитрин.Найти(СтрокаТаблицы.Витрина) = Неопределено Тогда
			МассивВитрин.Добавить(СтрокаТаблицы.Витрина);
		КонецЕсли;
	КонецЦикла;
	СписокДоступныхВитрин = Новый СписокЗначений;
	СписокДоступныхВитрин.ЗагрузитьЗначения(МассивВитрин);
	
	ЭлементОтбора = НастройкиКомпоновки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Витрина");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.ВСписке;
	ЭлементОтбора.Использование  = Истина;
	ЭлементОтбора.ПравоеЗначение = СписокДоступныхВитрин;
	
	Возврат НастройкиКомпоновки;
	
КонецФункции

