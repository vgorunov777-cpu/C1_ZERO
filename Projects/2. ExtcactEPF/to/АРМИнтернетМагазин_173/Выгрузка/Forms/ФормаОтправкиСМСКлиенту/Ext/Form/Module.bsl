#Область ОсновныеМетодыФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	О = РеквизитФормыВЗначение("Объект");
	Заголовок = О.Метаданные().Комментарий + ": " + О.Метаданные().Синоним + ": " + ЭтаФорма.Заголовок;
	ЭтаФорма.Заголовок = Заголовок;
	
	RegExp=Новый COMОбъект("VBScript.RegExp");
	RegExp.Global = Истина;
	RegExp.IgnoreCase = Истина;
	RegExp.Pattern = "[^0-9]";
	
	МассивОшибок = Новый Массив;
	Если Параметры.Свойство("МассивЗаказов") Тогда
		Если ТипЗнч(Параметры.МассивЗаказов) = Тип("Массив") Тогда
			Для Каждого ЭлементМассива Из Параметры.МассивЗаказов Цикл
				
				ПокупательФИО = "";
				ПокупательТелефон = "";
				ПокупательEmail = "";
				Имя = "";
				Фамилия = "";
				
				РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ЭлементМассива, "KDVID, ВитринаИнтернетМагазина, URL, НомерЗаказаНаСайте, ДатаЗаказаНаСайте, ПокупательФИО, ПокупательТелефон, ПокупательEmail");
				
				НомерЗаказаНаСайте = РеквизитыЗаказа.НомерЗаказаНаСайте;
				ДатаЗаказаНаСайте = РеквизитыЗаказа.ДатаЗаказаНаСайте;
				
				Если ПустаяСтрока(РеквизитыЗаказа.KDVID) Тогда
					ПокупательФИО = РеквизитыЗаказа.ПокупательФИО;
					ПокупательТелефон = РеквизитыЗаказа.ПокупательТелефон;
					ПокупательEmail = РеквизитыЗаказа.ПокупательEmail;
				Иначе
					Если РеквизитыЗаказа.ВитринаИнтернетМагазина = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс")
						ИЛИ РеквизитыЗаказа.ВитринаИнтернетМагазина = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен") Тогда
						main_partner_kdvid = "Yarche";
					ИначеЕсли РеквизитыЗаказа.ВитринаИнтернетМагазина = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.Игрушки") 
						И СтрНайти(НРег(РеквизитыЗаказа.URL), "kdvonline") > 0 Тогда
						main_partner_kdvid = "KDV";
					ИначеЕсли РеквизитыЗаказа.ВитринаИнтернетМагазина = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.Игрушки") 
						И СтрНайти(НРег(РеквизитыЗаказа.URL), "toybe") > 0 Тогда
						main_partner_kdvid = "Toybe";
					ИначеЕсли РеквизитыЗаказа.ВитринаИнтернетМагазина = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.Игрушки") 
						И СтрНайти(НРег(РеквизитыЗаказа.URL), "yarcheplus") > 0 Тогда
						main_partner_kdvid = "Yarche";
					Иначе
						main_partner_kdvid = Неопределено;
					КонецЕсли;
					СтруктураПерсональныхДанных = KDVID.АвторизоватьсяИПолучитьПерсональныеДанные(РеквизитыЗаказа.KDVID, main_partner_kdvid);
					Если ПустаяСтрока(СтруктураПерсональныхДанных.description) Тогда
						Если ТипЗнч(СтруктураПерсональныхДанных.data) = Тип("Структура") Тогда
							Если СтруктураПерсональныхДанных.data.Свойство("name") Тогда
								Имя = СтруктураПерсональныхДанных.data.name;
							КонецЕсли;
							Если СтруктураПерсональныхДанных.data.Свойство("surname") Тогда
								Фамилия = СтруктураПерсональныхДанных.data.surname;
							КонецЕсли;
							ПокупательФИО = Строка(Фамилия) + ?(ПустаяСтрока(Фамилия), "", " ") + Строка(Имя);
							Если СтруктураПерсональныхДанных.data.Свойство("phone") Тогда
								ПокупательТелефон = СтруктураПерсональныхДанных.data.phone;
							КонецЕсли;
							Если СтруктураПерсональныхДанных.data.Свойство("email") Тогда
								Если ТипЗнч(СтруктураПерсональныхДанных.data.email) = Тип("Структура") И СтруктураПерсональныхДанных.data.email.Свойство("email") Тогда
									ПокупательEmail = СтруктураПерсональныхДанных.data.email.email;
								КонецЕсли;
							КонецЕсли;
						КонецЕсли;
					Иначе 
						Если МассивОшибок.Найти(НомерЗаказаНаСайте) = Неопределено Тогда
							МассивОшибок.Добавить(НомерЗаказаНаСайте);
						КонецЕсли;
					КонецЕсли;
					
				КонецЕсли;

				ПокупательТелефон = СтрЗаменить(ПокупательТелефон, ",", Символы.ПС);
				ПокупательТелефон = СтрЗаменить(ПокупательТелефон, ";", Символы.ПС);
				
				Если СтрЧислоСтрок(ПокупательТелефон) = 0 Тогда
					Если МассивОшибок.Найти(НомерЗаказаНаСайте) = Неопределено Тогда
						МассивОшибок.Добавить(НомерЗаказаНаСайте);
					КонецЕсли;
				КонецЕсли;
				
				Для Сч = 1 По СтрЧислоСтрок(ПокупательТелефон) Цикл
					
					ТелефонДляОтправки = RegExp.Replace(СтрПолучитьСтроку(ПокупательТелефон, Сч), "");
					
					Если СтрДлина(ТелефонДляОтправки)>=10 Тогда
						НС = ТаблицаПолучателей.Добавить();
						НС.Заказ = ЭлементМассива;
						НС.НомерЗаказаНаСайте = НомерЗаказаНаСайте;
						НС.ДатаЗаказаНаСайте = ДатаЗаказаНаСайте;
						НС.ПокупательФИО = ПокупательФИО;
						НС.ПокупательТелефон = "7"+Прав(ТелефонДляОтправки,10);
						НС.Витрина = РеквизитыЗаказа.ВитринаИнтернетМагазина;
					Иначе
						Если МассивОшибок.Найти(НомерЗаказаНаСайте) = Неопределено Тогда
							МассивОшибок.Добавить(НомерЗаказаНаСайте);
						КонецЕсли;
					КонецЕсли;
					
				КонецЦикла;
				
			КонецЦикла;
		КонецЕсли;
	КонецЕсли;
	
	Если ТаблицаПолучателей.Количество() = 0 И МассивОшибок.Количество() = 0 Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Если МассивОшибок.Количество() > 0 Тогда
		ТекстСообщения = "Есть ошибки получения номеров телефонов по заказам:" + Символы.ПС;
		Для Каждого ЭлементМассива Из МассивОшибок Цикл
			ТекстСообщения = ТекстСообщения + ЭлементМассива + Символы.ПС;
		КонецЦикла;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)

КонецПроцедуры

