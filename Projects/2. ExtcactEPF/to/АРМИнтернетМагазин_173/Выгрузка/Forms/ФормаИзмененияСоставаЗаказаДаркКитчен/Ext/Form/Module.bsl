#Область СнятьПризнакТребуетсяОбработка

&НаКлиенте
Процедура СнятьПризнакТребуетсяОбработка(Команда)
	СтруктураПараметров = Новый Структура("Результат, ОписаниеРезультата", Истина, "");
	СнятьПризнакТребуетсяОбработкаНаСервере(СтруктураПараметров);
	Если СтруктураПараметров.Результат = Ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтруктураПараметров.ОписаниеРезультата);
		Возврат;
	КонецЕсли;
	ЭтаФорма.Закрыть();
КонецПроцедуры

&НаСервере
Процедура СнятьПризнакТребуетсяОбработкаНаСервере(СтруктураПараметров)
	
	НЗРС = РегистрыСведений.СтатусыПроизводстваДК.СоздатьНаборЗаписей();
	НЗРС.Отбор.Документ.Установить(Заказ);
	НЗРС.Прочитать();
	ТребуетсяЗаписьСтатусыПроизводства = Ложь;
	Для Каждого МЗРС Из НЗРС Цикл
		Если МЗРС.ТребуетсяОбработка Тогда
			МЗРС.ТребуетсяОбработка = Ложь;
			ТребуетсяЗаписьСтатусыПроизводства = Истина;
		КонецЕсли;
	КонецЦикла;
	НЗРС.ДополнительныеСвойства.Вставить("НЕПишемРСДК", Истина);
	
	НачатьТранзакцию();
	Попытка
		Если ТребуетсяЗаписьСтатусыПроизводства Тогда
			НЗРС.Записать();
		КонецЕсли;
		ДаркКитченСервер.ОбновитьРССтатусЗаказаДК(Заказ, Ложь, , , , Ложь);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		СтруктураПараметров.Вставить("Результат", Ложь);
		СтруктураПараметров.Вставить("ОписаниеРезультата", "Ошибка снятия ""Требуется обработка""" + Символы.ПС + "Закройте форму и выполните операцию еще раз");
		ЗаписьЖурналаРегистрации("ИМ.СнятиеТребуетсяОбработка", УровеньЖурналаРегистрации.Ошибка, Заказ.Метаданные(), Заказ, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат;
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти


