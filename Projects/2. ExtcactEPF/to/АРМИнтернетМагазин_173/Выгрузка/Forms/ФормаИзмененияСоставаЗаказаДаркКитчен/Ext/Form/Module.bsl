&НаКлиенте
Процедура ДобавитьНоменклатуру(Команда)
	ОткрытьФормуВыбораНоменклатуры(Ложь, Истина, Элементы.ДанныеЗаказНоменклатура, "ПриЗакрытииФормыВыбораНоменклатуры");
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуВыбораНоменклатуры(МножественныйВыбор, ЗакрыватьПриВыборе, Владелец, ПроцедураПриЗакрытии = Неопределено)
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ФиксированныеНастройки",	ПолучитьНастройкиКомпоновкиДляФормыВыбораНоменклатуры());
	ПараметрыФормы.Вставить("РежимВыбора",				Истина);
	ПараметрыФормы.Вставить("МножественныйВыбор",		МножественныйВыбор);
	ПараметрыФормы.Вставить("ЗакрыватьПриВыборе",		ЗакрыватьПриВыборе);
	ПараметрыФормы.Вставить("ОтображениеТаблицы",		ОтображениеТаблицы.Список);
	
	ОткрытьФорму("Справочник.Номенклатура.ФормаВыбора", ПараметрыФормы, Владелец
		, , , , ?(ПроцедураПриЗакрытии = Неопределено, Неопределено, Новый ОписаниеОповещения(ПроцедураПриЗакрытии, ЭтаФорма)));
	
КонецПроцедуры

&НаКлиенте
Функция ПолучитьНастройкиКомпоновкиДляФормыВыбораНоменклатуры()
	
	НастройкиКомпоновки = Новый НастройкиКомпоновкиДанных;
	
	СписокДоступнойНоменклатуры = Новый СписокЗначений;
	СписокДоступнойНоменклатуры.ЗагрузитьЗначения(ПолучитьМассивДоступныхНоменклатурНаСервере());
	
	ЭлементОтбора = НастройкиКомпоновки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных")); 
	ЭлементОтбора.ЛевоеЗначение  = Новый ПолеКомпоновкиДанных("Ссылка");
	ЭлементОтбора.ВидСравнения   = ВидСравненияКомпоновкиДанных.ВСписке;
	ЭлементОтбора.Использование  = Истина;
	ЭлементОтбора.ПравоеЗначение = СписокДоступнойНоменклатуры;
	
	Возврат НастройкиКомпоновки;
	
КонецФункции

&НаСервере
Функция ПолучитьМассивДоступныхНоменклатурНаСервере()
	
	ТаблицаНоменклатурДляДобавления.Очистить();
	МассивНоменклатур = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	сНоменклатура.Ссылка КАК Номенклатура,
	               |	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
	               |	ВЫБОР
	               |		КОГДА сНоменклатура.ТипМаркируемойПродукции = 0
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК МаркируемаяПродукция,
	               |	сНоменклатура.СтавкаНДС КАК СтавкаНДС,
	               |	сНоменклатура.АссортиментДК КАК Цех
	               |ИЗ
	               |	Справочник.Номенклатура КАК сНоменклатура
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаСреза, ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
	               |		ПО сНоменклатура.Ссылка = ЦеныНоменклатурыСрезПоследних.Номенклатура
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДоступностьТоваровКЗаказуДК КАК ДоступностьТоваровКЗаказуДК
	               |		ПО сНоменклатура.Ссылка = ДоступностьТоваровКЗаказуДК.Номенклатура
	               |			И (ДоступностьТоваровКЗаказуДК.Склад = &Склад)
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	               |		ПО сНоменклатура.Ссылка = НоменклатураСегмента.Номенклатура
	               |			И (НоменклатураСегмента.Сегмент = &СегментДаркКитчен)
	               |ГДЕ
	               |	НЕ сНоменклатура.ПометкаУдаления
	               |	И НЕ сНоменклатура.ЭтоГруппа
	               |	И сНоменклатура.АссортиментДК <> &АссортиментДКПустаяСсылка
	               |	И ЦеныНоменклатурыСрезПоследних.Цена <= &ПорогЦены
	               |	И ВЫБОР
	               |			КОГДА ДоступностьТоваровКЗаказуДК.Доступен ЕСТЬ NULL
	               |				ТОГДА ИСТИНА
	               |			КОГДА ДоступностьТоваровКЗаказуДК.Доступен
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ ЛОЖЬ
	               |		КОНЕЦ
	               |
	               |ОБЪЕДИНИТЬ ВСЕ
	               |
	               |ВЫБРАТЬ
	               |	сНоменклатура.Ссылка,
	               |	0,
	               |	ВЫБОР
	               |		КОГДА сНоменклатура.ТипМаркируемойПродукции = 0
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ,
	               |	сНоменклатура.СтавкаНДС,
	               |	сНоменклатура.АссортиментДК
	               |ИЗ
	               |	Справочник.Номенклатура КАК сНоменклатура
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаСреза, ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних
	               |		ПО сНоменклатура.Ссылка = ЦеныНоменклатурыСрезПоследних.Номенклатура
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДоступностьТоваровКЗаказуДК КАК ДоступностьТоваровКЗаказуДК
	               |		ПО сНоменклатура.Ссылка = ДоступностьТоваровКЗаказуДК.Номенклатура
	               |			И (ДоступностьТоваровКЗаказуДК.Склад = &Склад)
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	               |		ПО сНоменклатура.Ссылка = НоменклатураСегмента.Номенклатура
	               |			И (НоменклатураСегмента.Сегмент = &СегментДаркКитчен)
	               |ГДЕ
	               |	НЕ сНоменклатура.ПометкаУдаления
	               |	И НЕ сНоменклатура.ЭтоГруппа
	               |	И сНоменклатура.АссортиментДК = &АссортиментДКСопутствующиеТовары
	               |	И ЕСТЬNULL(ЦеныНоменклатурыСрезПоследних.Цена, 0) = 0
	               |	И ВЫБОР
	               |			КОГДА ДоступностьТоваровКЗаказуДК.Доступен ЕСТЬ NULL
	               |				ТОГДА ИСТИНА
	               |			КОГДА ДоступностьТоваровКЗаказуДК.Доступен
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ ЛОЖЬ
	               |		КОНЕЦ";
	
	Запрос.УстановитьПараметр("СегментДаркКитчен", СегментНоменклатурыДаркКитчен);
	Запрос.УстановитьПараметр("АссортиментДКПустаяСсылка", Справочники.ЦехДК.ПустаяСсылка());
	Запрос.УстановитьПараметр("АссортиментДКСопутствующиеТовары", Справочники.ЦехДК.НайтиПоКоду("000000006"));
	Запрос.УстановитьПараметр("ДатаСреза", ТекущаяДата());
	Запрос.УстановитьПараметр("Склад", СкладЗаказа);
	Запрос.УстановитьПараметр("ПорогЦены", СуммаДляПодбора);
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат МассивНоменклатур;
	КонецЕсли;
	
	РезультатВыборка = РезультатЗапроса.Выбрать();
	Пока РезультатВыборка.Следующий() Цикл
		НС = ТаблицаНоменклатурДляДобавления.Добавить();
		ЗаполнитьЗначенияСвойств(НС, РезультатВыборка);
		МассивНоменклатур.Добавить(РезультатВыборка.Номенклатура);
	КонецЦикла;
	
	Возврат МассивНоменклатур;
	
КонецФункции

&НаКлиенте
Процедура ПриЗакрытииФормыВыбораНоменклатуры(Результат, ДополнительныеПараметры) Экспорт
	
	Если Результат = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	НайденныеСтроки = Товары.НайтиСтроки(Новый Структура("Номенклатура", Результат));
	Если НайденныеСтроки.Количество() <> 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Результат) + " - уже есть в заказе, ");
		Возврат;
	КонецЕсли;
	
	НайденныеСтроки = ТаблицаНоменклатурДляДобавления.НайтиСтроки(Новый Структура("Номенклатура", Результат));
	Если НайденныеСтроки.Количество() = 0 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Добавление " + Строка(Результат) + " запрещено");
		Возврат;
	КонецЕсли;
	
	НС = Товары.Добавить();
	ЗаполнитьЗначенияСвойств(НС, НайденныеСтроки[0]);
	НС.Количество = 1;
	НС.КоличествоШтук = 1;
	НС.Сумма = Окр(НС.Цена * НС.Количество, 2);
	
	ЕстьИзменения = Истина;
	ПересчитатьСуммы();
	
КонецПроцедуры


