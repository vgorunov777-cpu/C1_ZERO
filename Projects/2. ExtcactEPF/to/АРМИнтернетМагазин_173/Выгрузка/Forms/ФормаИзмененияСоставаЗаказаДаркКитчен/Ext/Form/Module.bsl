	Если ПересчитатьСтрокуТовары(Элементы.ДанныеЗаказ.ТекущиеДанные, 3) Тогда
		Если НЕ ЕстьИзменения Тогда
			ЕстьИзменения = Истина;
		КонецЕсли;
		ПересчитатьСуммы();
	КонецЕсли;
