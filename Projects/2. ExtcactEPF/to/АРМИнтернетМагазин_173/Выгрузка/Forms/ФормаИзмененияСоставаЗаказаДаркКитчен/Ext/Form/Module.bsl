//НомерИзмененнойКолонки
//1 - Количество
//2 - КоличествоШтук
//3 - Отменено
&НаКлиенте
Функция ПересчитатьСтрокуТовары(ТекущиеДанные, НомерИзмененнойКолонки)
	
	//маркированная продукция
	Если ТекущиеДанные.МаркируемаяПродукция И ЗаказСобран Тогда
		
		//маркированная продукция
		Если НомерИзмененнойКолонки = 3 И ТекущиеДанные.Отменено = Истина Тогда
			ТекущиеДанные.Количество = 0;
			ТекущиеДанные.КоличествоШтук = 0;
			ТекущиеДанные.Сумма = 0;
			ЕстьИзмененияМаркруемыхТоваров = Истина;
		ИначеЕсли НомерИзмененнойКолонки = 3 И ТекущиеДанные.Отменено = Ложь Тогда
			ТекущиеДанные.Количество = ТекущиеДанные.КоличествоВЗаказе;
			ТекущиеДанные.КоличествоШтук = ТекущиеДанные.КоличествоШтукВЗаказе;
			ТекущиеДанные.Сумма = Окр(ТекущиеДанные.Количество * ТекущиеДанные.Цена, 2);
			ЕстьИзмененияМаркруемыхТоваров = Истина;
		Иначе
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Изменения количества маркируемой продукции запрещены. Возможен только полный вычерк строки.");
			ТекущиеДанные.Количество = ТекущиеДанные.КоличествоВЗаказе;
			Возврат Ложь;
		КонецЕсли;
		
	Иначе
		
		//немаркированная продукция
		Если НомерИзмененнойКолонки = 3 И ТекущиеДанные.Отменено = Истина Тогда
			ТекущиеДанные.Количество = 0;
			ТекущиеДанные.КоличествоШтук = 0;
			ТекущиеДанные.Сумма = 0;
		ИначеЕсли НомерИзмененнойКолонки = 3 И ТекущиеДанные.Отменено = Ложь Тогда
			ТекущиеДанные.Количество = ТекущиеДанные.КоличествоВЗаказе;
			ТекущиеДанные.КоличествоШтук = ТекущиеДанные.КоличествоШтукВЗаказе;
			ТекущиеДанные.Сумма = Окр(ТекущиеДанные.Количество * ТекущиеДанные.Цена, 2);
		ИначеЕсли НомерИзмененнойКолонки = 1 Тогда
			ТекущиеДанные.Отменено = ТекущиеДанные.Количество = 0;
			НовоеКоличествоШтук = ?(ТекущиеДанные.КоличествоВЗаказе > 0, ТекущиеДанные.Количество * ТекущиеДанные.КоличествоШтукВЗаказе / ТекущиеДанные.КоличествоВЗаказе, 0);
			Если НовоеКоличествоШтук <> ТекущиеДанные.КоличествоШтук Тогда
				//Если Вопрос("Пересчитать количество штук?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Да Тогда
					ТекущиеДанные.КоличествоШтук = НовоеКоличествоШтук;
				//КонецЕсли;
			КонецЕсли;
			ТекущиеДанные.Сумма = Окр(ТекущиеДанные.Количество * ТекущиеДанные.Цена, 2);
		ИначеЕсли НомерИзмененнойКолонки = 2 Тогда
			Если ТекущиеДанные.КоличествоШтукВЗаказе > 0 Тогда
				ТекущиеДанные.Отменено = ТекущиеДанные.КоличествоШтук = 0;
				НовоеКоличество = ТекущиеДанные.КоличествоВЗаказе * ТекущиеДанные.КоличествоШтук / ТекущиеДанные.КоличествоШтукВЗаказе;
				Если ТекущиеДанные.Количество <> НовоеКоличество Тогда
					//Если Вопрос("Пересчитать количество?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Да Тогда
						ТекущиеДанные.Количество = НовоеКоличество;
					//КонецЕсли;
				КонецЕсли;
				ТекущиеДанные.Сумма = Окр(ТекущиеДанные.Количество * ТекущиеДанные.Цена, 2);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

