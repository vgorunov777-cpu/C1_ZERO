&НаСервере
Функция СформироватьОтчетСервер()
	
	ОтчетРезультат.Очистить();
	О = РеквизитФормыВЗначение("Объект");
	Схема = О.ПОлучитьМакет("ДанныеНоменклатуры");
	ЗначениеВРеквизитФормы(О, "Объект");
	
	Настройки = Схема.НастройкиПОУмолчанию;
	ПараметрыДанных = Настройки.ПараметрыДанных;
	ПараметрыДанных.УстановитьЗначениеПараметра("СписокНоменклатуры", ОтборСписокНоменклатуры);
	ПараметрыДанных.УстановитьЗначениеПараметра("Склад", ОтборСклад);
	ПараметрыДанных.УстановитьЗначениеПараметра("СвойствоСтатусАктивности", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("СтатусАктивности"));
	
	СКДСерверВызовСервера.СкомпоноватьРезультатОтчета(ОтчетРезультат, Схема, Настройки);
	
КонецФункции

&НаКлиенте
Процедура ОтборНомерЗаказаПриИзменении(Элемент)
	
	ОтборСписокНоменклатуры.Очистить();
	ОтборСписокНоменклатуры.ЗагрузитьЗначения(НоменклатураЗаказа(ОтборНомерЗаказа));
	ОтборСклад = СкладПоЗаказу(ОтборНомерЗаказа);
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция НоменклатураЗаказа(НомерЗаказаОтбор)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ РАЗЛИЧНЫЕ
	               |	Т.Номенклатура КАК Номенклатура
	               |ИЗ
	               |	Документ.ЗаказКлиента.Товары КАК Т
	               |ГДЕ
	               |	Т.Ссылка.НомерЗаказаНаСайте = &НомерЗаказа";
	Запрос.УстановитьПараметр("НомерЗаказа", НомерЗаказаОтбор);
	
	Рез = Запрос.Выполнить().Выгрузить();
	Возврат Рез.ВыгрузитьКолонку("Номенклатура");
	
КонецФункции

&НаСервереБезКонтекста
Функция СкладПоЗаказу(НомерЗаказаОтбор)
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Т.Склад КАК Склад
	               |ИЗ
	               |	Документ.ЗаказКлиента КАК Т
	               |ГДЕ
	               |	Т.НомерЗаказаНаСайте = &НомерЗаказа";
	Запрос.УстановитьПараметр("НомерЗаказа", НомерЗаказаОтбор);
	
	Рез = Запрос.Выполнить().Выбрать();
	Рез.Следующий();
	Возврат Рез.Склад;
	
КонецФункции

&НаКлиенте
Процедура ОтборШКПриИзменении(Элемент)
	НоменклатураШК();
КонецПроцедуры

&НаСервере
Процедура НоменклатураШК()
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Штрихкод", ОтборШК);
	Запрос.Текст = "ВЫБРАТЬ
	|	ШтрихкодыНоменклатуры.Номенклатура
	|ИЗ
	|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
	|ГДЕ
	|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод";
	Рез = Запрос.Выполнить().Выбрать();
	ОтборСписокНоменклатуры.Очистить();
	Пока Рез.Следующий() Цикл
		ОтборСписокНоменклатуры.Добавить(Рез.Номенклатура);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
