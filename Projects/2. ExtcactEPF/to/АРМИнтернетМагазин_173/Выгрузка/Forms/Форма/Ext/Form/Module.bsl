&НаСервере
Процедура ПерезаполнитьТаблицуИнтернетМагазиныНаСервере()
	
	ТаблицаИнтернетМагазины.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СкладыДополнительныеРеквизиты.Ссылка КАК Магазин,
		|	ЕСТЬNULL(СкладыДополнительныеРеквизиты1.Значение, ЛОЖЬ) КАК СортировкаПоДатеЗаказа
		|ИЗ
		|	Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
		|		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты1
		|		ПО СкладыДополнительныеРеквизиты.Ссылка = СкладыДополнительныеРеквизиты1.Ссылка
		|			И (СкладыДополнительныеРеквизиты1.Свойство.Наименование = ""СортировкаПоДатеЗаказаИМ"")
		|ГДЕ
		|	СкладыДополнительныеРеквизиты.Свойство.Наименование = ""Склад интернет магазина""
		|	И СкладыДополнительныеРеквизиты.Значение = ИСТИНА
		|
		|УПОРЯДОЧИТЬ ПО
		|	СортировкаПоДатеЗаказа УБЫВ,
		|	СкладыДополнительныеРеквизиты.Ссылка.Наименование";

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		ЗаполнитьЗначенияСвойств(ТаблицаИнтернетМагазины.Добавить(), ВыборкаДетальныеЗаписи);
	КонецЦикла;
		
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьСписокСкладовИМ(СписокВыбора)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	СкладыДополнительныеРеквизиты.Ссылка КАК Склад,
		|	СкладыДополнительныеРеквизиты.Ссылка.Наименование КАК СкладНаименование
		|ИЗ
		|	Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланОбмена.ОбменССайтом КАК ОбменССайтом
		|		ПО СкладыДополнительныеРеквизиты.Ссылка = ОбменССайтом.Склад
		|ГДЕ
		|	СкладыДополнительныеРеквизиты.Свойство.Наименование = ""Склад интернет магазина""
		|	И СкладыДополнительныеРеквизиты.Значение = ИСТИНА
		|
		|УПОРЯДОЧИТЬ ПО
		|	СкладНаименование";
		
	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если Не ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Склад) Тогда
			Продолжить;
		КонецЕсли;
		СписокВыбора.Добавить(ВыборкаДетальныеЗаписи.Склад);
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура УстановитьСписокСкладовРозничныеМагазины(СписокВыбора)
	
	Склад = Новый Массив;
	Склад.Добавить(Справочники.Склады.НайтиПоНаименованию("Магазины работающие")); // Магазины работающие ()
	Склад.Добавить(Справочники.Склады.НайтиПоНаименованию("Магазины готовы к открытию")); // Магазины готовы к открытию ()
	Склад.Добавить(Справочники.Склады.НайтиПоНаименованию("Цеха Dark Kitchen")); // Цеха Dark Kitchen ()
	
	КодТекущегоУзла = ОбщегоНазначенияСерверПовтИсп.ПолучитьКодТекущегоУзла();
	УзелОбмена = Справочники.ИнформационныеБазыОбмена.ПолучитьИнформационнуюБазуПоКодуУзла(КодТекущегоУзла);
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	СкладыУзлаОбменаРИБ.Склад КАК Склад
	               |ИЗ
	               |	РегистрСведений.СкладыУзлаОбменаРИБ КАК СкладыУзлаОбменаРИБ
	               |ГДЕ
	               |	СкладыУзлаОбменаРИБ.УзелОбмена = &УзелОбмена
	               |	И СкладыУзлаОбменаРИБ.Склад В ИЕРАРХИИ(&Склад)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Склад
	               |АВТОУПОРЯДОЧИВАНИЕ";
	Запрос.УстановитьПараметр("УзелОбмена", УзелОбмена);
	Запрос.УстановитьПараметр("Склад", Склад);
	Результат = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Если Не ЗначениеЗаполнено(ВыборкаДетальныеЗаписи.Склад) Тогда
			Продолжить;
		КонецЕсли;
		СписокВыбора.Добавить(ВыборкаДетальныеЗаписи.Склад);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Функция ЧекИлиЭквайринговаяОперацияСуществуют(ЗаказСсылка)
	
	Если ЗначениеЗаполнено(ЗаказСсылка.ЧекПродажа) ИЛИ ЗначениеЗаполнено(ЗаказСсылка.ЭквайринговаяОперация) Тогда
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСоглашениеПоСкладу(Знач Склад)
	
	ТекстЗапроса = "ВЫБРАТЬ
	               |	СоглашенияСКлиентами.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.СоглашенияСКлиентами КАК СоглашенияСКлиентами
	               |ГДЕ
	               |	СоглашенияСКлиентами.Склад = &Склад
	               |	И СоглашенияСКлиентами.Наименование ПОДОБНО ""Интернет-магазин%""";
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Склад", Склад);
	РезультатВыборка = Запрос.Выполнить().Выбрать();
	Пока РезультатВыборка.Следующий() Цикл
		Возврат РезультатВыборка.Ссылка;
	КонецЦикла;
	
	Возврат Справочники.СоглашенияСКлиентами.ПустаяСсылка();
	
КонецФункции

#КонецОбласти



#Область Печать

&НаКлиенте
Процедура ПечатьЗаказа(Команда)
	
	МассивЗаказовДляПечати = ПолучитьМассивЗаказовДляПечати(Элементы.Заказы.ВыделенныеСтроки);
	
	Если МассивЗаказовДляПечати.Количество() = 0 Тогда
		Сообщить("Нет заказов для печати");
		Возврат;
	КонецЕсли;
	
	ВнешняяПечатнаяФорма = НайтиПечатнуюФормуЗаказа();
	ВнешняяПечатнаяФормаЭтикетка = НайтиПечатнуюФормуЭтикетки();
	
	Если НЕ ВнешняяПечатнаяФорма.Пустая() Тогда
		ПараметрыОткрытия = Новый Структура("ИсточникДанных, ПараметрыИсточника");
		ПараметрыОткрытия.ИсточникДанных = ВнешняяПечатнаяФорма;
		ПараметрыОткрытия.ПараметрыИсточника = Новый Структура("ИдентификаторКоманды, БезопасныйРежим, ОбъектыНазначения");
		ПараметрыОткрытия.ПараметрыИсточника.ИдентификаторКоманды = "ЗаказКлиентаИМ";
		ПараметрыОткрытия.ПараметрыИсточника.БезопасныйРежим = Ложь;
		ПараметрыОткрытия.ПараметрыИсточника.ОбъектыНазначения = МассивЗаказовДляПечати;
		ОткрытьФорму("ОбщаяФорма.ПечатьДокументов", ПараметрыОткрытия, , Истина, , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	Иначе
		Сообщить("Не обнаружена печатная форма заказа");
	КонецЕсли;
	//Если НЕ ВнешняяПечатнаяФормаЭтикетка.Пустая() Тогда
	//	ПараметрыОткрытияЭтикетка = Новый Структура("ИсточникДанных, ПараметрыИсточника");
	//    ПараметрыОткрытияЭтикетка.ИсточникДанных = ВнешняяПечатнаяФормаЭтикетка;
	//    ПараметрыОткрытияЭтикетка.ПараметрыИсточника = Новый Структура("ИдентификаторКоманды, БезопасныйРежим, ОбъектыНазначения");
	//    ПараметрыОткрытияЭтикетка.ПараметрыИсточника.ИдентификаторКоманды = "Этикетка";
	//	ПараметрыОткрытияЭтикетка.ПараметрыИсточника.БезопасныйРежим = Ложь;
	//    ПараметрыОткрытияЭтикетка.ПараметрыИсточника.ОбъектыНазначения = МассивЗаказовДляПечати;
	//    ОткрытьФорму("ОбщаяФорма.ПечатьДокументов", ПараметрыОткрытияЭтикетка, , Истина); 
	//Иначе
	//	Сообщить("Не обнаружена печатная форма этикетки");
	//КонецЕсли;
	
	//Если НЕ ВнешняяПечатнаяФорма.Пустая() ИЛИ НЕ ВнешняяПечатнаяФормаЭтикетка.Пустая() Тогда
	Если НЕ ВнешняяПечатнаяФорма.Пустая() Тогда
		ОтметитьЗаказыКакНапечатанные(МассивЗаказовДляПечати);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ОтметитьЗаказыКакНапечатанные(МассивЗаказовДляПечати)
	
	УстановитьПривилегированныйРежим(Истина);
	СвойствоШК = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Штрихкод документа");
	Для Каждого ЭлементЗаказ Из МассивЗаказовДляПечати Цикл
		РСМЗ = РегистрыСведений.ДополнительныеСведения.СоздатьМенеджерЗаписи();
		РСМЗ.Объект = ЭлементЗаказ;
		РСМЗ.Свойство = СвойствоШК;
		РСМЗ.Значение = ЭлементЗаказ.НомерЗаказаНаСайте;
		РСМЗ.Записать(Истина);
	КонецЦикла;
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаСервере
Функция ПолучитьМассивЗаказовДляПечати(Знач ИсходныйМассив)
	
	МассивЗаказов = новый Массив;
	Для Каждого ЭлементЗаказ Из ИсходныйМассив Цикл	
		//Если ЭлементЗаказ.Статус = Перечисления.СтатусыЗаказовКлиентов.Закрыт Тогда
		//	Продолжить;
		//КонецЕсли;
		ЕстьОшибка = Ложь;
		Если НЕ ЗначениеЗаполнено(ЭлементЗаказ.MagPayID) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + ЭлементЗаказ.НомерЗаказаНаСайте + " ошибка! Отсутствует ""MagPayID""");
			ЕстьОшибка = Истина;
		КонецЕсли;
		Если НЕ ЗначениеЗаполнено(ЭлементЗаказ.MagPayRef) Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("" + ЭлементЗаказ.НомерЗаказаНаСайте + " ошибка! Отсутствует ""MagPayRef""");
			ЕстьОшибка = Истина;
		КонецЕсли;
		Если ЕстьОшибка Тогда
			Продолжить;
		КонецЕсли;
		МассивЗаказов.Добавить(ЭлементЗаказ);
	КонецЦикла;
	Возврат МассивЗаказов;
	
КонецФункции

