#Область ОтменитьЗаказ

&НаКлиенте
Процедура ОтменитьЗаказ(Команда)
	
	ОтветПользователя = Вопрос(НСтр("ru = 'Вы действительно хотите отменить выделенные заказы?'"), РежимДиалогаВопрос.ДаНет);
	Если ОтветПользователя = КодВозвратаДиалога.Да Тогда
		
		ПричинаОтмены = "";
		ВвестиСтроку(ПричинаОтмены, "Введите причину отмены: ");
		
		Для Каждого Стр Из Элементы.Заказы.ВыделенныеСтроки Цикл
			
			ОтменаКлиентом = Ложь;
			НоменклатураУдержание = Неопределено;
			
			РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Стр, "НомерЗаказаНаСайте, ВитринаИнтернетМагазина, Статус, ПриложениеСборщика, ЧекПродажа, ЭквайринговаяОперация, Доставлен, Склад");
			НомерЗаказаНаСайте = РеквизитыЗаказа.НомерЗаказаНаСайте;
			ВитринаЗаказа = РеквизитыЗаказа.ВитринаИнтернетМагазина;
			
			//проверки
			Если НЕ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс") И 
				НЕ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.Игрушки") И 
				НЕ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.КДВ") И 
				НЕ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ОЗОН") И
				НЕ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен") Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + НомерЗаказаНаСайте + " не является заказом ЯрчеПлюс, Посылки, КДВ ИМ, ОЗОН, ДаркКитчен" + Символы.ПС + "Отмена заказа невозможна");
				Продолжить;
			КонецЕсли;
			
			Если (ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс") ИЛИ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен"))
				И РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.Закрыт") Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + НомерЗаказаНаСайте + " закрыт" + Символы.ПС + "Отмена закрытого заказа невозможна");
				Продолжить;
			КонецЕсли;
			
			Если ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.Игрушки") 
				И РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.Закрыт")
				И ЗначениеЗаполнено(РеквизитыЗаказа.ЭквайринговаяОперация) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + НомерЗаказаНаСайте + " закрыт" + Символы.ПС + "Отмена закрытого заказа невозможна");
				Продолжить;
			КонецЕсли;
			
			Если ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.КДВ") 
				И РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.Закрыт")
				И РеквизитыЗаказа.Доставлен = Истина Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + НомерЗаказаНаСайте + " закрыт" + Символы.ПС + "Отмена закрытого заказа невозможна");
				Продолжить;
			КонецЕсли;
			
			Если ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ОЗОН") 
				И РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.Закрыт")
				И (РеквизитыЗаказа.Доставлен = Истина ИЛИ ЗначениеЗаполнено(РеквизитыЗаказа.ЭквайринговаяОперация)) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + НомерЗаказаНаСайте + " закрыт" + Символы.ПС + "Отмена закрытого заказа невозможна");
				Продолжить;
			КонецЕсли;
			
			//логика отмены по витринам
			Если ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ОЗОН") Тогда
				
				Если Вопрос("Заказ ОЗОН " + НомерЗаказаНаСайте + " отменен по инициативе клиента (невозможности вручить клиенту заказ)?", РежимДиалогаВопрос.ДаНет) = КодВозвратаДиалога.Да Тогда
					ОтменаКлиентом = Истина;
				КонецЕсли;
				
			ИначеЕсли ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен") Тогда
				
				ОтменаКлиентом = Истина;
				
				СписокНоменклатурОтменыДаркКитчен = Новый СписокЗначений;
				НайденныеСтроки = ТаблицаНоменклатурОтменыДаркКитчен.НайтиСтроки(Новый Структура("Склад, Витрина", РеквизитыЗаказа.Склад, ВитринаЗаказа));
				Для Каждого СтрокаТаблицы Из НайденныеСтроки Цикл
					СписокНоменклатурОтменыДаркКитчен.Добавить(СтрокаТаблицы.Номенклатура, СтрокаТаблицы.Наименование);
				КонецЦикла;
				Если СписокНоменклатурОтменыДаркКитчен.Количество() Тогда
					РезультатВыбора = СписокНоменклатурОтменыДаркКитчен.ВыбратьЭлемент(Строка(НомерЗаказаНаСайте) + ": Выбери удержание");
					Если РезультатВыбора = Неопределено Тогда
						ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Заказ %1: не выбрано удержание.
                                                                                      |Отмена заказа невозможна'"), НомерЗаказаНаСайте));
						Продолжить;
					КонецЕсли;
					НоменклатураУдержание = РезультатВыбора.Значение;
				КонецЕсли;
				
			КонецЕсли;
			
			ЗакрытьЗаказ(Стр, ПричинаОтмены, ОтменаКлиентом, НоменклатураУдержание);
			
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗакрытьЗаказ(ЗаказСсылка, ОписаниеПричиныОтмены, ОтменаКлиентом = Ложь, НоменклатураУдержание = Неопределено)
	
	РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ЗаказСсылка, "НомерЗаказаНаСайте, ВитринаИнтернетМагазина, Статус, ПриложениеСборщика, ЧекПродажа, ЭквайринговаяОперация, Доставлен, Склад");
	
	УстановитьПривилегированныйРежим(Истина);
	
	ПричинаОтмены = Справочники.ПричиныОтменыЗаказовКлиентов.НайтиПоНаименованию("Отказ");
	ДатаОтменыЗаказа = ТекущаяДата();
	МассивДобавленныхНоменклатур = Новый Массив;
	
	ИспользуемКорРТУ = Ложь;
	Если РеквизитыЗаказа.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.КДВ Тогда
		ИспользуемКорРТУ = Истина;
	КонецЕсли;
	
	Заказ = ЗаказСсылка.ПолучитьОбъект();
	
	//отменяем заказ
	Для Каждого СЗ Из Заказ.Товары Цикл
		Если НЕ СЗ.Отменено Тогда
			СЗ.Отменено = Истина;
			СЗ.ПричинаОтмены = ПричинаОтмены;
		КонецЕсли;
	КонецЦикла;
	
	Если РеквизитыЗаказа.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.ДаркКитчен Тогда
		
		Если ЗначениеЗаполнено(НоменклатураУдержание) Тогда
			
			ЦенаДопУслуги = 0;
			РеквизитыСоглашения = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Заказ.Соглашение, "ВидЦен");
			
			НайденныеСтроки = ТаблицаНоменклатурОтменыДаркКитчен.НайтиСтроки(Новый Структура("Склад, Витрина, Номенклатура", РеквизитыЗаказа.Склад, РеквизитыЗаказа.ВитринаИнтернетМагазина, НоменклатураУдержание));
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				Если НайденнаяСтрока.УдержаниеУстановленнойЦены Тогда
					Если ЗначениеЗаполнено(РеквизитыСоглашения.ВидЦен) Тогда
						ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
						ЦенаДопУслуги = ОбработкаОбъект.ПолучитьЦенуНоменклатуры(НоменклатураУдержание, РеквизитыСоглашения.ВидЦен);
					КонецЕсли;
				Иначе
					ЦенаДопУслуги = Окр(Заказ.СуммаДокумента * НайденнаяСтрока.УдержаниеПроцентаОтСуммыЗаказа / 100, 2)
				КонецЕсли;
			КонецЦикла;
			
			Если ЦенаДопУслуги <> 0 Тогда
				
				ДопУслугаОтмены = Заказ.Товары.Добавить();
				ДопУслугаОтмены.Номенклатура = НоменклатураУдержание;
				ДопУслугаОтмены.КоличествоУпаковок = 1;
				ДопУслугаОтмены.Количество = 1;
				ДопУслугаОтмены.ВидЦены = РеквизитыСоглашения.ВидЦен;
				ДопУслугаОтмены.Цена = ЦенаДопУслуги;
				ДопУслугаОтмены.КоличествоШтук = 1;
				ДопУслугаОтмены.ДатаОтгрузки = Заказ.ЖелаемаяДатаОтгрузки;
				ДопУслугаОтмены.Склад = Заказ.Склад;
				
				СтруктураДействий = Новый Структура;
				СтруктураДействий.Вставить("ЗаполнитьСтавкуНДС", Заказ.НалогообложениеНДС);
				СтруктураДействий.Вставить("ПересчитатьСуммуНДС", ОбработкаТабличнойЧастиТоварыКлиентСервер.ПолучитьСтруктуруПересчетаСуммыНДСВСтрокеТЧ(Заказ));
				
				СтруктураДействий.Вставить("ПересчитатьКоличествоЕдиниц");
				СтруктураДействий.Вставить("ПересчитатьСумму");
				СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомРучнойСкидки", Новый Структура("Очищать", Ложь));
				СтруктураДействий.Вставить("ПересчитатьСуммуСУчетомАвтоматическойСкидки", Новый Структура("Очищать", Истина));
				
				КэшированныеЗначения = ОбработкаТабличнойЧастиТоварыКлиентСервер.ПолучитьСтруктуруКэшируемыеЗначения();
				ОбработкаТабличнойЧастиТоварыСервер.ОбработатьСтрокуТЧСервер(ДопУслугаОтмены, СтруктураДействий, КэшированныеЗначения);
				
				МассивДобавленныхНоменклатур.Добавить(НоменклатураУдержание);
				
				Заказ.Доставлен = Истина;
				
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	Заказ.Статус = Перечисления.СтатусыЗаказовКлиентов.Закрыт;
	Заказ.Комментарий = Заказ.Комментарий + ?(ЗначениеЗаполнено(Заказ.Комментарий), Символы.ПС, "") 
												+ Формат(ДатаОтменыЗаказа, "ДФ='dd.MM.yyyy HH:mm:ss'") + " " + Строка(ПараметрыСеанса.ТекущийПользователь) + Символы.ПС
												+ "Отменен по причине:" + ОписаниеПричиныОтмены;
	Заказ.ПользовательОтмены = ПараметрыСеанса.ТекущийПользователь;
	Заказ.СуммаДокумента = Заказ.ПолучитьСуммуЗаказанныхСтрок();
	Заказ.ОтменаКлиентом = ОтменаКлиентом;
	Заказ.ЗаполнитьЭтапыГрафикаОплаты();
	Заказ.ДополнительныеСвойства.Вставить("ОтключитьМеханизмБлокировкиОтгруженныхДокументов", Истина);
	Заказ.ДополнительныеСвойства.Вставить("НеКонтролироватьРезультатыПроведения", Истина);
	Заказ.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
	
	Реализация = Неопределено;
	
	Если РеквизитыЗаказа.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.Игрушки
		ИЛИ РеквизитыЗаказа.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.КДВ
		ИЛИ РеквизитыЗаказа.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.ОЗОН Тогда 
		
		Реализация = ИнтернетМагазинСлужебный.РеализацияПоЗаказу(ЗаказСсылка);
		Если Реализация <> Неопределено Тогда
			
			ВозвратОбъект = Неопределено;
			КорректировкаРегистровОбъект = Неопределено;

			Если ИспользуемКорРТУ Тогда
				ОснованиеКорректировки = ИнтернетМагазинСлужебный.ДокументаОснованиеДляКорректировкиРеализации(Реализация);
				КорректировкаРеализацииОбъект = ИнтернетМагазинСлужебный.СоздатьКорректировкуРеализации(ОснованиеКорректировки, ДатаОтменыЗаказа, ИнтернетМагазинСлужебный.ИнициализацияТаблицыТоваров()); 
				ВозвратОбъект = ИнтернетМагазинСлужебный.СоздатьВозвратОтКлиентаПоРеализации(ДатаОтменыЗаказа, Реализация);
			Иначе 
				ВозвратОбъект = ИнтернетМагазинСлужебный.СоздатьВозвратОтКлиентаПоРеализации(ДатаОтменыЗаказа, Реализация);
				РеализацияОбъект = Реализация.ПолучитьОбъект();
				РеализацияОбъект.Товары.Очистить();
				//РеализацияОбъект.ДатыВыпуска.Очистить();
				//РеализацияОбъект.ТоварыГИСМ.Очистить();
				//РеализацияОбъект.ДополнительныеСвойства.Вставить("НеКонтролироватьДатуЗапретаРедактирования", Истина);
				РеализацияОбъект.ДополнительныеСвойства.Вставить("НеКонтролироватьРезультатыПроведения", Истина);
				РеализацияОбъект.ДополнительныеСвойства.Вставить("ОтключитьМеханизмБлокировкиОтгруженныхДокументов", Истина);
				СписокТоваров = ИнтернетМагазинСлужебный.ПолучитьСписокТоваровДляКорректировкиРегистров(Реализация); 
				Если СписокТоваров <> Неопределено Тогда
					КорректировкаРегистровОбъект = ИнтернетМагазинСлужебный.СформироватьКорректировкуРегистров_ОтменаЗаказа(Реализация, СписокТоваров, ДатаОтменыЗаказа, " # Закрыто роботом # Возврат по заказу клиенту, формирование резерва по свободным остаткам");
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
	КонецЕсли;
	
	НачатьТранзакцию();
	Попытка
		
		Если Реализация <> Неопределено Тогда
			Если ИспользуемКорРТУ Тогда 
				Если КорректировкаРеализацииОбъект <> Неопределено Тогда
					КорректировкаРеализацииОбъект.Записать(РежимЗаписиДокумента.Проведение);
					СФОбъект = ИнтернетМагазинСлужебный.СоздатьСФПоРТУ(КорректировкаРеализацииОбъект.Ссылка, ДатаОтменыЗаказа, Заказ.Организация);
					СФОбъект.Записать();
				КонецЕсли;
			Иначе
				РеализацияОбъект.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			Если ВозвратОбъект <> Неопределено Тогда
				ВозвратОбъект.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			Если КорректировкаРегистровОбъект <> Неопределено Тогда
				КорректировкаРегистровОбъект.Записать();
			КонецЕсли;
		КонецЕсли;
		
		Заказ.Записать(РежимЗаписиДокумента.Проведение);
		ИнтернетМагазинСлужебный.УдалитьИзМаршрутов(ЗаказСсылка);
		
		Если РеквизитыЗаказа.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.ДаркКитчен Тогда
			ДаркКитченСервер.ЗаписатьОтменуЗаказаПоРегистрамДК(ЗаказСсылка, Ложь);
			Для Каждого ЭлементМассива Из МассивДобавленныхНоменклатур Цикл
				СтруктураЗаписиРегистраПроизводства = Новый Структура;
				СтруктураЗаписиРегистраПроизводства.Вставить("Склад", Заказ.Склад);
				СтруктураЗаписиРегистраПроизводства.Вставить("Цех", Справочники.ЦехДК.ПустаяСсылка());
				СтруктураЗаписиРегистраПроизводства.Вставить("Номенклатура", ЭлементМассива);
				СтруктураЗаписиРегистраПроизводства.Вставить("Документ", ЗаказСсылка);
				СтруктураЗаписиРегистраПроизводства.Вставить("ДатаНовый", ТекущаяДата());
				СтруктураЗаписиРегистраПроизводства.Вставить("ЖДВ", Заказ.ВремяДоставкиС);
				СтруктураЗаписиРегистраПроизводства.Вставить("Количество", 1);
				СтруктураЗаписиРегистраПроизводства.Вставить("ТекущийСтатус", Перечисления.СтатусыПроизводственныхЗаказовДК.ВСборке);
				СтруктураДополнительныеСвойства = Новый Структура("НЕПишемРСДК", Истина);
				ДаркКитченСервер.ДобавитьСтрокуВРССтатусыПроизводстваДК(СтруктураЗаписиРегистраПроизводства, СтруктураДополнительныеСвойства);
			КонецЦикла;
			//временно делаем отправку изменений заказов ДаркКитчен в телегу
			ТекстСообщения = Строка(ЗаказСсылка) + Символы.ПС + Строка(Заказ.НомерЗаказаНаСайте) + Символы.ПС + Строка(ПараметрыСеанса.ТекущийПользователь) + Символы.ПС + "<b>Отмена заказа ДаркКитчен</b>";
			Telegram_Admin.SendMessage(Строка(ОбщегоНазначенияПовтИсп.ПолучитьАббревиатуруТекущейБазы()) + Символы.ПС + ТекстСообщения,, "-728074965", "HTML");
		КонецЕсли;
		
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		СообщениеОбОшибке = "Ошибка формирования документов на возврат через АРМ ИМ:" + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,СообщениеОбОшибке);
		СообщениеОбОшибке = "Ошибка формирования документов на возврат через АРМ ИМ:" + Символы.ПС + ОписаниеОшибки();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеОбОшибке);
		Возврат;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область ПеренестиСрок

&НаКлиенте
Процедура ПеренестиСрок(Команда)
	
	Если Элементы.Заказы.ВыделенныеСтроки.Количество() <> 1 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Измененеие сроков доставки не выполняется для группы заказов");
		Возврат;
	КонецЕсли;
	
	ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов( Элементы.Заказы.ВыделенныеСтроки[0], "Ссылка, ВитринаИнтернетМагазина, ВремяДоставкиПо, ВремяДоставкиС, ПриложениеСборщика, НомерЗаказаНаСайте, Статус");
	
	//Если ДанныеЗаказа.ПриложениеСборщика <> 0 Тогда
	//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + ДанныеЗаказа.НомерЗаказаНаСайте + " управляется сайтом" + Символы.ПС + "Изменение в 1С запрещено");
	//	Возврат;
	//КонецЕсли;
	
	Если ДанныеЗаказа.ВитринаИнтернетМагазина = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен")
		И ДанныеЗаказа.Статус <> ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.Согласован") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Изменение времени доставки заказов ""Дарк китчен"" разрешено только в статусе ""Новый""'"));
		Возврат;
	КонецЕсли;
	
	ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаВыборИнтервала", ДанныеЗаказа, ЭтаФорма);
	
КонецПроцедуры

#КонецОбласти

#Область Комментарий

&НаКлиенте
Процедура ДобавитьКомментарий(Команда)
	
	Комментарий = "";
	ВвестиСтроку(Комментарий, "Введите комментарий");
	Если ЗначениеЗаполнено(Комментарий) Тогда
		Для Каждого Стр Из Элементы.Заказы.ВыделенныеСтроки Цикл
			//ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Стр, "ПриложениеСборщика, НомерЗаказаНаСайте");
			//Если ДанныеЗаказа.ПриложениеСборщика <> 0 Тогда
			//	ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + ДанныеЗаказа.НомерЗаказаНаСайте + " управляется сайтом" + Символы.ПС + "Изменение в 1С запрещено");
			//	Продолжить;
			//КонецЕсли;
			ВвестиКомментарий(Стр, Комментарий)
		КонецЦикла;
	КонецЕсли;
	
КонецПроцедуры

Процедура ВвестиКомментарий(ЗаказСсылка, Комментарий)
	
	УстановитьПривилегированныйРежим(Истина);
	Заказ = ЗаказСсылка.ПолучитьОбъект();
	Заказ.Комментарий = Заказ.Комментарий + ?(ЗначениеЗаполнено(Заказ.Комментарий), Символы.ПС, "") + Комментарий;
	Заказ.ДополнительнаяИнформация = Заказ.ДополнительнаяИнформация + ?(ЗначениеЗаполнено(Заказ.ДополнительнаяИнформация), Символы.ПС, "") + Комментарий;
	Заказ.ДополнительныеСвойства.Вставить("ОтключитьМеханизмБлокировкиОтгруженныхДокументов", Истина);
	Заказ.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
	Заказ.Записать(РежимЗаписиДокумента.Запись);
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область ПереносНаДругойМагазин

&НаКлиенте
Процедура ПеренестиНаДругойМагазин(Команда)
	
	Если Элементы.Заказы.ВыделенныеСтроки.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	
	ОтветПользователя = Вопрос(НСтр("ru = 'Вы действительно хотите переместить выделенные заказы на другой магазин?'"), РежимДиалогаВопрос.ДаНет);
	Если ОтветПользователя = КодВозвратаДиалога.Да Тогда
		
		СписокСкладовДляВыбора = Новый СписокЗначений;
		МассивДоступныхСкладов = ПолучитьМассивСкладовДляЗамены(Элементы.Заказы.ВыделенныеСтроки);
		СписокСкладовДляВыбора.ЗагрузитьЗначения(МассивДоступныхСкладов);
		
		РезультатВыбора = СписокСкладовДляВыбора.ВыбратьЭлемент("Выбери новый склад:");
		Если РезультатВыбора = Неопределено Тогда
			Возврат;
		КонецЕсли;
		
		НовыйСклад = РезультатВыбора.Значение;
		
		Для Каждого Заказ Из Элементы.Заказы.ВыделенныеСтроки Цикл
			
			РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Заказ, "НомерЗаказаНаСайте, ВитринаИнтернетМагазина, Статус, Доставлен, ОтменаКлиентом, Склад");
			НомерЗаказаНаСайте = РеквизитыЗаказа.НомерЗаказаНаСайте;
			ВитринаЗаказа = РеквизитыЗаказа.ВитринаИнтернетМагазина;
			
			Если РеквизитыЗаказа.Склад = НовыйСклад Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + НомерЗаказаНаСайте + " не изменен." + Символы.ПС + "Текущий магазин заказа равен выбранному магазину");
				Продолжить;
			КонецЕсли;
			
			//проверки
			Если НЕ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс") И 
				НЕ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен") Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + НомерЗаказаНаСайте + " не является заказом ЯрчеПлюс, ДаркКитчен" + Символы.ПС + "Передача на другой магазин невозможна");
				Продолжить;
			КонецЕсли;
			
			Если (ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс") ИЛИ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен"))
				И (РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.Закрыт") ИЛИ РеквизитыЗаказа.Доставлен) Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + НомерЗаказаНаСайте + " закрыт" + Символы.ПС + "Передача на другой магазин невозможна");
				Продолжить;
			КонецЕсли;
			
			Если (ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс") ИЛИ ВитринаЗаказа = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен"))
				И РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОтгрузке") Тогда
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + НомерЗаказаНаСайте + " собран" + Символы.ПС + "Передача на другой магазин невозможна");
				Продолжить;
			КонецЕсли;
			
			ПеренестиНаДругойМагазинНаСервере(Заказ, РеквизитыЗаказа.Склад, НовыйСклад);
			
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьМассивСкладовДляЗамены(Знач МассивЗаказов)
	
	МассивСкладов = Новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ОбменССайтом.Склад КАК Склад
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланОбмена.ОбменССайтом КАК ОбменССайтом
		|		ПО ЗаказКлиента.ВитринаИнтернетМагазина = ОбменССайтом.Витрина
		|			И (ОбменССайтом.ОбменЗаказами)
		|			И (ОбменССайтом.ИспользоватьРегламентныеЗадания)
		|ГДЕ
		|	ЗаказКлиента.Ссылка В(&МассивЗаказов)
		|
		|УПОРЯДОЧИТЬ ПО
		|	Склад
		|АВТОУПОРЯДОЧИВАНИЕ";
	
	Запрос.УстановитьПараметр("МассивЗаказов", МассивЗаказов);
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		МассивСкладов.Добавить(ВыборкаДетальныеЗаписи.Склад);
	КонецЦикла;
	
	Возврат МассивСкладов;
	
КонецФункции

&НаСервере
Процедура ПеренестиНаДругойМагазинНаСервере(Заказ, СтарыйСклад, НовыйСклад)
	
	НоваяЗонаДоставки = ЗонаДоставкиСклада(НовыйСклад);
	НовоеСоглашение = ПолучитьСоглашениеПоСкладу(НовыйСклад);
	
	ОбъектЗаказ = Заказ.ПолучитьОбъект();
	ОбъектЗаказ.Склад = НовыйСклад;
	ОбъектЗаказ.ЗонаДоставки = НоваяЗонаДоставки;
	ОбъектЗаказ.Соглашение = НовоеСоглашение;
	ОбъектЗаказ.ДатаНачалаКомплектовки = Дата(1,1,1);
	ОбъектЗаказ.ДатаОкончанияКомплектовки = Дата(1,1,1);
	ОбъектЗаказ.Комплектовщик = Справочники.ФизическиеЛица.ПустаяСсылка();
	ОбъектЗаказ.ТерминалИд = "";
	
	Для Каждого СтрокаТовары Из ОбъектЗаказ.Товары Цикл
		СтрокаТовары.Склад = НовыйСклад;
	КонецЦикла;
	
	НаименованиеГруппыДопРеквизита = "Документ ""Заказ на клиента""";
	ГруппаДопРеквизита = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию(НаименованиеГруппыДопРеквизита, Истина);
	ДопРеквизит = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("ЗонаДоставки", Истина, ГруппаДопРеквизита);
	НайденныеСтроки = ОбъектЗаказ.ДополнительныеРеквизиты.НайтиСтроки(Новый Структура("Свойство", ДопРеквизит));
	Для Каждого СтрокаДопРеквизитов Из НайденныеСтроки Цикл
		СтрокаДопРеквизитов.Значение = НоваяЗонаДоставки;
	КонецЦикла;
	
	Если ОбъектЗаказ.ПриложениеСборщика = 0 Тогда
		ОбъектЗаказ.Статус = Перечисления.СтатусыЗаказовКлиентов.Согласован;
	КонецЕсли;
	
	Шаблон = "Изменение %1 с %2 на %3 %4 %5";
	ТекстКоммента = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Шаблон
																			, "Склад"
																			, СокрЛП(СтарыйСклад)
																			, СокрЛП(НовыйСклад)
																			, ПараметрыСеанса.ТекущийПользователь
																			, ТекущаяДата()
																			); 
	ОбъектЗаказ.Комментарий = ОбъектЗаказ.Комментарий + ?(ЗначениеЗаполнено(ОбъектЗаказ.Комментарий), Символы.ПС, "") + ТекстКоммента;
	ОбъектЗаказ.ДополнительныеСвойства.Вставить("ОтключитьМеханизмБлокировкиОтгруженныхДокументов", Истина);
	ОбъектЗаказ.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
	
	ЗаказНужноГотовить = Ложь;
	Отказ = Ложь;
	
	НачатьТранзакцию();
	Попытка
		
		Если ОбъектЗаказ.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.ДаркКитчен Тогда
			ДаркКитченСервер.ЗаписатьОтменуЗаказаПоРегистрамДК(Заказ, Отказ);
			ЗаказНужноГотовить = ДаркКитченСервер.ЗаказНужноГотовить(ОбъектЗаказ);
			ДаркКитченСервер.ЗаписатьПустыеСтатусыВРССтатусыПроизводстваДК(ОбъектЗаказ, Отказ);
			Если НЕ ЗаказНужноГотовить Тогда
				ДаркКитченСервер.ЗаписатьСборкуЗаказаПоРегистрам(ОбъектЗаказ, Отказ);
			Иначе
				ДаркКитченСервер.ЗаписатьНовыйВРССтатусыЗаказовДК(ОбъектЗаказ, Отказ);
				ДаркКитченСервер.ЗаписатьНовыйВРССтатусыПроизводстваДК(ОбъектЗаказ, Отказ);
			КонецЕсли;
		КонецЕсли;
		
		Если Отказ Тогда
			ОтменитьТранзакцию();
			ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, Заказ.Метаданные(), Заказ, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			ОписаниеРезультата = ОписаниеОшибки();
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка переноса заказа " + ОбъектЗаказ.НомерЗаказаНаСайте + Символы.ПС + ОписаниеОшибки());
			Возврат;
		КонецЕсли;
		
		ОбъектЗаказ.Записать(РежимЗаписиДокумента.Проведение);
		
		ЗафиксироватьТранзакцию();
		
	Исключение
		ОтменитьТранзакцию();
		ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, Заказ.Метаданные(), Заказ, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ОписаниеРезультата = ОписаниеОшибки();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка переноса заказа " + ОбъектЗаказ.НомерЗаказаНаСайте + Символы.ПС + ОписаниеОшибки());
	КонецПопытки;
	
КонецПроцедуры

&НаСервере
Функция ЗонаДоставкиСклада(Склад)
	Если Склад = Справочники.Склады.ПустаяСсылка() ИЛИ НЕ ТипЗнч(Склад) = Тип("СправочникСсылка.Склады") Тогда
		Возврат "";
	КонецЕсли;
	Возврат Лев(Склад.Наименование, 4);
КонецФункции

#КонецОбласти

#Область Версионирование

&НаКлиенте
Процедура ВосстановитьСобранный(Команда)
	
	Для Каждого Заказ Из Элементы.Заказы.ВыделенныеСтроки Цикл
		
		ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Заказ, "ПриложениеСборщика, НомерЗаказаНаСайте");
		Если ДанныеЗаказа.ПриложениеСборщика <> 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + ДанныеЗаказа.НомерЗаказаНаСайте + " управляется сайтом" + Символы.ПС + "Изменение в 1С запрещено");
			Продолжить;
		КонецЕсли;
		
		Версия = ВерсияСборка(Заказ, Ложь);
		Если Версия = 0 Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + ДанныеЗаказа.НомерЗаказаНаСайте + " " + "не собирался");
			Продолжить;
		КонецЕсли;
			
		ОписаниеРезультата = "";
		Если НЕ ВосстановитьНаВерсию(Заказ, Версия, ОписаниеРезультата) Тогда
			Сообщить(Строка(Заказ) + Символы.ПС + ОписаниеРезультата);
			Продолжить;
		КонецЕсли;
		
		ИнтернетМагазинСлужебный.УдалитьИзМаршрутов(Заказ);
		
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьНаИсходную(Команда)
	Для Каждого Заказ Из Элементы.Заказы.ВыделенныеСтроки Цикл
		ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Заказ, "ПриложениеСборщика, НомерЗаказаНаСайте");
		Если ДанныеЗаказа.ПриложениеСборщика <> 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + ДанныеЗаказа.НомерЗаказаНаСайте + " управляется сайтом" + Символы.ПС + "Изменение в 1С запрещено");
			Продолжить;
		КонецЕсли;
		ОписаниеРезультата = "";
		Если НЕ ВосстановитьНаВерсию(Заказ, 1, ОписаниеРезультата) Тогда
			Сообщить(Строка(Заказ) + Символы.ПС + ОписаниеРезультата);
			Продолжить;
		КонецЕсли;
		ИнтернетМагазинСлужебный.УдалитьИзМаршрутов(Заказ);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ВосстановитьНачалоСборки(Команда)
	
	Для Каждого Заказ Из Элементы.Заказы.ВыделенныеСтроки Цикл
		
		ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Заказ, "ПриложениеСборщика, НомерЗаказаНаСайте");
		Если ДанныеЗаказа.ПриложениеСборщика <> 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + ДанныеЗаказа.НомерЗаказаНаСайте + " управляется сайтом" + Символы.ПС + "Изменение в 1С запрещено");
			Продолжить;
		КонецЕсли;
			
		Версия = ВерсияСборка(Заказ, Истина);
		Если Версия = 0 Тогда 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + Заказ.НомерЗаказаНаСайте + " " + "не собирался");
			Продолжить;
		КонецЕсли;
			
		ОписаниеРезультата = "";
		Если НЕ ВосстановитьНаВерсию(Заказ, Версия, ОписаниеРезультата) Тогда
			Сообщить(Строка(Заказ) + Символы.ПС + ОписаниеРезультата);
			Продолжить;
		КонецЕсли;
		ИнтернетМагазинСлужебный.УдалитьИзМаршрутов(Заказ);

	КонецЦикла;	
	
КонецПроцедуры

&НаСервере
Функция ВерсияСборка(Ссылка, Начало = Истина)
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	isnull(@МинМакс(ВерсииОбъектов.НомерВерсии),0) КАК НомерВерсии
		|ИЗ
		|	РегистрСведений.ВерсииОбъектов КАК ВерсииОбъектов
		|ГДЕ
		|	ВерсииОбъектов.Объект = &Ссылка
		|	И ВерсииОбъектов.АвторВерсии.Наименование = ""USER1CWEB""";

	Запрос.УстановитьПараметр("Ссылка", Ссылка);

	Запрос.Текст = СтрЗаменить(Запрос.Текст, "@МинМакс", ?(Начало, "МИНИМУМ", "МАКСИМУМ"));
	
	УстановитьПривилегированныйРежим(Истина);
	Результат = Запрос.Выполнить();
	УстановитьПривилегированныйРежим(Ложь);
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.НомерВерсии;
	Иначе
		Возврат 0;
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ВосстановитьНаВерсию(Заказ, Версия, ОписаниеРезультата)
	
	ОписаниеРезультата = "";
	Если Заказ.ВитринаИнтернетМагазина <> Справочники.ВитриныИнтернетМагазина.ЯрчеПлюс Тогда
		ОписаниеРезультата = ОписаниеРезультата + ?(ПустаяСтрока(ОписаниеРезультата), "", Символы.ПС) + "Восстановление заказов " + Заказ.ВитринаИнтернетМагазина + " - не поддерживается";
	КонецЕсли;
	Если ЗначениеЗаполнено(Заказ.ЧекПродажа) Тогда
		ОписаниеРезультата = ОписаниеРезультата + ?(ПустаяСтрока(ОписаниеРезультата), "", Символы.ПС) + "Для заказа зарегистрирован документ оплаты: " + Строка(Заказ.ЧекПродажа);
	КонецЕсли;
	Если ЗначениеЗаполнено(Заказ.ЭквайринговаяОперация) Тогда
		ОписаниеРезультата = ОписаниеРезультата + ?(ПустаяСтрока(ОписаниеРезультата), "", Символы.ПС) + "Для заказа зарегистрирован документ оплаты: " + Строка(Заказ.ЭквайринговаяОперация);
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(ОписаниеРезультата) Тогда
		Возврат Ложь;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	ТаблицаДокументовОплаты = Заказ.Оплаты.Выгрузить();
	ПриложениеСборщика = Заказ.ПриложениеСборщика;
	НачатьТранзакцию();
	Попытка
		РегистрыСведений.ВерсииОбъектов.ВернутьсяКВерсии(Заказ, Версия);
		ЗаказОбъект = Заказ.ПолучитьОбъект();
		ЗаказОбъект.Оплаты.Загрузить(ТаблицаДокументовОплаты);
		ЗаказОбъект.ПриложениеСборщика = ПриложениеСборщика;
		ЗаказОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
		ЗаказОбъект.Записать(РежимЗаписиДокумента.Запись);
		ЗафиксироватьТранзакцию();
	Исключение
		ОтменитьТранзакцию();
		ОписаниеРезультата = ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, Заказ.Метаданные(), Заказ, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Ложь;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Функция ПолучитьТекущийНомерВерсии(Заказ)
	Возврат РеквизитФормыВЗначение("Объект").ПолучитьТекущийНомерВерсии(Заказ);
КонецФункции

#КонецОбласти

#Область ИзменитьСостав

&НаКлиенте
Процедура ИзменитьСостав(Команда)
	
	ОписаниеРезультата = "";
	
	РазрешитьВыполнение = Истина;
	РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Элементы.Заказы.ТекущаяСтрока, "Ссылка, ВитринаИнтернетМагазина, Статус");
	Если РеквизитыЗаказа.ВитринаИнтернетМагазина = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс") Тогда
		
		Если РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.Согласован")
			ИЛИ РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОтгрузке") Тогда
			РазрешитьВыполнение = Истина;
		Иначе
			ОписаниеРезультата = "Изменение заказов ""Ярче плюс"" разрешено только в статусах ""Новый"", ""Собран"", ""Передан курьеру""";
			РазрешитьВыполнение = Ложь;
		КонецЕсли;
		
	ИначеЕсли РеквизитыЗаказа.ВитринаИнтернетМагазина = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен") Тогда
		
		Если РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.Согласован")
			Или РеквизитыЗаказа.Статус = ПредопределенноеЗначение("Перечисление.СтатусыЗаказовКлиентов.КОбеспечению") Тогда
			
			ТекущийСтатусДокумента = ДаркКитченСервер.ПолучитьТекущийСтатусДокумента(Элементы.Заказы.ТекущаяСтрока);
			Если ТекущийСтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыПроизводственныхЗаказовДК.Новый")
				ИЛИ ТекущийСтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыПроизводственныхЗаказовДК.ВПроизводстве")
				ИЛИ ТекущийСтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыПроизводственныхЗаказовДК.Согласован")
				ИЛИ ТекущийСтатусДокумента = ПредопределенноеЗначение("Перечисление.СтатусыПроизводственныхЗаказовДК.ВСборке") Тогда
				РазрешитьВыполнение = Истина;
			Иначе
				ОписаниеРезультата = "Изменение заказов ""Дарк Китчен"" разрешено только до момента начала сборки";
				РазрешитьВыполнение = Ложь;
			КонецЕсли;
			
		Иначе
			ОписаниеРезультата = "Изменение заказов ""Дарк Китчен"" разрешено только в статусах ""Новый"", ""На сборке""";
			РазрешитьВыполнение = Ложь;
		КонецЕсли;
		
	Иначе //заглушка, пропускаем только ярче плюс
		
		ОписаниеРезультата = "Разрешено изменение заказов ""Ярче плюс"", ""Дарк Китчен""";
		РазрешитьВыполнение = Ложь;
		
	КонецЕсли;
	
	Если Не РазрешитьВыполнение Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеРезультата);
		Возврат;
	КонецЕсли;
	
	ТекущийНомерВерсии = ПолучитьТекущийНомерВерсии(РеквизитыЗаказа.Ссылка);
	ПараметрыОткрытия = Новый Структура("Заказ, НомерВерсииПриНачалеРедактирования", РеквизитыЗаказа.Ссылка, ТекущийНомерВерсии);
	
	Если РеквизитыЗаказа.ВитринаИнтернетМагазина = ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен") Тогда
		ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаИзмененияСоставаЗаказаДаркКитчен", ПараметрыОткрытия);
	Иначе
		ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаИзмененияСоставаЗаказа", ПараметрыОткрытия);
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ВозвратТоваров

&НаКлиенте
Процедура ВозвратТоваров(Команда)
	
	ТекущийЗаказа = Элементы.Заказы.ТекущаяСтрока;
	ТекущийНомерВерсии = ПолучитьТекущийНомерВерсии(ТекущийЗаказа);
	ВариантВозврата = ПолучитьВариантВозвратаЗаказа(ТекущийЗаказа);
	
	Если ВариантВозврата = "ярчеплюс" Тогда
		П = Новый Структура;
		П.Вставить("Заказ", ТекущийЗаказа);
		П.Вставить("НомерВерсииПриНачалеРедактирования", ТекущийНомерВерсии);
		ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаВозвратаТоваров", П);
	ИначеЕсли ВариантВозврата = "дарккитчен" Тогда
		П = Новый Структура;
		П.Вставить("Заказ", ТекущийЗаказа);
		П.Вставить("НомерВерсииПриНачалеРедактирования", ТекущийНомерВерсии);
		ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаВозвратаТоваров", П);
	ИначеЕсли ВариантВозврата = "озон" Тогда 
		П = Новый Структура;
		П.Вставить("Заказ", ТекущийЗаказа);
		П.Вставить("НомерВерсииПриНачалеРедактирования", ТекущийНомерВерсии); 
		П.Вставить("ВариантВозврата", ВариантВозврата);
		ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаВозвратаТоваровРЦ", П);
	ИначеЕсли ВариантВозврата = "игрушки" Тогда
		//Сообщить("Возврат заказов посылочной торговли запрещен");
		П = Новый Структура;
		П.Вставить("Заказ", ТекущийЗаказа);
		П.Вставить("НомерВерсииПриНачалеРедактирования", ТекущийНомерВерсии);
		П.Вставить("ВариантВозврата", ВариантВозврата);
		ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаВозвратаТоваровРЦ", П);
	ИначеЕсли ВариантВозврата = "неопределено" Тогда
		Сообщить("Ошибка определения состояния заказа, возврат невозможен");
	Иначе
		Сообщить(ВариантВозврата);
	КонецЕсли;
	
КонецПроцедуры

Функция ПолучитьВариантВозвратаЗаказа(Заказ)
	
	МассивФормОплаты = Новый Массив;
	МассивФормОплаты.Добавить(Перечисления.ФормыОплаты.Безналичная);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка КАК Заказ,
		|	МАКСИМУМ(ВЫБОР
		|			КОГДА ЗаказКлиентаОплаты.Документ ЕСТЬ NULL
		|				ТОГДА ЛОЖЬ
		|			КОГДА ЗаказКлиентаОплаты.Документ.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.СБП)
		|				ТОГДА ИСТИНА
		|			ИНАЧЕ ЛОЖЬ
		|		КОНЕЦ) КАК СБП
		|ПОМЕСТИТЬ ВТ_ОплатаСБП
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.Оплаты КАК ЗаказКлиентаОплаты
		|		ПО ЗаказКлиента.Ссылка = ЗаказКлиентаОплаты.Ссылка
		|ГДЕ
		|	ЗаказКлиентаОплаты.Ссылка = &Заказ
		|	И ЗаказКлиентаОплаты.Документ ССЫЛКА Документ.ЧекККМ
		|	И ЗаказКлиента.ФормаОплаты В(&ФормаОплаты)
		|
		|СГРУППИРОВАТЬ ПО
		|	ЗаказКлиента.Ссылка
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка КАК Заказ,
		|	ВЫБОР
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс)
		|				И ЕСТЬNULL(ВТ_ОплатаСБП.СБП, ЛОЖЬ) = ИСТИНА
		|			ТОГДА ""Заказ оплачен по QR-коду. Необходимо выполнить возврат в магпей.""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс)
		|				И ЗаказКлиента.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.Безналичная)
		|				И ЗаказКлиента.ВозвратMagPayЗапрещен
		|			ТОГДА ""Возврат запрещен, требуется разрешение на возврат этого заказа""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс)
		|				И НЕ ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.Закрыт)
		|			ТОГДА ""Возврат разрешен только для закрытых заказов Ярче плюс с чеком продажи""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс)
		|				И ЗаказКлиента.ЧекПродажа = ЗНАЧЕНИЕ(Документ.ЧекККМ.ПустаяССылка)
		|			ТОГДА ""Возврат разрешен только для закрытых заказов Ярче плюс с чеком продажи""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс)
		|				И ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.Закрыт)
		|				И НЕ ЗаказКлиента.ЧекПродажа = ЗНАЧЕНИЕ(Документ.ЧекККМ.ПустаяССылка)
		|				И НЕ ЗаказКлиента.ВозвратMagPayЗапрещен
		|				И ЗаказКлиента.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.Безналичная)
		|			ТОГДА ""ярчеплюс""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс)
		|				И ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.Закрыт)
		|				И НЕ ЗаказКлиента.ЧекПродажа = ЗНАЧЕНИЕ(Документ.ЧекККМ.ПустаяССылка)
		|			ТОГДА ""ярчеплюс""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ДаркКитчен)
		|				И ЕСТЬNULL(ВТ_ОплатаСБП.СБП, ЛОЖЬ) = ИСТИНА
		|			ТОГДА ""Заказ оплачен по QR-коду. Необходимо выполнить возврат в магпей.""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ДаркКитчен)
		|				И ЗаказКлиента.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.Безналичная)
		|				И ЗаказКлиента.ВозвратMagPayЗапрещен
		|			ТОГДА ""Возврат запрещен, требуется разрешение на возврат этого заказа""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ДаркКитчен)
		|				И НЕ ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.Закрыт)
		|			ТОГДА ""Возврат разрешен только для закрытых заказов Дарк китчен с чеком продажи""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ДаркКитчен)
		|				И ЗаказКлиента.ЧекПродажа = ЗНАЧЕНИЕ(Документ.ЧекККМ.ПустаяССылка)
		|			ТОГДА ""Возврат разрешен только для закрытых заказов Дарк китчен с чеком продажи""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ДаркКитчен)
		|				И ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.Закрыт)
		|				И НЕ ЗаказКлиента.ЧекПродажа = ЗНАЧЕНИЕ(Документ.ЧекККМ.ПустаяССылка)
		|				И НЕ ЗаказКлиента.ВозвратMagPayЗапрещен
		|				И ЗаказКлиента.ФормаОплаты = ЗНАЧЕНИЕ(Перечисление.ФормыОплаты.Безналичная)
		|			ТОГДА ""дарккитчен""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ДаркКитчен)
		|				И ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.Закрыт)
		|				И НЕ ЗаказКлиента.ЧекПродажа = ЗНАЧЕНИЕ(Документ.ЧекККМ.ПустаяССылка)
		|			ТОГДА ""дарккитчен""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ОЗОН)
		|				И НЕ ЗаказКлиента.Доставлен
		|			ТОГДА ""Возврат разрешен только доставленных заказов""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ОЗОН)
		|				И ЗаказКлиента.Доставлен
		|			ТОГДА ""озон""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.Игрушки)
		|				И ЗаказКлиента.ЭквайринговаяОперация = ЗНАЧЕНИЕ(Документ.ОперацияПоПлатежнойКарте.ПустаяСсылка)
		|			ТОГДА ""Возврат разрешен только при наличии документа оплаты""
		|		КОГДА ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.Игрушки)
		|				И НЕ ЗаказКлиента.ЭквайринговаяОперация = ЗНАЧЕНИЕ(Документ.ОперацияПоПлатежнойКарте.ПустаяСсылка)
		|			ТОГДА ""игрушки""
		|		ИНАЧЕ ""неопределено""
		|	КОНЕЦ КАК ВариантВозврата
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_ОплатаСБП КАК ВТ_ОплатаСБП
		|		ПО ЗаказКлиента.Ссылка = ВТ_ОплатаСБП.Заказ
		|ГДЕ
		|	ЗаказКлиента.Ссылка = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ); 
	Запрос.УстановитьПараметр("ФормаОплаты", МассивФормОплаты);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат "неопределено";
	КонецЕсли;
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	ВыборкаДетальныеЗаписи.Следующий();
	Возврат ВыборкаДетальныеЗаписи.ВариантВозврата;
	
КонецФункции

#КонецОбласти

#Область ЗарегистрироватьКОбмену

&НаКлиенте
Процедура ЗарегистрироватьКОбмену(Команда)
	мЗаказы = Элементы.Заказы.ВыделенныеСтроки;
	ЗарегистрироватьКОбменуСервер(мЗаказы);
КонецПроцедуры

&НаСервере
Процедура ЗарегистрироватьКОбменуСервер(мЗаказы)
	
	Для Каждого ЭлементМассива Из мЗаказы Цикл
		Отказ = Ложь;
		ОбменССайтом.ОбменССайтомПриЗаписиОбъектаПриЗаписи(ЭлементМассива, Отказ);
		Если Отказ Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Ошибка регистрации заказа %1 к выгрузке на сайт'"), Строка(ЭлементМассива)));
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

&НаКлиенте
Процедура ЗарегистрироватьКОбменуMagPay(Команда)
	мЗаказы = Элементы.Заказы.ВыделенныеСтроки;
	ЗарегистрироватьКОбменуMagPayСервер(мЗаказы);
КонецПроцедуры

&НаСервере
Процедура ЗарегистрироватьКОбменуMagPayСервер(мЗаказы)
	
	Для Каждого ЭлементМассива Из мЗаказы Цикл
		Отказ = Ложь;
		ПодпискиНаСобытия.ОбменСMagPayПриЗаписи(ЭлементМассива, Отказ);
		Если Отказ Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Ошибка регистрации заказа %1 к выгрузке в MagPay'"), Строка(ЭлементМассива)));
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти

#Область Доставлен

&НаКлиенте
Процедура Доставлен(Команда)
	
	Для Каждого СтрЗаказ Из Элементы.Заказы.ВыделенныеСтроки Цикл
		УстановитьФлагДоставлен(СтрЗаказ);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура УстановитьФлагДоставлен(Заказ)
	
	РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Заказ, "ЖелаемаяДатаОтгрузки, Доставлен, СуммаДокумента, СпособДоставки, ВитринаИнтернетМагазина, ПриложениеСборщика, ОтменаКлиентом");
	
	Сообщение = "";
	
	Если РеквизитыЗаказа.Доставлен Тогда
		//уже флаг установлен
		Возврат;
	КонецЕсли;
	
	Если РеквизитыЗаказа.СуммаДокумента = 0 ИЛИ РеквизитыЗаказа.ОтменаКлиентом Тогда
		Сообщение = Сообщение + ?(ПустаяСтрока(Сообщение), "", Символы.ПС) + "%1 - отменен";
	КонецЕсли;
	
	Если ЧекИлиЭквайринговаяОперацияСуществуют(Заказ) = Истина Тогда
		Сообщение = Сообщение + ?(ПустаяСтрока(Сообщение), "", Символы.ПС) + "%1 - существует документ оплаты";
	КонецЕсли;
	
	Если РеквизитыЗаказа.ВитринаИнтернетМагазина <> Справочники.ВитриныИнтернетМагазина.ЯрчеПлюс
		И РеквизитыЗаказа.ВитринаИнтернетМагазина <> Справочники.ВитриныИнтернетМагазина.ДаркКитчен Тогда
		Сообщение = Сообщение + ?(ПустаяСтрока(Сообщение), "", Символы.ПС) + "%1 - это не ЯрчеПлюс и не ДаркКитчен";
	КонецЕсли;
	
	Если Не Сообщение = "" Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(Сообщение, Строка(Заказ)));
		Возврат;
	КонецЕсли;
	
	ЗаказОбъект = Заказ.ПолучитьОбъект();
	ЗаказОбъект.Доставлен = Истина;
	ЗаказОбъект.Статус = Перечисления.СтатусыЗаказовКлиентов.Закрыт;
	
	Если РеквизитыЗаказа.СпособДоставки = Перечисления.СпособыДоставки.Аутсорс Тогда
		ЗаказОбъект.Курьер = ОбщегоНазначенияСерверПовтИсп.ЗначениеКонстанты("КурьерАутсорсИМ");
	Иначе
		ЗаказОбъект.Курьер = Заказ.Комплектовщик;
	КонецЕсли;
	
	Попытка
		СформироватьЧек(ЗаказОбъект);
		ЗаказОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
		ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(Заказ));
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки()); 
		ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, Заказ.Метаданные(), Заказ, "АРМ установка флага доставлен" + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецПроцедуры 

&НаСервере
Процедура СформироватьЧек(ЗаказОбъект)
	
	УстановитьПривилегированныйРежим(Истина);
		
	ВнешнийМодуль = Неопределено;
	ВнешнийМодульОбработка = Неопределено;
	Если ОбменССайтом.ИспользоватьВнешнийМодульИнтернетМагазина(ВнешнийМодульОбработка) Тогда
		ИмяФайла = ПолучитьИмяВременногоФайла("epf");
		ВнешнийМодульОбработка.Записать(ИмяФайла);
		Попытка
			ВнешнийМодуль = ВнешниеОбработки.Создать(ИмяФайла, Ложь);//в небезопасном режиме, т.к. ПМ может содержать небезопасный код
		Исключение
			ВнешнийМодуль = Неопределено;
		КонецПопытки;
	КонецЕсли;
		
	Если ВнешнийМодуль = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(ЗаказОбъект.Ссылка));
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Невозможно создать чек по заказу");
		Возврат;
	КонецЕсли;
	
	КассаЭквайринговыйТерминал = ВнешнийМодуль.ПолучитьДанныеДляЧекаПоЗаказу(ЗаказОбъект.Ссылка);
	ДанныеЧекаКассы = Новый Структура("date_check, organization, typepay, identnumber, terminalid, ordercheck, numcheck, uniqnumber, regnumber, shiftnumber, СуммаЧека, Склад, ЭквайринговыйТерминал, ВитринаИнтернетМагазина"
											, ТекущаяДата()
											, КассаЭквайринговыйТерминал.Организация
											, КассаЭквайринговыйТерминал.ТипОплаты
											, 0
											, 0
											, 0
											, 0
											, 0
											, 0
											, 1
											, ЗаказОбъект.СуммаДокумента
											, КассаЭквайринговыйТерминал.Склад
											, КассаЭквайринговыйТерминал.ЭквайринговыйТерминал
											, ЗаказОбъект.ВитринаИнтернетМагазина);
	
	ЧекККМ = ВнешнийМодуль.СоздатьЧекПоЗаказу(ЗаказОбъект.Ссылка, ДанныеЧекаКассы, КассаЭквайринговыйТерминал.Касса, ЗаказОбъект.Товары);
	ЗаказОбъект.ЧекПродажа = ЧекККМ;
	ЗаказОбъект.КассаККМ = КассаЭквайринговыйТерминал.Касса;
	ВнешнийМодуль.ДобавитьДокументОплатыВЗаказОплаты(ЗаказОбъект, ЧекККМ, , Перечисления.ИсточникиФормированияЧеков.Система); 
	ВнешнийМодуль.ДобавитьДокументПродажиВТабличнуюЧастьАкцизныеМаркиЗаказаВсеСтроки(ЗаказОбъект, ЧекККМ, Ложь);	
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область ИзменениеАдресаДоставки

&НаКлиенте
Процедура ИзменитьАдресДоставки(Команда)
	
	Если Элементы.Заказы.ВыделенныеСтроки.Количество() <> 1 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Необходимо выбрать 1 заказ для изменения адреса'"));
		Возврат;
	КонецЕсли;
	
	СтруктураДанныхЗаказа = ПолучитьСтруктуруДанныхЗаказа(Элементы.Заказы.ВыделенныеСтроки[0]);
	
	Если СтруктураДанныхЗаказа.Свойство("ПричинаОтказа") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтруктураДанныхЗаказа.ПричинаОтказа);
	Иначе
		ПараметрыАдреса = Новый Структура("АдресИсходный, АдресJSON, РучноеИзменениеАдресаДоставки", СтруктураДанныхЗаказа.АдресДоставки, СтруктураДанныхЗаказа.АдресДоставкиJSON, Истина);
		ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаВыбораАдреса", ПараметрыАдреса);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция ПолучитьСтруктуруДанныхЗаказа(ЗаказСсылка)
	
	ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ЗаказСсылка, "АдресДоставки, АдресДоставкиJSON, ВитринаИнтернетМагазина, ЧекПродажа, Статус, СуммаДокумента, ОтменаКлиентом, Доставлен");
	
	Если ДанныеЗаказа.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.ЯрчеПлюс Тогда
		
		Если ДанныеЗаказа.СуммаДокумента = 0 Тогда
			ДанныеЗаказа.Вставить("ПричинаОтказа", "Заказ отменен, изменение адреса доставки невозможно.");
			Возврат ДанныеЗаказа;
		ИначеЕсли ДанныеЗаказа.Статус = Перечисления.СтатусыЗаказовКлиентов.Закрыт Тогда
			ДанныеЗаказа.Вставить("ПричинаОтказа", "Заказ доставлен, изменение адреса доставки невозможно.");
			Возврат ДанныеЗаказа;
		КонецЕсли;
		
	ИначеЕсли ДанныеЗаказа.ВитринаИнтернетМагазина <> Справочники.ВитриныИнтернетМагазина.ДаркКитчен Тогда
		
		Если ДанныеЗаказа.ОтменаКлиентом Тогда
			ДанныеЗаказа.Вставить("ПричинаОтказа", "Заказ отменен, изменение адреса доставки невозможно.");
			Возврат ДанныеЗаказа;
		ИначеЕсли ДанныеЗаказа.Статус = Перечисления.СтатусыЗаказовКлиентов.Закрыт ИЛИ ДанныеЗаказа.Доставлен Тогда
			ДанныеЗаказа.Вставить("ПричинаОтказа", "Заказ доставлен, изменение адреса доставки невозможно.");
			Возврат ДанныеЗаказа;
		КонецЕсли;
		
	Иначе
		
		ДанныеЗаказа.Вставить("ПричинаОтказа", "Изменять адрес доставки возможно только для заказов Ярче плюс и Дарк китчен");
		Возврат ДанныеЗаказа;
		
	КонецЕсли;
	
	Возврат ДанныеЗаказа;
	
КонецФункции

&НаСервере
Процедура ИзменитьАдресДоставкиЗаказа(Заказ, Параметр)
	
	Попытка
		ЗаказОбъект = Заказ.ПолучитьОбъект();
		ИсходныйАдресДоставки = ЗаказОбъект.АдресДоставки;
		ЗаказОбъект.АдресДоставки = Параметр.Адрес;
		АдресДоставкиСвойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("АдресДоставки");
		НайденныеСтроки = ЗаказОбъект.ДополнительныеРеквизиты.НайтиСтроки(Новый Структура("Свойство", АдресДоставкиСвойство));
		Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
			НайденнаяСтрока.Значение = Параметр.Адрес;
		КонецЦикла;
		ЗаказОбъект.Широта = Параметр.Широта;
		ЗаказОбъект.Долгота = Параметр.Долгота;
		ЗаказОбъект.АдресДоставкиJSON = Параметр.АдресJSON;
		ЗаказОбъект.Комментарий = ЗаказОбъект.Комментарий + ?(ПустаяСтрока(ЗаказОбъект), "", Символы.ПС) + "Адрес доставки изменен:" + Символы.ПС + "Исходный - " + ИсходныйАдресДоставки + Символы.ПС + "Новый - " + ЗаказОбъект.АдресДоставки;
		ЗаказОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
		ЗаказОбъект.Записать(РежимЗаписиДокумента.Запись);
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка изменения адреса доставки: " + Символы.ПС + ОписаниеОшибки());
		ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, Заказ.Метаданные(), Заказ, "Ошибка изменения адреса доставки: " + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
КонецПроцедуры

#КонецОбласти

#Область СтатусОплаты

&НаКлиенте
Процедура СтатусОплаты(Команда)
	
	ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ДанныеОплаты", Новый Структура("Заказ", Элементы.Заказы.ТекущаяСтрока));
	
	Если ЧекИлиЭквайринговаяОперацияСуществуют(Элементы.Заказы.ТекущаяСтрока) Тогда
		Возврат;
	КонецЕсли;
	
	МассивПараметров = Новый Массив;
	МассивПараметров.Добавить(Неопределено);
	МассивПараметров.Добавить("ЗагрузитьОплатуПоЗаказуМагпей");
	МассивПараметров.Добавить(Новый Структура("Заказ", Элементы.Заказы.ТекущаяСтрока));
	МассивПараметров.Добавить(Неопределено);
	
	ДлительныеОперации.СоздатьФоновоеЗадание("ОбменССайтом.ВыполнитьМетодВнешнейОбработки", МассивПараметров, "ЗагрузкаЧекаМагпей" + Новый УникальныйИдентификатор(), "ЗагрузкаЧекаМагпей");
	
КонецПроцедуры

#КонецОбласти
 
#Область РазрешитьВозвратMagPay

&НаКлиенте
Процедура РазрешитьВозвратMagPay(Команда)
	
	МассивЗаказов = Новый Массив;
	Для Каждого СтрЗаказ Из Элементы.Заказы.ВыделенныеСтроки Цикл
		МассивЗаказов.Добавить(СтрЗаказ);
	КонецЦикла;
	
	Если МассивЗаказов.Количество() > 0 Тогда
		РазрешитьВозвратMagPayНаСервере(МассивЗаказов);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Процедура РазрешитьВозвратMagPayНаСервере(МассивЗаказов)
	
	Для Каждого ЭлементМассива Из МассивЗаказов Цикл
		
		ЗаказОбъект = ЭлементМассива.ПолучитьОбъект();
		Если ЗаказОбъект.ВозвратMagPayЗапрещен Тогда
			ЗаказОбъект.ВозвратMagPayЗапрещен = Ложь;
			ЗаказОбъект.ДополнительныеСвойства.Вставить("НеКонтролироватьДатуЗапретаРедактирования", Истина);
			Попытка
				ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
			Исключение
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(Строка(ЭлементМассива));
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеОшибки());
				ЗаписьЖурналаРегистрации("ИМ.АРМСнятиеФлагаВозвратMagPayЗапрещен", УровеньЖурналаРегистрации.Ошибка, ЭлементМассива.Метаданные(), ЭлементМассива, ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			КонецПопытки;
		КонецЕсли;
		
	КонецЦикла;
	
КонецПроцедуры

#КонецОбласти


#Область СтатусГотовки

&НаКлиенте
Процедура СтатусГотовки(Команда)
	
	Если Элементы.Заказы.ВыделенныеСтроки.Количество() <> 1 Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Необходимо выбрать 1 заказ Дарк китчен для просмотра статуса готовки'"));
		Возврат;
	КонецЕсли;
	
	РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Элементы.Заказы.ТекущаяСтрока, "НомерЗаказаНаСайте, ВитринаИнтернетМагазина");
	
	Если РеквизитыЗаказа.ВитринаИнтернетМагазина <> ПредопределенноеЗначение("Справочник.ВитриныИнтернетМагазина.ДаркКитчен") Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Заказ %1 не является заказом Дарк китчен'"), РеквизитыЗаказа.НомерЗаказаНаСайте));
		Возврат;
	КонецЕсли;
	
	ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаСтатусыЗаказовКухни", Новый Структура("Заказ", Элементы.Заказы.ТекущаяСтрока));

КонецПроцедуры

#КонецОбласти


#Область Игрушки

&НаСервере
Функция ЗапуститьФоновоеЗадание(ИмяМетода, МассивПараметровМетода, КлючНаименование = "")
	МассивСостоянийФоновыхЗаданий = Новый Массив;
	МассивСостоянийФоновыхЗаданий.Добавить(СостояниеФоновогоЗадания.Активно);
	МассивСостоянийФоновыхЗаданий.Добавить(СостояниеФоновогоЗадания.Завершено);
	СтруктураОтбора = Новый Структура;
	СтруктураОтбора.Вставить("Ключ", КлючНаименование);
	СтруктураОтбора.Вставить("Состояние", МассивСостоянийФоновыхЗаданий);
	СтруктураОтбора.Вставить("Начало", ТекущаяДата() - 5*60);
	МассивЗаданий = ФоновыеЗадания.ПолучитьФоновыеЗадания(СтруктураОтбора);
	Если МассивЗаданий.Количество() = 0 Тогда
		Задание = ФоновыеЗадания.Выполнить(ИмяМетода, МассивПараметровМетода, КлючНаименование, КлючНаименование);
		Возврат Задание.УникальныйИдентификатор;
	Иначе
		Возврат МассивЗаданий[0].УникальныйИдентификатор;
	КонецЕсли;
КонецФункции

//посылки индикатор в фоне:
//есть заказы: изменяется заголовок закладки происходит обновление динмического списка
//нет заказов: изменяется заголовок закладки
&НаСервереБезКонтекста
Функция ТекстЗапросаЗаказыПосылки()
	
	лТекст = "ВЫБРАТЬ
	         |	ЗаказКлиента.Ссылка,
	         |	ЗаказКлиента.НомерЗаказаНаСайте,
	         |	ЗаказКлиента.ДатаЗаказаНаСайте,
	         |	ЗаказКлиента.Склад,
	         |	ЗаказКлиента.СуммаДокумента,
	         |	ЗаказКлиента.ЖелаемаяДатаОтгрузки,
	         |	ЗаказКлиента.Статус,
	         |	ВЫБОР
	         |		КОГДА ЗаказКлиента.СтатусПроверки = 0
	         |			ТОГДА ""Проверку Не Проходил""
	         |		КОГДА ЗаказКлиента.СтатусПроверки = 1
	         |			ТОГДА ""Проверку Прошел""
	         |		КОГДА ЗаказКлиента.СтатусПроверки = 2
	         |			ТОГДА ""Выявлены Отклонения""
	         |		КОГДА ЗаказКлиента.СтатусПроверки = 3
	         |			ТОГДА ""Отгрузка Разрешена""
	         |		КОГДА ЗаказКлиента.СтатусПроверки = 4
	         |			ТОГДА ""Отгрузка Запрещена""
	         |		ИНАЧЕ """"
	         |	КОНЕЦ КАК СтатусПроверки,
	         |	ЗаказКлиента.АдресДоставки,
	         |	ЗаказКлиента.ПокупательФИО,
	         |	ЗаказКлиента.ПокупательТелефон,
	         |	ЗаказКлиента.ПокупательEmail,
	         |	ЗаказКлиента.Комментарий,
	         |	ЗаказКлиента.ВитринаИнтернетМагазина,
	         |	""{{ДополнительнаяОбработка.АРМЗаказовИнтернетМагазина.ТекстЗапросаЗаказыПосылки}}"" КАК НаименованиеЗапроса
	         |ИЗ
	         |	Документ.ЗаказКлиента КАК ЗаказКлиента
	         |ГДЕ
	         |	(ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.Игрушки)
	         |			ИЛИ ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.КДВ))
	         |	И ЗаказКлиента.ЖелаемаяДатаОтгрузки МЕЖДУ &ДатаНачала И &ДатаОкончания
	         |	И ЗаказКлиента.СтатусПроверки = &СтатусПроверки
	         |	И ЗаказКлиента.Статус В(&МассивСтатусов)";
		
	Возврат лТекст;
	
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьМассивСтатусовЗаказовПосылки()
	МассивСтатусов = Новый Массив;
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаказовКлиентов.НеСогласован); // Не согласован
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаказовКлиентов.Согласован); // Согласован
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаказовКлиентов.КОбеспечению); // К обеспечению
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаказовКлиентов.КВыгрузкеWMS); // К выгрузке WMS
	МассивСтатусов.Добавить(Перечисления.СтатусыЗаказовКлиентов.КОтгрузке); // К отгрузке
	Возврат МассивСтатусов;	
КонецФункции

&НаКлиенте
Процедура ЗаказыПосылкиЗапуститьФоновоеЗадание()
	
	МассивСтатусов = ПолучитьМассивСтатусовЗаказовПосылки();
	
	ИмяМетода = "ДлительныеОперации.ВыполнитьЗапросВФоне";
	ТекстЗапроса = ТекстЗапросаЗаказыПосылки();
	МассивПараметровМетода = Новый Массив;
	МассивПараметровМетода.Добавить(ТекстЗапроса);
	МассивПараметровМетода.Добавить(Новый Структура("ДатаНачала, ДатаОкончания, СтатусПроверки, МассивСтатусов", НачалоДня(ОтборИгрушкиДатаНачала), КонецДня(ОтборИгрушкиДатаОкончания), 2, МассивСтатусов));
	КлючНаименование = "ПолучениеПризнакаНаличиеЗаказовИгрушки";
	
	ПосылкиКлючФЗ = ЗапуститьФоновоеЗадание(ИмяМетода, МассивПараметровМетода, КлючНаименование);
	
	//ЭтаФорма.ПодключитьОбработчикОжидания("ЗаказыПосылкиРезультатФоновогоЗаданияНаКлиенте", 300);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыПосылкиРезультатФоновогоЗаданияНаКлиенте()
	
	ЗаданиеВыполнено = Ложь;
	ЗаказыПосылкиРезультатФоновогоЗадания(ПосылкиКлючФЗ, ЗаданиеВыполнено);
	Если ЗаданиеВыполнено Тогда 
		ЭтаФорма.ОтключитьОбработчикОжидания("ЗаказыПосылкиРезультатФоновогоЗаданияНаКлиенте");
		ОбновитьЗаголовокСтраницыЗаказыПосылки();
		ЗаказыПосылкиЗапуститьФоновоеЗадание();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаказыПосылкиРезультатФоновогоЗадания(ИдЗадания, ЗаданиеВыполнено = Ложь)
	
	Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдЗадания);
	Если ТипЗнч(Задание) = Тип("ФоновоеЗадание") Тогда
		Если Задание.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
			Сообщения = Задание.ПолучитьСообщенияПользователю();
			ЗаданиеВыполнено = Истина;
			Если Сообщения.Количество() > 0 Тогда 
				Рез = ЗначениеИзСтрокиВнутр(Сообщения[0].Текст);
				Если ТипЗнч(Рез) = Тип("РезультатЗапроса") Тогда
					ОбновитьТаблицуЗаказыПосылкиНаСервере(Рез);
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ЗаданиеВыполнено = Истина;
	КонецЕсли;

КонецПроцедуры

&НаКлиенте
Процедура ИгрушкиЗапретитьОтгрузку(Команда)
	
	ТД = Элементы.ЗаказыИгрушки.ТекущиеДанные;
	
	Результат = Ложь;
	ТекстОшибки = "";
	
	ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ТД.Ссылка, "Номер, Дата");
	Если ТД <> Неопределено Тогда
		РазрешитьОтгрузкуНаСервере(ДанныеЗаказа.Номер + "_" + Формат(ДанныеЗаказа.Дата, "ДФ=yy"), 2, ТД.Ссылка, Результат, ТекстОшибки);		
	КонецЕсли;
	
	Если Результат = Истина Тогда 
		ОбновитьЗаказыПосылкиНаСервере();
		ОбновитьЗаголовокСтраницыЗаказыПосылки();
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИгрушкиРазрешитьОтгрузку(Команда)

	ТД = Элементы.ЗаказыИгрушки.ТекущиеДанные;
	
	Результат = Ложь;
	ТекстОшибки = "";
	
	ДанныеЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ТД.Ссылка, "Номер, Дата");
	Если ТД <> Неопределено Тогда
		РазрешитьОтгрузкуНаСервере(ДанныеЗаказа.Номер + "_" + Формат(ДанныеЗаказа.Дата, "ДФ=yy"), 1, ТД.Ссылка, Результат, ТекстОшибки);		
	КонецЕсли;
	
	Если Результат = Истина Тогда
		ОбновитьЗаказыПосылкиНаСервере();
		ОбновитьЗаголовокСтраницыЗаказыПосылки();
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура РазрешитьОтгрузкуНаСервере(НомерДокумента, Отгрузка, ДокументСсылка, Результат, ТекстОшибки)
	
	Обработка = РеквизитФормыВЗначение("Объект");
	Обработка.РазрешитьОтгрузкуНаСервере(НомерДокумента, Отгрузка, ДокументСсылка, Результат, ТекстОшибки);
	ЗначениеВРеквизитФормы(Обработка, "Объект");
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборИгрушкиДатаНачалаПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(ОтборИгрушкиДатаНачала) Тогда
		ОтборИгрушкиДатаНачала = ДобавитьМесяц(ТекущаяДата(), -2);
	КонецЕсли;
	
	НоваяДатаОкончания = ДобавитьМесяц(ОтборИгрушкиДатаНачала, 2) + 2 * 24 *3600;
	Если НоваяДатаОкончания < ОтборИгрушкиДатаОкончания Тогда
		ОтборИгрушкиДатаОкончания = НоваяДатаОкончания;
	КонецЕсли;
	
	ОбновитьЗаказыПосылкиНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборИгрушкиДатаОкончанияПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(ОтборИгрушкиДатаОкончания) Тогда
        ОтборИгрушкиДатаОкончания = ТекущаяДата() + 2*24*3600;
	КонецЕсли;
	
	НоваяДатаНачала = ДобавитьМесяц(ОтборИгрушкиДатаОкончания - 2*24*3600, -2);
	Если НоваяДатаНачала > ОтборИгрушкиДатаНачала Тогда
		ОтборИгрушкиДатаНачала = НоваяДатаНачала;
	КонецЕсли;
	
	ОбновитьЗаказыПосылкиНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗаказыПосылки(Команда)
	ОбновитьЗаказыПосылкиНаСервере();
	ОбновитьЗаголовокСтраницыЗаказыПосылки();
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗаказыПосылкиНаСервере()

	МассивСтатусов = ПолучитьМассивСтатусовЗаказовПосылки();
	ТекстЗапроса = ТекстЗапросаЗаказыПосылки();
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ОтборИгрушкиДатаНачала));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ОтборИгрушкиДатаОкончания));
	Запрос.УстановитьПараметр("СтатусПроверки", 2);
	Запрос.УстановитьПараметр("МассивСтатусов", МассивСтатусов);
	РезультатЗапроса = Запрос.Выполнить();
	ОбновитьТаблицуЗаказыПосылкиНаСервере(РезультатЗапроса);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьТаблицуЗаказыПосылкиНаСервере(РезультатЗапроса)
	
	ЗаказыИгрушки.Очистить();
	
	РезультатВыборка = РезультатЗапроса.Выбрать();
	Пока РезультатВыборка.Следующий() Цикл
		НС = ЗаказыИгрушки.Добавить();
		ЗаполнитьЗначенияСвойств(НС, РезультатВыборка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗаголовокСтраницыЗаказыПосылки()
	КоличествоСтрокРезультата = ЗаказыИгрушки.Количество();
	Если КоличествоСтрокРезультата = 0 Тогда
		Элементы.ГруппаИгрушки.Заголовок = "Посылки"; 
		Элементы.ГруппаИгрушки.Картинка = Новый Картинка;
	Иначе
		Элементы.ГруппаИгрушки.Заголовок = "Посылки (" + КоличествоСтрокРезультата + ")";
		Элементы.ГруппаИгрушки.Картинка = БиблиотекаКартинок.Внимание;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыИгрушкиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийЗаказ = Элемент.ТекущиеДанные.Ссылка;
	
	ОткрытьФормуЗаказаПосылки(ТекущийЗаказ);
	
КонецПроцедуры

&НаКлиенте
Процедура ПросмотрЗаказаИгрушки(Команда)
	
	Если Элементы.ЗаказыИгрушки.ВыделенныеСтроки.Количество()<>1 Тогда
		Возврат;
	КонецЕсли;
	
	Если Элементы.ЗаказыИгрушки.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийЗаказ = Элементы.ЗаказыИгрушки.ТекущиеДанные.Ссылка;
	
	ОткрытьФормуЗаказаПосылки(ТекущийЗаказ);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуЗаказаПосылки(ТекущийЗаказ)
	
	Если ТекущийЗаказ = Неопределено ИЛИ ТекущийЗаказ.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	П = Новый Структура("Заказ", ТекущийЗаказ);
	ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаЗаказаПосылки", П);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыИгрушкиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыИгрушкиПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыИгрушкиПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

#КонецОбласти

#Область КурьерыИКомплектовщики

&НаКлиенте
Процедура ИзменитьДанныеКурьера(Команда)
	
	Если Элементы.Заказы.ВыделенныеСтроки.Количество()<>1 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийКурьер = Элементы.Заказы.ТекущиеДанные.Курьер;
	
	Если ТекущийКурьер = Неопределено ИЛИ ТекущийКурьер.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	П = Новый Структура("ТекущийКурьер", ТекущийКурьер);
	ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаИзмененияДанныхКурьера", П);
	
КонецПроцедуры

&НаСервере
Процедура ПеречитатьТаблицуКК()
	
	КурьерыИКомплектовщики.Очистить();
	
	ГруппаВидКИ = Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Контактная информация справочника ""Физические лица""");
	ВидКИ = Справочники.ВидыКонтактнойИнформации.НайтиПоНаименованию("Телефон", , ГруппаВидКИ);
	СвойствоИМ = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("ИнтернетМагазин");

	Запрос = новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ФизическиеЛица.Ссылка КАК ФизическоеЛицоСсылка,
	               |	ФизическиеЛица.ПометкаУдаления КАК ПометкаУдаления,
	               |	ФизическиеЛица.Наименование КАК ФИО,
	               |	ФизическиеЛица.РольИМ КАК РольИМ,
	               |	ЕСТЬNULL(ФизическиеЛицаКонтактнаяИнформация.НомерТелефона, """") КАК Телефон,
	               |	ЕСТЬNULL(ФизическиеЛицаДополнительныеРеквизиты.Значение, ЗНАЧЕНИЕ(Справочник.Склады.ПустаяСсылка)) КАК Магазин
	               |ИЗ
	               |	Справочник.ФизическиеЛица КАК ФизическиеЛица
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица.ДополнительныеРеквизиты КАК ФизическиеЛицаДополнительныеРеквизиты
	               |		ПО ФизическиеЛица.Ссылка = ФизическиеЛицаДополнительныеРеквизиты.Ссылка
	               |			И (ФизическиеЛицаДополнительныеРеквизиты.Свойство = &СвойствоИМ)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.ФизическиеЛица.КонтактнаяИнформация КАК ФизическиеЛицаКонтактнаяИнформация
	               |		ПО ФизическиеЛица.Ссылка = ФизическиеЛицаКонтактнаяИнформация.Ссылка
	               |			И (ФизическиеЛицаКонтактнаяИнформация.Тип = &ТипКИ)
	               |			И (ФизическиеЛицаКонтактнаяИнформация.Вид = &ВидКИ)
	               |ГДЕ
	               |	ФизическиеЛица.РольИМ <> ЗНАЧЕНИЕ(Перечисление.РолиСотрудниковИМ.ПустаяСсылка)
	               |	И ВЫБОР
	               |			КОГДА &СкрытьПомеченныеНаУдаление = ИСТИНА
	               |				ТОГДА НЕ ФизическиеЛица.ПометкаУдаления
	               |			ИНАЧЕ ИСТИНА
	               |		КОНЕЦ
	               |	И ВЫБОР
	               |			КОГДА &РольСотрудникаИМ = ЗНАЧЕНИЕ(Перечисление.РолиСотрудниковИМ.ПустаяСсылка)
	               |				ТОГДА ИСТИНА
	               |			ИНАЧЕ ФизическиеЛица.РольИМ = &РольСотрудникаИМ
	               |		КОНЕЦ";
	Запрос.УстановитьПараметр("СвойствоИМ", СвойствоИМ);
	Запрос.УстановитьПараметр("ТипКИ", Перечисления.ТипыКонтактнойИнформации.Телефон);
	Запрос.УстановитьПараметр("ВидКИ", ВидКИ);
	Запрос.УстановитьПараметр("СкрытьПомеченныеНаУдаление", КурьерыИКомплектовщикиСкрытьПомеченныеНаУдаление);
	Запрос.УстановитьПараметр("РольСотрудникаИМ", РольСотрудникаИМ);
	
	ВыборкаРезультата = Запрос.Выполнить().Выбрать();
	Пока ВыборкаРезультата.Следующий() Цикл
		Если XMLСтрока(ВыборкаРезультата.ФизическоеЛицоСсылка) = "7c4920c2-0f67-11eb-8125-005056a95b82" Тогда
			//исключаем показ курьера Курьер аутсорс ИМ
			Продолжить;
		КонецЕсли;
		НС = КурьерыИКомплектовщики.Добавить();
		ЗаполнитьЗначенияСвойств(НС, ВыборкаРезультата);
		НС.ГУИД = XMLСтрока(НС.ФизическоеЛицоСсылка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура КурьерыИКомплектовщикиДобавить(Команда)
	
	Если Не ЗначениеЗаполнено(РольСотрудникаИМ) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = '""Роль"" не выбрана'"));
		Возврат;
	КонецЕсли;
	
	П = Новый Структура;
	П.Вставить("РольСотрудникаИМ", РольСотрудникаИМ);
	ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаИзмененияДанныхКурьера", П);
	
КонецПроцедуры

&НаКлиенте
Процедура КурьерыИКомплектовщикиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	ИзменитьКурьераКомплектовщика();
КонецПроцедуры

&НаКлиенте
Процедура КурьерыИКомплектовщикиИзменить(Команда)
	ИзменитьКурьераКомплектовщика();
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьКурьераКомплектовщика()
	
	Если Элементы.КурьерыИКомплектовщики.ВыделенныеСтроки.Количество()<>1 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийКурьер = Элементы.КурьерыИКомплектовщики.ТекущиеДанные.ФизическоеЛицоСсылка;
	
	Если ТекущийКурьер = Неопределено ИЛИ ТекущийКурьер.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	П = Новый Структура("ТекущийКурьер", ТекущийКурьер);
	ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаИзмененияДанныхКурьера", П);
	
КонецПроцедуры

&НаКлиенте
Процедура КурьерыиКомплектовщикиПеречитать(Команда)
	ПеречитатьТаблицуКК();
КонецПроцедуры

&НаСервереБезКонтекста
Процедура КурьерыИКомплектовщикиУдалитьНаСервере(ТекущийКурьер);
	
	Если ТекущийКурьер = Неопределено ИЛИ ТекущийКурьер.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	ТекущаяПометкаУдаления = ТекущийКурьер.ПометкаУдаления;
	
	УстановитьПривилегированныйРежим(Истина);
	Попытка
		ТекущийКурьерОбъект = ТекущийКурьер.ПолучитьОбъект();
		ТекущийКурьерОбъект.УстановитьПометкуУдаления(?(ТекущаяПометкаУдаления, Ложь, Истина));
	Исключение
		ШаблонТекстаСообщения = НСтр("ru='Ошибка изменения пометки удаления ""%Курьер%"": %ОписаниеОшибки%'");
		ТекстСообщения = СтрЗаменить(ШаблонТекстаСообщения, "%Курьер%", СокрЛП(ТекущийКурьер.Наименование));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
	КонецПопытки;
	
КонецПроцедуры

&НаКлиенте
Процедура КурьерыИКомплектовщикиУдалить(Команда)
	
	Если Элементы.КурьерыИКомплектовщики.ВыделенныеСтроки.Количество()<>1 Тогда
		Возврат;
	КонецЕсли;
	
	ТекущийКурьер = Элементы.КурьерыИКомплектовщики.ТекущиеДанные.ФизическоеЛицоСсылка;
	
	Если ТекущийКурьер = Неопределено ИЛИ ТекущийКурьер.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	КурьерыИКомплектовщикиУдалитьНаСервере(ТекущийКурьер);
	ПеречитатьТаблицуКК();

КонецПроцедуры

&НаКлиенте
Процедура КурьерыИКомплектовщикиСкрытьПомеченныеНаУдалениеПриИзменении(Элемент)
	ПеречитатьТаблицуКК();
КонецПроцедуры

&НаКлиенте
Процедура РольСотрудникаИМПриИзменении(Элемент)
	ПеречитатьТаблицуКК();
КонецПроцедуры

&НаКлиенте
Процедура ВывестиВТабличныйДокумент(Команда)
	ТабличныйДокумент = ПолучитьТабличныйДокументКурьеровИКомплектовщиковНаСервере();
	ТабличныйДокумент.Показать("Список курьеров и комплектовщиков");
КонецПроцедуры

&НаСервере
Функция ПолучитьТабличныйДокументКурьеровИКомплектовщиковНаСервере()
	
	ТЗ = КурьерыИКомплектовщики.Выгрузить(,"ФИО, Телефон, РольИМ, ГУИД, Магазин");
	
	ТабличныйДокумент = ДанныеТаблицыЗначенийВТабличныйДокумент(ТЗ);
	Возврат ТабличныйДокумент;
	
КонецФункции

&НаСервереБезКонтекста
Функция ДанныеТаблицыЗначенийВТабличныйДокумент(Знач ТЗ)
	
	ТабличныйДокумент = Новый ТабличныйДокумент;
	Построитель = Новый ПостроительОтчета;
	Построитель.ИсточникДанных = Новый ОписаниеИсточникаДанных(ТЗ);
	Построитель.ВыводитьЗаголовокОтчета = Ложь;
	Построитель.ВыводитьПодвалОтчета = Ложь;
	Построитель.ВыводитьПодвалТаблицы = Ложь;
	Построитель.Вывести(ТабличныйДокумент);
	
	ОбластьТабличногоДокумента = ТабличныйДокумент.Область(,1,1,1);
	ТабличныйДокумент.УдалитьОбласть(ОбластьТабличногоДокумента, ТипСмещенияТабличногоДокумента.ПоВертикали);
	Возврат ТабличныйДокумент;
	
КонецФункции // ДанныеТаблицыЗначенийВТабличныйДокумент()

#КонецОбласти

#Область Магазины

&НаКлиенте
Процедура МагазиныСкладПриИзменении(Элемент)
	МагазиныСкладПриИзмененииНаКлиенте();				
КонецПроцедуры

&НаКлиенте
Процедура МагазиныСкладПриИзмененииНаКлиенте()
	
	Если МагазиныСклад.Пустая() Тогда
		Элементы.ИзменитьПризнакИМ.Заголовок = "Изменить признак интернет-магазин";
		Элементы.ИзменитьПризнакИМ.Доступность = Ложь;
	Иначе
		Элементы.ИзменитьПризнакИМ.Доступность = Истина;		
		ПризнакИнтернетМагазин = ПолучитьПризнакИнтернетМагазин(МагазиныСклад);
		Если ПризнакИнтернетМагазин Тогда 
			Элементы.ИзменитьПризнакИМ.Заголовок = "Снять признак интернет-магазин";
		Иначе
			Элементы.ИзменитьПризнакИМ.Заголовок = "Установить признак интернет-магазин";
		КонецЕсли;
	КонецЕсли;

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьПризнакИнтернетМагазин(СкладСсылка)
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	СкладыДополнительныеРеквизиты.Значение КАК ИнтернетМагазин
		|ИЗ
		|	Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
		|ГДЕ
		|	СкладыДополнительныеРеквизиты.Свойство.Наименование = ""Склад интернет магазина""
		|	И СкладыДополнительныеРеквизиты.Ссылка = &Склад";
	Запрос.УстановитьПараметр("Склад", СкладСсылка);	
	Результат = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.ИнтернетМагазин;	
	КонецЦикла;
	Возврат Ложь;
КонецФункции

&НаКлиенте
Процедура ИзменитьПризнакИМ(Команда)
	ИзменитьПризнакИМНаСервере(МагазиныСклад);
	МагазиныСкладПриИзмененииНаКлиенте();
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ИзменитьПризнакИМНаСервере(СкладСсылка)
	
	УстановитьПривилегированныйРежим(Истина);
	СвойствоИнтернетМагазин = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Склад интернет магазина");
	
	Если СкладСсылка.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	Попытка
		СкладОбъект = СкладСсылка.ПолучитьОбъект();
	Исключение
		ШаблонТекстаСообщения = НСтр("ru='Ошибка доступа к ""%Склад%"": %ОписаниеОшибки%'");
		ТекстСообщения = СтрЗаменить(ШаблонТекстаСообщения, "%Склад%", СокрЛП(СкладСсылка));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецПопытки;
	
	СкладПодключен = Ложь;
	НайденныеСтроки = СкладОбъект.ДополнительныеРеквизиты.НайтиСтроки(Новый Структура("Свойство", СвойствоИнтернетМагазин));
	Если НайденныеСтроки.Количество() > 0 Тогда
		Для Каждого НайденнаяСтроки Из НайденныеСтроки Цикл
			НайденнаяСтроки.Значение 	= НЕ НайденнаяСтроки.Значение;
			СкладПодключен 				= НайденнаяСтроки.Значение;
		КонецЦикла;
	Иначе
		НДр								= СкладОбъект.ДополнительныеРеквизиты.Добавить();
		НДр.Свойство					= СвойствоИнтернетМагазин;
		НДр.Значение					= Истина;
		СкладПодключен					= Истина;
	КонецЕсли;
	
	Попытка
		СкладОбъект.Записать();
	Исключение
		ШаблонТекстаСообщения = НСтр("ru='Ошибка записи ""%Склад%"": %ОписаниеОшибки%'");
		ТекстСообщения = СтрЗаменить(ШаблонТекстаСообщения, "%Склад%", СокрЛП(СкладСсылка));
		ТекстСообщения = СтрЗаменить(ТекстСообщения, "%ОписаниеОшибки%", ОписаниеОшибки());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецПопытки;
	
	//Корректируем расписание узлов обмена
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОбменССайтом.Ссылка,
		|	ВЫБОР
		|		КОГДА ОбменССайтом.ОбменЗаказами = ИСТИНА
		|			ТОГДА ""Заказы""
		|		КОГДА ОбменССайтом.ОбменТоварами = ИСТИНА
		|			ТОГДА ""Товары""
		|		ИНАЧЕ """"
		|	КОНЕЦ КАК ТипУзла
		|ИЗ
		|	ПланОбмена.ОбменССайтом КАК ОбменССайтом
		|ГДЕ
		|	ОбменССайтом.Склад = &Склад";

	Запрос.УстановитьПараметр("Склад", СкладСсылка);

	ВыборкаУзлыОбмена = Запрос.Выполнить().Выбрать();
	Пока ВыборкаУзлыОбмена.Следующий() Цикл
		
		УзелОбменаОбъект = ВыборкаУзлыОбмена.Ссылка.ПолучитьОбъект();
		
		Если СкладПодключен Тогда //включили ИМ
			
			Задание = РегламентныеЗадания.СоздатьРегламентноеЗадание("ОбменССайтом");
			Задание.Использование = Истина;
			Задание.Ключ = Строка(Новый УникальныйИдентификатор);
			Задание.Наименование = УзелОбменаОбъект.Наименование;
			ПараметрыЗадания = Новый Массив;
			ПараметрыЗадания.Добавить(УзелОбменаОбъект.Код);
			Задание.Параметры = ПараметрыЗадания;
			Задание.Расписание = РасписаниеРегламентногоЗадания(ВыборкаУзлыОбмена.ТипУзла);
			Задание.ИмяПользователя = "ОбменСайт";
			Задание.Записать();
			
			УзелОбменаОбъект.ИспользоватьРегламентныеЗадания = Истина;
			УзелОбменаОбъект.ИдентификаторРегламентногоЗадания = Задание.УникальныйИдентификатор;
		
		Иначе //выключили ИМ
			
			Если ВыборкаУзлыОбмена.ТипУзла = "Товары" Тогда
				ДополнительныеОтчетыИОбработки.УдалитьРегламентноеЗадание(УзелОбменаОбъект.ИдентификаторРегламентногоЗадания);
				УзелОбменаОбъект.ИспользоватьРегламентныеЗадания = Ложь;
				УзелОбменаОбъект.ИдентификаторРегламентногоЗадания = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
			Иначе
				Задание = ДополнительныеОтчетыИОбработки.НайтиРегламентноеЗадание(УзелОбменаОбъект.ИдентификаторРегламентногоЗадания);
				Если Задание <> Неопределено Тогда
					РасписаниеЗадания = Задание.Расписание;
					РасписаниеЗадания.ДатаКонца = НачалоДня(ТекущаяДатаСеанса()) + 2 * 86400;
					Задание.Расписание = РасписаниеЗадания;
					Задание.Записать();
				Иначе
					УзелОбменаОбъект.ИспользоватьРегламентныеЗадания = Ложь;
					УзелОбменаОбъект.ИдентификаторРегламентногоЗадания = Новый УникальныйИдентификатор("00000000-0000-0000-0000-000000000000");
				КонецЕсли;
			КонецЕсли;
			
		КонецЕсли;
		
		УзелОбменаОбъект.Записать();
		
		//очистка логов обмена по узлу
		НЗРС = РегистрыСведений.СостоянияОбменовССайтом.СоздатьНаборЗаписей();
		НЗРС.Отбор.НастройкаОбменаССайтом.Установить(ВыборкаУзлыОбмена.Ссылка);
		НЗРС.Записать();
		
		НЗРС = РегистрыСведений.УспешныеОбменыССайтом.СоздатьНаборЗаписей();
		НЗРС.Отбор.НастройкаОбменаССайтом.Установить(ВыборкаУзлыОбмена.Ссылка);
		НЗРС.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция РасписаниеРегламентногоЗадания(ТипУзла)
	
	Месяцы = Новый Массив;
	Месяцы.Добавить(1);
	Месяцы.Добавить(2);
	Месяцы.Добавить(3);
	Месяцы.Добавить(4);
	Месяцы.Добавить(5);
	Месяцы.Добавить(6);
	Месяцы.Добавить(7);
	Месяцы.Добавить(8);
	Месяцы.Добавить(9);
	Месяцы.Добавить(10);
	Месяцы.Добавить(11);
	Месяцы.Добавить(12);

	ДниНедели = Новый Массив;
	ДниНедели.Добавить(1);
	ДниНедели.Добавить(2);
	ДниНедели.Добавить(3);
	ДниНедели.Добавить(4);
	ДниНедели.Добавить(5);
	ДниНедели.Добавить(6);
	ДниНедели.Добавить(7);
	
	Расписание = Новый РасписаниеРегламентногоЗадания;
	Расписание.Месяцы					= Месяцы;
	Расписание.ДниНедели				= ДниНедели;
	
	Расписание.ДатаНачала = НачалоДня(ТекущаяДатаСеанса());
	
	Если ТипУзла = "Товары" Тогда
		Расписание.ВремяНачала = Дата(1,1,1,6,0,0);
		Расписание.ВремяКонца = Дата(1,1,1,2,0,0);
		ПериодПовтораВТечениеДня = 300;
	ИначеЕсли ТипУзла = "Заказы" Тогда
		ПериодПовтораВТечениеДня = 120;
	Иначе
		ПериодПовтораВТечениеДня = 0;
	КонецЕсли;
	
	Расписание.ПериодПовтораВТечениеДня = ПериодПовтораВТечениеДня; // секунды
	Расписание.ПериодПовтораДней		= 1; // каждый день
	
	Возврат Расписание;
	
КонецФункции

&НаКлиенте
Процедура ТаблицаИнтернетМагазиныСортировкаПоДатеЗаказаПриИзменении(Элемент)
	
	ТекДан = Элементы.ТаблицаИнтернетМагазины.ТекущиеДанные;
	Если Не УстановитьСортировкуПриВыдаче(ТекДан.Магазин, ТекДан.СортировкаПоДатеЗаказа) Тогда 
		ТекДан.СортировкаПоДатеЗаказа = Не ТеКДан.СортировкаПоДатеЗаказа;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция УстановитьСортировкуПриВыдаче(Склад, Значение)
	
	Свойство = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("СортировкаПоДатеЗаказаИМ");
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Склады.Ссылка КАК Ссылка
	               |ИЗ
	               |	Справочник.Склады КАК Склады
	               |ГДЕ
	               |	Склады.Ссылка = &Склад
	               |	И Склады.ДополнительныеРеквизиты.Свойство = &Свойство";
	Запрос.УстановитьПараметр("Свойство", Свойство);
	Запрос.УстановитьПараметр("Склад", Склад);
	
	Результат = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	
	СкладОбъект = Склад.ПолучитьОбъект();
	
	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Для Каждого Стр Из СкладОбъект.ДополнительныеРеквизиты Цикл
			Если Стр.Свойство = Свойство Тогда
				Стр.Значение = Значение;
				Прервать;
			КонецЕсли;
		КонецЦикла;
	Иначе
		ЗаполнитьЗначенияСвойств(СкладОбъект.ДополнительныеРеквизиты.Добавить(), Новый Структура("Свойство, Значение", Свойство, Значение));
	КонецЕсли;
	
	Попытка
		СкладОбъект.Записать();
	Исключение
		Сообщить(ОписаниеОшибки());
		Возврат Ложь;
	КонецПопытки;
	
	Возврат Истина;
	
КонецФункции

#КонецОбласти

#Область Отчеты

&НаКлиенте
Процедура ОткрытьДополнительныйОтчет(НаименованиеОтчета)
	
	СтруктураОбработкиОтчета = ПолучитьДополнительныйОтчет(НаименованиеОтчета);
	Если СтруктураОбработкиОтчета = Неопределено Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Отчет не доступен в этой базе");
		Возврат;
	КонецЕсли;
	ОткрытьФорму(СтруктураОбработкиОтчета.ВнешняяОбработка, , , , , , , РежимОткрытияОкнаФормы.БлокироватьОкноВладельца);
	//ФормаВнешнегоОтчета = ПолучитьФорму(СтруктураОбработкиОтчета.ВнешняяОбработка);
	//ФормаВнешнегоОтчета.Открыть();
	
КонецПроцедуры

Функция ПолучитьДополнительныйОтчет(НаименованиеОтчета)
	
	УстановитьПривилегированныйРежим(Истина);
	
	ВнешняяОбработка = Справочники.ДополнительныеОтчетыИОбработки.НайтиПоНаименованию(НаименованиеОтчета);
	Если НЕ ЗначениеЗаполнено(ВнешняяОбработка) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ДвоичныеДанныеОбработки = ВнешняяОбработка.ПолучитьОбъект().ХранилищеОбработки.Получить();
	АдресВоВременномХранилище = ПоместитьВоВременноеХранилище(ДвоичныеДанныеОбработки);
	
	Если ВнешняяОбработка.Вид = Перечисления.ВидыДополнительныхОтчетовИОбработок.Отчет
		ИЛИ ВнешняяОбработка.Вид = Перечисления.ВидыДополнительныхОтчетовИОбработок.ДополнительныйОтчет Тогда
		ИмяОбработки = ВнешниеОтчеты.Подключить(АдресВоВременномХранилище,, Ложь);
	Иначе
		ИмяОбработки = ВнешниеОбработки.Подключить(АдресВоВременномХранилище,, Ложь);
	КонецЕсли;
	
	Структура = Новый Структура;
	Структура.Вставить("ВнешняяОбработка","ВнешнийОтчет."+ИмяОбработки+".Форма");
	
	Возврат Структура;
	
КонецФункции

