&НаСервере
Процедура СбермаркетЗаписатьМагазиныНаСервере()
	
	МассивГруппМагазинов = Новый Массив;
	МассивГруппМагазинов.Добавить(Справочники.Склады.НайтиПоНаименованию("Магазины работающие"));
	МассивГруппМагазинов.Добавить(Справочники.Склады.НайтиПоНаименованию("Магазины готовы к открытию"));
    СвойствоСбермаркет = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Сбермаркет");
	
	ТекстЗапроса = "ВЫБРАТЬ
	               |	ДанныеФормы.Магазин,
	               |	ДанныеФормы.Подключен
	               |ПОМЕСТИТЬ ВТ_ДанныеФормы
	               |ИЗ
	               |	&ДанныеФормы КАК ДанныеФормы
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	Склады.Ссылка КАК Магазин,
	               |	ЕСТЬNULL(СкладыДополнительныеРеквизиты.Значение, ЛОЖЬ) КАК Подключен
	               |ПОМЕСТИТЬ ВТ_ДанныеБД
	               |ИЗ
	               |	Справочник.Склады КАК Склады
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
	               |		ПО Склады.Ссылка = СкладыДополнительныеРеквизиты.Ссылка
	               |			И (СкладыДополнительныеРеквизиты.Свойство = &СвойствоСберкмаркет)
	               |ГДЕ
	               |	Склады.Ссылка В ИЕРАРХИИ(&МассивГруппСкладов)
	               |	И Склады.ЭтоГруппа = ЛОЖЬ
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_ДанныеФормы.Магазин,
	               |	ВТ_ДанныеФормы.Подключен
	               |ИЗ
	               |	ВТ_ДанныеФормы КАК ВТ_ДанныеФормы
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ВТ_ДанныеБД КАК ВТ_ДанныеБД
	               |		ПО ВТ_ДанныеФормы.Магазин = ВТ_ДанныеБД.Магазин
	               |			И ВТ_ДанныеФормы.Подключен <> ВТ_ДанныеБД.Подключен";

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("МассивГруппСкладов", МассивГруппМагазинов);
	Запрос.УстановитьПараметр("ДанныеФормы", МагазиныСбермаркет.Выгрузить(, "Магазин, Подключен"));
	Запрос.УстановитьПараметр("СвойствоСберкмаркет", СвойствоСбермаркет);
	
	РезультатЗапроса = Запрос.Выполнить();
	Если РезультатЗапроса.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	РезультатВыборка = РезультатЗапроса.Выбрать();
	Пока РезультатВыборка.Следующий() Цикл
		
		СкладОбъект = РезультатВыборка.Магазин.ПолучитьОбъект();
		
		ЕстьРеквизит = Ложь;
		МассивРеквизитовСбермаркет = СкладОбъект.ДополнительныеРеквизиты.НайтиСтроки(Новый Структура("Свойство", СвойствоСбермаркет));
		Для Каждого РеквизитСбермаркет Из МассивРеквизитовСбермаркет Цикл
			РеквизитСбермаркет.Значение = РезультатВыборка.Подключен;
			ЕстьРеквизит = Истина;
		КонецЦикла;
		
		Если НЕ ЕстьРеквизит Тогда
			НС = СкладОбъект.ДополнительныеРеквизиты.Добавить();
			НС.Свойство = СвойствоСбермаркет;
			НС.Значение = РезультатВыборка.Подключен;
		КонецЕсли;
		
		СкладОбъект.Записать();
		
	КонецЦикла;
	
КонецПроцедуры

