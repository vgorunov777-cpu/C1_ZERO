
#Область Фильтры

&НаКлиенте
Процедура ФильтрМагазин()
	
	//ОтборыСписковКлиентСервер.УдалитьЭлементОтбораСписка(Заказы, "Склад");
	
	ПКДСклад = Новый ПолеКомпоновкиДанных("Склад");
	
	Если ЗначениеЗаполнено(Магазин) Тогда 
		
		СкладУстановлен = Ложь;
		Для Каждого ЭлементОтбора Из Заказы.Отбор.Элементы Цикл
			Если Не ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				Продолжить;
			КонецЕсли;
			Если ЭлементОтбора.ЛевоеЗначение = ПКДСклад Тогда
				ЭлементОтбора.Использование = Истина;
				ЭлементОтбора.ПравоеЗначение = Магазин;
				СкладУстановлен = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ СкладУстановлен Тогда
			ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(Заказы, "Склад", Магазин, ВидСравненияКомпоновкиДанных.Равно);
		КонецЕсли;
		
	Иначе
		
		Для Каждого ЭлементОтбора Из Заказы.Отбор.Элементы Цикл
			Если Не ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				Продолжить;
			КонецЕсли;
			Если ЭлементОтбора.ЛевоеЗначение = ПКДСклад Тогда
				ЭлементОтбора.Использование = Ложь;
				ЭлементОтбора.ПравоеЗначение = Неопределено;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФильтрЖДП(КоличествоДней = 2, Включить = Истина)
	
	Если ЗначениеЗаполнено(Дата) Тогда
		ДатаНачалаОтбора = Дата;
		ДатаОкончанияОтбора = Дата;
	Иначе
		ДатаНачалаОтбора = ТекущаяДатаСервера() - КоличествоДней * 24 * 3600;
		ДатаОкончанияОтбора = ТекущаяДатаСервера() + КоличествоДней * 24 * 3600;
	КонецЕсли;
	
	ОтборЖДП = Новый ПолеКомпоновкиДанных("ЖелаемаяДатаОтгрузки");
	
	//заказы
	ДатаНачалаУстановлена = Ложь;
	ДатаокончанияУстановлена = Ложь;
	
	Для Каждого ЭлементОтбора Из Заказы.Отбор.Элементы Цикл
		Если Не ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
			Продолжить;
		КонецЕсли;
		Если ЭлементОтбора.ЛевоеЗначение = ОтборЖДП И ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.БольшеИлиРавно Тогда
			ЭлементОтбора.Использование = Включить;
			ЭлементОтбора.ПравоеЗначение = ДатаНачалаОтбора;
			ДатаНачалаУстановлена = Истина;
		ИначеЕсли ЭлементОтбора.ЛевоеЗначение = ОтборЖДП И ЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.МеньшеИлиРавно Тогда
			ЭлементОтбора.ПравоеЗначение = ДатаОкончанияОтбора;
			ЭлементОтбора.Использование = Включить;
			ДатаокончанияУстановлена = Истина;
		КонецЕсли;
	КонецЦикла;
	
	Если НЕ ДатаНачалаУстановлена Тогда
		ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(Заказы, "ЖелаемаяДатаОтгрузки", ДатаНачалаОтбора, ВидСравненияКомпоновкиДанных.БольшеИлиРавно);
	КонецЕсли;
	Если НЕ ДатаокончанияУстановлена Тогда
		ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(Заказы, "ЖелаемаяДатаОтгрузки", ДатаОкончанияОтбора, ВидСравненияКомпоновкиДанных.МеньшеИлиРавно);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФильтрНомерЗаказа()
	
	ПКДНомерЗаказаНаСайте = Новый ПолеКомпоновкиДанных("НомерЗаказаНаСайте");
	
	Если ЗначениеЗаполнено(НомерЗаказа) Тогда 
		
		НомерЗаказаУстановлен = Ложь;
		Для Каждого ЭлементОтбора Из Заказы.Отбор.Элементы Цикл
			Если Не ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				Продолжить;
			КонецЕсли;
			Если ЭлементОтбора.ЛевоеЗначение = ПКДНомерЗаказаНаСайте Тогда
				ЭлементОтбора.Использование = Истина;
				ЭлементОтбора.ПравоеЗначение = НомерЗаказа;
				НомерЗаказаУстановлен = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ НомерЗаказаУстановлен Тогда
			ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(Заказы, "НомерЗаказаНаСайте", НомерЗаказа, ВидСравненияКомпоновкиДанных.Равно);
		КонецЕсли;
		
		ФильтрЖДП(2, Ложь);
		
	Иначе
		
		ФильтрЖДП(2, Истина);
		
		Для Каждого ЭлементОтбора Из Заказы.Отбор.Элементы Цикл
			Если Не ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				Продолжить;
			КонецЕсли;
			Если ЭлементОтбора.ЛевоеЗначение = ПКДНомерЗаказаНаСайте Тогда
				ЭлементОтбора.Использование = Ложь;
				ЭлементОтбора.ПравоеЗначение = Неопределено;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФильтрЗаказПросрочен()
	
	ПросроченныеЗаказы = ОтборыСписковКлиентСервер.СоздатьГруппуЭлементовОтбора(Заказы.Отбор.Элементы,	"ПросроченныеЗаказы", ТипГруппыЭлементовОтбораКомпоновкиДанных.ГруппаИли);
	
	Если ЗаказПросрочен Тогда
		Заказы.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ТекущаяДатаСервера());
		ОтборыСписковКлиентСервер.УстановитьЭлементОтбораГруппыСписка(ПросроченныеЗаказы, "СборкаПросрочена", Истина, Истина, ВидСравненияКомпоновкиДанных.Равно);
		ОтборыСписковКлиентСервер.УстановитьЭлементОтбораГруппыСписка(ПросроченныеЗаказы, "ДоставкаПросрочена", Истина, Истина, ВидСравненияКомпоновкиДанных.Равно);
	Иначе
		ПросроченныеЗаказы.Использование = Ложь;
		ОтборыСписковКлиентСервер.УстановитьЭлементОтбораГруппыСписка(ПросроченныеЗаказы, "СборкаПросрочена", Истина, Ложь, ВидСравненияКомпоновкиДанных.Равно);
		ОтборыСписковКлиентСервер.УстановитьЭлементОтбораГруппыСписка(ПросроченныеЗаказы, "ДоставкаПросрочена", Истина, Ложь, ВидСравненияКомпоновкиДанных.Равно);
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФильтрТребуетсяОбработка()
	ОтборыСписковКлиентСервер.ИзменитьЭлементОтбораСписка(Заказы, "ТребуетсяОбработка", ТребуетсяВнимание, ТребуетсяВнимание);
КонецПроцедуры

&НаКлиенте
Процедура ФильтрТрекНомер()
	
	ФильтрЖДП(2, Истина);
	
	ОтборыСписковКлиентСервер.УдалитьЭлементОтбораСписка(Заказы, "ТрекНомер");
	
	Если ЗначениеЗаполнено(ТрекНомер) Тогда
		
		ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(Заказы, "ТрекНомер", ТрекНомер, ВидСравненияКомпоновкиДанных.Содержит);
		ФильтрЖДП(30, Истина);
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ФильтрВитрина()

	ПКДВитринаИнтернетМагазина = Новый ПолеКомпоновкиДанных("ВитринаИнтернетМагазина");
	
	Если ЗначениеЗаполнено(Витрина) Тогда 
		
		ВитринаУстановлен = Ложь;
		Для Каждого ЭлементОтбора Из Заказы.Отбор.Элементы Цикл
			Если Не ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				Продолжить;
			КонецЕсли;
			Если ЭлементОтбора.ЛевоеЗначение = ПКДВитринаИнтернетМагазина Тогда
				ЭлементОтбора.Использование = Истина;
				ЭлементОтбора.ПравоеЗначение = Витрина;
				ВитринаУстановлен = Истина;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
		Если НЕ ВитринаУстановлен Тогда
			ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(Заказы, "ВитринаИнтернетМагазина", Витрина, ВидСравненияКомпоновкиДанных.Равно);
		КонецЕсли;
		
	Иначе
		
		Для Каждого ЭлементОтбора Из Заказы.Отбор.Элементы Цикл
			Если Не ТипЗнч(ЭлементОтбора) = Тип("ЭлементОтбораКомпоновкиДанных") Тогда
				Продолжить;
			КонецЕсли;
			Если ЭлементОтбора.ЛевоеЗначение = ПКДВитринаИнтернетМагазина Тогда
				ЭлементОтбора.Использование = Ложь;
				ЭлементОтбора.ПравоеЗначение = Неопределено;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	ФильтрЖДП(ФильтрКоличествоДнейПоВитрине(Витрина), Истина);

КонецПроцедуры

&НаСервереБезКонтекста
Функция ФильтрКоличествоДнейПоВитрине(Витрина)

	Если Витрина = Справочники.ВитриныИнтернетМагазина.Игрушки Тогда
		Возврат 15;
	ИначеЕсли Витрина = Справочники.ВитриныИнтернетМагазина.ОЗОН Тогда
		Возврат 15;
	ИначеЕсли Витрина = Справочники.ВитриныИнтернетМагазина.ДаркКитчен Тогда
		Возврат 7;
	Иначе
		Возврат 2;
	КонецЕсли;
	
КонецФункции

&НаКлиенте
Процедура МагазинПриИзменении(Элемент)
	
	ФильтрМагазин();
	
КонецПроцедуры

&НаКлиенте
Процедура ДатаПриИзменении(Элемент)
	
	ФильтрЖДП(2, Истина);
	
КонецПроцедуры

&НаКлиенте
Процедура НомерЗаказаПриИзменении(Элемент)
	
	ФильтрНомерЗаказа();
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказПросроченПриИзменении(Элемент)
	
	ФильтрЗаказПросрочен();
	
КонецПроцедуры

&НаКлиенте
Процедура ТребуетсяВниманиеПриИзменении(Элемент)
	ФильтрТребуетсяОбработка();
КонецПроцедуры

&НаКлиенте
Процедура ТрекНомерПриИзменении(Элемент)
	
	ФильтрТрекНомер();
	
КонецПроцедуры

&НаКлиенте
Процедура ВитринаПриИзменении(Элемент)
	
	ФильтрВитрина();
	
КонецПроцедуры

