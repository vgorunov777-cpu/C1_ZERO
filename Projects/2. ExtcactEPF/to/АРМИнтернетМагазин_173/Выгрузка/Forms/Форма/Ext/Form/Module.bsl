КонецПроцедуры

&НаКлиенте
Процедура ВыгрузкаОстатковПеречитатьДанные()
	
	Если НЕ ЗначениеЗаполнено(ВыгрузкаОстатковМагазин) Тогда
		ВыгрузкаОстатковОстаток = 0;
		ВыгрузкаОстатковНКЗ = 0;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВыгрузкаОстатковНоменклатура) Тогда
		ВыгрузкаОстатковОстаток = 0;
		ВыгрузкаОстатковНКЗ = 0;
		ВыгрузкаОстатковСтатусАктивности = 0;
	КонецЕсли;
	
	ВыгрузкаОстатковПеречитатьДанныеНаСервере(ВыгрузкаОстатковМагазин, ВыгрузкаОстатковНоменклатура, ВыгрузкаОстатковОстаток, ВыгрузкаОстатковНКЗ, ВыгрузкаОстатковСтатусАктивности);
	
	СменаСегментаТекущийСегмент = ПолучитьСегментУзлаОбмена(СменаСегментаУзел);
	
КонецПроцедуры

&НаСервере
Процедура ВыгрузкаОстатковПеречитатьДанныеНаСервере(ПараметрМагазин, ПараметрНоменклатура, ВыходОстаток, ВыходНКЗ, ВыходСтатусАктивности)
	
	Если НЕ ЗначениеЗаполнено(ПараметрМагазин) Тогда
		Возврат;
	КонецЕсли;
	
	ПолучатьОстатки = Истина;
	ПолучатьСменаСегмента = Истина;
	
	Если НЕ ЗначениеЗаполнено(ПараметрНоменклатура) Тогда
		ПолучатьОстатки = Ложь;
	КонецЕсли;
	
	Если ПолучатьОстатки Тогда
		
		ТЗРезультатКомпоновщика = Новый ТаблицаЗначений;
		
		ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
		СКД = ОбработкаОбъект.ПолучитьМакет("ОстаткиМагазина");
		
		КомпоновщикНастроекТекущий = Новый КомпоновщикНастроекКомпоновкиДанных;
		АдресВХ = ПоместитьВоВременноеХранилище(СКД, Новый УникальныйИдентификатор);
		ИсточникНастроекТекущий = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресВХ);
		КомпоновщикНастроекТекущий.Инициализировать(ИсточникНастроекТекущий);
		КомпоновщикНастроекТекущий.ЗагрузитьНастройки(СКД.НастройкиПоУмолчанию);
		
		КомпоновщикНастроекТекущий.Настройки.Отбор.Элементы.Очистить();
		
		//номенклатура
		НовыйЭлементОтбора = КомпоновщикНастроекТекущий.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЛевоеЗначениеОтбора = Новый ПолеКомпоновкиДанных("Номенклатура");
		НовыйЭлементОтбора.ЛевоеЗначение = ЛевоеЗначениеОтбора;
		НовыйЭлементОтбора.Использование = Истина;
		НовыйЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлементОтбора.ПравоеЗначение = ПараметрНоменклатура;
		
		//Склад
		НовыйЭлементОтбора = КомпоновщикНастроекТекущий.Настройки.Отбор.Элементы.Добавить(Тип("ЭлементОтбораКомпоновкиДанных"));
		ЛевоеЗначениеОтбора = Новый ПолеКомпоновкиДанных("Склад");
		НовыйЭлементОтбора.ЛевоеЗначение = ЛевоеЗначениеОтбора;
		НовыйЭлементОтбора.Использование = Истина;
		НовыйЭлементОтбора.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
		НовыйЭлементОтбора.ПравоеЗначение = ПараметрМагазин;
		
		ПроцентУменьшенияОстаткаНаСайт = ОбщегоНазначенияСерверПовтИсп.ЗначениеКонстанты("ПроцентУменьшенияОстаткаНаСайт");
		ПроцентУменьшенияОстаткаНаСайт = ?(ПроцентУменьшенияОстаткаНаСайт = Неопределено, 0, ПроцентУменьшенияОстаткаНаСайт);
		ПараметрСКД = КомпоновщикНастроекТекущий.Настройки.ПараметрыДанных.Элементы.Найти("ПроцентУменьшенияОстаткаНаСайт");
		ПараметрСКД.Использование = Истина;
		ПараметрСКД.Значение = ПроцентУменьшенияОстаткаНаСайт;
		
		ПараметрСКД = КомпоновщикНастроекТекущий.Настройки.ПараметрыДанных.Элементы.Найти("ТекущаяДата");
		ПараметрСКД.Использование = Истина;
		ПараметрСКД.Значение = ТекущаяДата();
		
		НастройкаКомпоновки = КомпоновщикНастроекТекущий.ПолучитьНастройки();
		
		КомпоновщикМакета = Новый КомпоновщикМакетаКомпоновкиДанных;
		МакетКомпоновки = КомпоновщикМакета.Выполнить(СКД, НастройкаКомпоновки, , , Тип("ГенераторМакетаКомпоновкиДанныхДляКоллекцииЗначений"));
		
		ПроцессорКомпоновки = Новый ПроцессорКомпоновкиДанных;
		ПроцессорКомпоновки.Инициализировать(МакетКомпоновки);
		
		ПроцессорВыводаРезультата = Новый ПроцессорВыводаРезультатаКомпоновкиДанныхВКоллекциюЗначений;
		ПроцессорВыводаРезультата.УстановитьОбъект(ТЗРезультатКомпоновщика);
		ПроцессорВыводаРезультата.Вывести(ПроцессорКомпоновки);
		
		Для Каждого СтрокаТаблицы Из ТЗРезультатКомпоновщика Цикл
			Если СтрокаТаблицы.Номенклатура = ПараметрНоменклатура И СтрокаТаблицы.Склад = ПараметрМагазин Тогда
				ВыходОстаток = СтрокаТаблицы.ДоступныйОстаток;
				ВыходНКЗ = СтрокаТаблицы.НормативноеКоличествоЗапаса;
				ВыходСтатусАктивности = СтрокаТаблицы.СтатусАктивности;
				Прервать;
			КонецЕсли;
		КонецЦикла;
		
	КонецЕсли;
	
	////получение координат склада
	Если НЕ ЗначениеЗаполнено(КоординатыМагазин) Тогда
		КоординатыМагазин = ПараметрМагазин;
		КоординатыПеречитатьДанные(КоординатыМагазин);
	КонецЕсли;
	
	//смена сегмента
	Если ПолучатьСменаСегмента Тогда
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ОбменССайтом.Ссылка КАК Ссылка
		               |ИЗ
		               |	ПланОбмена.ОбменССайтом КАК ОбменССайтом
		               |ГДЕ
		               |	НЕ ОбменССайтом.ПометкаУдаления
		               |	И ОбменССайтом.ОбменТоварами
		               |	И ОбменССайтом.ВыгружатьНаСайт
		               |	И ОбменССайтом.Склад = &Склад
		               |	И ОбменССайтом.Витрина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.ЯрчеПлюс)
		               |	И ОбменССайтом.ИспользоватьРегламентныеЗадания";
		Запрос.УстановитьПараметр("Склад", ПараметрМагазин);
		РезультатЗапроса = Запрос.Выполнить();
		Если РезультатЗапроса.Пустой() Тогда
			СменаСегментаУзел = ПланыОбмена.ОбменССайтом.ПустаяСсылка();
		Иначе
			РезультатВыборка = РезультатЗапроса.Выбрать();
			РезультатВыборка.Следующий();
			СменаСегментаУзел = РезультатВыборка.Ссылка;
		КонецЕсли;
		
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузкаОстатковНоменклатураОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	ВыгрузкаОстатковПроверкаВыбораНаСервере(ВыбранноеЗначение, СтандартнаяОбработка);
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузкаОстатковМагазинОбработкаВыбора(Элемент, ВыбранноеЗначение, СтандартнаяОбработка)
	ВыгрузкаОстатковПроверкаВыбораНаСервере(ВыбранноеЗначение, СтандартнаяОбработка);
КонецПроцедуры

&НаСервере
Процедура ВыгрузкаОстатковПроверкаВыбораНаСервере(ВыбранноеЗначение, СтандартнаяОбработка)
	Если ЗначениеЗаполнено(ВыбранноеЗначение) Тогда
		Если ВыбранноеЗначение.ЭтоГруппа Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Выбор групп запрещен");
			СтандартнаяОбработка = Ложь;
		КонецЕсли;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузкаОстатовВыгрузитьНаСайт(Команда)
	
	Если НЕ ЗначениеЗаполнено(ВыгрузкаОстатковМагазин) Тогда
		ВыгрузкаОстатковОстаток = 0;
		ВыгрузкаОстатковНКЗ = 0;
		Возврат;
	КонецЕсли;
	
	Если НЕ ЗначениеЗаполнено(ВыгрузкаОстатковНоменклатура) Тогда
		ВыгрузкаОстатковОстаток = 0;
		ВыгрузкаОстатковНКЗ = 0;
		ВыгрузкаОстатковСтатусАктивности = 0;
		Возврат;
	КонецЕсли;
	
	ОписаниеРезультатаВыполнения = "";
	
	РезультатВыполнения = ВыгрузкаОстатковВыгрузитьНаСайтНаСервере(ВыгрузкаОстатковМагазин, ВыгрузкаОстатковНоменклатура, ВыгрузкаОстатковОстаток, ВыгрузкаОстатковНКЗ, ВыгрузкаОстатковСтатусАктивности, ОписаниеРезультатаВыполнения);
	
	Если РезультатВыполнения = Ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка!");
	КонецЕсли;
	ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ОписаниеРезультатаВыполнения);
	
КонецПроцедуры

&НаСервере
Функция ВыгрузкаОстатковВыгрузитьНаСайтНаСервере(ПараметрМагазин, ПараметрНоменклатура, ПараметрОстаток, ПараметрНКЗ, ПараметрСтатусАктивности, ВыходОписаниеРезультата)
	
	Если НЕ ЗначениеЗаполнено(ПараметрМагазин) Тогда
		ВыходОписаниеРезультата = "Магазин не заполнено";
		Возврат Ложь;
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(ПараметрНоменклатура) Тогда
		ВыходОписаниеРезультата = "Номенклатура не заполнено";
		Возврат Ложь;
	КонецЕсли;
	
	ТЗ_ИсходныеДанные = Новый ТаблицаЗначений;
	ТЗ_ИсходныеДанные.Колонки.Добавить("СкладУзла"						, Новый ОписаниеТипов("СправочникСсылка.Склады"));
	ТЗ_ИсходныеДанные.Колонки.Добавить("Номенклатура"					, Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
	ТЗ_ИсходныеДанные.Колонки.Добавить("НормативноеКоличествоЗапаса"	, Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15,3)));
	ТЗ_ИсходныеДанные.Колонки.Добавить("СтатусАктивности"				, Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(10,0)));
	ТЗ_ИсходныеДанные.Колонки.Добавить("ОстатокНаСкладе"				, Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15,3)));
	
	ТекущийУзелСайта = ПланыОбмена.ОбменССайтом.ПустаяСсылка();
	
	РезультатВыполнения = Истина;
	
	ВнешнийМодуль	= Неопределено;
	ИмяФайла		= Неопределено;
	
	СтруктураПараметров = Новый Структура;
	СтруктураПараметров.Вставить("ВнешнийМодульНаименование",		"ИМ выгрузка произвольных пакетов предложений");
	СтруктураПараметров.Вставить("Метод",							"ВыгрузкаПроизвольногоПакетаПредложений");

	ВнешнийМодульРаботаСWebПолучениеДанных.ВыполнитьМетодВнешнейОбработки(ВнешнийМодуль, "МетодыВнешнегоМодуля", СтруктураПараметров, ИмяФайла); 
			
	Если СтруктураПараметров.Результат = Ложь Тогда
		ВыходОписаниеРезультата = "Ошибка подключаемого модуля";
		Возврат Ложь;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ОбменССайтом.Ссылка
		|ИЗ
		|	ПланОбмена.ОбменССайтом КАК ОбменССайтом
		|ГДЕ
		|	ОбменССайтом.Склад = &Склад
		|	И ОбменССайтом.ОбменТоварами = ИСТИНА";
	Запрос.УстановитьПараметр("Склад", ПараметрМагазин);
	Результат = Запрос.Выполнить();
	Если Результат.Пустой() Тогда
		ВыходОписаниеРезультата = "Для магазина не определен узел сайта";
		Возврат Ложь;
	КонецЕсли;
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		
		ТекущийУзелСайта = ВыборкаДетальныеЗаписи.Ссылка;		
		
		Если НЕ ЗначениеЗаполнено(ТекущийУзелСайта) Тогда
			ВыходОписаниеРезультата = ВыходОписаниеРезультата + ?(ПустаяСтрока(ВыходОписаниеРезультата), "", Символы.ПС) + "Ошибка получения узла сайта";
			Продолжить;
		КонецЕсли;	

		ТЗ_ИсходныеДанные.Очистить();
		
		НС = ТЗ_ИсходныеДанные.Добавить();
		НС.СкладУзла = ПараметрМагазин;
		НС.Номенклатура = ПараметрНоменклатура;
		НС.НормативноеКоличествоЗапаса = ПараметрНКЗ;
		НС.СтатусАктивности = ПараметрСтатусАктивности;
		НС.ОстатокНаСкладе = ПараметрОстаток;
	
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ТЗИсходныеДанные", 				ТЗ_ИсходныеДанные);
		СтруктураПараметров.Вставить("ТекущийУзел", 					ТекущийУзелСайта);
		СтруктураПараметров.Вставить("Метод",							"ВыгрузкаПроизвольногоПакетаПредложений");
		СтруктураПараметров.Вставить("ВнешнийМодульНаименование",		"ИМ выгрузка произвольных пакетов предложений");
			
		ВнешнийМодульРаботаСWebПолучениеДанных.ВыполнитьМетодВнешнейОбработки(ВнешнийМодуль, СтруктураПараметров.Метод, СтруктураПараметров);
		РезультатВыполнения = ?(РезультатВыполнения = Ложь, Ложь, СтруктураПараметров.Результат);
		ВыходОписаниеРезультата = ВыходОписаниеРезультата + ?(ПустаяСтрока(ВыходОписаниеРезультата), "", Символы.ПС) + СтруктураПараметров.ОписаниеОшибки;
		
	КонецЦикла;
	
	ВнешнийМодульРаботаСWebПолучениеДанных.УдалитьФайлПодключенногоМодуля(ИмяФайла);
	
	Возврат РезультатВыполнения;
	
КонецФункции

&НаКлиенте
Процедура ВыгрузкаОстатковПодобратьПоШтрихкоду(Команда)
	
	ВведенноеЗначениеШК = "";
	МассивНоменклатур = Новый Массив;
	
	Если ВвестиСтроку(ВведенноеЗначениеШК, "Штрихкод номенклатуры:", 25, Ложь) Тогда
		МассивНоменклатур = ПолучитьНоменклатуруПоШтрихкоду(ВведенноеЗначениеШК);
		КоличествоНоменклатур = МассивНоменклатур.Количество();
		Если КоличествоНоменклатур = 0 Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Номенклатура с штрихкодом "+ВведенноеЗначениеШК+" не найдена");
		ИначеЕсли КоличествоНоменклатур = 1 Тогда
			ВыгрузкаОстатковНоменклатура = МассивНоменклатур[0];
		Иначе
			СписокНоменклатур = Новый СписокЗначений;
			СписокНоменклатур.ЗагрузитьЗначения(МассивНоменклатур);
			ВыбранныйЭлемент = СписокНоменклатур.ВыбратьЭлемент("Выберите номенклатуру:");
			Если ВыбранныйЭлемент = Неопределено Тогда
				Возврат;
			КонецЕсли;
			ВыгрузкаОстатковНоменклатура = ВыбранныйЭлемент.Значение;
		КонецЕсли;
	КонецЕсли;
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция ПолучитьНоменклатуруПоШтрихкоду(ВведенноеЗначениеШК)
	
	МассивНоменклатур = новый Массив;
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ РАЗЛИЧНЫЕ
		|	ШтрихкодыНоменклатуры.Номенклатура КАК Номенклатура
		|ИЗ
		|	РегистрСведений.ШтрихкодыНоменклатуры КАК ШтрихкодыНоменклатуры
		|ГДЕ
		|	ШтрихкодыНоменклатуры.Штрихкод = &Штрихкод";
	Запрос.УстановитьПараметр("Штрихкод", ВведенноеЗначениеШК);
	ТЗ_Результат = Запрос.Выполнить().Выгрузить();
    МассивНоменклатур = ТЗ_Результат.ВыгрузитьКолонку("Номенклатура");

	Возврат МассивНоменклатур;
		
КонецФункции

&НаКлиенте
Процедура ПерезаполнитьТаблицуИнтернетМагазины(Команда)
	ПерезаполнитьТаблицуИнтернетМагазиныНаСервере();
КонецПроцедуры

&НаКлиенте
Процедура ЗаписатьКоординатыСклада(Команда)
	
	Если ПустаяСтрока(Широта) ИЛИ ПустаяСтрока(Долгота) Тогда
		Возврат;
	КонецЕсли;
	
	Широта = СокрЛП(Широта);
	Долгота = СокрЛП(Долгота);
	
	ОшибкаШирота = Ложь;
	Попытка
		ШиротаЧисло = Число(Широта);
	Исключение  
		ОшибкаШирота = Истина;
	КонецПопытки;
	
	ДобавочнаяСтрока = "";
	Для Сч = 1 По СтрДлина(Широта) - СтрДлина(Формат(ШиротаЧисло, "ЧРД=.; ЧГ=0")) Цикл
		ДобавочнаяСтрока = ДобавочнаяСтрока + "0";
	КонецЦикла;
	
	Если Формат(ШиротаЧисло, "ЧРД=.; ЧГ=0")+ДобавочнаяСтрока <> Широта Тогда
		ОшибкаШирота = Истина;
	КонецЕсли;
	
	Если ОшибкаШирота Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Неверный формат поля Широта");
	КонецЕсли;
	
	ОшибкаДолгота = Ложь;
	Попытка
		ДолготаЧисло = Число(Долгота);
	Исключение
		ОшибкаДолгота = Истина;
	КонецПопытки;
	
	ДобавочнаяСтрока = "";
	Для Сч = 1 По СтрДлина(Долгота) - СтрДлина(Формат(ДолготаЧисло, "ЧРД=.; ЧГ=0")) Цикл
		ДобавочнаяСтрока = ДобавочнаяСтрока + "0";
	КонецЦикла;
	
	Если Формат(ДолготаЧисло, "ЧРД=.; ЧГ=0")+ДобавочнаяСтрока <> Долгота Тогда
		ОшибкаДолгота = Истина;
	КонецЕсли;
	
	Если ОшибкаДолгота Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Неверный формат поля Долгота");
	КонецЕсли;
	
	Если Не ОшибкаШирота И Не ОшибкаДолгота Тогда
		ЗаписатьКоординатыСкладаНаСервере();
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаписатьКоординатыСкладаНаСервере()
	
	УстановитьПривилегированныйРежим(Истина);
	Попытка
		СкладОбъект = КоординатыМагазин.ПолучитьОбъект();
		//Широта
		НайденныеСвойства = СкладОбъект.ДополнительныеРеквизиты.НайтиСтроки(Новый Структура("Свойство", СвойствоШиротаСклада));
		Если НайденныеСвойства.Количество() = 0 Тогда
			НС = СкладОбъект.ДополнительныеРеквизиты.Добавить();
			НС.Свойство = СвойствоШиротаСклада;
			НС.Значение = Широта; 
		Иначе
			Для Каждого НайденноеСвойство Из НайденныеСвойства Цикл
				НайденноеСвойство.Значение = Широта;
			КонецЦикла;
		КонецЕсли;
		//Долгота
		НайденныеСвойства = СкладОбъект.ДополнительныеРеквизиты.НайтиСтроки(Новый Структура("Свойство", СвойствоДолготаСклада));
		Если НайденныеСвойства.Количество() = 0 Тогда
			НС = СкладОбъект.ДополнительныеРеквизиты.Добавить();
			НС.Свойство = СвойствоДолготаСклада;
			НС.Значение = Долгота; 
		Иначе
			Для Каждого НайденноеСвойство Из НайденныеСвойства Цикл
				НайденноеСвойство.Значение = Долгота;
			КонецЦикла;
		КонецЕсли;
		//Координаты
		НайденныеСвойства = СкладОбъект.ДополнительныеРеквизиты.НайтиСтроки(Новый Структура("Свойство", СвойствоКоординатыГугл));
		Если НайденныеСвойства.Количество() = 0 Тогда
			НС = СкладОбъект.ДополнительныеРеквизиты.Добавить();
			НС.Свойство = СвойствоКоординатыГугл;
			НС.Значение = Широта + "," + Долгота; 
		Иначе
			Для Каждого НайденноеСвойство Из НайденныеСвойства Цикл
				НайденноеСвойство.Значение = Широта + "," + Долгота; 
			КонецЦикла;
		КонецЕсли;
		СкладОбъект.Записать();
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Координаты склада успешно записаны");
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка записи координат склада" + ОписаниеОшибки());
		ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,"Ошибка записи координат склада" + Символы.пс + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

&НаКлиенте
Процедура СменитьСегментТоваровУзла(Команда)
	
	ТекстОшибки = "";
	Если НЕ ЗначениеЗаполнено(СменаСегментаУзел) Тогда
		ТекстОшибки = ТекстОшибки + ?(ПустаяСтрока(ТекстОшибки), "", Символы.ПС) + "Узел обмена не заполнен";
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(СменаСегментаТекущийСегмент) Тогда
		ТекстОшибки = ТекстОшибки + ?(ПустаяСтрока(ТекстОшибки), "", Символы.ПС) + "Текущий сегмент не заполнен";
	КонецЕсли;
	Если НЕ ЗначениеЗаполнено(СменаСегментаЦелевойСегмент) Тогда
		ТекстОшибки = ТекстОшибки + ?(ПустаяСтрока(ТекстОшибки), "", Символы.ПС) + "Целевой сегмент не выбран";
	КонецЕсли;
	Если ЗначениеЗаполнено(СменаСегментаТекущийСегмент)
		И ЗначениеЗаполнено(СменаСегментаЦелевойСегмент)
		И СменаСегментаТекущийСегмент = СменаСегментаЦелевойСегмент Тогда
		ТекстОшибки = ТекстОшибки + ?(ПустаяСтрока(ТекстОшибки), "", Символы.ПС) + "Текущий сегмент равен Целевому сегменту";
	КонецЕсли;
	
	Если НЕ ПустаяСтрока(ТекстОшибки) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстОшибки);
		Возврат;
	КонецЕсли;
	
	Результат = СменитьСегментТоваровУзлаНаСервере();
	
	Если Результат Тогда
		СменаСегментаТекущийСегмент = ПолучитьСегментУзлаОбмена(СменаСегментаУзел); 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Смена сегмента выполнена успешно!");
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("ОШИБКА: Попробуйте еще раз");
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СменитьСегментТоваровУзлаНаСервере()
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		ЗаписатьВУзелОбменаОтборПоСегменту(СменаСегментаЦелевойСегмент, СменаСегментаУзел);
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка смены сегмента:" + Символы.ПС + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,"Смена сегмента" + Символы.ПС + "Ошибка смены сегмента:" + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Ложь;
	КонецПопытки;
	
	//Сравниваем сегменты
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	НоменклатураСегмента.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ВТ_сегмент1
	               |ИЗ
	               |	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	               |ГДЕ
	               |	НоменклатураСегмента.Сегмент = &Сегмент1
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	НоменклатураСегмента.Номенклатура КАК Номенклатура
	               |ПОМЕСТИТЬ ВТ_сегмент2
	               |ИЗ
	               |	РегистрСведений.НоменклатураСегмента КАК НоменклатураСегмента
	               |ГДЕ
	               |	НоменклатураСегмента.Сегмент = &Сегмент2
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_сегмент1.Номенклатура КАК Номенклатура,
	               |	ЕСТЬNULL(ДополнительныеСведения.Значение, 0) КАК СтатусАктивности,
	               |	ЕСТЬNULL(ТоварныеОграничения.НормативноеКоличествоЗапаса, 0) КАК Норма
	               |ИЗ
	               |	ВТ_сегмент1 КАК ВТ_сегмент1
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_сегмент2 КАК ВТ_сегмент2
	               |		ПО ВТ_сегмент1.Номенклатура = ВТ_сегмент2.Номенклатура
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДополнительныеСведения
	               |		ПО ВТ_сегмент1.Номенклатура = ДополнительныеСведения.Объект
	               |			И (ДополнительныеСведения.Свойство = &СвойствоСтатусАктивности)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ТоварныеОграничения КАК ТоварныеОграничения
	               |		ПО ВТ_сегмент1.Номенклатура = ТоварныеОграничения.Номенклатура
	               |			И (ТоварныеОграничения.Склад = &Склад)
	               |ГДЕ
	               |	ВТ_сегмент2.Номенклатура ЕСТЬ NULL
	               |;
	               |
	               |////////////////////////////////////////////////////////////////////////////////
	               |ВЫБРАТЬ
	               |	ВТ_сегмент2.Номенклатура КАК Номенклатура
	               |ИЗ
	               |	ВТ_сегмент2 КАК ВТ_сегмент2
	               |		ЛЕВОЕ СОЕДИНЕНИЕ ВТ_сегмент1 КАК ВТ_сегмент1
	               |		ПО (ВТ_сегмент1.Номенклатура = ВТ_сегмент2.Номенклатура)
	               |ГДЕ
	               |	ВТ_сегмент1.Номенклатура ЕСТЬ NULL";
	
	Запрос.УстановитьПараметр("Сегмент1", СменаСегментаТекущийСегмент);
	Запрос.УстановитьПараметр("Сегмент2", СменаСегментаЦелевойСегмент);
	Запрос.УстановитьПараметр("СвойствоСтатусАктивности", СвойствоСтатусАктивности);
	Запрос.УстановитьПараметр("Склад", ВыгрузкаОстатковМагазин);
	
	Запрос.МенеджерВременныхТаблиц = Новый МенеджерВременныхТаблиц;
	
	РезультатЗапроса = Запрос.ВыполнитьПакет();
	ТаблицаТоваровКЗанулению = РезультатЗапроса[2].Выгрузить();
	ТаблицаТоваровКРегистрации = РезультатЗапроса[3].Выгрузить();
	
	//Регистрируем номенклаутры в узел
	Если ТаблицаТоваровКРегистрации.Количество() > 0 Тогда
		Попытка
			Для Каждого СтрокаТаблицы Из ТаблицаТоваровКРегистрации Цикл
				ПланыОбмена.ЗарегистрироватьИзменения(СменаСегментаУзел, СтрокаТаблицы.Номенклатура);
			КонецЦикла;
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка регистрации номенклатур в обмен: " + Символы.ПС + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,"Смена сегмента" + Символы.ПС + "Ошибка регистрации номенклатур в обмен:" + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
			Возврат Ложь;
		КонецПопытки;
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Зарегистрировано в обмен: " + ТаблицаТоваровКРегистрации.Количество());
	КонецЕсли;
	
	//Зануляем номенклатуры
	Если ТаблицаТоваровКЗанулению.Количество() > 0 Тогда
		
		ТЗ_ИсходныеДанные = Новый ТаблицаЗначений;
		ТЗ_ИсходныеДанные.Колонки.Добавить("СкладУзла"						, Новый ОписаниеТипов("СправочникСсылка.Склады"));
		ТЗ_ИсходныеДанные.Колонки.Добавить("Номенклатура"					, Новый ОписаниеТипов("СправочникСсылка.Номенклатура"));
		ТЗ_ИсходныеДанные.Колонки.Добавить("НормативноеКоличествоЗапаса"	, Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15,3)));
		ТЗ_ИсходныеДанные.Колонки.Добавить("СтатусАктивности"				, Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(10,0)));
		ТЗ_ИсходныеДанные.Колонки.Добавить("ОстатокНаСкладе"				, Новый ОписаниеТипов("Число",Новый КвалификаторыЧисла(15,3)));
		
		РезультатВыполнения = Истина;
		ВнешнийМодуль	= Неопределено;
		ИмяФайла		= Неопределено;
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ВнешнийМодульНаименование",		"ИМ выгрузка произвольных пакетов предложений");
		СтруктураПараметров.Вставить("Метод",							"ВыгрузкаПроизвольногоПакетаПредложений");
		
		ВнешнийМодульРаботаСWebПолучениеДанных.ВыполнитьМетодВнешнейОбработки(ВнешнийМодуль, "МетодыВнешнегоМодуля", СтруктураПараметров, ИмяФайла);
		
		Если СтруктураПараметров.Результат = Ложь Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка зануления номенклатур: Ошибка подключаемого модуля");
			ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,"Смена сегмента" + Символы.ПС + "Ошибка зануления номенклатур: Ошибка подключаемого модуля");
			Возврат Ложь;
		КонецЕсли;
		
		ТЗ_ИсходныеДанные.Очистить();
		
		Для Каждого СтрокаТаблицы Из ТаблицаТоваровКЗанулению Цикл
			
			НС = ТЗ_ИсходныеДанные.Добавить();
			НС.СкладУзла = ВыгрузкаОстатковМагазин;
			НС.Номенклатура = СтрокаТаблицы.Номенклатура;
			НС.НормативноеКоличествоЗапаса = СтрокаТаблицы.Норма;
			НС.СтатусАктивности = СтрокаТаблицы.СтатусАктивности;
			НС.ОстатокНаСкладе = 0;
			
		КонецЦикла;
		
		СтруктураПараметров = Новый Структура;
		СтруктураПараметров.Вставить("ТЗИсходныеДанные", 				ТЗ_ИсходныеДанные);
		СтруктураПараметров.Вставить("ТекущийУзел", 					СменаСегментаУзел);
		СтруктураПараметров.Вставить("Метод",							"ВыгрузкаПроизвольногоПакетаПредложений");
		СтруктураПараметров.Вставить("ВнешнийМодульНаименование",		"ИМ выгрузка произвольных пакетов предложений");
			
		ВнешнийМодульРаботаСWebПолучениеДанных.ВыполнитьМетодВнешнейОбработки(ВнешнийМодуль, СтруктураПараметров.Метод, СтруктураПараметров);
		Если НЕ СтруктураПараметров.Результат Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка зануления номенклатур: " + Символы.ПС + СтруктураПараметров.ОписаниеОшибки);
			ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,"Смена сегмента" + Символы.ПС + "Ошибка зануления номенклатур: " + Символы.ПС + СтруктураПараметров.ОписаниеОшибки);
			Возврат Ложь;
		КонецЕсли;
		
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Занулено номенклатур: " + ТаблицаТоваровКЗанулению.Количество());
		
		ВнешнийМодульРаботаСWebПолучениеДанных.УдалитьФайлПодключенногоМодуля(ИмяФайла);
		
	КонецЕсли;
	
	Возврат Истина;

КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьСегментУзлаОбмена(УзелОбмена)
	
	Если ЗначениеЗаполнено(УзелОбмена) = Ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Узел обмена не определен");
		Возврат Справочники.СегментыНоменклатуры.ПустаяСсылка();
	КонецЕсли;
	
	Попытка
		РеквизитыУзла = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(УзелОбмена, "СохраненнаяТаблицаКаталогов, РежимВыгрузки");
		ТаблицаКаталогов = РеквизитыУзла.СохраненнаяТаблицаКаталогов.Получить();
	Исключение
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Ошибка получения текущего сегмента узла" + Символы.ПС + КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,"Смена сегмента" + Символы.ПС + "Ошибка получения текущего сегмента узла" + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Справочники.СегментыНоменклатуры.ПустаяСсылка();
	КонецПопытки;
	
	Для Каждого ТекущаяСтрокаТаблицыКаталогов Из ТаблицаКаталогов Цикл
		
		Если ТекущаяСтрокаТаблицыКаталогов = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если РеквизитыУзла.РежимВыгрузки = 2 Тогда
			ЗначениеХранилищеНастроекПакетПредложений = ТекущаяСтрокаТаблицыКаталогов.ХранилищеНастроекПакетПредложений.Получить();
		ИначеЕсли РеквизитыУзла.РежимВыгрузки = 0 Тогда
			ЗначениеХранилищеНастроекПакетПредложений = ТекущаяСтрокаТаблицыКаталогов.ХранилищеНастроекКаталогПакет.Получить();
		Иначе
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеХранилищеНастроекПакетПредложений = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьНеобходимыйЭлементВОтборе = Ложь;
		ПКДСегмент = новый ПолеКомпоновкиДанных("СегментНоменклатуры");
		Для Каждого ЭлементОтбораСтрокиКаталога Из ЗначениеХранилищеНастроекПакетПредложений.Отбор.Элементы Цикл
			
			Если ЭлементОтбораСтрокиКаталога.ЛевоеЗначение = ПКДСегмент 
				И ЭлементОтбораСтрокиКаталога.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно 
				И ЭлементОтбораСтрокиКаталога.Использование = Истина Тогда
				
				Возврат ЭлементОтбораСтрокиКаталога.ПравоеЗначение;
				
			КонецЕсли;
			
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Справочники.СегментыНоменклатуры.ПустаяСсылка();
	
КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьВУзелОбменаОтборПоСегменту(Сегмент, УзелОбмена)
	
	Если ЗначениеЗаполнено(Сегмент) = Ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Сегмент не выбран");
		Возврат;
	КонецЕсли;
	
	Если ЗначениеЗаполнено(УзелОбмена) = Ложь Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Узел обмена не определен");
		Возврат;
	КонецЕсли;
	
	УзелОбменаОбъект = УзелОбмена.ПолучитьОбъект();
	
	ТаблицаКаталогов = УзелОбменаОбъект.СохраненнаяТаблицаКаталогов.Получить();
	Для Каждого ТекущаяСтрокаТаблицыКаталогов Из ТаблицаКаталогов Цикл
		
		Если ТекущаяСтрокаТаблицыКаталогов = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		Если УзелОбменаОбъект.РежимВыгрузки = 2 Тогда
			ЗначениеХранилищеНастроекПакетПредложений = ТекущаяСтрокаТаблицыКаталогов.ХранилищеНастроекПакетПредложений.Получить();
		ИначеЕсли УзелОбменаОбъект.РежимВыгрузки = 0 Тогда
			ЗначениеХранилищеНастроекПакетПредложений = ТекущаяСтрокаТаблицыКаталогов.ХранилищеНастроекКаталогПакет.Получить();
		Иначе
			Продолжить;
		КонецЕсли;
		
		Если ЗначениеХранилищеНастроекПакетПредложений = Неопределено Тогда
			Продолжить;
		КонецЕсли;
		
		ЕстьНеобходимыйЭлементВОтборе = Ложь;
		ПКДСегмент = новый ПолеКомпоновкиДанных("СегментНоменклатуры");
		Для Каждого ЭлементОтбораСтрокиКаталога Из ЗначениеХранилищеНастроекПакетПредложений.Отбор.Элементы Цикл
			
			Если ЭлементОтбораСтрокиКаталога.ЛевоеЗначение = ПКДСегмент 
				И ЭлементОтбораСтрокиКаталога.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно 
				И ЭлементОтбораСтрокиКаталога.Использование = Истина Тогда
				
				ЕстьНеобходимыйЭлементВОтборе = Истина;
				ЭлементОтбораСтрокиКаталога.ПравоеЗначение = Сегмент;
				
			КонецЕсли;
			
			Если ЕстьНеобходимыйЭлементВОтборе Тогда
				Прервать;  //уже добавили в одно из условий, остальные не смотрим
			КонецЕсли;
				
		КонецЦикла;
		
		Если УзелОбменаОбъект.РежимВыгрузки = 2 Тогда
			ТекущаяСтрокаТаблицыКаталогов.ХранилищеНастроекПакетПредложений = Новый ХранилищеЗначения(ЗначениеХранилищеНастроекПакетПредложений);
		ИначеЕсли УзелОбменаОбъект.РежимВыгрузки = 0 Тогда
			ТекущаяСтрокаТаблицыКаталогов.ХранилищеНастроекКаталогПакет = Новый ХранилищеЗначения(ЗначениеХранилищеНастроекПакетПредложений);	
		Иначе
			Продолжить;
		КонецЕсли;
		
	КонецЦикла;
	
	УзелОбменаОбъект.СохраненнаяТаблицаКаталогов = Новый ХранилищеЗначения(ТаблицаКаталогов);
	УзелОбменаОбъект.Записать();
	
КонецПроцедуры

&НаКлиенте
Процедура КоординатыМагазинПриИзменении(Элемент)
	КоординатыПеречитатьДанные(КоординатыМагазин);
КонецПроцедуры

&НаСервере
Процедура КоординатыПеречитатьДанные(ПараметрМагазин)
	
	Если НЕ ЗначениеЗаполнено(ПараметрМагазин) Тогда
		Широта = "";
		Долгота = "";
		Возврат;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Склады.Ссылка КАК Склад,
	               |	МАКСИМУМ(ЕСТЬNULL(ДР_Долгота.Значение, """")) КАК Долгота,
	               |	МАКСИМУМ(ЕСТЬNULL(ДР_Широта.Значение, """")) КАК Широта
	               |ИЗ
	               |	Справочник.Склады КАК Склады
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.ДополнительныеРеквизиты КАК ДР_Широта
	               |		ПО Склады.Ссылка = ДР_Широта.Ссылка
	               |			И (ДР_Широта.Свойство = &СвойствоШирота)
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.ДополнительныеРеквизиты КАК ДР_Долгота
	               |		ПО Склады.Ссылка = ДР_Долгота.Ссылка
	               |			И (ДР_Долгота.Свойство = &СвойствоДолгота)
	               |ГДЕ
	               |	Склады.Ссылка = &Склад
	               |
	               |СГРУППИРОВАТЬ ПО
	               |	Склады.Ссылка";
	
	Запрос.УстановитьПараметр("СвойствоДолгота", СвойствоДолготаСклада);
	Запрос.УстановитьПараметр("СвойствоШирота", СвойствоШиротаСклада);
	Запрос.УстановитьПараметр("Склад", ПараметрМагазин);
	
	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл 
		Широта = СокрЛП(ВыборкаДетальныеЗаписи.Широта);
		Долгота = СокрЛП(ВыборкаДетальныеЗаписи.Долгота);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура ПолучитьТекущуюДатуЗапускаРоботаОтменыЗаказов()
	
	Если НЕ ПустаяСтрока(УИДРоботаОтменыЗаказов) Тогда
		УстановитьПривилегированныйРежим(Истина);
		Попытка
			РегламентноеЗаданиеGUID = Новый УникальныйИдентификатор(УИДРоботаОтменыЗаказов);
			РЗ = РегламентныеЗадания.НайтиПоУникальномуИдентификатору(РегламентноеЗаданиеGUID);
			Если НЕ РЗ = Неопределено Тогда
				РасписаниеРЗ = РЗ.Расписание;
				Если ЗначениеЗаполнено(РасписаниеРЗ.ДатаНачала) Тогда 
					Элементы.ДекорацияТекущееСостояниеРоботаОтменыЗаказов.Заголовок = НСтр("ru = 'Робот выполняется с '") + Формат(РасписаниеРЗ.ДатаНачала, "ДФ=dd.MM.yyyy");
				Иначе
					Элементы.ДекорацияТекущееСостояниеРоботаОтменыЗаказов.Заголовок = НСтр("ru = 'Робот выполняется с '") + Формат(Дата(2025,1,1), "ДФ=dd.MM.yyyy");
				КонецЕсли;
			Иначе
				Элементы.ДекорацияТекущееСостояниеРоботаОтменыЗаказов.Заголовок = НСтр("ru = 'Расписание не установлено'");
			КонецЕсли;
		Исключение
			Элементы.ДекорацияТекущееСостояниеРоботаОтменыЗаказов.Заголовок = НСтр("ru = 'Расписание не установлено'");
			ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,СтрШаблон(НСтр("ru = 'Ошибка получения расписания робота отмены заказов: 
                                                                                              |%1'"), ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));

		КонецПопытки;
		УстановитьПривилегированныйРежим(Ложь);
	Иначе
		Элементы.ДекорацияТекущееСостояниеРоботаОтменыЗаказов.Заголовок = НСтр("ru = 'Расписание не установлено'");
	КонецЕсли;
	
КонецПроцедуры

&НаКлиенте
Процедура ИзменитьДатуСЗапускаРоботаОтменыЗаказов(Команда)
	
	Если НЕ ЗначениеЗаполнено(ДатаЗапускаРоботаОтменыЗаказовС) Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Не указана дата начала выполнения'"));
		Возврат;
	КонецЕсли;
	
	ИзменитьДатуСЗапускаРоботаОтменыЗаказовНаСервере(ДатаЗапускаРоботаОтменыЗаказовС, УИДРоботаОтменыЗаказов);
	ПолучитьТекущуюДатуЗапускаРоботаОтменыЗаказов();
	
КонецПроцедуры

&НаСервереБезКонтекста
Процедура ИзменитьДатуСЗапускаРоботаОтменыЗаказовНаСервере(ДатаЗапускаРоботаОтменыЗаказовС, УИДРоботаОтменыЗаказов)
	
	Если НЕ ПустаяСтрока(УИДРоботаОтменыЗаказов) Тогда
		УстановитьПривилегированныйРежим(Истина);
		Попытка
			РегламентноеЗаданиеGUID = Новый УникальныйИдентификатор(УИДРоботаОтменыЗаказов);
			РЗ = РегламентныеЗадания.НайтиПоУникальномуИдентификатору(РегламентноеЗаданиеGUID);
			Если НЕ РЗ = Неопределено Тогда
				РасписаниеРЗ = РЗ.Расписание;
				РасписаниеРЗ.ДатаНачала = ДатаЗапускаРоботаОтменыЗаказовС;
				РегламентныеЗаданияСервер.УстановитьРасписаниеРегламентногоЗаданияИзСтруктуры(РегламентноеЗаданиеGUID, РасписаниеРЗ);
			Иначе
				ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Ошибка изменения расписания: регламеное задание не найдено'"));
			КонецЕсли;
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СтрШаблон(НСтр("ru = 'Ошибка изменения расписания: 
                                                                                              |%1'"), КраткоеПредставлениеОшибки(ИнформацияОбОшибке())));
			ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,СтрШаблон(НСтр("ru = 'Ошибка изменения расписания: 
                                                                                              |%1'"), ПодробноеПредставлениеОшибки(ИнформацияОбОшибке())));
		КонецПопытки;
		УстановитьПривилегированныйРежим(Ложь);
	Иначе
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(НСтр("ru = 'Ошибка изменения расписания: регламеное задание не найдено'"));
	КонецЕсли;


КонецПроцедуры

#КонецОбласти



 #Область ИзменитьПриложениеСборщика

&НаКлиенте
Процедура УстановитьСборку1С(Команда)
	ОтветПользователя = Вопрос(НСтр("ru = 'Вы действительно хотите изменить приложение для сборки выделенных заказов на 1С?'"), РежимДиалогаВопрос.ДаНет);
	Если ОтветПользователя = КодВозвратаДиалога.Да Тогда
		Для Каждого Стр Из Элементы.Заказы.ВыделенныеСтроки Цикл
			УстановитьПриложениеСборщикаНаСервере(Стр, 0);
		КонецЦикла;
	КонецЕсли;
	ОбновитьОтображение();
КонецПроцедуры

&НаКлиенте
Процедура УстановитьСборкуМП(Команда)
	ОтветПользователя = Вопрос(НСтр("ru = 'Вы действительно хотите изменить приложение для сборки выделенных заказов на МП Сборщик?'"), РежимДиалогаВопрос.ДаНет);
	Если ОтветПользователя = КодВозвратаДиалога.Да Тогда
		Для Каждого Стр Из Элементы.Заказы.ВыделенныеСтроки Цикл
			УстановитьПриложениеСборщикаНаСервере(Стр, 1);
		КонецЦикла;
	КонецЕсли;
	ОбновитьОтображение();
КонецПроцедуры

&НаСервере
Процедура УстановитьПриложениеСборщикаНаСервере(ЗаказСсылка, ПриложениеСборщика)
	
	НаименованиеПриложениеСборщика = ?(ПриложениеСборщика = 0, "1С", "МП Сборщик");
	РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ЗаказСсылка, "НомерЗаказаНаСайте, ВитринаИнтернетМагазина, ПриложениеСборщика, Статус");
	
	Если Не РеквизитыЗаказа.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.ЯрчеПлюс Тогда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + РеквизитыЗаказа.НомерЗаказаНаСайте + " не является заказом ЯрчеПлюс" + Символы.ПС + "Изменение приложения для сборки невозможно");
		Возврат;
	КонецЕсли;
	
	Если ПриложениеСборщика = 1 Тогда
		Если Не РеквизитыЗаказа.Статус = Перечисления.СтатусыЗаказовКлиентов.Согласован Тогда
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Заказ " + РеквизитыЗаказа.НомерЗаказаНаСайте + " не в статусе ""Новый""" + Символы.ПС + "Изменение приложения для сборки невозможно");
			Возврат;
		КонецЕсли;
	ИначеЕсли ПриложениеСборщика = 0 Тогда
		//проверку на состояние заказа не делаю, на 1С можно переключить в любом состоянии	
	КонецЕсли;
	
	Если РеквизитыЗаказа.ПриложениеСборщика = ПриложениеСборщика Тогда
		Возврат;
	КонецЕсли;
	
	УстановитьПривилегированныйРежим(Истина);
	
	Попытка
		Заказ = ЗаказСсылка.ПолучитьОбъект();
		Заказ.ПриложениеСборщика = ПриложениеСборщика;
		Заказ.Комментарий = Заказ.Комментарий + ?(ЗначениеЗаполнено(Заказ.Комментарий), Символы.ПС, "") 
												+ СтрШаблон(НСтр("ru = 'Передан на сборку ""%1"" - %2 %3'"), НаименованиеПриложениеСборщика, Строка(ПараметрыСеанса.ТекущийПользователь), Формат(ТекущаяДата(),"ДФ='dd.MM.yyyy HH:mm'"));
		Заказ.ДополнительныеСвойства.Вставить("ОтключитьМеханизмБлокировкиОтгруженныхДокументов", Истина);
		Заказ.ДополнительныеСвойства.Вставить("НеКонтролироватьРезультатыПроведения", Истина);
		Заказ.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
		Заказ.Записать(РежимЗаписиДокумента.Проведение);
	Исключение
		СообщениеОбОшибке = СтрШаблон(НСтр("ru = 'Ошибка изменения приложения для сборки заказа %1 на ""%2"" через АРМ ИМ: %3'"), РеквизитыЗаказа.НомерЗаказаНаСайте, НаименованиеПриложениеСборщика, Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
		ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , ,СообщениеОбОшибке);
		СообщениеОбОшибке = СтрШаблон(НСтр("ru = 'Ошибка изменения приложения для сборки заказа %1 на ""%2"" через АРМ ИМ: %3'"), РеквизитыЗаказа.НомерЗаказаНаСайте, НаименованиеПриложениеСборщика, Символы.ПС + ОписаниеОшибки());
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(СообщениеОбОшибке);
		Возврат;
	КонецПопытки;
	
	УстановитьПривилегированныйРежим(Ложь);
	
КонецПроцедуры

#КонецОбласти

#Область Aliexpress

&НаСервереБезКонтекста
Функция ТекстЗапросаЗаказыАли()
	
	ТекстЗапроса = "
		|ВЫБРАТЬ
		|	ЗаказКлиента.Ссылка,
		|	ЗаказКлиента.НомерЗаказаНаСайте,
		|	ЗаказКлиента.ДатаЗаказаНаСайте,
		|	ЗаказКлиента.Склад,
		|	ЗаказКлиента.СуммаДокумента,
		|	ЗаказКлиента.ЖелаемаяДатаОтгрузки,
		|	ЗаказКлиента.Статус,
		|	ЗаказКлиента.СтатусПроверки,
		|	ЗаказКлиента.АдресДоставки,
		|	ЗаказКлиента.ПокупательФИО,
		|	ЗаказКлиента.ПокупательТелефон,
		|	ЗаказКлиента.ПокупательEmail,
		|	ЗаказКлиента.Комментарий
		|ИЗ
		|	Документ.ЗаказКлиента КАК ЗаказКлиента
		|ГДЕ
		|	ЗаказКлиента.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
		|	И ЗаказКлиента.ВитринаИнтернетМагазина = ЗНАЧЕНИЕ(Справочник.ВитриныИнтернетМагазина.Алиэкспресс)
		|	И ЗаказКлиента.Статус = ЗНАЧЕНИЕ(Перечисление.СтатусыЗаказовКлиентов.НеСогласован)
		|";
		
	Возврат ТекстЗапроса;
	
КонецФункции

&НаКлиенте
Процедура ОтборЗаказыАлиДатаНачалаПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(ОтборЗаказыАлиДатаНачала) Тогда
		ОтборЗаказыАлиДатаНачала = ТекущаяДата() - 15*86400;
	КонецЕсли;
	
	НоваяДатаОкончания = ОтборЗаказыАлиДатаНачала + 15*86400 + 2*86400;
	Если НоваяДатаОкончания < ОтборЗаказыАлиДатаОкончания Тогда
		ОтборЗаказыАлиДатаОкончания = НоваяДатаОкончания;
	КонецЕсли;
	
	ОбновитьЗаказыАлиНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборЗаказыАлиДатаОкончанияПриИзменении(Элемент)
	
	Если НЕ ЗначениеЗаполнено(ОтборЗаказыАлиДатаОкончания) Тогда
        ОтборЗаказыАлиДатаОкончания = ТекущаяДата() + 2*86400;
	КонецЕсли;
	
	НоваяДатаНачала = ОтборЗаказыАлиДатаОкончания - 2*86400 - 15*86400;
	Если НоваяДатаНачала > ОтборЗаказыАлиДатаНачала Тогда
		ОтборЗаказыАлиДатаНачала = НоваяДатаНачала;
	КонецЕсли;
	
	ОбновитьЗаказыАлиНаСервере();
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗаказыАли(Команда)
	
	ОбновитьЗаказыАлиНаСервере();
	ОбновитьЗаголовокСтраницыЗаказыАли();
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьЗаказыАлиНаСервере()
	
	ТекстЗапроса = ТекстЗапросаЗаказыАли();
	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ДатаНачала", НачалоДня(ОтборЗаказыАлиДатаНачала));
	Запрос.УстановитьПараметр("ДатаОкончания", КонецДня(ОтборЗаказыАлиДатаОкончания));
	РезультатЗапроса = Запрос.Выполнить();
	ОбновитьТаблицуЗаказыАлиНаСервере(РезультатЗапроса);
	
КонецПроцедуры

&НаСервере
Процедура ОбновитьТаблицуЗаказыАлиНаСервере(РезультатЗапроса)
	
	ЗаказыАли.Очистить();
	
	РезультатВыборка = РезультатЗапроса.Выбрать();
	Пока РезультатВыборка.Следующий() Цикл
		НС = ЗаказыАли.Добавить();
		ЗаполнитьЗначенияСвойств(НС, РезультатВыборка);
	КонецЦикла;
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьЗаголовокСтраницыЗаказыАли()
	КоличествоСтрокРезультата = ЗаказыАли.Количество();
	Если КоличествоСтрокРезультата = 0 Тогда
		Элементы.ГруппаАлиекспресс.Заголовок = "Aliexpress"; 
		Элементы.ГруппаАлиекспресс.Картинка = Новый Картинка;
	Иначе
		Элементы.ГруппаАлиекспресс.Заголовок = "Aliexpress (" + КоличествоСтрокРезультата + ")";
		Элементы.ГруппаАлиекспресс.Картинка = БиблиотекаКартинок.Внимание;
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыАлиЗапуститьФоновоеЗадание()
	
	ИмяМетода = "ДлительныеОперации.ВыполнитьЗапросВФоне";
	ТекстЗапроса = ТекстЗапросаЗаказыАли();
	МассивПараметровМетода = Новый Массив;                                                                                                                                                                                            
	МассивПараметровМетода.Добавить(ТекстЗапроса);
	МассивПараметровМетода.Добавить(Новый Структура("ДатаНачала, ДатаОкончания", НачалоДня(ОтборЗаказыАлиДатаНачала), КонецДня(ОтборЗаказыАлиДатаОкончания)));
	КлючНаименование = "ПолучениеПризнакаНаличиеЗаказовАли";
	
	ЗаказыАлиКлючФЗ = ЗапуститьФоновоеЗадание(ИмяМетода, МассивПараметровМетода, КлючНаименование);
	
	//ЭтаФорма.ПодключитьОбработчикОжидания("ЗаказыАлиРезультатФоновогоЗаданияНаКлиенте", 300);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыАлиРезультатФоновогоЗаданияНаКлиенте()
	
	ЗаданиеВыполнено = Ложь;
	ЗаказыАлиРезультатФоновогоЗадания(ЗаказыАлиКлючФЗ, ЗаданиеВыполнено);
	Если ЗаданиеВыполнено Тогда 
		ЭтаФорма.ОтключитьОбработчикОжидания("ЗаказыАлиРезультатФоновогоЗаданияНаКлиенте");
		ОбновитьЗаголовокСтраницыЗаказыАли();
		//ЗаказыАлиЗапуститьФоновоеЗадание();	
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Процедура ЗаказыАлиРезультатФоновогоЗадания(ИдЗадания, ЗаданиеВыполнено = Ложь)
	
	Задание = ФоновыеЗадания.НайтиПоУникальномуИдентификатору(ИдЗадания);
	Если ТипЗнч(Задание) = Тип("ФоновоеЗадание") Тогда
		Если Задание.Состояние = СостояниеФоновогоЗадания.Завершено Тогда
			Сообщения = Задание.ПолучитьСообщенияПользователю();
			ЗаданиеВыполнено = Истина;
			Если Сообщения.Количество() > 0 Тогда 
				Рез = ЗначениеИзСтрокиВнутр(Сообщения[0].Текст);
				Если ТипЗнч(Рез) = Тип("РезультатЗапроса") Тогда
					ОбновитьТаблицуЗаказыАлиНаСервере(Рез);	
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
	Иначе
		ЗаданиеВыполнено = Истина;	
	КонецЕсли;

КонецПроцедуры                                       

&НаКлиенте
Процедура ЗаказыАлиВыбор(Элемент, ВыбраннаяСтрока, Поле, СтандартнаяОбработка)
	
	СтандартнаяОбработка = Ложь;
	Если Элемент.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекущийЗаказ = Элемент.ТекущиеДанные.Ссылка;
	ОткрытьФормуЗаказаАли(ТекущийЗаказ);
	
КонецПроцедуры

&НаКлиенте
Процедура ПроверитьЗаказАли(Команда)
	
	Если Элементы.ЗаказыАли.ВыделенныеСтроки.Количество()<>1 Тогда
		Возврат;
	КонецЕсли;
	Если Элементы.ЗаказыАли.ТекущиеДанные = Неопределено Тогда
		Возврат;
	КонецЕсли;
	ТекущийЗаказ = Элементы.ЗаказыАли.ТекущиеДанные.Ссылка;
	ОткрытьФормуЗаказаАли(ТекущийЗаказ);
	
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьФормуЗаказаАли(ТекущийЗаказ)
	
	Если ТекущийЗаказ = Неопределено ИЛИ ТекущийЗаказ.Пустая() Тогда
		Возврат;
	КонецЕсли;
	
	П = Новый Структура("Заказ", ТекущийЗаказ);
	ОткрытьФорму("ВнешняяОбработка.АРМИнтернетМагазин.Форма.ФормаЗаказаАли", П);
	
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыАлиПередНачаломДобавления(Элемент, Отказ, Копирование, Родитель, Группа)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыАлиПередНачаломИзменения(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ЗаказыАлиПередУдалением(Элемент, Отказ)
	Отказ = Истина;
КонецПроцедуры

#КонецОбласти

#Область Сбермаркет

&НаКлиенте
Процедура СбермаркетЗаполнитьМагазины(Команда)
	СбермаркетЗаполнитьМагазиныНаСервере();
КонецПроцедуры

&НаСервере
Процедура СбермаркетЗаполнитьМагазиныНаСервере()

	МассивГруппМагазинов = Новый Массив;
	МассивГруппМагазинов.Добавить(Справочники.Склады.НайтиПоНаименованию("Магазины работающие"));
	МассивГруппМагазинов.Добавить(Справочники.Склады.НайтиПоНаименованию("Магазины готовы к открытию"));
	
	МагазиныСбермаркет.Очистить();
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	Склады.Ссылка КАК Склад,
	               |	КИ.ЗначенияПолей,
	               |	КИ.Представление,
	               |	ЕСТЬNULL(СкладыДополнительныеРеквизиты.Значение, ЛОЖЬ) КАК Сбермаркет
	               |ИЗ
	               |	Справочник.Склады КАК Склады
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.КонтактнаяИнформация КАК КИ
	               |		ПО Склады.Ссылка = КИ.Ссылка
	               |			И (КИ.Тип = ЗНАЧЕНИЕ(Перечисление.ТипыКонтактнойИнформации.Адрес))
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Справочник.Склады.ДополнительныеРеквизиты КАК СкладыДополнительныеРеквизиты
	               |		ПО Склады.Ссылка = СкладыДополнительныеРеквизиты.Ссылка
	               |			И (СкладыДополнительныеРеквизиты.Свойство = &СвойствоСбермаркет)
	               |ГДЕ
	               |	Склады.Ссылка В ИЕРАРХИИ(&МассивГруппСкладов)
	               |	И Склады.ЭтоГруппа = ЛОЖЬ
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Склад
	               |АВТОУПОРЯДОЧИВАНИЕ";
	Запрос.УстановитьПараметр("МассивГруппСкладов", МассивГруппМагазинов);
	Запрос.УстановитьПараметр("СвойствоСбермаркет", ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Сбермаркет"));
	
	РезультатЗапрос = Запрос.Выполнить();
	Если РезультатЗапрос.Пустой() Тогда
		Возврат;
	КонецЕсли;
	
	РезультатВыборка = РезультатЗапрос.Выбрать();
	Пока РезультатВыборка.Следующий() Цикл
		
		НС = МагазиныСбермаркет.Добавить();
		НС.Магазин = РезультатВыборка.Склад;
		НС.Подключен = РезультатВыборка.Сбермаркет;
		НС.address = РезультатВыборка.Представление;
		НС.shop_id = Сбермаркет.ПолучитьЦифровойКодСклада(Лев(Строка(РезультатВыборка.Склад),4));
		НС.city = ПолучитьНазваниеГорода(РезультатВыборка.ЗначенияПолей);
		
	КонецЦикла;

КонецПроцедуры // ЗаполнитьСписокМагазиновНаСервере()

&НаСервере
Функция ПолучитьНазваниеГорода(ЗначенияПолей)
	
	СЗ = ПолучитьСписокЗначенийИзСтрокиАдреса(ЗначенияПолей);
	Регион = "";
	Город = "";
	Префикс = "";
	
	Для Каждого ЗначениеАдреса Из СЗ Цикл
		Если ЗначениеАдреса.Представление = "Регион" Тогда 
			Регион = ЗначениеАдреса.Значение;
		КонецЕсли;
		Если ЗначениеАдреса.Представление = "Город" Тогда
			Если Префикс = "" Тогда
				Город = ЗначениеАдреса.Значение;				
				Префикс = "г";
			КонецЕсли;
		КонецЕсли;
		Если ЗначениеАдреса.Представление = "НаселенныйПункт" Тогда 
			Город = ЗначениеАдреса.Значение;				
			Префикс = "п";
		КонецЕсли;
	КонецЦикла;
	
	//ФИКС: Москва не город, а регион в КЛАДР
	Если Город = "" И Префикс = "" И НЕ Регион = "" Тогда
		Город = Регион;
		Префикс = "г";
	КонецЕсли;

	ИсходноеНазвание = СтрЗаменить(Город, " ", Символы.ПС);
	Город = "";
		
	Для Сч = 1 По СтрЧислоСтрок(ИсходноеНазвание) Цикл
		Стр = СтрПолучитьСтроку(ИсходноеНазвание, Сч);
		Стр = УбратьЗнаки(Стр);
		Если СтрДлина(Стр) = 0 Тогда 
			Продолжить;
		КонецЕсли;
		Если НРег(Стр) = "пгт" ИЛИ НРег(Стр) = "п" ИЛИ НРег(Стр) = "с" ИЛИ НРег(Стр) = "д" ИЛИ НРег(Стр) = "дп" ИЛИ НРег(Стр) = "рп" ИЛИ НРег(Стр) = "гп" Тогда
			Продолжить;
		КонецЕсли;
		Если НРег(Стр) = "г" Тогда 
			Продолжить;
		КонецЕсли;
		Если НРег(Стр) = "мкр" Тогда 
			Продолжить;
		КонецЕсли;	
		Город = Город + ?(ПустаяСтрока(Город),""," ") + СокрЛП(Стр);
	КонецЦикла;
	
	Возврат Город;
	
КонецФункции

&НаСервере
Функция ПолучитьСписокЗначенийИзСтрокиАдреса(СтрокаАдреса)
	СЗАдреса = Новый СписокЗначений;
	ПоследнийЭлемент = Неопределено;
	
	Для Сч = 1 По СтрЧислоСтрок(СтрокаАдреса) Цикл
		Стр = СтрПолучитьСтроку(СтрокаАдреса, Сч);
		Если Лев(Стр, 1) = Символы.Таб Тогда
			Если ПоследнийЭлемент <> Неопределено Тогда
				ПоследнийЭлемент.Значение = ПоследнийЭлемент.Значение + Символы.ПС + Сред(Стр, 2);
			КонецЕсли;
		Иначе
			Поз = Найти(Стр, "=");
			Если Поз <> 0 Тогда
				ПоследнийЭлемент = СЗАдреса.Добавить(Сред(Стр, Поз+1), Лев(Стр, Поз-1));
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	
	Возврат СЗАдреса;
КонецФункции

&НаСервере
Функция УбратьЗнаки(Вход)
	ТолькоРусскиеБуквыИЦифры = ",.;";
    Выход = "";
	Для К=1 по СтрДлина(Вход) Цикл
		Бкв = Сред(Вход,К,1);
		Если НЕ Найти(ТолькоРусскиеБуквыИЦифры, Бкв) = 0 Тогда
			Продолжить;
		Иначе
			Выход = Выход + Бкв;
		КонецЕсли;
    КонецЦикла;
    Возврат Выход;
КонецФункции

&НаКлиенте
Процедура СбермаркетВыбратьПоГруппеСкладов(Команда)
	
	Элементы.МагазиныСбермаркет.ВыделенныеСтроки.Очистить();
	
	МассивТипов = Новый Массив;
	МассивТипов.Добавить(Тип("СправочникСсылка.Склады"));
	ТипыДанных = Новый ОписаниеТипов(МассивТипов);
	
	ПараметрыВыбора = Новый Структура;
	ПараметрыВыбора.Вставить("РежимВыбора", Истина);
	ПараметрыВыбора.Вставить("ВыборГруппИЭлементов", ИспользованиеГруппИЭлементов.Группы);
	ПараметрыВыбора.Вставить("РазрешитьВыборКорня", Ложь);
	ПараметрыВыбора.Вставить("ТекущаяСтрока", СбермаркетГруппаМагазиновДляВыделения);
	ПараметрыВыбора.Вставить("ЗакрыватьПослеВыбора", Истина);
	ОткрытьФорму("Справочник.Склады.ФормаВыбора", ПараметрыВыбора, ЭтаФорма);	
	
КонецПроцедуры

&НаСервереБезКонтекста
Функция СкладыПустаяСсылка()
	Возврат Справочники.Склады.ПустаяСсылка();
КонецФункции

&НаСервере
Функция ПолучитьМассивМагазиновПоГруппеМагазинов(ГруппаМагазинов = Неопределено)
	
	МассивМагазинов = Новый Массив;
	
	Если НЕ ТипЗнч(ГруппаМагазинов) = Тип("СправочникСсылка.Склады") Тогда
		Возврат МассивМагазинов;
	КонецЕсли;
	
	Если ГруппаМагазинов = Справочники.Склады.ПустаяСсылка() И НЕ ГруппаМагазинов.ЭтоГруппа Тогда
		Возврат МассивМагазинов;	
	КонецЕсли;
	
	ТекстЗапроса = "
		|ВЫБРАТЬ
		|	Склады.Ссылка
		|ИЗ
		|	Справочник.Склады КАК Склады
		|ГДЕ
		|	Склады.Ссылка В ИЕРАРХИИ(&ГруппаМагазинов)
		|	И НЕ Склады.ЭтоГруппа
		|";

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ГруппаМагазинов", ГруппаМагазинов);
	РезультатЗапроса = Запрос.Выполнить();
	МассивМагазинов = РезультатЗапроса.Выгрузить().ВыгрузитьКолонку("Ссылка");
	Возврат МассивМагазинов;
	
КонецФункции

&НаКлиенте
Процедура ОбработкаВыбора(ВыбранноеЗначение, ИсточникВыбора)
	Если ИсточникВыбора.ИмяФормы = "Справочник.Склады.Форма.ФормаВыбора" Тогда
		
		Если ТипЗнч(ВыбранноеЗначение) = Тип("СправочникСсылка.Склады") Тогда
			
			СбермаркетГруппаМагазиновДляВыделения = ВыбранноеЗначение;
			МассивМагазинов = ПолучитьМассивМагазиновПоГруппеМагазинов(СбермаркетГруппаМагазиновДляВыделения);
			Если МассивМагазинов.Количество() = 0 Тогда
				Возврат;
			КонецЕсли;
			
			Для Каждого СтрокаТаблицы Из МагазиныСбермаркет Цикл
				
				Если МассивМагазинов.Найти(СтрокаТаблицы.Магазин) = Неопределено Тогда
					Продолжить;
				КонецЕсли;
				
				Если Элементы.МагазиныСбермаркет.ВыделенныеСтроки.Количество()=0 Тогда
					Элементы.МагазиныСбермаркет.ТекущаяСтрока = СтрокаТаблицы.ПолучитьИдентификатор();
				КонецЕсли;
				
				Элементы.МагазиныСбермаркет.ВыделенныеСтроки.Добавить(СтрокаТаблицы.ПолучитьИдентификатор());
				
			КонецЦикла;
			
		Иначе
			
			СбермаркетГруппаМагазиновДляВыделения = СкладыПустаяСсылка();
			
		КонецЕсли;
		
	КонецЕсли;
КонецПроцедуры

