			Для Каждого ЗначениеАдреса Из АдресОтправленияСЗ Цикл
				Если ЗначениеАдреса.Представление = "Индекс" Тогда 
					АО_Индекс = ЗначениеАдреса.Значение;
					Прервать;
				КонецЕсли;
			КонецЦикла;
			АдресОтправления = СокрЛП(СтрЗаменить(АдресОтправления, АО_Индекс+",", ""));
		Иначе
			АО_Индекс = "";
			АО_Регион = "";
			АО_Город = ""; 
			АО_НаселенныйПункт = "";
			АО_Улица = "";
			АО_Дом = "";
			АО_ТипДома = "";
			АО_Корпус = "";   
			АО_Строение = "";
			АО_Дополнение = "";
			Для Каждого ЗначениеАдреса Из АдресОтправленияСЗ Цикл
				Если ЗначениеАдреса.Представление = "Индекс" Тогда 
					АО_Индекс = ЗначениеАдреса.Значение;
				КонецЕсли;
				Если ЗначениеАдреса.Представление = "Регион" Тогда 
					АО_Регион = ЗначениеАдреса.Значение;
				КонецЕсли;
				Если ЗначениеАдреса.Представление = "Город" Тогда 
					АО_Город = ЗначениеАдреса.Значение;
				КонецЕсли;
				Если ЗначениеАдреса.Представление = "НаселенныйПункт" Тогда
					АО_НаселенныйПункт = ЗначениеАдреса.Значение;
				КонецЕсли;
				Если ЗначениеАдреса.Представление = "Улица" Тогда 
					АО_Улица = ЗначениеАдреса.Значение;
				КонецЕсли;
				Если ЗначениеАдреса.Представление = "Дом" Тогда 
					АО_Дом = ЗначениеАдреса.Значение;
				КонецЕсли;
				Если ЗначениеАдреса.Представление = "ТипДома" Тогда 
					АО_ТипДома = ЗначениеАдреса.Значение;
				КонецЕсли;   
				Если ЗначениеАдреса.Представление = "Корпус" Тогда
					АО_Корпус = ЗначениеАдреса.Значение;
				КонецЕсли;            
				Если ЗначениеАдреса.Представление = "Строение" Тогда  
					АО_Строение = ЗначениеАдреса.Значение;
				КонецЕсли;
				Если ЗначениеАдреса.Представление = "Дополнение" Тогда
					АО_Дополнение = ЗначениеАдреса.Значение;
				КонецЕсли;
			КонецЦикла;
			АдресОтправления = АО_Регион
								+ ?(ПустаяСтрока(АО_Город), "", ", ") + АО_Город
								+ ?(ПустаяСтрока(АО_НаселенныйПункт), "", ", ") + АО_НаселенныйПункт
								+ ?(ПустаяСтрока(АО_Улица), "", ", ") + АО_Улица
								+ ?(ПустаяСтрока(АО_ТипДома), "", ", ") + АО_ТипДома + ?(ПустаяСтрока(АО_ТипДома), "", " ")
								+ ?(ПустаяСтрока(АО_Дом), "", "№ ") + АО_Дом
								+ ?(ПустаяСтрока(АО_Корпус), "", ", к. ") + АО_Корпус
								+ ?(ПустаяСтрока(АО_Строение), "", ", стр. ") + АО_Строение
								+ ?(ПустаяСтрока(АО_Дополнение), "", ", ") + АО_Дополнение;
		КонецЕсли;
		
		ОбластьСтрока.Параметры.АдресОтправления = АдресОтправления;
		ОбластьСтрока.Параметры.ПочтовыйИндексОтправления = АО_Индекс;
		
		ТабДок1.Вывести(ОбластьСтрока);
		
	КонецЦикла;
	
	СписокТабДок.Добавить(ТабДок1, "data");
	
	Возврат СписокТабДок;
	
КонецФункции

&НаКлиенте
Процедура СохранитьОтчетыВФайлExcelСЛистами(СписокОтчетов, ИмяФайла) Экспорт
	
	Эксель    = Новый COMObject("Excel.Application");
	Эксель.FileValidation = 1;	
	Эксель.DisplayAlerts = false;	
	
	Первый = истина;
	
	//Для защиты от дублей имен
	СооИмена = Новый СписокЗначений();
	
	//Перебираем отчеты в MXL
	Для Каждого Элемент ИЗ СписокОтчетов Цикл
		ТабДок = Элемент.Значение;
		ИмяВременногоФайла = ПолучитьИмяВременногоФайла("XLSX");
		ТабДок.Записать(ИмяВременногоФайла, ТипФайлаТабличногоДокумента.XLSX); //Сохраняем в временный файл

		ТекКнига = Эксель.Workbooks.Open(ИмяВременногоФайла, ,1);
		Если Первый Тогда
			Книга = ТекКнига; //Первый файл и есть результат, чтобы сохранялись цвета
		Иначе
			ТекКнига.Sheets(1).Copy(, Книга.Sheets(Книга.Sheets.Count)); //Copy(Before, After)
		КонецЕсли;

		УдалитьФайлы(ИмяВременногоФайла);
		
        //Защита от одинаковых ярлыков
		ТекБазаНаименование = Элемент.Представление;
		ТекНаименование = ТекБазаНаименование; СчНаименований = 2;
		Пока СооИмена.НайтиПоЗначению(ТекНаименование) <> Неопределено Цикл
			ТекНаименование = ТекБазаНаименование + "(" + СчНаименований + ")";
			СчНаименований = СчНаименований + 1;
		КонецЦикла;
		СооИмена.Добавить(ТекНаименование);
		Книга.Sheets(Книга.Sheets.Count).Name = ТекНаименование; //Переименовываем

		Если Первый Тогда
			//Делаем доступными ярлыки листов
			Эксель.ActiveWindow.DisplayWorkbookTabs = 1;
			Эксель.ActiveWindow.TabRatio = 0.6;
			Первый = ложь;
		Иначе
			ТекКнига.Close();
		КонецЕсли;

	КонецЦикла;
	
	//Удаляем, чтобы не переспрашивал
	Файл = Новый Файл(ИмяФайла);
	Если Файл.Существует() Тогда
		УдалитьФайлы(ИмяФайла);
	КонецЕсли;

	Книга.SaveAs(ИмяФайла, 51); //18 - xls 97-2003; 51 - xlsx 2007-2013

	Книга.Close();
	Эксель.Application.Quit();
	
КонецПроцедуры

