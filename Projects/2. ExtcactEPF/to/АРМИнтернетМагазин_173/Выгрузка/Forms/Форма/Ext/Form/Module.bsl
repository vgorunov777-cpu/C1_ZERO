#Область ЯндексТакси

&НаКлиенте
Процедура СформироватьФайлЗаказаЯндексТакси(Команда)
	
	СписокТабДок = новый СписокЗначений;
	
	//СписокТабДок = ЯндексТаксиПолучитьСписокТабличныхДокументов(Элементы.Заказы.ВыделенныеСтроки);
	СписокТабДок = ЯндексТаксиПолучитьСписокТабличныхДокументов20230427(Элементы.Заказы.ВыделенныеСтроки);
	Если СписокТабДок.Количество() = 0 Тогда
		ТекстСообщения = НСтр("ru='Ошибка формирование файла'");
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		Возврат;
	КонецЕсли;

	ДиалогСохраненияФайла = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение); 
	ДиалогСохраненияФайла.ПолноеИмяФайла = "Заявка вызова яндекс такси "+Формат(ТекущаяДата(),"ДФ=гггг-ММ-дд_ЧЧ-мм"); 
	ДиалогСохраненияФайла.Фильтр = "Книга Excel (*.xlsx)|*.xlsx";
	ДиалогСохраненияФайла.МножественныйВыбор = Ложь; 
	ДиалогСохраненияФайла.Заголовок = "Выберите файл"; 
	Если ДиалогСохраненияФайла.Выбрать() Тогда 
		ИмяФайла = ДиалогСохраненияФайла.ПолноеИмяФайла; 
	Иначе
		Возврат;
	КонецЕсли;   	
	
	СохранитьОтчетыВФайлExcelСЛистами(СписокТабДок, ИмяФайла);
	ОбщегоНазначенияКлиентСервер.Задержка(5);
	ЗапуститьПриложение(ИмяФайла);
	
КонецПроцедуры

&НаСервере
Функция ЯндексТаксиПолучитьСписокТабличныхДокументов(Знач МассивЗаказов)
	
	СписокТабДок = Новый СписокЗначений;
	СписокЗаказов = Новый СписокЗначений;
	СписокЗаказов.ЗагрузитьЗначения(МассивЗаказов);
	СписокСкладов = Новый СписокЗначений;
	Для Каждого ЭлементЗаказ Из МассивЗаказов Цикл
		Если ЭлементЗаказ = Документы.ЗаказКлиента.ПустаяСсылка() Тогда
			Продолжить;
		КонецЕсли;
		Если СписокСкладов.НайтиПоЗначению(ЭлементЗаказ.Склад) = Неопределено Тогда
			СписокСкладов.Добавить(ЭлементЗаказ.Склад);
		КонецЕсли;
	КонецЦикла;
	О = РеквизитФормыВЗначение("Объект"); 
    НомераЗаказовСтрокой = "";
	//Страница 1
	ТабДок1 = Новый ТабличныйДокумент;
	МакетСтраница1 = О.ПолучитьМакет("ЯндексТаксиOrders");    
	ОбластьШапка = МакетСтраница1.ПолучитьОбласть("ОбластьШапка");
	ТабДок1.Вывести(ОбластьШапка);
	Запрос = Новый Запрос;
	Запрос.Текст = "
	|ВЫБРАТЬ
	|	ЗаказКлиента.НомерЗаказаНаСайте,
	|	ЗаказКлиента.Широта,
	|	ЗаказКлиента.Долгота,
	|	ЗаказКлиента.ПокупательФИО,
	|	ЗаказКлиента.АдресДоставки,
	|	ЗаказКлиента.АдресДоставкиJSON,
	|	ЗаказКлиента.ПокупательТелефон,
	|	ЗаказКлиента.ВремяДоставкиС,
	|	ЗаказКлиента.ВремяДоставкиПо,
	|	ЗаказКлиента.Комментарий,
	|	ЗаказКлиента.КоличествоПакетов,
	|	ЕСТЬNULL(зкСтроки.КоличествоСтрок,0) КАК КоличествоСтрок,
	|	ЕСТЬNULL(ДС_Вес.Значение, 0) КАК Вес
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|	ЛЕВОЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|				ЗаказКлиентаТовары.Ссылка КАК Ссылка,
	|				КОЛИЧЕСТВО(РАЗЛИЧНЫЕ ЗаказКлиентаТовары.НомерСтроки) КАК КоличествоСтрок
	|			ИЗ
	|				Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	|			ГДЕ
	|				НЕ ЗаказКлиентаТовары.Отменено
	|			СГРУППИРОВАТЬ ПО
	|				ЗаказКлиентаТовары.Ссылка) КАК зкСтроки
	|		ПО ЗаказКлиента.Ссылка = зкСтроки.Ссылка
	|	ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.ДополнительныеСведения КАК ДС_Вес
	|	ПО ЗаказКлиента.Ссылка = ДС_Вес.Объект
	|		И (ДС_Вес.Свойство.Наименование = ""Вес(ВМС)"")
	|ГДЕ
	|	ЗаказКлиента.Ссылка В(&СписокЗаказов)
	|";
	Запрос.УстановитьПараметр("СписокЗаказов", СписокЗаказов);
	ВыборкаЗаказы = Запрос.Выполнить().Выбрать();
	Пока ВыборкаЗаказы.Следующий() Цикл
		
		КоличествоМест = ВыборкаЗаказы.КоличествоПакетов;
		Если КоличествоМест < 1 Тогда //2020-11-30 только для перехода (1-2 дня), пока есть заказы с КолчествоПакетов = 0
			КоличествоМестТочное = ВыборкаЗаказы.КоличествоСтрок / 10;
			КоличествоМест = Цел(КоличествоМестТочное);
			Если КоличествоМестТочное - КоличествоМест > 0 Тогда
				КоличествоМест = КоличествоМест + 1;
			КонецЕсли;
		КонецЕсли;
		
		ВремяДоставкиС = ВыборкаЗаказы.ВремяДоставкиС;
		ВремяДоставкиПо = ВыборкаЗаказы.ВремяДоставкиПо;
		Если ПланыОбмена.Полный.ЭтотУзел().Код = "000" Тогда
			ВремяДоставкиС = ВремяДоставкиС - 4*3600;
			ВремяДоставкиПО = ВремяДоставкиПо - 4*3600;
		КонецЕсли;

		АдресДоставкиJSON = ВыборкаЗаказы.АдресДоставкиJSON;
		Попытка
			СтруктураАдресДоставкиJSON = JSONСерверВызовСервера.ПрочитатьJSON82(АдресДоставкиJSON);
		Исключение
			СтруктураАдресДоставкиJSON = новый Структура;
		КонецПопытки;
		Если ТипЗнч(СтруктураАдресДоставкиJSON) = Тип("Массив") Тогда
			Если СтруктураАдресДоставкиJSON.Количество()>0 Тогда
				СтруктураАдресДоставкиJSON = СтруктураАдресДоставкиJSON[0];
			Иначе
				СтруктураАдресДоставкиJSON = Новый Структура;
			КонецЕсли;
		КонецЕсли;
		АдресДоставки = ВыборкаЗаказы.АдресДоставки;
		Подъезд = "";
		Этаж = "";
		Квартира = "";
		Домофон = "";
		Если ТипЗнч(СтруктураАдресДоставкиJSON) = Тип("Структура") Тогда
			Если СтруктураАдресДоставкиJSON.Свойство("address") Тогда
				Если ЗначениеЗаполнено(СтруктураАдресДоставкиJSON.address) Тогда
					АдресДоставки = СтруктураАдресДоставкиJSON.address;
				КонецЕсли;
			КонецЕсли;
			Если СтруктураАдресДоставкиJSON.Свойство("entrance") Тогда
				Подъезд = СтруктураАдресДоставкиJSON.entrance;
			КонецЕсли;
			Если СтруктураАдресДоставкиJSON.Свойство("floor") Тогда
				Этаж = СтруктураАдресДоставкиJSON.floor;
			КонецЕсли;
			Если СтруктураАдресДоставкиJSON.Свойство("apartment") Тогда
				Квартира = СтруктураАдресДоставкиJSON.apartment;
			КонецЕсли;
			Если СтруктураАдресДоставкиJSON.Свойство("intercom") Тогда
				Домофон = СтруктураАдресДоставкиJSON.intercom;
			КонецЕсли;
		КонецЕсли;
		
		Попытка 
			Широта = Число(Лев(СокрЛП(ВыборкаЗаказы.Широта),10));
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В заказе " + ВыборкаЗаказы.НомерЗаказаНаСайте + " не заполнена ""Широта"" доставки");
			Широта = "";
		КонецПопытки;
		Попытка
			Долгота = Число(Лев(СокрЛП(ВыборкаЗаказы.Долгота),10));
		Исключение
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю("В заказе " + ВыборкаЗаказы.НомерЗаказаНаСайте + " не заполнена ""Долгота"" доставки");
			Долгота = "";
		КонецПопытки;
		
		НомераЗаказовСтрокой = НомераЗаказовСтрокой + ?(СтрДлина(НомераЗаказовСтрокой)>0, ", ", "") + ВыборкаЗаказы.НомерЗаказаНаСайте;
		ОбластьСтрока = МакетСтраница1.ПолучитьОбласть("ОбластьСтрока");
		ОбластьСтрока.Параметры.НомерЗаказа = ВыборкаЗаказы.НомерЗаказаНаСайте;
		ОбластьСтрока.Параметры.Широта = Широта;
		ОбластьСтрока.Параметры.Долгота = Долгота;
		ОбластьСтрока.Параметры.НаименованиеПолучателя = ВыборкаЗаказы.ПокупательФИО;
		ОбластьСтрока.Параметры.АдресПолучателя = АдресДоставки;
		ОбластьСтрока.Параметры.Подъезд = Подъезд;
		ОбластьСтрока.Параметры.Этаж = Этаж;
		ОбластьСтрока.Параметры.Квартира = Квартира;
		ОбластьСтрока.Параметры.Домофон = "";
		ОбластьСтрока.Параметры.Телефон = ВыборкаЗаказы.ПокупательТелефон;
		ОбластьСтрока.Параметры.ВременноеОкно = Формат(ВремяДоставкиС, "ДФ = ЧЧ:мм") + " - " + Формат(ВремяДоставкиПо, "ДФ = ЧЧ:мм");
		ОбластьСтрока.Параметры.ЖесткоеВременноеОкно = "TRUE";
		ОбластьСтрока.Параметры.ВремяОбслуживанияНаАдрес = 600;
		ОбластьСтрока.Параметры.ВремяОбслуживанияНаЗаказ = 120;
		ОбластьСтрока.Параметры.ВесБрутто = Окр(ВыборкаЗаказы.Вес+0.5,0,РежимОкругления.Окр15как20);
		ОбластьСтрока.Параметры.КоличествоМест = КоличествоМест;
		ОбластьСтрока.Параметры.Ширина = "";
		ОбластьСтрока.Параметры.Глубина = "";
		ОбластьСтрока.Параметры.Высота = "";
		ОбластьСтрока.Параметры.ТипЗаказа = "delivery";
		ОбластьСтрока.Параметры.МестоНазначения = "";
		ОбластьСтрока.Параметры.ТипСовместимости = "food";
		ОбластьСтрока.Параметры.ВремяЗагрузкиНаСкладе = 180;
		ОбластьСтрока.Параметры.Комментарий = ВыборкаЗаказы.Комментарий;
		ТабДок1.Вывести(ОбластьСтрока);
		
	КонецЦикла;
	
	//Страница 2
