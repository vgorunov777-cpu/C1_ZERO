#Область МетодыФормыИСписоков

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	О = РеквизитФормыВЗначение("Объект");
	Заголовок = О.Метаданные().Комментарий + ": " + О.Метаданные().Синоним;
	ЭтаФорма.Заголовок = Заголовок;
	
	ПолныеПрава = РольДоступна("ПолныеПрава");
	ТехподдержкаИМРасширенная = РольДоступна("ТехподдержкаИМРасширенная");
	
	МассивВитринАРМ = Новый Массив;
	МассивВитринАРМ.Добавить(Справочники.ВитриныИнтернетМагазина.ЯрчеПлюс);
	МассивВитринАРМ.Добавить(Справочники.ВитриныИнтернетМагазина.ДаркКитчен);
	МассивВитринАРМ.Добавить(Справочники.ВитриныИнтернетМагазина.Игрушки);
	МассивВитринАРМ.Добавить(Справочники.ВитриныИнтернетМагазина.ОМС);
	МассивВитринАРМ.Добавить(Справочники.ВитриныИнтернетМагазина.КДВ);
	МассивВитринАРМ.Добавить(Справочники.ВитриныИнтернетМагазина.ЯндексЕда);
	
	Элементы.Витрина.СписокВыбора.ЗагрузитьЗначения(МассивВитринАРМ);
	
	ДатаСейчас = ТекущаяДатаСервера();
	Заказы.Параметры.УстановитьЗначениеПараметра("ТекущаяДата", ДатаСейчас);
	//Заказы.Параметры.УстановитьЗначениеПараметра("ТекущаяДатаМинус20", ДатаСейчас - 20 * 3600 * 24);

	ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(Заказы, "ЖелаемаяДатаОтгрузки", ДатаСейчас - 2 * 24 * 3600, ВидСравненияКомпоновкиДанных.БольшеИлиРавно);
	ОтборыСписковКлиентСервер.УстановитьЭлементОтбораСписка(Заказы, "ЖелаемаяДатаОтгрузки", ДатаСейчас + 2 * 24 * 3600, ВидСравненияКомпоновкиДанных.МеньшеИлиРавно);
	
	СписокСкладовИМ = Новый СписокЗначений;
	УстановитьСписокСкладовИМ(СписокСкладовИМ);
	Элементы.Магазин.СписокВыбора.ЗагрузитьЗначения(СписокСкладовИМ.ВыгрузитьЗначения());
	Элементы.ВыгрузкаОстатковМагазин.СписокВыбора.ЗагрузитьЗначения(СписокСкладовИМ.ВыгрузитьЗначения());
	
	СписокСкладовРозничныеМагазины = Новый СписокЗначений;
	УстановитьСписокСкладовРозничныеМагазины(СписокСкладовРозничныеМагазины);
	Элементы.КоординатыМагазин.СписокВыбора.ЗагрузитьЗначения(СписокСкладовРозничныеМагазины.ВыгрузитьЗначения());
	
	КурьерыИКомплектовщикиСкрытьПомеченныеНаУдаление = Истина;

	ОтборИгрушкиДатаНачала = ДобавитьМесяц(ДатаСейчас, -2);
	ОтборИгрушкиДатаОкончания = ДатаСейчас + 2 * 24 * 3600;
	
	//ОтборЗаказыАлиДатаНачала = ДатаСейчас - 15 * 86400;
	//ОтборЗаказыАлиДатаОкончания = ДатаСейчас + 2 * 86400;
	
	СКД = О.ПолучитьМакет("ОстаткиМагазина");
	АдресВХ = ПоместитьВоВременноеХранилище(СКД, Новый УникальныйИдентификатор);
	ИсточникНастроек = Новый ИсточникДоступныхНастроекКомпоновкиДанных(АдресВХ);
	ОстаткиКомпоновщикНастроек.Инициализировать(ИсточникНастроек);
	ОстаткиКомпоновщикНастроек.ЗагрузитьНастройки(СКД.НастройкиПоУмолчанию);
	ПКДСклад = новый ПолеКомпоновкиДанных("Склад");
	ПКДНоменклатура = Новый ПолеКомпоновкиДанных("Номенклатура");
	Для Каждого ЭлементОтбораКомпоновщика Из ОстаткиКомпоновщикНастроек.Настройки.Отбор.Элементы Цикл
		Если ТипЗнч(ЭлементОтбораКомпоновщика) = Тип("ГруппаЭлементовОтбораКомпоновкиДанных") Тогда
			Продолжить;
		КонецЕсли;
		Если ЭлементОтбораКомпоновщика.ЛевоеЗначение = ПКДСклад Тогда
			ЭлементОтбораКомпоновщика.Использование = Истина;
			ЭлементОтбораКомпоновщика.ВидСравнения = ВидСравненияКомпоновкиДанных.Равно;
			ЭлементОтбораКомпоновщика.ПравоеЗначение = Справочники.Склады.ПустаяСсылка();
		КонецЕсли;
		Если ЭлементОтбораКомпоновщика.ЛевоеЗначение = ПКДНоменклатура Тогда
			ЭлементОтбораКомпоновщика.Использование = Истина;
			ЭлементОтбораКомпоновщика.ВидСравнения = ВидСравненияКомпоновкиДанных.ВИерархии;
			ЭлементОтбораКомпоновщика.ПравоеЗначение = Справочники.Номенклатура.НайтиПоНаименованию("Ассортиментная матрица");
		КонецЕсли;
	КонецЦикла;
	
	ЗначениеВРеквизитФормы(О, "Объект");
	
	ПерезаполнитьТаблицуИнтернетМагазиныНаСервере();
	
	СвойствоШиротаСклада = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Широта");
	СвойствоДолготаСклада = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Долгота");
	СвойствоКоординатыГугл = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("Координаты Google");
	СвойствоСтатусАктивности = ПланыВидовХарактеристик.ДополнительныеРеквизитыИСведения.НайтиПоНаименованию("СтатусАктивнсти");
	
	ДоступныРасширенныеФункцииАРМ = ПолныеПрава ИЛИ ТехподдержкаИМРасширенная;
	
	СписокСегментовЯрчеПлюс.Добавить(Справочники.СегментыНоменклатуры.НайтиПоНаименованию("Ярче плюс без энергетиков", Истина));
	СписокСегментовЯрчеПлюс.Добавить(Справочники.СегментыНоменклатуры.НайтиПоНаименованию("Ярче плюс без энергетиков и мороженого", Истина));
	СписокСегментовЯрчеПлюс.Добавить(Справочники.СегментыНоменклатуры.НайтиПоНаименованию("Ярче плюс без энергетиков и выпечки", Истина));
	СписокСегментовЯрчеПлюс.Добавить(Справочники.СегментыНоменклатуры.НайтиПоНаименованию("Ярче плюс без энергетиков и заморозки", Истина));
	СписокСегментовЯрчеПлюс.Добавить(Справочники.СегментыНоменклатуры.НайтиПоНаименованию("Ярче плюс без энергетиков и выпечки и заморозки", Истина));
	СписокСегментовЯрчеПлюс.Добавить(Справочники.СегментыНоменклатуры.НайтиПоНаименованию("Ярче плюс без энергетиков и мороженого и выпечки", Истина));
	СписокСегментовЯрчеПлюс.Добавить(Справочники.СегментыНоменклатуры.НайтиПоНаименованию("Ярче плюс без энергетиков и мороженого и заморозки", Истина));
	СписокСегментовЯрчеПлюс.Добавить(Справочники.СегментыНоменклатуры.НайтиПоНаименованию("Ярче плюс без энерг. морож. выпеч. замороз", Истина));
	Для Каждого ЭлементСписка Из СписокСегментовЯрчеПлюс Цикл
		Элементы.СменаСегментаЦелевойСегмент.СписокВыбора.Добавить(ЭлементСписка.Значение);
	КонецЦикла;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ОбменССайтом.Склад КАК Склад,
	               |	ОбменССайтом.Витрина КАК Витрина,
	               |	ОбменССайтомУдержанияПриОтмене.Номенклатура КАК Номенклатура,
	               |	ОбменССайтомУдержанияПриОтмене.УдержаниеУстановленнойЦены КАК УдержаниеУстановленнойЦены,
	               |	ОбменССайтомУдержанияПриОтмене.УдержаниеПроцентаОтСуммыЗаказа КАК УдержаниеПроцентаОтСуммыЗаказа,
	               |	ПРЕДСТАВЛЕНИЕССЫЛКИ(ОбменССайтомУдержанияПриОтмене.Номенклатура) КАК Наименование
	               |ИЗ
	               |	ПланОбмена.ОбменССайтом.УдержанияПриОтмене КАК ОбменССайтомУдержанияПриОтмене
	               |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ ПланОбмена.ОбменССайтом КАК ОбменССайтом
	               |		ПО ОбменССайтомУдержанияПриОтмене.Ссылка = ОбменССайтом.Ссылка
	               |ГДЕ
	               |	ОбменССайтом.Витрина В(&МассивВитрин)
	               |
	               |УПОРЯДОЧИТЬ ПО
	               |	Склад,
	               |	Витрина,
	               |	УдержаниеУстановленнойЦены,
	               |	УдержаниеПроцентаОтСуммыЗаказа
	               |ИТОГИ ПО
	               |	Склад,
	               |	Витрина
	               |АВТОУПОРЯДОЧИВАНИЕ";
	Запрос.УстановитьПараметр("МассивВитрин", МассивВитринАРМ);
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаСклад = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
	Пока ВыборкаСклад.Следующий() Цикл
		ВыборкаВитрина = ВыборкаСклад.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока ВыборкаВитрина.Следующий() Цикл
			ВыборкаДетальныеЗаписи = ВыборкаВитрина.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
				НС = ТаблицаНоменклатурОтменыДаркКитчен.Добавить();
				ЗаполнитьЗначенияСвойств(НС, ВыборкаДетальныеЗаписи);
			КонецЦикла;
			НС = ТаблицаНоменклатурОтменыДаркКитчен.Добавить();
			НС.Склад = ВыборкаВитрина.Склад;
			НС.Витрина = ВыборкаВитрина.Витрина;
			НС.Номенклатура = Справочники.Номенклатура.ПустаяСсылка();
			НС.Наименование = "Не удерживать";
			НС.УдержаниеУстановленнойЦены = Ложь;
			НС.УдержаниеПроцентаОтСуммыЗаказа = 0;
		КонецЦикла;
	КонецЦикла;
	
	УстановитьПривилегированныйРежим(Истина);
	ОтборРЗ = Новый Структура;
	ОтборРЗ.Вставить("Наименование", "Запуск обработок: Отмена заказов Ярче плюс");
	МассивРЗ = РегламентныеЗадания.ПолучитьРегламентныеЗадания(ОтборРЗ);
	Для каждого ЭлементМассива Из МассивРЗ Цикл
		УИДРоботаОтменыЗаказов = ЭлементМассива.УникальныйИдентификатор;
		Прервать;
	КонецЦикла;
	ДатаЗапускаРоботаОтменыЗаказовС = ТекущаяДата() + 3*86400;
	УстановитьПривилегированныйРежим(Ложь);

КонецПроцедуры

