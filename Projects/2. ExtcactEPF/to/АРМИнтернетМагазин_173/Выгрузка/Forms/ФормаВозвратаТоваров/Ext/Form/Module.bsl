&НаКлиенте
Процедура ТоварыПричинаОтменыПриИзменении(Элемент)
	
	ТекущиеДанные = Элементы.ДанныеЗаказ.ТекущиеДанные;
	
	Если ТекущиеДанные.ПричинаОтмены = ПричинаОтменыПустаяСсылка Тогда
		СвернутьТовары();
	Иначе
		Если ТекущиеДанные.ТипНоменклатуры = ТипНоменклатурыУслуга Тогда
			ТекущиеДанные.ПричинаОтмены = ПричинаОтменыКомплектация;
		КонецЕсли;
		АлгоритмВозврата(ТекущиеДанные);
	КонецЕсли;
	
	ОбновитьПоказателиКВозврату();
	
КонецПроцедуры

&НаКлиенте
Процедура АлгоритмВозврата(ТекущиеДанные)
	
	Если ТекущиеДанные.МаркируемаяПродукция Тогда 
		//ничего не делаем просто меняем причину
	Иначе

		КоличествоДляВозврата = ТекущиеДанные.Количество;
		ТекстВопроса = "Сколько вернуть?";
		ОтветПользователя = "";               

		Если ТекущиеДанные.КоличествоШтук > 0 Тогда
			СЗ_Кнопки = новый СписокЗначений;
			СЗ_Кнопки.Добавить("Штуки", "Штуки");
			СЗ_Кнопки.Добавить("Вес", "Вес");
			ОтветПользователя = Вопрос("Возвращаем штуки или вес?", СЗ_Кнопки);
			Если ОтветПользователя = "Штуки" Тогда
				КоличествоДляВозврата = ТекущиеДанные.КоличествоШтук;
				ТекстВопроса = "Сколько штук вернуть?";
			Иначе
				КоличествоДляВозврата = ТекущиеДанные.Количество;
				ТекстВопроса = "Какой вес вернуть?";
			КонецЕсли;
		КонецЕсли;
		ИсходноеКоличество = КоличествоДляВозврата;
	
		Если ВвестиЧисло(КоличествоДляВозврата, ТекстВопроса) Тогда
		
			Если КоличествоДляВозврата > ИсходноеКоличество Тогда
				Предупреждение("Нельзя вернуть больше чем продано!");
				ТекущиеДанные.ПричинаОтмены = ПричинаОтменыПустаяСсылка;
				СвернутьТовары();
				Возврат;
			КонецЕсли;

			Если КоличествоДляВозврата < 0 Тогда
				Предупреждение("Нельзя вернуть отрицательное количество!");
				ТекущиеДанные.ПричинаОтмены = ПричинаОтменыПустаяСсылка;
				СвернутьТовары();
				Возврат;
			КонецЕсли;
		
			Если ОтветПользователя = "Штуки" Тогда
				КолШтукВозврат = КоличествоДляВозврата;
				КолВозврат = Окр(ТекущиеДанные.Количество * КоличествоДляВозврата / ТекущиеДанные.КоличествоШтук, 3);
			Иначе
				КолШтукВозврат = Окр(КоличествоДляВозврата * ТекущиеДанные.КоличествоШтук / ТекущиеДанные.Количество, 0);
				КолШтукВозврат = ?(КолШтукВозврат = 0 И ТекущиеДанные.КоличествоШтук > 0, 1, КолШтукВозврат);
				КолВозврат = КоличествоДляВозврата;
			КонецЕсли;	
			
			Если КолВозврат < ТекущиеДанные.Количество Тогда
				
				НС = Товары.Добавить();
				НС.Номенклатура = ТекущиеДанные.Номенклатура;
				НС.Количество = ТекущиеДанные.Количество - КолВозврат;
				НС.КоличествоШтук = ТекущиеДанные.КоличествоШтук - КолШтукВозврат;
				НС.ПричинаОтмены = ПричинаОтменыПустаяСсылка;
				НС.Цена = ТекущиеДанные.Цена;
				НС.МаркируемаяПродукция = ТекущиеДанные.МаркируемаяПродукция;
				НС.ТипНоменклатуры = ТекущиеДанные.ТипНоменклатуры;
				
				ТекущиеДанные.Количество = КолВозврат;
				ТекущиеДанные.КоличествоШтук = КолШтукВозврат;
				
			КонецЕсли;
		
		Иначе
		
			ТекущиеДанные.ПричинаОтмены = ПричинаОтменыПустаяСсылка;
		
		КонецЕсли;
		
	КонецЕсли;
		
	Если ТекущиеДанные.МаркируемаяПродукция И ТекущиеДанные.ПричинаОтмены <> ПричинаОтменыБрак ТОгда
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю("Для маркируемой продукции возврат возможен только с причиной ""Брак""");
		ТекущиеДанные.ПричинаОтмены = ПричинаОтменыБрак;
	КонецЕсли;
	
	СвернутьТовары();
	
КонецПроцедуры

&НаКлиенте
Процедура СвернутьТовары()
	
	НоменклатураСтроки = Элементы.ДанныеЗаказ.ТекущиеДанные.Номенклатура;
	ПричинаОтменыСтроки = Элементы.ДанныеЗаказ.ТекущиеДанные.ПричинаОтмены;
	СвернутьТоварыНаСервере();
	Для Каждого СтрокаТаблицы Из Товары Цикл
		Если СтрокаТаблицы.Номенклатура = НоменклатураСтроки 
			И СтрокаТаблицы.ПричинаОтмены = ПричинаОтменыСтроки Тогда
			Элементы.ДанныеЗаказ.ТекущаяСтрока = СтрокаТаблицы.ПолучитьИдентификатор();
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
Процедура СвернутьТоварыНаСервере()
	
	ТЗ_Товары = Товары.Выгрузить();
	ТЗ_Товары.Свернуть("Номенклатура, ПричинаОтмены, МаркируемаяПродукция, Марка, Цена, ТипНоменклатуры", "Количество, КоличествоШтук");
	Товары.Загрузить(ТЗ_Товары);
	Товары.Сортировать("Номенклатура, ПричинаОтмены");
	
КонецПроцедуры

&НаКлиенте
Процедура ОбновитьПоказателиКВозврату()
	
	КоличествоПозицийКВозвратуБрак = 0;
	ОбщееКоличествоКВозвратуБрак = 0;
	ОбщаяСуммаКВозвратуБрак = 0;
	КоличествоПозицийКВозвратуКомплектация = 0;
	ОбщееКоличествоКВозвратуКомплектация = 0;
	ОбщаяСуммаКВозвратуКомплектация = 0;
	
	Для Каждого СтрокаТаблицы Из Товары Цикл
		
		Если СтрокаТаблицы.ПричинаОтмены = ПричинаОтменыБрак Тогда
			КоличествоПозицийКВозвратуБрак = КоличествоПозицийКВозвратуБрак + 1;
			ОбщееКоличествоКВозвратуБрак = ОбщееКоличествоКВозвратуБрак + СтрокаТаблицы.Количество;
			ОбщаяСуммаКВозвратуБрак = ОбщаяСуммаКВозвратуБрак + Окр(СтрокаТаблицы.Количество * СтрокаТаблицы.Цена,2);
		ИначеЕсли СтрокаТаблицы.ПричинаОтмены = ПричинаОтменыКомплектация Тогда
			КоличествоПозицийКВозвратуКомплектация = КоличествоПозицийКВозвратуКомплектация + 1;
			ОбщееКоличествоКВозвратуКомплектация = ОбщееКоличествоКВозвратуКомплектация + СтрокаТаблицы.Количество;
			ОбщаяСуммаКВозвратуКомплектация = ОбщаяСуммаКВозвратуКомплектация + Окр(СтрокаТаблицы.Количество * СтрокаТаблицы.Цена,2);
		КонецЕсли;
		
	КонецЦикла;
	
	Элементы.нПоказателиВозвратаБрак.Заголовок = "К возврату позиций (количество) брак: " + КоличествоПозицийКВозвратуБрак + " (" + ОбщееКоличествоКВозвратуБрак + "), на сумму " + Формат(ОбщаяСуммаКВозвратуБрак,"ЧДЦ=2; ЧРД=.; ЧГ=0") + " руб.";
	Элементы.нПоказателиВозвратаКомплектация.Заголовок = "К возврату позиций (количество) комплектация: " + КоличествоПозицийКВозвратуКомплектация + " (" + ОбщееКоличествоКВозвратуКомплектация + "), на сумму " + Формат(ОбщаяСуммаКВозвратуКомплектация,"ЧДЦ=2; ЧРД=.; ЧГ=0") + " руб.";
	ИтогоКоличествоПозицийКВозврату = КоличествоПозицийКВозвратуБрак + КоличествоПозицийКВозвратуКомплектация;
	ИтогоОбщееКоличествоКВозврату =  ОбщееКоличествоКВозвратуБрак + ОбщееКоличествоКВозвратуКомплектация;
	ИтогоОбщаяСуммаКВозврату = ОбщаяСуммаКВозвратуБрак + ОбщаяСуммаКВозвратуКомплектация;
	Элементы.нПоказателиВозвратаИтоги.Заголовок = "Итого к возврату позиций (количество): " + ИтогоКоличествоПозицийКВозврату + " (" + ИтогоОбщееКоличествоКВозврату + "), на сумму " + Формат(ИтогоОбщаяСуммаКВозврату,"ЧДЦ=2; ЧРД=.; ЧГ=0") + " руб.";
	
КонецПроцедуры

