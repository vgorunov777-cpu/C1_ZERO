&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	
	Если Не Параметры.Свойство("Заказ", Заказ) Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Если НЕ Параметры.Свойство("НомерВерсииПриНачалеРедактирования", НомерВерсииПриНачалеРедактирования) Тогда
		НомерВерсииПриНачалеРедактирования = 0;
	КонецЕсли;
	
	О = РеквизитФормыВЗначение("Объект");
	Заголовок = О.Метаданные().Комментарий + ": " + О.Метаданные().Синоним + ": " + ЭтаФорма.Заголовок;
	ЭтаФорма.Заголовок = Заголовок;
	
	СтруктураРеквизитов = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(Заказ, "НомерЗаказаНаСайте, ЧекПродажа, ЭквайринговаяОперация, ФормаОплаты, ВозвратMagPayЗапрещен, ВитринаИнтернетМагазина");
	ЗаказНомер				= СтруктураРеквизитов.НомерЗаказаНаСайте;
	ЧекККМ					= СтруктураРеквизитов.ЧекПродажа;
	ЭквайринговаяОперация	= СтруктураРеквизитов.ЭквайринговаяОперация;
	ВитринаИМ				= СтруктураРеквизитов.ВитринаИнтернетМагазина;
	
	ВыполнятьВозвратВМагПей = Ложь;
	Если СтруктураРеквизитов.ФормаОплаты = Перечисления.ФормыОплаты.Безналичная
		ИЛИ СтруктураРеквизитов.ФормаОплаты = Перечисления.ФормыОплаты.ПлатежнаяКарта Тогда
		Если СтруктураРеквизитов.ВозвратMagPayЗапрещен Тогда
			Отказ = Истина;
		Иначе
			ЗаполнитьТаблицуОплатМагПей();
		КонецЕсли;
	КонецЕсли;

	Если ЧекККМ.Пустая() Тогда
		Отказ = Истина;
	КонецЕсли;
	
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ
	               |	ЗаказКлиентаТовары.Номенклатура,
	               |	ЕСТЬNULL(ЗаказКлиентаАкцизныеМарки.Количество, ЗаказКлиентаТовары.КоличествоУпаковок) КАК Количество,
	               |	ВЫБОР
	               |		КОГДА ЗаказКлиентаАкцизныеМарки.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЗаказКлиентаТовары.КоличествоШтук
	               |		ИНАЧЕ 1
	               |	КОНЕЦ КАК КоличествоШтук,
	               |	ЗаказКлиентаТовары.ПричинаОтмены,
	               |	ЗаказКлиентаТовары.Цена,
	               |	ВЫБОР
	               |		КОГДА ЗаказКлиентаАкцизныеМарки.Ссылка ЕСТЬ NULL
	               |			ТОГДА ЛОЖЬ
	               |		ИНАЧЕ ИСТИНА
	               |	КОНЕЦ КАК МаркируемаяПродукция,
	               |	ЗаказКлиентаТовары.Номенклатура.ТипНоменклатуры КАК ТипНоменклатуры,
	               |	ЕСТЬNULL(ЗаказКлиентаАкцизныеМарки.Марка, """") КАК Марка
	               |ИЗ
	               |	Документ.ЗаказКлиента.Товары КАК ЗаказКлиентаТовары
	               |		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ЗаказКлиента.АкцизныеМарки КАК ЗаказКлиентаАкцизныеМарки
	               |		ПО ЗаказКлиентаТовары.Ссылка = ЗаказКлиентаАкцизныеМарки.Ссылка
	               |			И ЗаказКлиентаТовары.КодСтроки = ЗаказКлиентаАкцизныеМарки.КлючСвязи
	               |			И (НЕ ЗаказКлиентаАкцизныеМарки.Отменено)
	               |ГДЕ
	               |	ЗаказКлиентаТовары.Ссылка = &Заказ
	               |	И НЕ ЗаказКлиентаТовары.Отменено
	               |	И ЗаказКлиентаТовары.ПричинаОтмены = ЗНАЧЕНИЕ(Справочник.ПричиныОтменыЗаказовКлиентов.ПустаяСсылка)";

	Запрос.УстановитьПараметр("Заказ", Заказ);

	Товары.Загрузить(Запрос.Выполнить().Выгрузить());

	Товары.Сортировать("Номенклатура, ПричинаОтмены");
	
	ПричинаОтменыПустаяСсылка 	= Справочники.ПричиныОтменыЗаказовКлиентов.ПустаяСсылка();
	ПричинаОтменыБрак			= Справочники.ПричиныОтменыЗаказовКлиентов.НайтиПоНаименованию("Брак");
	ПричинаОтменыКомплектация	= Справочники.ПричиныОтменыЗаказовКлиентов.НайтиПоНаименованию("Недостача");
	ТипНоменклатурыУслуга		= Перечисления.ТипыНоменклатуры.Услуга;
	
	Элементы.ТоварыПричинаОтмены.СписокВыбора.Очистить();
	Элементы.ТоварыПричинаОтмены.СписокВыбора.Добавить(ПричинаОтменыПустаяСсылка, " ");
	Элементы.ТоварыПричинаОтмены.СписокВыбора.Добавить(ПричинаОтменыКомплектация, "Недостача");
	Элементы.ТоварыПричинаОтмены.СписокВыбора.Добавить(ПричинаОтменыБрак, "Брак");
	
КонецПроцедуры

&НаСервере
Процедура ЗаполнитьТаблицуОплатМагПей()
	
	ВыполнятьВозвратВМагПей = Истина;
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	ОперацииJSON = ОбработкаОбъект.ЗагрузитьОперацииМагПей(Заказ);
	
	Если ТипЗнч(ОперацииJSON) = Тип("Соответствие") Тогда
		Если Не ОперацииJSON.Получить("data") = Неопределено Тогда 
			Для Каждого ОперацииЗаказаСоответствие Из ОперацииJSON.Получить("data") Цикл
					
				ОперацииЗаказаСтруктура = ОбщегоНазначения.СоответствиеВСтруктуру(ОперацииЗаказаСоответствие);  
				
				Если ОперацииЗаказаСтруктура.Свойство("operations") Тогда
					Для Каждого Операция Из ОперацииЗаказаСтруктура.operations Цикл
						ОперацияСтруктура = ОбщегоНазначения.СоответствиеВСтруктуру(Операция);
						
						//типа операции 
						ТипОперации = Неопределено;
						Если ОперацияСтруктура.Свойство("type", ТипОперации) = Ложь Тогда
							ВыполнятьВозвратВМагПей = Ложь;
							Возврат;
						КонецЕсли;

						Множитель = 0; 
						Если ТипОперации = "SELL" Тогда 
							Множитель = 1;
						ИначеЕсли ТипОперации = "SELL_REFUND" Тогда
							Множитель = -1;
						Иначе      
							ВыполнятьВозвратВМагПей = Ложь;
							Возврат;
						КонецЕсли;							
						
						//реквизиты оплаты текущей операции
						Если ОперацияСтруктура.Свойство("payment") = Ложь Тогда
							ВыполнятьВозвратВМагПей = Ложь;
							Возврат;
						КонецЕсли;
						
						Если ОперацияСтруктура.payment.type <> "CARD" Тогда
							ВыполнятьВозвратВМагПей = Ложь;
							Возврат;
						КонецЕсли;
							
						РРНОперации = ОперацияСтруктура.payment.rrn;
						МерчантОперации = ОперацияСтруктура.payment.merchant;
						ТерминалОперации = ОперацияСтруктура.payment.terminal;
						КодАвторизацииОперации = ОперацияСтруктура.payment.auth_code;
						
						// номенклатура, марки и количество
						ИспользоватьМультичекиВОперации = ОперацияСтруктура.Свойство("cheques");
						Если ИспользоватьМультичекиВОперации Тогда
							
							Для каждого ЧекОперации Из ОперацияСтруктура.cheques Цикл
								ЧекОперацииСтруктура = ОбщегоНазначения.СоответствиеВСтруктуру(ЧекОперации);
								Если ЧекОперацииСтруктура.Свойство("items") = Ложь Тогда
									ВыполнятьВозвратВМагПей = Ложь;
									Возврат;
								КонецЕсли;
								Для Каждого ПозицияЧека Из ЧекОперацииСтруктура.items Цикл
									ПозицияЧекаСтруктура = ОбщегоНазначения.СоответствиеВСтруктуру(ПозицияЧека);
									ИдентификаторНоменклатуры = ПозицияЧекаСтруктура.nomenclature_id;
									УИДНоменклатуры = ПозицияЧекаСтруктура.id;
									КоличествоНоменклатуры = ПозицияЧекаСтруктура.quantity * Множитель;
									Если ПозицияЧекаСтруктура.Свойство("marking_codes") И ПозицияЧекаСтруктура.marking_codes.Количество() > 0 Тогда
										Для Каждого Марка Из ПозицияЧекаСтруктура.marking_codes Цикл
											МаркаПреобразованная = ОбменССайтом.ЭкранироватьНечитаемыеСимволы(Марка,"\u001d");
											НСОперацииМагПей = ТоварыПоОперациямМагПей.Добавить();
											НСОперацииМагПей.ИдентификаторНоменклатуры = ИдентификаторНоменклатуры;
											НСОперацииМагПей.УИДНоменклатуры = УИДНоменклатуры;
											НСОперацииМагПей.Марка = МаркаПреобразованная;
											НСОперацииМагПей.Количество = Множитель;
											НСОперацииМагПей.rrn = РРНОперации;
											НСОперацииМагПей.merchant_id = МерчантОперации;
											НСОперацииМагПей.terminal_id = ТерминалОперации;
											НСОперацииМагПей.auth_code = КодАвторизацииОперации;
										КонецЦикла;
									Иначе        
										НСОперацииМагПей = ТоварыПоОперациямМагПей.Добавить();
										НСОперацииМагПей.ИдентификаторНоменклатуры = ИдентификаторНоменклатуры;
										НСОперацииМагПей.УИДНоменклатуры = УИДНоменклатуры;
										НСОперацииМагПей.Марка = "";
										НСОперацииМагПей.Количество = Множитель * КоличествоНоменклатуры;
										НСОперацииМагПей.rrn = РРНОперации;
										НСОперацииМагПей.merchant_id = МерчантОперации;
										НСОперацииМагПей.terminal_id = ТерминалОперации;
										НСОперацииМагПей.auth_code = КодАвторизацииОперации;
									КонецЕсли;
								КонецЦикла;
							КонецЦикла;
									
						Иначе
							
							Если ОперацияСтруктура.Свойство("items") = Ложь Тогда
								ВыполнятьВозвратВМагПей = Ложь;
								Возврат;                       
							КонецЕсли;
							Для Каждого ПозицияЧека Из ОперацияСтруктура.items Цикл  
								ПозицияЧекаСтруктура = ОбщегоНазначения.СоответствиеВСтруктуру(ПозицияЧека);
								ИдентификаторНоменклатуры = ПозицияЧекаСтруктура.nomenclature_id;  
								УИДНоменклатуры = ПозицияЧекаСтруктура.id;
								КоличествоНоменклатуры = ПозицияЧекаСтруктура.quantity;
								Если ПозицияЧекаСтруктура.Свойство("marking_codes") И ПозицияЧекаСтруктура.marking_codes.Количество() > 0 Тогда
									Для Каждого Марка Из ПозицияЧекаСтруктура.marking_codes Цикл  
										МаркаПреобразованная = ОбменССайтом.ЭкранироватьНечитаемыеСимволы(Марка,"\u001d");
										НСОперацииМагПей = ТоварыПоОперациямМагПей.Добавить();
										НСОперацииМагПей.ИдентификаторНоменклатуры = ИдентификаторНоменклатуры; 
										НСОперацииМагПей.УИДНоменклатуры = УИДНоменклатуры;
										НСОперацииМагПей.Марка = МаркаПреобразованная;
										НСОперацииМагПей.Количество = Множитель;
										НСОперацииМагПей.rrn = РРНОперации;
										НСОперацииМагПей.merchant_id = МерчантОперации;
										НСОперацииМагПей.terminal_id = ТерминалОперации;
										НСОперацииМагПей.auth_code = КодАвторизацииОперации;
									КонецЦикла;
								Иначе
									НСОперацииМагПей = ТоварыПоОперациямМагПей.Добавить();
									НСОперацииМагПей.ИдентификаторНоменклатуры = ИдентификаторНоменклатуры;  
									НСОперацииМагПей.УИДНоменклатуры = УИДНоменклатуры;
									НСОперацииМагПей.Марка = "";
									НСОперацииМагПей.Количество = Множитель * КоличествоНоменклатуры;
									НСОперацииМагПей.rrn = РРНОперации;
									НСОперацииМагПей.merchant_id = МерчантОперации;
									НСОперацииМагПей.terminal_id = ТерминалОперации;
									НСОперацииМагПей.auth_code = КодАвторизацииОперации;
								КонецЕсли;
							КонецЦикла;    
							
						КонецЕсли;  // ИспользоватьМультичекиВОперации
					КонецЦикла;  // ОперацииЗаказаСтруктура.operations
				Иначе
					ВыполнятьВозвратВМагПей = Ложь; 
					Возврат;
				КонецЕсли;  // ОперацииЗаказаСтруктура.Свойство("operations")

			КонецЦикла;  // ОперацииJSON.Получить("data")  
			
			// количество из ТЧ марок заказа + Номенклатура
			ТаблицаМарокЗаказа = Заказ.АкцизныеМарки.Выгрузить();
			Для Каждого СтрокаТаблицы Из ТоварыПоОперациямМагПей Цикл 

				СтрокаТаблицы.Номенклатура = Справочники.Номенклатура.ПолучитьСсылку(Новый УникальныйИдентификатор(СтрокаТаблицы.ИдентификаторНоменклатуры));

				Если ПустаяСтрока(СтрокаТаблицы.Марка) Тогда
					Продолжить;
				КонецЕсли;      
				
				Для Каждого СтрокаТаблицыМарокЗаказа Из ТаблицаМарокЗаказа Цикл
					Если СтрокаТаблицы.Марка = СтрЗаменить(СтрокаТаблицыМарокЗаказа.Марка, "\u001d", "")
						ИЛИ СтрокаТаблицы.Марка = СтрокаТаблицыМарокЗаказа.Марка Тогда
						СтрокаТаблицы.Количество = СтрокаТаблицы.Количество * СтрокаТаблицыМарокЗаказа.Количество; 
						Прервать;
					КонецЕсли;
				КонецЦикла;
			КонецЦикла;
			
			ТЗ_ТоварыПоОперациямМагПей = ТоварыПоОперациямМагПей.Выгрузить();
			ТЗ_ТоварыПоОперациямМагПей.Свернуть("УИДНоменклатуры, Номенклатура, Марка, rrn, merchant_id, terminal_id, auth_code", "Количество");
			ТоварыПоОперациямМагПей.Загрузить(ТЗ_ТоварыПоОперациямМагПей);
			
		Иначе
			ВыполнятьВозвратВМагПей = Ложь;
			Возврат;
		КонецЕсли;  // Не ОперацииJSON.Получить("data") = Неопределено
	Иначе 
		ВыполнятьВозвратВМагПей = Ложь;
		Возврат;
	КонецЕсли; // ТипЗнч(ОперацииJSON) = Тип("Соответствие")
	
КонецПроцедуры

