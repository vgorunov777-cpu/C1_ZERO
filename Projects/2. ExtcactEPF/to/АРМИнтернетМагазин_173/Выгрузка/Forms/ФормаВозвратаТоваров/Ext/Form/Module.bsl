КонецПроцедуры

&НаСервере
Процедура СформироватьДокументыНаВозвратНаСервере(СтруктураПараметров)
	
	УстановитьПривилегированныйРежим(Истина);
	
	СообщениеОбОшибке = "";
	Если НЕ СтруктураПараметров.Свойство("Заказ") Тогда
		СообщениеОбОшибке = СообщениеОбОшибке + ?(СтрДлина(СообщениеОбОшибке)>0, ", ", "") + "Заказ";
	КонецЕсли;
			
	Если ЗначениеЗаполнено(СообщениеОбОшибке) Тогда
		СообщениеОбОшибке = "Ошибка входных данных, отсутствуют параметры: " + СообщениеОбОшибке;
		СтруктураПараметров.Вставить("Результат", Ложь);
		СтруктураПараметров.Вставить("ОписаниеРезультата", СообщениеОбОшибке);
		Возврат;
	КонецЕсли;
		
	ТЗ_Возврат = Товары.Выгрузить();
	ТЗ_Возврат.Очистить();
	
	Для Каждого СтрокаТЗ Из Товары Цикл
		Если СтрокаТЗ.ПричинаОтмены = ПричинаОтменыПустаяСсылка Тогда
			Продолжить;
		КонецЕсли;
		НС = ТЗ_Возврат.Добавить();
		ЗаполнитьЗначенияСвойств(НС, СтрокаТЗ);
	КонецЦикла;
	
	Если ТЗ_Возврат.Количество() = 0 Тогда
		СтруктураПараметров.Вставить("Результат", Ложь);
		СтруктураПараметров.Вставить("ОписаниеРезультата", "Нет данных для формирования документов на возврат");
		Возврат;
	КонецЕсли;

	//Формирование таблицы брака
	ТЗ_Брак = ТЗ_Возврат.Скопировать();
	ТЗ_Брак.Очистить();
	Для Каждого СтрокаТЗ Из ТЗ_Возврат Цикл
		Если СтрокаТЗ.ПричинаОтмены = ПричинаОтменыБрак Тогда
			Если СтрокаТЗ.ТипНоменклатуры = Перечисления.ТипыНоменклатуры.Услуга Тогда
				Продолжить;
			КонецЕсли;
			НС = ТЗ_Брак.Добавить();
			ЗаполнитьЗначенияСвойств(НС, СтрокаТЗ);
		КонецЕсли;
	КонецЦикла;
	
	ЕстьЧВ = Ложь;
	ЕстьТН = Ложь;
	
	ОбработкаОбъект = РеквизитФормыВЗначение("Объект");
	
	Если ТЗ_Брак.Количество() > 0 Тогда 
		ТНОбъект = Документы.ТребованиеНакладная.СоздатьДокумент();
		ТЗ_ТоварыДляТН = ТЗ_Брак.Скопировать();
		ТЗ_ТоварыДляТН.Свернуть("Номенклатура", "Количество");
		ОбработкаОбъект.СформироватьТребованиеНакладную(ТНОбъект, СтруктураПараметров.Заказ, ТЗ_ТоварыДляТН);
		ЕстьТН = Истина;
	КонецЕсли;
	
	ЗаказОбъект = СтруктураПараметров.Заказ.ПолучитьОбъект();
	
	Если ВыполнятьВозвратВМагПей Тогда
		
		ТЗ_ТоварыКВозвратуМагПей = ТоварыПоОперациямМагПей.Выгрузить();
		ТЗ_ТоварыКВозвратуМагПей.Очистить();
		ТЗ_ТоварыПоОперациямМагПей = ТоварыПоОперациямМагПей.Выгрузить(); 
		ТЗ_ТоварыКВозврату = ТЗ_Возврат.Скопировать();
		ТЗ_ТоварыКВозврату.Свернуть("Номенклатура, Марка, Цена", "Количество");
		
		Для Каждого СтрокаВозврата Из ТЗ_ТоварыКВозврату Цикл
			
			//СтрокаВозврата.Марка = СтрЗаменить(СтрокаВозврата.Марка, "\u001d", "");
			
			НайденныеСтроки = ТЗ_ТоварыПоОперациямМагПей.НайтиСтроки(Новый Структура("Номенклатура, Марка", СтрокаВозврата.Номенклатура, СтрокаВозврата.Марка));
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл

				Если СтрокаВозврата.Количество = 0 Тогда
					//уже распределили
					Продолжить;
				КонецЕсли;
				
				НС = ТЗ_ТоварыКВозвратуМагПей.Добавить();
				ЗаполнитьЗначенияСвойств(НС, НайденнаяСтрока);
				НС.Цена = СтрокаВозврата.Цена;
				Если НайденнаяСтрока.Количество >= СтрокаВозврата.Количество Тогда
					НС.Количество = СтрокаВозврата.Количество;
					СтрокаВозврата.Количество = 0;
				Иначе
					СтрокаВозврата.Количество = СтрокаВозврата.Количество - НС.Количество;
				КонецЕсли;
				
			КонецЦикла;
			
		КонецЦикла;
		
		ЧасовойПоясСервера = ОбщегоНазначенияСерверПовтИсп.ЗначениеКонстанты("ЧасовойПоясСервера");
		СмещениеВремени = 0;
		Если ТипЗнч(ЧасовойПоясСервера) = Тип("Число") Тогда
			СмещениеВремени = ЧасовойПоясСервера * 3600;
		КонецЕсли; 
		
		СерверМП = ОбщегоНазначенияСерверПовтИсп.ЗначениеКонстанты("СерверМагпей");
		АпиКлючМП = ОбщегоНазначенияСерверПовтИсп.ЗначениеКонстанты("АпиКлючMagPay");
		
		Запрос = Новый Запрос;
		Запрос.Текст = "ВЫБРАТЬ
		               |	ВЫРАЗИТЬ(ТоварыКВозврату.УИДНоменклатуры КАК СТРОКА(36)) КАК УИДНоменклатуры,
		               |	ВЫРАЗИТЬ(ТоварыКВозврату.Номенклатура КАК Справочник.Номенклатура) КАК Номенклатура,
		               |	ВЫРАЗИТЬ(ТоварыКВозврату.Марка КАК СТРОКА(100)) КАК Марка,
		               |	ВЫРАЗИТЬ(ТоварыКВозврату.Количество КАК ЧИСЛО(15, 3)) КАК Количество,
		               |	ВЫРАЗИТЬ(ТоварыКВозврату.Цена КАК ЧИСЛО(15, 2)) КАК Цена,
		               |	ВЫРАЗИТЬ(ТоварыКВозврату.rrn КАК СТРОКА(50)) КАК rrn,
		               |	ВЫРАЗИТЬ(ТоварыКВозврату.merchant_id КАК СТРОКА(50)) КАК merchant_id,
		               |	ВЫРАЗИТЬ(ТоварыКВозврату.terminal_id КАК СТРОКА(50)) КАК terminal_id,
		               |	ВЫРАЗИТЬ(ТоварыКВозврату.auth_code КАК СТРОКА(50)) КАК auth_code
		               |ПОМЕСТИТЬ ТЗ_ТоварыКВозврату
		               |ИЗ
		               |	&ТоварыКВозврату КАК ТоварыКВозврату
		               |;
		               |
		               |////////////////////////////////////////////////////////////////////////////////
		               |ВЫБРАТЬ
		               |	ТЗ_ТоварыКВозврату.УИДНоменклатуры КАК УИДНоменклатуры,
		               |	ТЗ_ТоварыКВозврату.Номенклатура,
		               |	ТЗ_ТоварыКВозврату.Марка КАК Марка,
		               |	ТЗ_ТоварыКВозврату.Количество КАК Количество,
		               |	ТЗ_ТоварыКВозврату.Цена КАК Цена,
		               |	ТЗ_ТоварыКВозврату.rrn КАК rrn,
		               |	ТЗ_ТоварыКВозврату.merchant_id КАК merchant_id,
		               |	ТЗ_ТоварыКВозврату.terminal_id КАК terminal_id,
		               |	ТЗ_ТоварыКВозврату.auth_code КАК auth_code,
		               |	ВЫРАЗИТЬ(ТЗ_ТоварыКВозврату.Количество * ТЗ_ТоварыКВозврату.Цена КАК ЧИСЛО(15, 2)) КАК Сумма
		               |ИЗ
		               |	ТЗ_ТоварыКВозврату КАК ТЗ_ТоварыКВозврату
		               |ИТОГИ
		               |	СУММА(Количество),
		               |	МАКСИМУМ(merchant_id),
		               |	МАКСИМУМ(terminal_id),
		               |	МАКСИМУМ(auth_code),
		               |	СУММА(Сумма)
		               |ПО
		               |	rrn,
		               |	УИДНоменклатуры,
		               |	Марка";
	
		Запрос.УстановитьПараметр("ТоварыКВозврату", ТЗ_ТоварыКВозвратуМагПей);
		РезультатЗапроса = Запрос.Выполнить();
	
		Выборкаrrn = РезультатЗапроса.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
		Пока Выборкаrrn.Следующий() Цикл
		
			СтруктураPayment = Новый Структура;
			СтруктураPayment.Вставить("type", "CARD");
			СтруктураPayment.Вставить("sum", Выборкаrrn.Сумма);
			СтруктураPayment.Вставить("merchant_id", СокрЛП(Выборкаrrn.merchant_id));
			СтруктураPayment.Вставить("rrn", СокрЛП(Выборкаrrn.rrn));
			СтруктураPayment.Вставить("terminal_id", СокрЛП(Выборкаrrn.terminal_id));
			СтруктураPayment.Вставить("auth_code", СокрЛП(Выборкаrrn.auth_code));

			СоответствиеPositions = Новый Соответствие;

			ВыборкаИдентификаторНоменклатуры = Выборкаrrn.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
			Пока ВыборкаИдентификаторНоменклатуры.Следующий() Цикл

				СтруктураPositionКоличествоМарки = Новый Структура;
				СтруктураPositionКоличествоМарки.Вставить("quantity", ВыборкаИдентификаторНоменклатуры.Количество);
				
				МассивМарок = Новый Массив;
				ВыборкаМарка = ВыборкаИдентификаторНоменклатуры.Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);
				Пока ВыборкаМарка.Следующий() Цикл
					Если ПустаяСтрока(СокрЛП(ВыборкаМарка.Марка)) Тогда
						Продолжить;
					КонецЕсли;
					МассивМарок.Добавить(СокрЛП(ВыборкаМарка.Марка));
				КонецЦикла;
				
				Если МассивМарок.Количество() > 0 Тогда
					СтруктураPositionКоличествоМарки.Вставить("marking_items", МассивМарок);
				КонецЕсли;
				
				СоответствиеPositions.Вставить(ВыборкаИдентификаторНоменклатуры.УИДНоменклатуры, СтруктураPositionКоличествоМарки);
				
			КонецЦикла;
			
			СтруктураОтправки = Новый Структура;
			СтруктураОтправки.Вставить("timestamp", Формат(ТекущаяДата() - СмещениеВремени, "ДЛФ=DT"));
			СтруктураОтправки.Вставить("positions", СоответствиеPositions);
			СтруктураОтправки.Вставить("payment", СтруктураPayment);

			//ТелоЗапроса = JSON_1C.ЗаписатьJSON82(СтруктураОтправки);
			ТелоЗапроса = РаботаСHTTPСервисами.ЗаписьСтруктурыВJSON(СтруктураОтправки);
			ТелоЗапроса = СтрЗаменить(ТелоЗапроса, "\\u001d", "\u001d");
			//ТелоЗапроса = JSONСерверВызовСервера.СформироватьСтрокуJSON(СтруктураОтправки);
			
			ЗаголовкиHTTP = Новый Соответствие;
			ЗаголовкиHTTP.Вставить("Content-Type", "application/json");
			ЗаголовкиHTTP.Вставить("x-access-token", АпиКлючМП);
			ЗаголовкиHTTP.Вставить("Content-Charset", "utf-8");
			
			СтруктураОтвета = ИнтеграцияСервер.ВыполнитьИнтернетЗапрос("post", СерверМП + "/api/v2/order/"+Строка(ЗаказОбъект.MagPayID)+"/refund", ТелоЗапроса, ЗаголовкиHTTP);
		
			Если СтруктураОтвета.Статус <> 200 Тогда  
				СообщениеОбОшибке = "Ошибка формирования документов на возврат через АРМ ИМ:" + Символы.ПС + СтруктураОтвета.ТелоОтвета;
				ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , Заказ, СообщениеОбОшибке);
				СтруктураПараметров.Вставить("Результат", Ложь);
				СтруктураПараметров.Вставить("ОписаниеРезультата", СообщениеОбОшибке);
				Возврат;
			КонецЕсли;
		
			ЧтениеJSON = Новый ЧтениеJSON;
			ЧтениеJSON.УстановитьСтроку(СтруктураОтвета.ТелоОтвета);
			ТелоОтветаСтруктура =  ПрочитатьJSON(ЧтениеJSON, Ложь, "", ФорматДатыJSON.ISO);

			Если ТипЗнч(ТелоОтветаСтруктура) = Тип("Структура") И ТелоОтветаСтруктура.Свойство("error") Тогда
				Ошибка = "";
				Код = 0;
				Описание = "";
				Если ТелоОтветаСтруктура.Свойство("error", Ошибка) = Неопределено Тогда 
					Ошибка = НСтр("ru = 'Ошибка не определена'");
				КонецЕсли;
				Если ТелоОтветаСтруктура.Свойство("code", Код) = Неопределено Тогда 
					Код = 0;
				КонецЕсли;
				Если ТелоОтветаСтруктура.Свойство("message", Описание) = Неопределено Тогда 
					Описание = "";
				КонецЕсли;
				СообщениеОбОшибке = "Ошибка формирования документов на возврат через АРМ ИМ:" + Символы.ПС + "Ошибка: " + Ошибка + Символы.ПС + "Код: " + Код + Символы.ПС + "Описание: " + Описание;
				ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , Заказ, СообщениеОбОшибке);
				СтруктураПараметров.Вставить("Результат", Ложь);
				СтруктураПараметров.Вставить("ОписаниеРезультата", СообщениеОбОшибке);
				Возврат;
			КонецЕсли;
			
		КонецЦикла;
		
		//отправляем заказ в загрузку операций магпей
		ИмяФайлаПМ = "";
		ОбменССайтом.ВыполнитьМетодВнешнейОбработки(Неопределено, "ЗагрузитьОплатуПоЗаказуМагпей", Новый Структура("Заказ", Заказ), ИмяФайлаПМ);
		ОбменССайтом.УдалитьФайлПодключенногоМодуля(ИмяФайлаПМ);
		
		НачатьТранзакцию();
		Попытка
			Если ЕстьТН Тогда 
				ТНОбъект.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
			ЗафиксироватьТранзакцию();
		Исключение
			ОтменитьТранзакцию();
			СообщениеОбОшибке = "Ошибка формирования документов на возврат через АРМ ИМ:" + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , Заказ, СообщениеОбОшибке);
			СообщениеОбОшибке = "Ошибка формирования документов на возврат через АРМ ИМ:" + Символы.ПС + ОписаниеОшибки();
			СтруктураПараметров.Вставить("Результат", Ложь);
			СтруктураПараметров.Вставить("ОписаниеРезультата", СообщениеОбОшибке);
		КонецПопытки;
		
	Иначе
		
		ЧВОбъект = Документы.ЧекККМВозврат.СоздатьДокумент();
		ЧВОбъектСсылка = Документы.ЧекККМВозврат.ПолучитьСсылку(Новый УникальныйИдентификатор);
		ЧВОбъект.УстановитьСсылкуНового(ЧВОбъектСсылка);

		//корректируем заказ
		Результат = ОбработкаОбъект.СкорректироватьТоварыЗаказа(ЗаказОбъект, ТЗ_Возврат, СообщениеОбОшибке, ЧВОбъектСсылка);
		Если Не Результат Тогда
			СтруктураПараметров.Вставить("Результат", Ложь);
			СтруктураПараметров.Вставить("ОписаниеРезультата", СообщениеОбОшибке);
			Возврат;
		КонецЕсли;		
			
		ТЗ_ВозвратДляЧека = ТЗ_Возврат.Скопировать();
		ТЗ_ВозвратДляЧека.Свернуть("Номенклатура, Цена, СтавкаНДС, Упаковка", "Количество, КоличествоУпаковок, Сумма, СуммаНДС");
		ОбработкаОбъект.СформироватьЧекККМВозврат(ЧВОбъект, СтруктураПараметров.Заказ, ТЗ_ВозвратДляЧека);
		ЕстьЧВ = Истина;
	
		ТекущийНомерВерсии = ПолучитьТекущийНомерВерсии(Заказ);
		Если НомерВерсииПриНачалеРедактирования <> ТекущийНомерВерсии Тогда
			СтруктураПараметров.Вставить("Результат", Ложь);
			СтруктураПараметров.Вставить("ОписаниеРезультата", "Заказ был изменен другим пользователем, сохранение невозможно" + Символы.ПС + "Закройте форму и выполните операцию еще раз");
			Возврат;
		КонецЕсли;
	
		НачатьТранзакцию();
		Попытка
			ЗаказОбъект.ДополнительныеСвойства.Вставить("ПроверкаДатыЗапретаИзменения", Ложь);
		
			Если ЕстьЧВ Тогда
			
				ЧВОбъект.Записать(РежимЗаписиДокумента.Проведение);
			
				ТекстЗапроса = "ВЫБРАТЬ
				               |	ДополнительныеДанныеЧеков.НомерКассовойСмены,
				               |	ДополнительныеДанныеЧеков.ИнтернетМагазин,
				               |	ДополнительныеДанныеЧеков.КассаККМ
				               |ИЗ
				               |	РегистрСведений.ДополнительныеДанныеЧеков КАК ДополнительныеДанныеЧеков
				               |ГДЕ
				               |	ДополнительныеДанныеЧеков.Документ = &ЧекККМ";
				Запрос = Новый Запрос(ТекстЗапроса);
				Запрос.УстановитьПараметр("ЧекККМ", ЧВОбъект.ЧекККМ);
				РезультатВыборка = Запрос.Выполнить().Выбрать();
				Пока РезультатВыборка.Следующий() Цикл
					ДДЧ_МЗ = РегистрыСведений.ДополнительныеДанныеЧеков.СоздатьМенеджерЗаписи();
					ДДЧ_МЗ.Документ = ЧВОбъект.Ссылка;
					ДДЧ_МЗ.НомерКассовойСмены = РезультатВыборка.НомерКассовойСмены;
					ДДЧ_МЗ.ИнтернетМагазин = Истина;
					ДДЧ_МЗ.КассаККМ = ЧВОбъект.КассаККМ;
					ДДЧ_МЗ.Записать(Истина);
					Прервать;
				КонецЦикла;	
			
				//Данные чеков с безналичной оплатой
				МЗРС = РегистрыСведений.ДанныеЧековСБезналичнойОплатой.СоздатьМенеджерЗаписи();
				МЗРС.Период = ЧВОбъект.Дата;
				МЗРС.ФормаОплаты = Перечисления.ФормыОплаты.ПлатежнаяКарта;
				МЗРС.КассаККМ = ЧВОбъект.КассаККМ;
				МЗРС.Склад = ЧВОбъект.Склад;
				МЗРС.ЧекККМ = ЧВОбъект.Ссылка;
				МЗРС.ВитринаИнтернетМагазина = ЗаказОбъект.ВитринаИнтернетМагазина;
				МЗРС.СуммаДокумента = ЧВОбъект.СуммаДокумента;
				МЗРС.Записать();
				
				НС = ЗаказОбъект.Оплаты.Добавить();
				НС.Документ = ЧВОбъект.Ссылка;
				НС.Дата = ТекущаяДата();
				НС.СуммаДокумента = ЧВОбъект.СуммаДокумента;
				НС.Источник = Перечисления.ИсточникиФормированияЧеков.Система;
	
				//{ Константинова 03.09.25 
				РегистрыСведений.ЧекиПоЗаказамКлиента.ДобавитьЗапись(ЧВОбъект.Ссылка, СтруктураПараметров.Заказ);
				//} Константинова
			КонецЕсли;
		
			ЗаказОбъект.Записать(РежимЗаписиДокумента.Проведение);
		
			
			Если ЕстьТН Тогда 
				ТНОбъект.Записать(РежимЗаписиДокумента.Проведение);
			КонецЕсли;
		
			ЗафиксироватьТранзакцию();
			
		Исключение
			ОтменитьТранзакцию();
			СообщениеОбОшибке = "Ошибка формирования документов на возврат через АРМ ИМ:" + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ЗаписьЖурналаРегистрации("АРМ ИМ", УровеньЖурналаРегистрации.Ошибка, , Заказ, СообщениеОбОшибке);
			СообщениеОбОшибке = "Ошибка формирования документов на возврат через АРМ ИМ:" + Символы.ПС + ОписаниеОшибки();
			СтруктураПараметров.Вставить("Результат", Ложь);
			СтруктураПараметров.Вставить("ОписаниеРезультата", СообщениеОбОшибке);
		КонецПопытки;
		
	КонецЕсли;
	
КонецПроцедуры

