&НаСервере
Функция ПроверкаВыполненияЗакрытияСменИМ() Экспорт
	НаименованиеФЗ = "ЗакрытьСменыСоздатьОРП_ИМ";
	МассивФЗ = ФоновыеЗадания.ПолучитьФоновыеЗадания(Новый Структура("Состояние", СостояниеФоновогоЗадания.Активно));
