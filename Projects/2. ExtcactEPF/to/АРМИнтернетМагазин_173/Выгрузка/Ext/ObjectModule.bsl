	Возврат Ложь;	
КонецФункции

//МагПей
Функция ЗагрузитьОперацииМагПей(Заказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
	"ВЫБРАТЬ
	|	ЗаказКлиента.Ссылка,
	|	ЗаказКлиента.MagPayID
	|ИЗ
	|	Документ.ЗаказКлиента КАК ЗаказКлиента
	|ГДЕ
	|	ЗаказКлиента.Ссылка = &Заказ";
	
	Запрос.УстановитьПараметр("Заказ", Заказ);
	
	Результат = Запрос.Выполнить();
	
	ВыборкаДетальныеЗаписи = Результат.Выбрать();
	Порция = СтруктураОплаты();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Порция.Data.Добавить(Новый Структура("id", ВыборкаДетальныеЗаписи.MagPayID));
	КонецЦикла;
	
	Если Порция.Data.Количество() Тогда  
		ТекстЗапроса = JSONСерверВызовСервера.СформироватьСтрокуJSON(Порция);
		тРез = "";
		Результат = ВыполнитьЗапрос(РесурсыЗапроса().Оплата, ТекстЗапроса, "Оплата", тРез); 
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция СтруктураОплаты()
	Возврат СтруктураИзСпискаПолей("data", Новый Массив);	
КонецФункции 

Функция СтруктураИзСпискаПолей(СпискоПолейСтрока, Значение = Неопределено) Экспорт
	
	Структура = Новый СТруктура;
	МассивПОлей = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(СпискоПолейСтрока, ",");
	ДЛя Каждого ИмяПоля Из МассивПОлей Цикл
		
		Структура.Вставить(СокрЛП(ИмяПоля), Значение);
		
	КонецЦикла;
	
	Возврат Структура;
	
КонецФункции

Функция РесурсыЗапроса() Экспорт
	
	Ресурсы = Новый Структура;
	
	
	Ресурсы.Вставить("УдалитьКассиров", "cashiers/delete");
	//Команда на удаление списка кассиров
	
	Ресурсы.Вставить("СоздатьЗаказы", "orders");
	//Команда на сохранение списка заказов
	
	Ресурсы.Вставить("УдалитьЗаказы", "orders/delete");
	//Команда на удаление списка заказов
	
	Ресурсы.Вставить("Оплата", "orders/report");
	//Команда на получение отчета по оплате
	
	Ресурсы.Вставить("СоздатьОрганизации", "organizations");
	//Команда на сохранение списка организаций.
	
	Ресурсы.Вставить("УдалитьОрганизации", "organizations/delete");
	//Команда на удаление списка организаций.
	
	Ресурсы.Вставить("Маршрут", "schedule");
	//Команда на сохранение расписания
	
	Ресурсы.Вставить("УдалитьМаршрут", "schedule/delete");
	//Команда на удаление расписания
	
	Ресурсы.Вставить("УдалитьОрганизации", "organizations/delete");
	
	Ресурсы.Вставить("ЗаблокироватьЗаказы", "orders/lock");
	//Команда заблокировать заказы
	
	Ресурсы.Вставить("РазблокироватьЗаказы", "orders/unlock");
	//Команда разблокировать заказы
	
	Возврат Ресурсы;
	
КонецФункции

Функция ВыполнитьЗапрос(Ресурс, ТекстЗапроса, ИмяЗапроса = "", тРез = "") Экспорт
	
	//тестовый сервер магпей "https://pay2.k.dev.magdv.com"
	//тестовый токен camelot-1c-0123456789
	//боевой сервер магпей "https://pay2.magonline.ru"     
	//боевой токен gab5933MrtVHDyVHXWMK9g5ttZqSqx32Vzd6UxvvMWrqN63uY5xBhzBcWyJ9C74U

	ИспользоватьWinHTTP = Ложь;
	Ресурс = "/api/v2/" + Ресурс;
	СерверМП = ОбщегоНазначенияСерверПовтИсп.ЗначениеКонстанты("СерверМагпей");
	
	ЗаписьЖурналаРегистрации("ИМ.MagPay.HTTPОтправка", УровеньЖурналаРегистрации.Информация, , , Ресурс + Символы.ПС + ТекстЗапроса);
	
	ЗаголовокHTTP = Новый Соответствие();
	ЗаголовокHTTP.Вставить("Content-Type", "application/json");
	ЗаголовокHTTP.Вставить("x-access-token", ОбщегоНазначенияСерверПовтИсп.ЗначениеКонстанты("АпиКлючMagPay"));
	ЗаголовокHTTP.Вставить("Content-Charset", "utf-8");
	
	Если ИспользоватьWinHTTP Тогда
	
		WinHttp = Новый COMОбъект("WinHttp.WinHttpRequest.5.1");
		WinHttp.Open("POST", СерверМП + Ресурс);
		Для Каждого КлючЗначение Из ЗаголовокHTTP Цикл
			WinHttp.SetRequestHeader(КлючЗначение.Ключ, КлючЗначение.Значение);
		КонецЦикла;

		Попытка
			WinHttp.Send(ТекстЗапроса);//ФайлОтправки);
		Исключение
			Сообщить(ОписаниеОшибки());
		КонецПопытки;
	
		тРез = WinHttp.ResponseText();
		СтатусВыполненияЗапроса = WinHttp.Status;
		
	Иначе
		
		HTTPОтвет = Неопределено;
		Таймаут = 0;

		HTTPЗапрос 	= Новый HTTPЗапрос();
		HTTPЗапрос.АдресРесурса = Ресурс;
		HTTPЗапрос.Заголовки = ЗаголовокHTTP; 
		HTTPЗапрос.УстановитьТелоИзСтроки(ТекстЗапроса, "CESU-8");
		
		ИспользоватьSSL = Ложь;
		Если Лев(НРег(СерверМП), 5) = "https" Тогда
			ИспользоватьSSL = Истина; 
			СерверМП = СтрЗаменить(НРег(СерверМП), "https://", "");
		Иначе
			СерверМП = СтрЗаменить(НРег(СерверМП), "http://", "");
		КонецЕсли;
		
		Прокси = Новый ИнтернетПрокси;
	
		Если ИспользоватьSSL Тогда
			ssl = Новый ЗащищенноеСоединениеOpenSSL;
			СоединениеССайтом = Новый HTTPСоединение(СерверМП, , , ,Прокси,Таймаут,ssl);
		Иначе
			СоединениеССайтом = Новый HTTPСоединение(СерверМП, , , ,Прокси,Таймаут);
		КонецЕсли;
		
		Попытка
			HTTPОтвет = СоединениеССайтом.ОтправитьДляОбработки(HTTPЗапрос);
		Исключение  
			ПредставлениеОшибки = "Текст JSON: " + Символы.ПС + тРез + Символы.ПС + "Текст ошибки: " + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
			ТекстСообщенияЖР = "ВыполнитьЗапрос." + Символы.ПС + Строка(ПараметрыСеанса.ТекущийПользователь) + Символы.ПС + ПредставлениеОшибки;
			ОбщегоНазначения.ЗаписатьОшибкуВЖурналРегистрации("ИМ.АРМДанныеОплаты", ТекстСообщенияЖР); 
			ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
			Возврат Неопределено;
		КонецПопытки;
		
		Если HTTPОтвет = Неопределено Тогда
			ПредставлениеОшибки = "Текст JSON: " + Символы.ПС + тРез + Символы.ПС + "Текст ошибки: Получен http ответ - Неопределено";
			ТекстСообщенияЖР = "ВыполнитьЗапрос." + Символы.ПС + Строка(ПараметрыСеанса.ТекущийПользователь) + Символы.ПС + ПредставлениеОшибки;
			ОбщегоНазначения.ЗаписатьОшибкуВЖурналРегистрации("ИМ.АРМДанныеОплаты", ТекстСообщенияЖР); 
			Возврат Неопределено;
		КонецЕсли;
		
		СтатусВыполненияЗапроса = HTTPОтвет.КодСостояния;
		
		тРез = HTTPОтвет.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
		Если тРез = Неопределено Тогда	
			ПутьКФайлу = HTTPОтвет.ПолучитьИмяФайлаТела();
			ТекстовыйФайл = Новый ТекстовыйДокумент;
			ТекстовыйФайл.Прочитать(ПутьКФайлу,КодировкаТекста.UTF8);
			тРез = ТекстовыйФайл.ПолучитьТекст();
			Файл = Новый Файл(ПутьКФайлу);
			Если Файл.Существует() Тогда
				УдалитьФайлы(ПутьКФайлу);
			КонецЕсли;
		КонецЕсли;
		
	КонецЕсли;
	
	Если Не СтатусВыполненияЗапроса = 200 Тогда
		ПредставлениеОшибки = ПолучитьПредставлениеОшибки(тРез);
		Если ПредставлениеОшибки = Неопределено Тогда
			ПредставлениеОшибки = тРез;
		КонецЕсли;
		ПредставлениеОшибки = "Текст JSON: " + Символы.ПС + тРез + Символы.ПС + "Текст ошибки: " + Символы.ПС + ПредставлениеОшибки;
		ТекстСообщенияЖР = "ВыполнитьЗапрос." + Символы.ПС + Строка(ПараметрыСеанса.ТекущийПользователь) + Символы.ПС + ПредставлениеОшибки;
		ОбщегоНазначения.ЗаписатьОшибкуВЖурналРегистрации("ИМ.АРМДанныеОплаты", ТекстСообщенияЖР); 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ПредставлениеОшибки);
		Возврат Неопределено;
	КонецЕсли;
	
	Попытка
		Если ИспользоватьWinHTTP Тогда
			Текст = новый ТекстовыйДокумент;
			Текст.УстановитьТекст(тРез);
			ИмяВФ = ПолучитьИмяВременногоФайла("txt"); 
			Текст.Записать(ИмяВФ, "iso-8859-1");
			Текст.Прочитать(ИмяВФ, КодировкаТекста.UTF8);
			тРез = Текст.ПолучитьТекст();
		КонецЕсли;
		Ответ = JSONСерверВызовСервера.ПрочитатьJSON82(тРез, Истина, Ложь, Ложь);
	Исключение
		ПредставлениеОшибки = "Текст JSON: " + Символы.ПС + тРез + Символы.ПС + "Текст ошибки: " + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		ТекстСообщенияЖР = "ВыполнитьЗапрос." + Символы.ПС + Строка(ПараметрыСеанса.ТекущийПользователь) + Символы.ПС + ПредставлениеОшибки;
		ОбщегоНазначения.ЗаписатьОшибкуВЖурналРегистрации("ИМ.АРМДанныеОплаты", ТекстСообщенияЖР); 
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(КраткоеПредставлениеОшибки(ИнформацияОбОшибке()));
		Возврат Неопределено;
	КонецПопытки;
	
	Возврат Ответ;
	
КонецФункции

Функция ПолучитьПредставлениеОшибки(СтрокаИсходная)
	Если ЭтоHTML(СтрокаИсходная) Тогда
		НачалоЗаголовка = Найти(НРег(СтрокаИсходная),"<title>");
		КонецЗаголовка = Найти(НРег(СтрокаИсходная),"</title>");
		Если НачалоЗаголовка > 0 И КонецЗаголовка > 0 Тогда
			НачалоЗаголовка = НачалоЗаголовка + 7;
			СтрокаОшибки = Сред(СтрокаИсходная, НачалоЗаголовка, КонецЗаголовка - НачалоЗаголовка);
			Если Лев(СтрокаОшибки, 3) = "503" Тогда //исключаем этот спам
				Возврат Неопределено;
			КонецЕсли;
			Возврат Сред(СтрокаИсходная, НачалоЗаголовка, КонецЗаголовка - НачалоЗаголовка);
		Иначе
			Возврат СтрокаИсходная;
		КонецЕсли;
	Иначе
		Возврат СтрокаИсходная;
	КонецЕсли;
КонецФункции

Функция ЭтоHTML(ИсходнаяСтрока)
	Возврат Найти(НРег(ИсходнаяСтрока), "<html>")>0 И Найти(НРег(ИсходнаяСтрока), "</html>")>0;
КонецФункции

&НаСервереБезКонтекста
Функция ПолучитьЦенуНоменклатуры(Номенклатура, ВидЦены)
	
	Цена = 0;
	Запрос = Новый Запрос;
	Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена
	               |ИЗ
	               |	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
	               |			&ТекДата,
	               |			Номенклатура = &Номенклатура
	               |				И ВидЦены = &ВидЦены) КАК ЦеныНоменклатурыСрезПоследних";
	
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ТекДата", ТекущаяДата());
	
	РезультатЗапроса = Запрос.Выполнить();
	ВыборкаДетальныеЗаписи = РезультатЗапроса.Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Цена = ВыборкаДетальныеЗаписи.Цена;
	КонецЦикла;
	
	Возврат Цена;
	
КонецФункции


