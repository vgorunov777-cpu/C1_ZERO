Процедура ОтправитьНаПочту(ТемаСообщения, Текст, Вложение = "") Экспорт
		
	Текст = "Время: " + Формат(ТекущаяДата(),"ДФ=дд.ММ.гггг ЧЧ:мм") + Символы.ПС +
		"Модуль: " + ЭтотОбъект.Метаданные().Синоним + Символы.ПС + 
		"Версия: " + ЭтотОбъект.Метаданные().Комментарий + Символы.ПС + Текст;
	Текст = ВернутьТелоПисьма(Текст);
	
	Если НЕ Вложение = "" Тогда
		
		ИмяТД = ПолучитьИмяВременногоФайла("txt");
		ТД = Новый ТекстовыйДокумент;
		ТД.УстановитьТекст(Вложение);
		ТД.Записать(ИмяТД);
		Вложения = Новый Массив;
		Вложения.Добавить(ИмяТД);
	
		ИнтеграцияСервер.ОтправитьУведомлениеНаПочту(Текст, ТемаСообщения, М, , , , Вложения, , , , ТипТекстаПочтовогоСообщения.HTML);
	
		УдалитьФайлы(ИмяТД);
		
	Иначе
		
		ИнтеграцияСервер.ОтправитьУведомлениеНаПочту(Текст, ТемаСообщения, М, , , , , , , , ТипТекстаПочтовогоСообщения.HTML);
		
	КонецЕсли;		
	
КонецПроцедуры

Функция ОтправитьСМС(Абоненты, Сообщение) Экспорт 
	
	МассивАбонентов = СтроковыеФункцииКлиентСервер.РазложитьСтрокуВМассивПодстрок(Абоненты);
	
	МассивРезультатов = Новый Массив;
	
	//*** Отправка СМС через МТС Маркетолог ***
	СтруктураНастроек = Новый Структура;
	СтруктураНастроек.Вставить("Сервер"			, "https://omnichannel.mts.ru/http-api/v1/messages");
	СтруктураНастроек.Вставить("Имя"			, "gw_rwTKNj2S7OFY");
	СтруктураНастроек.Вставить("Пароль"			, "Hsg1Pkis");
	СтруктураНастроек.Вставить("Токен"			, "273cd385-910d-388d-9181-ce3ce8057d87");
	СтруктураНастроек.Вставить("Нейминг"		, "Yarche");
	
	//если более 10 сообщений в 1 запросе, рекомендуется отправка в буфер
	Если МассивАбонентов.Количество() > 10 Тогда
		СтруктураНастроек.Сервер = "https://omnichannel.mts.ru/http-api/v1/b/messages/";
	КонецЕсли;
	
	Заголовки = Новый Соответствие;
	Заголовки.Вставить("Authorization","Basic " + ПреобразоватьСтрокуВBase64(СтруктураНастроек.Имя+":"+СтруктураНастроек.Пароль));
	Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	
	Если Час(ТекущаяДата()) < 7 Тогда
		Для Каждого Абонент Из МассивАбонентов Цикл
			СтруктураВозврата = Новый Структура;
			СтруктураВозврата.Вставить("Абонент", Абонент);
			СтруктураВозврата.Вставить("Результат"	, Ложь);
			СтруктураВозврата.Вставить("Комментарий", "Запрет отправки СМС с 00:00 до 07:00");
			МассивРезультатов.Добавить(СтруктураВозврата);
		КонецЦикла;
		Возврат МассивРезультатов;		
	КонецЕсли;
	
	СтруктураОтправки = Новый Структура;
	МассивСообщений = Новый Массив;
	
	Для Каждого Абонент Из МассивАбонентов Цикл
		
		ОчередноеСообщение = Новый Структура;
		ОчередноеСообщение.Вставить("content", Новый Структура("short_text", Сообщение));
		ОчередноеСообщение.Вставить("from", Новый Структура("sms_address", СтруктураНастроек.Нейминг));
		МассивАдресата = Новый Массив;
		МассивАдресата.Добавить(Новый Структура("msisdn, message_id", Абонент, Строка(Новый УникальныйИдентификатор)));
		ОчередноеСообщение.Вставить("to", МассивАдресата);
		МассивСообщений.Добавить(ОчередноеСообщение);
	
	КонецЦикла;
	
	СтруктураОтправки.Вставить("messages", МассивСообщений);
	СтрокаJSON = JSON_1C.ЗаписатьJSON82(СтруктураОтправки);
	
	HTTPОтвет = Неопределено;
	ОписаниеОшибкиОтправкиЗапроса = "";
	
	Таймаут = 0;
	//Таймаут = 10000;
	
	WinHttp = Новый COMОбъект("WinHttp.WinHttpRequest.5.1");
	Если Таймаут > 0 Тогда
		WinHttp.SetTimeouts(Таймаут, Таймаут, Таймаут, Таймаут);
	КонецЕсли;
	
	WinHttp.Open("POST", СтруктураНастроек.Сервер);
		
	Для Каждого КлючЗначение Из Заголовки Цикл
		WinHttp.SetRequestHeader(КлючЗначение.Ключ, КлючЗначение.Значение);
	КонецЦикла;
	
	сч = 1;
	ЧислоПопыток = 3;
	Пока сч < ЧислоПопыток Цикл
		Попытка
			WinHttp.Send(СтрокаJSON);
			HTTPОтвет = Новый Структура;
			HTTPОтвет.Вставить("КодСостояния", WinHttp.Status);
			HTTPОтвет.Вставить("ТекстОтвета", WinHttp.ResponseText());
			Прервать;
		Исключение
			ОписаниеОшибкиОтправкиЗапроса = ОписаниеОшибки();
			сч = сч + 1;
		КонецПопытки;
	КонецЦикла;

	ОтправленоАбонентам = новый Массив;
	РезультатОтправки = Истина;
	Комментарий = "";
	
	Если HTTPОтвет = Неопределено Тогда
		
		РезультатОтправки = Ложь;
		
		СЗ = Новый СписокЗначений;
		СЗ.ЗагрузитьЗначения(МассивАбонентов);
		ОтправленоАбонентам = СЗ.ВыгрузитьЗначения();
		
		Комментарий = ОписаниеОшибкиОтправкиЗапроса;
		
	ИначеЕсли HTTPОтвет.КодСостояния <> 200 Тогда
		
		РезультатОтправки = Ложь;
		
		СЗ = Новый СписокЗначений;
		СЗ.ЗагрузитьЗначения(МассивАбонентов);
		ОтправленоАбонентам = СЗ.ВыгрузитьЗначения();
		
		ОтветСервера = JSON_1C.ПрочитатьJSON82(HTTPОтвет.ТекстОтвета);
		Если ТипЗнч(ОтветСервера) = Тип("Соответствие") Тогда
			Комментарий = ОтветСервера.Получить("message");
		ИначеЕсли ТипЗнч(ОтветСервера) = Тип("Структура") Тогда
			ОтветСервера.Свойство("message", Комментарий);
		Иначе
			Комментарий = "Ошибка отправки СМС";
		КонецЕсли;
		
	Иначе
		
		ОтветСервера = JSON_1C.ПрочитатьJSON82(HTTPОтвет.ТекстОтвета);
		ОтправленоАбонентам = новый Массив;
		МассивОтветов = Новый Массив;
		Если ТипЗнч(ОтветСервера) = Тип("Соответствие") Тогда
			МассивОтветов = ОтветСервера.Получить("messages");
		ИначеЕсли ТипЗнч(ОтветСервера) = Тип("Структура") Тогда
			ОтветСервера.Свойство("messages", МассивОтветов);
		КонецЕсли;
		Если ТипЗнч(МассивОтветов) = Тип("Массив") Тогда
			Для Каждого ЭлементОтвет Из МассивОтветов Цикл
				Если ТипЗнч(ЭлементОтвет) = Тип("Соответствие") Тогда
					ОтправленоАбонентам.Добавить(ЭлементОтвет.Получить("msisdn"));
				ИначеЕсли ТипЗнч(ЭлементОтвет) = Тип("Структура") Тогда
					msisdn = "";
					ЭлементОтвет.Свойство("msisdn", msisdn);
					ОтправленоАбонентам.Добавить(msisdn);
				КонецЕсли;
			КонецЦикла;
		КонецЕсли;
		
		Комментарий = "Отправлено";
		
	КонецЕсли;
	
	Для Каждого Абонент Из ОтправленоАбонентам Цикл
		СтруктураВозврата = Новый Структура;
		СтруктураВозврата.Вставить("Абонент", Абонент);
		СтруктураВозврата.Вставить("Результат", РезультатОтправки);
		СтруктураВозврата.Вставить("Комментарий", Комментарий);
		МассивРезультатов.Добавить(СтруктураВозврата);
	КонецЦикла;
	
	Возврат МассивРезультатов;
	
КонецФункции

Функция ПреобразоватьСтрокуВBase64(ИсходнаяСтрока)
	
	ВременныйФайл = ПолучитьИмяВременногоФайла();
    Запись = Новый ЗаписьТекста(ВременныйФайл);
    Запись.Записать(ИсходнаяСтрока);
    Запись.Закрыть();
    
    ДвДанные = Новый ДвоичныеДанные(ВременныйФайл);
    СтрокаBase64 = Base64Строка(ДвДанные);
	СтрокаBase64 = СтрЗаменить(СтрокаBase64, "77u/", "");
	СтрокаBase64 = СтрЗаменить(СтрокаBase64, Символы.ПС, "");
	
	Попытка
    	УдалитьФайлы(ВременныйФайл);	
	Исключение
	КонецПопытки;
	
	Возврат СтрокаBase64;
	
КонецФункции

