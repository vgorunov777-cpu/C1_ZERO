&НаСервере
Процедура УдалитьРеализациюПоЗаказу(ЗаказСсылка) Экспорт
	
	УстановитьПривилегированныйРежим(Истина);
	
	лТекст = "
		|ВЫБРАТЬ
		|	ДокЗаказКлиента.Ссылка КАК Заказ,
		|	ЕСТЬNULL(РеализацияТоваровУслуг.Ссылка, ЗНАЧЕНИЕ(Документ.РеализацияТоваровУслуг.ПустаяСсылка)) КАК Реализация
		|ИЗ
		|	Документ.ЗаказКлиента КАК ДокЗаказКлиента
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
		|		ПО ДокЗаказКлиента.Ссылка = РеализацияТоваровУслуг.ЗаказКлиента
		|			И НЕ РеализацияТоваровУслуг.ПометкаУдаления
		|ГДЕ
		|	ДокЗаказКлиента.Ссылка = &ЗаказКлиента
		|";
		
	лЗапрос = Новый Запрос(лТекст);
	лЗапрос.УстановитьПараметр("ЗаказКлиента", ЗаказСсылка);
	лВыборка = лЗапрос.Выполнить().Выбрать();
	Пока лВыборка.Следующий() Цикл
		РеализацияСсылка = лВыборка.Реализация;
		Если РеализацияСсылка = Документы.РеализацияТоваровУслуг.ПустаяСсылка() Тогда
			Продолжить;
		КонецЕсли;
		РеализацияОбъект = РеализацияСсылка.ПолучитьОбъект();
		РеализацияОбъект.ДополнительныеСвойства.Вставить("ОтключитьМеханизмБлокировкиОтгруженныхДокументов", Истина);
		РеализацияОбъект.ДополнительныеСвойства.Вставить("НеКонтролироватьРезультатыПроведения", Истина);
		РеализацияОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
		РеализацияОбъект.УстановитьПометкуУдаления(Истина);
	КонецЦикла;
	
КонецПроцедуры

Функция ПолучитьТекущийНомерВерсии(Заказ) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЕСТЬNULL(МАКСИМУМ(ВерсииОбъектов.НомерВерсии), 0) КАК НомерВерсии
		|ИЗ
		|	РегистрСведений.ВерсииОбъектов КАК ВерсииОбъектов
		|ГДЕ
		|	ВерсииОбъектов.Объект = &Заказ
		|	И ВерсииОбъектов.Объект ССЫЛКА Документ.ЗаказКлиента";

	Запрос.УстановитьПараметр("Заказ", Заказ);
	ВыборкаДетальныеЗаписи = Запрос.Выполнить().Выбрать();
	Пока ВыборкаДетальныеЗаписи.Следующий() Цикл
		Возврат ВыборкаДетальныеЗаписи.НомерВерсии;
	КонецЦикла;

	Возврат 0;
	
КонецФункции

//Методы возврат

//Отмечаются товары из СписокТоваровВозврат как отмененные
//	ДокументОбъект - Объект документа (заказ клиента)
//	СписокТоваровВозврат - вход: ТЗ (Номенклатура, Количество, КоличествоШтук, ПричинаОтмены)
//	СписокТоваровВозврат - выход: ТЗ (Номенклатура, Количество, КоличествоШтук, ПричинаОтмены, Упаковка, Цена, КоличествоУпаковок, Сумма, СтавкаНДС, СуммаНДС)
//	ОписаниеРезультата - Текстовое представление ошибки
//Возврат: Булево
&НаСервере
Функция СкорректироватьТоварыЗаказа(ДокументОбъект, СписокТоваровВозврат, ОписаниеРезультата, СсылкаНаДокументПродажи = Неопределено) Экспорт

	Если СсылкаНаДокументПродажи = Неопределено Тогда
		СсылкаНаДокументПродажи = Документы.ЧекККМ.ПустаяСсылка();
	КонецЕсли;
	
	Если ТипЗнч(ДокументОбъект) = Тип("ДокументОбъект.ЗаказКлиента") Тогда
		
		СписокТоваровВозврат.Колонки.Добавить("Упаковка");
		СписокТоваровВозврат.Колонки.Добавить("КоличествоУпаковок");
		СписокТоваровВозврат.Колонки.Добавить("Сумма");
		СписокТоваровВозврат.Колонки.Добавить("СтавкаНДС");
		СписокТоваровВозврат.Колонки.Добавить("СуммаНДС");
		
		//Товары
		Для Каждого СтрокаТовар Из ДокументОбъект.Товары Цикл
			
			Если СтрокаТовар.Отменено ИЛИ СтрокаТовар.ПричинаОтмены <> Справочники.ПричиныОтменыЗаказовКлиентов.ПустаяСсылка() Тогда
				Продолжить;
			КонецЕсли;
			
			Если СтрокаТовар.КоличествоУпаковок = 0 ИЛИ СтрокаТовар.Количество = 0 Тогда
				КоэфУпаковки = 1;
			Иначе
				КоэфУпаковки = СтрокаТовар.Количество / СтрокаТовар.КоличествоУпаковок;
			КонецЕсли;
			
			СтруктураОтбора = Новый Структура;
			СтруктураОтбора.Вставить("Номенклатура", СтрокаТовар.Номенклатура);
			НайденныеСтроки = СписокТоваровВозврат.НайтиСтроки(СтруктураОтбора);
			
			Для Каждого НайденнаяСтрока Из НайденныеСтроки Цикл
				
				КоличествоУпаковокВозврат = НайденнаяСтрока.Количество;
				КоличествоВозврат = НайденнаяСтрока.Количество * КоэфУпаковки;
				КоличествоШтукВозврат = НайденнаяСтрока.КоличествоШтук;
				
				Если КоличествоВозврат > СтрокаТовар.Количество Тогда
					
					ОписаниеРезультата = "Для " + СтрокаТовар.Номенклатура + " количество к возврату больше чем продано";
					Возврат Ложь;
					
				ИначеЕсли КоличествоВозврат = СтрокаТовар.Количество Тогда
				
					СтрокаТовар.Отменено = Истина;
					СтрокаТовар.ПричинаОтмены = НайденнаяСтрока.ПричинаОтмены;
					
				Иначе
					
					НС = ДокументОбъект.Товары.Добавить();
					ЗаполнитьЗначенияСвойств(НС, СтрокаТовар);
					
					НовоеКоличество = СтрокаТовар.Количество - КоличествоВозврат;
					НовоеКоличествоУпаковок = СтрокаТовар.КоличествоУпаковок - КоличествоУпаковокВозврат;
					НовоеКоличествоШтук = СтрокаТовар.КоличествоШтук - КоличествоШтукВозврат;
					
					СтрокаТовар.Количество 			= НовоеКоличество;
					СтрокаТовар.КоличествоШтук 		= НовоеКоличествоШтук;
					СтрокаТовар.КоличествоУпаковок 	= НовоеКоличествоУпаковок;
					СтрокаТовар.Сумма 				= СтрокаТовар.Цена * НовоеКоличествоУпаковок;
					СтрокаТовар.СуммаНДС 			= Ценообразование.РассчитатьСуммуНДС(СтрокаТовар.Сумма, СтрокаТовар.СтавкаНДС, Истина);
					
					НС.Количество 					= КоличествоВозврат;
					НС.КоличествоШтук 				= КоличествоШтукВозврат;
					НС.КоличествоУпаковок 			= КоличествоУпаковокВозврат;
					НС.Сумма		 				= НС.Цена * КоличествоУпаковокВозврат;
					НС.СуммаНДС 					= Ценообразование.РассчитатьСуммуНДС(НС.Сумма, НС.СтавкаНДС, Истина);
					НС.Отменено 					= Истина;
					НС.ПричинаОтмены 				= НайденнаяСтрока.ПричинаОтмены;
					
				КонецЕсли;
				
				НайденнаяСтрока.Упаковка			= СтрокаТовар.Упаковка;
				НайденнаяСтрока.Цена 				= СтрокаТовар.Цена;
				НайденнаяСтрока.КоличествоУпаковок 	= КоличествоУпаковокВозврат;
				НайденнаяСтрока.Количество			= КоличествоВозврат;
				НайденнаяСтрока.Сумма			 	= СтрокаТовар.Цена * КоличествоУпаковокВозврат;
				НайденнаяСтрока.СтавкаНДС		 	= СтрокаТовар.СтавкаНДС;
				НайденнаяСтрока.СуммаНДС		 	= Ценообразование.РассчитатьСуммуНДС(НайденнаяСтрока.Сумма, СтрокаТовар.СтавкаНДС, Истина);
				
				//удаление марок
				НайденныеАкцизныеМарки = ДокументОбъект.АкцизныеМарки.НайтиСтроки(Новый Структура("Марка", НайденнаяСтрока.Марка));
				Для Каждого НайденнаяАкцизнаяМарка Из НайденныеАкцизныеМарки Цикл
					НайденнаяАкцизнаяМарка.Отменено = Истина;
					НайденнаяАкцизнаяМарка.ДокументПродажи = СсылкаНаДокументПродажи;
				КонецЦикла;
				
			КонецЦикла;
			
		КонецЦикла;
		
		ДокументОбъект.Комментарий = ДокументОбъект.Комментарий + ?(ЗначениеЗаполнено(ДокументОбъект.Комментарий), Символы.ПС, "") 
												+ Формат(ТекущаяДата(), "ДФ='dd.MM.yyyy HH:mm:ss'") + " " + Строка(ПараметрыСеанса.ТекущийПользователь) + " - " + "Оформление возврата от клиента";  
		ДокументОбъект.СуммаДокумента = ДокументОбъект.ПолучитьСуммуЗаказанныхСтрок();
		ДокументОбъект.ЗаполнитьЭтапыГрафикаОплаты();     
		ДокументОбъект.ДополнительныеСвойства.Вставить("ОтключитьМеханизмБлокировкиОтгруженныхДокументов", Истина);	
		ДокументОбъект.ДополнительныеСвойства.Вставить("НеКонтролироватьРезультатыПроведения", Истина);
		ДокументОбъект.ДополнительныеСвойства.Вставить("НеПроверятьДатыЗапретаИзмененияДанных", Истина);
		
	КонецЕсли;
	
	Возврат Истина;
	
КонецФункции

//Формирует возврат от клиента на товары СписокТоваровВозврат
//	ДокументОбъект - документ Возврат от клиента объект
//	ЗаказСсылка - ссылка на заказ
//	ОРПСсылка - ссылка на ОРП (можно пустую)
//	СписокТоваровВозврат - ТЗ (Номенклатура, Количество, КоличествоШтук, ПричинаОтмены, Упаковка, Цена, КоличествоУпаковок, Сумма, СтавкаНДС, СуммаНДС)
&НаСервере
Процедура СформироватьВозвратОтКлиента(ДокументОбъект, ЗаказСсылка, ОРПСсылка, СписокТоваровВозврат) Экспорт
	
	ДокументОбъект.Дата 				= ТекущаяДата();
	ДокументОбъект.Организация			= ЗаказСсылка.Организация;
	ДокументОбъект.Партнер				= ЗаказСсылка.Партнер;
	ДокументОбъект.Контрагент			= ЗаказСсылка.Контрагент;
	ДокументОбъект.Соглашение			= ЗаказСсылка.Соглашение;
	ДокументОбъект.Сделка				= ЗаказСсылка.Сделка;
	ДокументОбъект.Валюта				= ЗаказСсылка.Валюта;
	ДокументОбъект.Склад				= ЗаказСсылка.Склад;
	ДокументОбъект.ЦенаВключаетНДС		= ЗаказСсылка.ЦенаВключаетНДС;
	ДокументОбъект.Подразделение		= Справочники.СтруктураПредприятия.НайтиПоНаименованию("Камелот – А");
	ДокументОбъект.Менеджер 			= ПараметрыСеанса.ТекущийПользователь;
	ДокументОбъект.Комментарий			= "Возврат по заказу ИМ: " + ЗаказСсылка;
	ДокументОбъект.ДокументРеализации 	= ОРПСсылка;
	ДокументОбъект.НалогообложениеНДС	= ЗаказСсылка.НалогообложениеНДС;
	ДокументОбъект.ХозяйственнаяОперация= Перечисления.ХозяйственныеОперации.ВозвратОтРозничногоПокупателя;
	ДокументОбъект.ЧекККМ				= ЗаказСсылка.ЧекПродажа;
	
	Для Каждого СтрокаТЗ Из СписокТоваровВозврат Цикл
		
		НСТовары = ДокументОбъект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НСТовары, СтрокаТЗ);
		
		НСВидыЗапасов = ДокументОбъект.ВидыЗапасов.Добавить();
		ЗаполнитьЗначенияСвойств(НСВидыЗапасов, СтрокаТЗ);
		
		НСВидыЗапасов.СкладОтгрузки = ЗаказСсылка.Склад;
		НСВидыЗапасов.ВидЗапасов = Справочники.ВидыЗапасов.ПустаяСсылка();
		НСВидыЗапасов.СуммаСНДС = СтрокаТЗ.Сумма;
		
		ТекстЗапроса = "
			|ВЫБРАТЬ ПЕРВЫЕ 1
			|	ВидыЗапасов.Ссылка
			|ИЗ
			|	Справочник.ВидыЗапасов КАК ВидыЗапасов
			|ГДЕ
			|	ВидыЗапасов.Организация = &Организация
			|	И ВидыЗапасов.ТипЗапасов = &ТипЗапасов
			|";
		Запрос = Новый Запрос(ТекстЗапроса);
		Запрос.УстановитьПараметр("Организация", ЗаказСсылка.Организация);
		Запрос.УстановитьПараметр("ТипЗапасов", Перечисления.ТипыЗапасов.Товар);
		РезультатВыборка = Запрос.Выполнить().Выбрать();
		Пока РезультатВыборка.Следующий() Цикл
        	НСВидыЗапасов.ВидЗапасов = РезультатВыборка.Ссылка;
			Прервать;
		КонецЦикла;
		
	КонецЦикла;
	
	ДокументОбъект.СуммаДокумента		= ДокументОбъект.Товары.Итог("Сумма");
	
КонецПроцедуры

&НаСервере
Процедура СформироватьВозвратОтКлиентаПоРеализации(ДокументОбъект, ЗаказСсылка, ДокументРеализации, СписокТоваровВозврат, ДатаВозврата) Экспорт
	ДокументОбъект.Заполнить(ДокументРеализации);
	ДокументОбъект.Товары.Очистить();
	Для Каждого СтрокаВозврат Из СписокТоваровВозврат Цикл
		НС = ДокументОбъект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НС, СтрокаВозврат);
	КонецЦикла;    
	ДокументОбъект.СуммаДокумента 		= ДокументОбъект.Товары.Итог("Сумма");
	ДокументОбъект.НеОтражатьВБУ		= Истина;
	ДокументОбъект.Дата 				= ДатаВозврата;
	ДокументОбъект.Комментарий			= "Возврат по заказу клиента: " + ЗаказСсылка;
	ДокументОбъект.ХозяйственнаяОперация= Перечисления.ХозяйственныеОперации.ВозвратТоваровОтКлиента; 
КонецПроцедуры

//Формирует эквайринговую операцию на сумму возврата
//	ДокументОбъект - документ Операция по платежной карте
//	ЗаказСсылка - ссылка на заказ
//	СуммаОперации - СуммаДокумента
&НаСервере
Процедура СформироватьЭквайринговуюОперацию(ДокументОбъект, ЗаказСсылка, СуммаОперации) Экспорт
	
	ДокументОбъект.Дата 						= ТекущаяДата();
	ДокументОбъект.Организация 					= ЗаказСсылка.Организация;
	ДокументОбъект.СуммаДокумента 				= СуммаОперации;
	ДокументОбъект.ЭквайринговыйТерминал	 	= ЭквайринговыйТерминал(ЗаказСсылка.ЧекПродажа.КассаККМ);
	ДокументОбъект.ДоговорЭквайринга 			= ДокументОбъект.ЭквайринговыйТерминал.Владелец;
	ДокументОбъект.ВидПлатежнойКарты 			= "Платежная карта"; 
	ДокументОбъект.НомерПлатежнойКарты 			= "123456789012";
	ДокументОбъект.Валюта 						= ЗаказСсылка.Валюта;
	ДокументОбъект.ХозяйственнаяОперация 		= Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту;
	ДокументОбъект.Контрагент 					= ЗаказСсылка.Контрагент;
	ДокументОбъект.СтатьяДвиженияДенежныхСредств= Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("01-000004");
	
	НС = ДокументОбъект.РасшифровкаПлатежа.Добавить();
	НС.Партнер		= ЗаказСсылка.Партнер;
	НС.Заказ		= ЗаказСсылка;
	НС.Сумма		= СуммаОперации;
	
КонецПроцедуры

//Формирует требование накладную на товары СписокТоваровВозврат
//	ДокументОбъект - документ требование накладная
//	ЗаказСсылка - ссылка на заказ
//	СписокТоваровВозврат - ТЗ (Номенклатура, Количество, КоличествоШтук, ПричинаОтмены, Упаковка, Цена, КоличествоУпаковок, Сумма, СтавкаНДС, СуммаНДС)
&НаСервере
Процедура СформироватьТребованиеНакладную(ДокументОбъект, ЗаказСсылка, СписокТоваровВозврат) Экспорт
	
	РеквизитыЗаказа = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ЗаказСсылка, "ВитринаИнтернетМагазина");
	
	ДокументОбъект.Дата 				= ТекущаяДата();
	ДокументОбъект.Организация			= ЗаказСсылка.Организация;
	ДокументОбъект.Склад				= ЗаказСсылка.Склад;
	Если РеквизитыЗаказа.ВитринаИнтернетМагазина = Справочники.ВитриныИнтернетМагазина.ДаркКитчен Тогда
		ДокументОбъект.СтатьяРасходов		= ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("01-000010"); //Списание бой/брак
	Иначе
		ДокументОбъект.СтатьяРасходов		= ПланыВидовХарактеристик.СтатьиРасходов.НайтиПоКоду("01-000024"); //Истекший срок годности
	КонецЕсли;
	ДокументОбъект.АналитикаРасходов 	= ЗаказСсылка.Организация;
	ДокументОбъект.Подразделение		= Справочники.СтруктураПредприятия.НайтиПоНаименованию("Камелот – А");
	ДокументОбъект.Ответственный		= ПараметрыСеанса.ТекущийПользователь;
	ДокументОбъект.Комментарий			= "Списание брака из возврата покупателя по заказу ИМ: " + ЗаказСсылка;
	ДокументОбъект.СтатусОтгрузки		= Перечисления.СтатусыОтгрузки.Отгружено;
	ДокументОбъект.ВидЦены				= ДокументОбъект.Склад.УчетныйВидЦены;
	
	Для Каждого СтрокаТЗ Из СписокТоваровВозврат Цикл
		
		НСТовары = ДокументОбъект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НСТовары, СтрокаТЗ);
		НСТовары.КоличествоУпаковок = НСТовары.Количество;
		
	КонецЦикла;
	
КонецПроцедуры

//Формирует чек ккм возврат на товары СписокТоваровВозврат
//	ДокументОбъект - документ ЧекККМВозврат
//	ЗаказСсылка - ссылка на заказ
//	СписокТоваровВозврат - ТЗ (Номенклатура, Количество, КоличествоШтук, ПричинаОтмены, Упаковка, Цена, КоличествоУпаковок, Сумма, СтавкаНДС, СуммаНДС)
&НаСервере
Процедура СформироватьЧекККМВозврат(ДокументОбъект, ЗаказСсылка, СписокТоваровВозврат) Экспорт
	
	ЧекККМСсылка = ЗаказСсылка.ЧекПродажа;
	
	РеквизитыЧека = ОбщегоНазначения.ПолучитьЗначенияРеквизитов(ЧекККМСсылка, "Валюта, ВидЦены, КассаККМ, Кассир, НалогообложениеНДС, Организация, Склад, ЦенаВключаетНДС, ОплатаПлатежнымиКартами, ФормаОплаты");
	
	ДокументОбъект.Дата 				= ТекущаяДата();
	ДокументОбъект.Архивный				= Ложь;
	ДокументОбъект.Валюта				= РеквизитыЧека.Валюта;
	ДокументОбъект.ВидЦены				= РеквизитыЧека.ВидЦены;
	ДокументОбъект.КассаККМ				= РеквизитыЧека.КассаККМ;
	ДокументОбъект.Кассир				= РеквизитыЧека.Кассир;
	ДокументОбъект.Комментарий			= "Возврата по заказу ИМ: " + ЗаказСсылка + " (Чек: " + ЧекККМСсылка + ")";
	ДокументОбъект.НалогообложениеНДС	= РеквизитыЧека.НалогообложениеНДС;
	ДокументОбъект.НомерЧекаККМ			= 0;
	ДокументОбъект.Организация			= РеквизитыЧека.Организация;
	ДокументОбъект.Склад				= РеквизитыЧека.Склад;
	ДокументОбъект.ЦенаВключаетНДС		= РеквизитыЧека.ЦенаВключаетНДС;
	ДокументОбъект.ЧекККМ				= ЧекККМСсылка;
	ДокументОбъект.Статус				= Перечисления.СтатусыЧековККМ.Пробит;
	ДокументОбъект.ФормаОплаты			= РеквизитыЧека.ФормаОплаты;
	
	Для Каждого СтрокаТЗ Из СписокТоваровВозврат Цикл
		
		НСТовары = ДокументОбъект.Товары.Добавить();
		ЗаполнитьЗначенияСвойств(НСТовары, СтрокаТЗ);
		
	КонецЦикла;
	
	ДокументОбъект.СуммаДокумента = ДокументОбъект.Товары.Итог("Сумма");
	ДокументОбъект.СуммаНаличными = 0;
	ДокументОбъект.СуммаБезналичными = ДокументОбъект.СуммаДокумента;
	
	ВыборкаОплатЧека = РеквизитыЧека.ОплатаПлатежнымиКартами.Выбрать();
	Если ВыборкаОплатЧека.Количество() = 0 Тогда
		НСОплата = ДокументОбъект.ОплатаПлатежнымиКартами.Добавить();
		НСОплата.ВидПлатежнойКарты			= "Платежная карта";
		НСОплата.НомерПлатежнойКарты		= "123456789012";
		НСОплата.Сумма						= ДокументОбъект.СуммаДокумента;
		НСОплата.ЭквайринговыйТерминал		= ЭквайринговыйТерминал(ЧекККМСсылка.КассаККМ);
	Иначе
		ВыборкаОплатЧека.Следующий();
		НСОплата = ДокументОбъект.ОплатаПлатежнымиКартами.Добавить();
		НСОплата.ВидПлатежнойКарты			= ВыборкаОплатЧека.ВидПлатежнойКарты;
		НСОплата.НомерПлатежнойКарты		= ВыборкаОплатЧека.НомерПлатежнойКарты;
		НСОплата.Сумма						= ДокументОбъект.СуммаДокумента;
		НСОплата.ЭквайринговыйТерминал		= ВыборкаОплатЧека.ЭквайринговыйТерминал;
	КонецЕсли;
	
КонецПроцедуры

&НаСервере
Функция СкорректироватьТоварыРТУ(ДокументОбъект, Товары, ЭтоВозврат, ОписаниеРезультата) Экспорт
	
	МассивУдаляемых = Новый Массив;
	МассивУдаляемыхДатыВыпуска = Новый Массив;
		
	Для Каждого СтрТовар Из ДокументОбъект.Товары Цикл
			
		СтрокаПродажи = Товары.Найти(СтрТовар.Номенклатура, "Номенклатура");
		Если СтрокаПродажи = Неопределено Тогда
			Если ЭтоВозврат Тогда
				Продолжить;
			Иначе
				МассивУдаляемых.Добавить(СтрТовар);
				Продолжить;
			КонецЕсли;
		КонецЕсли;
			
		Если Не ЭтоВозврат И СтрТовар.Количество <> СтрокаПродажи.Количество Тогда
				
			СтрТовар.Количество = СтрокаПродажи.Количество;
			СтрТовар.КоличествоУпаковок = СтрТовар.Количество;
				
			СтрТовар.Сумма = СтрТовар.Цена * СтрТовар.КоличествоУпаковок;
			СтрТовар.СуммаНДС = Ценообразование.РассчитатьСуммуНДС(СтрТовар.Сумма, СтрТовар.СтавкаНДС, Истина);
				
		ИначеЕсли ЭтоВозврат И СтрТовар.Количество <> СтрокаПродажи.Количество Тогда
				
			СтрТовар.Количество = СтрТовар.Количество - СтрокаПродажи.Количество;
			СтрТовар.КоличествоУпаковок = СтрТовар.Количество;
				
			СтрТовар.Сумма = СтрТовар.Цена * СтрТовар.КоличествоУпаковок;
			СтрТовар.СуммаНДС = Ценообразование.РассчитатьСуммуНДС(СтрТовар.Сумма, СтрТовар.СтавкаНДС, Истина);
				
		ИначеЕсли ЭтоВозврат И СтрТовар.Количество = СтрокаПродажи.Количество Тогда	
			
			МассивУдаляемых.Добавить(СтрТовар);
			Продолжить;
			
		ИначеЕсли Не ЭтоВозврат И СтрТовар.Количество = СтрокаПродажи.Количество Тогда	
			
			Продолжить;
			
		КонецЕсли;
		
		СтрокиНоменклатура = ДокументОбъект.ДатыВыпуска.НайтиСтроки(Новый Структура("Номенклатура", СтрТовар.Номенклатура));
		
		Если СтрокиНоменклатура.Количество() > 1 Тогда
			
			ОстатокРаспределить = СтрТовар.Количество;
			
			Для Каждого Стр Из СтрокиНоменклатура ЦИкл
				
				Если ОстатокРаспределить <= 0 Тогда
					МассивУдаляемыхДатыВыпуска.Добавить(Стр);
					Продолжить;
				КонецЕсли;
				
				Стр.Количество = Мин(Стр.Количество, ОстатокРаспределить);
				ОстатокРаспределить = ОстатокРаспределить - Мин(Стр.Количество, ОстатокРаспределить);				
				
			КонецЦикла;
				
		ИначеЕсли СтрокиНоменклатура.Количество() = 1 Тогда
				
			СтрокиНоменклатура[0].Количество = СтрТовар.Количество;
				
		КонецЕсли;
			
	КонецЦикла;
		
	Для Каждого Удаляемая Из МассивУдаляемых Цикл
		ДокументОбъект.Товары.Удалить(Удаляемая);
	КонецЦикла;
	Для Каждого Удаляемая Из МассивУдаляемыхДатыВыпуска Цикл
		ДокументОбъект.ДатыВыпуска.Удалить(Удаляемая);
	КонецЦикла;
		
	МассивУдаляемых.Очистить();
	МассивУдаляемыхДатыВыпуска.Очистить();
		
	Для Каждого СтрокаДВ Из ДокументОбъект.ДатыВыпуска Цикл
			
		СтрокиНоменклатура = ДокументОбъект.Товары.НайтиСтроки(Новый Структура("Номенклатура", СтрокаДВ.Номенклатура));
		Если Не СтрокиНоменклатура.Количество() Тогда
			МассивУдаляемыхДатыВыпуска.Добавить(СтрокаДВ);
		КонецЕсли;
		
	КонецЦикла;
		
	Для Каждого Удаляемая Из МассивУдаляемыхДатыВыпуска Цикл
		ДокументОбъект.ДатыВыпуска.Удалить(Удаляемая);
	КонецЦикла;
	
	ДокументОбъект.СуммаДокумента = ДокументОбъект.Товары.Итог("Сумма");
	
	Возврат Истина;
	
КонецФункции

&НаСервере
Процедура СформироватьРезервПоВозвращеннымТоварам(ДокументОбъект, ДокументДляСторно, ТЗ_Возврат, СообщениеОбОшибке) Экспорт
	
	ДатаВыполнения = ТекущаяДата();
	
	ДокументОбъект.Дата = ДатаВыполнения;
	ДокументОбъект.Ответственный  = ПараметрыСеанса.ТекущийПользователь;
	ДокументОбъект.Комментарий  = "# Закрыто роботом # Возврат по заказу клиенту, формирование резерва по свободным остаткам";
	ДокументОбъект.Основание = ДокументДляСторно;
	
	НаборДвижений = ДокументОбъект.Движения.СвободныеОстатки;
	Для Каждого СтрокаВозврат Из ТЗ_Возврат Цикл
		
		ДвижениеСторно = НаборДвижений.Добавить();
		ДвижениеСторно.Активность = Истина;
		ДвижениеСторно.ВидДвижения = ВидДвиженияНакопления.Приход;
		ДвижениеСторно.Период = ДатаВыполнения;
		ДвижениеСторно.Номенклатура = СтрокаВозврат.Номенклатура;
		ДвижениеСторно.Склад = ДокументДляСторно.Склад;
		ДвижениеСторно.Характеристика = Справочники.ХарактеристикиНоменклатуры.ПустаяСсылка();
		ДвижениеСторно.ВНаличии = 0;
		ДвижениеСторно.ВРезерве = СтрокаВозврат.Количество;
		
	КонецЦикла;
	
	СтрокаТабДвижения = ДокументОбъект.ТаблицаРегистров.Добавить();
	СтрокаТабДвижения.Имя = "СвободныеОстатки";
	
КонецПроцедуры

&НаСервере
Процедура СформироватьЭквайринговуюОперациюВозврата(ДокументОбъект, ДокументДляВозврата, СуммаВозврата) Экспорт
	
	ДокументОбъект = ДокументДляВозврата.Скопировать();
	ДокументОбъект.ХозяйственнаяОперация = Перечисления.ХозяйственныеОперации.ВозвратОплатыКлиенту;
	ДокументОбъект.СтатьяДвиженияДенежныхСредств = Справочники.СтатьиДвиженияДенежныхСредств.НайтиПоКоду("01-000004");
	ДокументОбъект.СуммаДокумента = СуммаВозврата;
	Для Каждого СтрокаРасшифровкиПлатежа Из ДокументОбъект.РасшифровкаПлатежа Цикл
		СтрокаРасшифровкиПлатежа.Сумма = СуммаВозврата;
	КонецЦикла;
	
КонецПроцедуры

//возвращает ссылку на ближайший к чеку ОРП
//или пустаю ссылку Документ.ОтчетОРозничныхПродажах
&НаСервере
Функция ПолучитьОРПЧека(СсылкаЧек) Экспорт
	
	ОРП = Документы.ОтчетОРозничныхПродажах.ПустаяСсылка();
	
	ТекстЗапроса = "
		|ВЫБРАТЬ ПЕРВЫЕ 1
		|	ОтчетОРозничныхПродажах.Ссылка КАК ОРП
		|ИЗ
		|	Документ.ЧекККМ КАК ЧекККМ
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ОтчетОРозничныхПродажах КАК ОтчетОРозничныхПродажах
		|		ПО ЧекККМ.Дата <= ОтчетОРозничныхПродажах.Дата
		|			И ЧекККМ.КассаККМ = ОтчетОРозничныхПродажах.КассаККМ
		|			И ЧекККМ.Склад = ОтчетОРозничныхПродажах.Склад
		|ГДЕ
		|	ЧекККМ.Ссылка = &ЧекККМ
		|	И НЕ ОтчетОРозничныхПродажах.ПометкаУдаления
		|
		|УПОРЯДОЧИТЬ ПО
		|	ОРП
		|АВТОУПОРЯДОЧИВАНИЕ
		|";

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("ЧекККМ", СсылкаЧек);
	РезультатВыборка = Запрос.Выполнить().Выбрать();
	Пока РезультатВыборка.Следующий() Цикл
		ОРП = РезультатВыборка.ОРП;
	КонецЦикла;
	
	Возврат ОРП;
	
КонецФункции

Функция ЭквайринговыйТерминал(Касса) Экспорт
	
	Запрос = Новый Запрос;
	Запрос.УстановитьПараметр("Касса", Касса);
	Запрос.Текст = 
		"ВЫБРАТЬ Первые 1
		|	ЭквайринговыеТерминалы.Ссылка
		|ИЗ
		|	Справочник.ЭквайринговыеТерминалы КАК ЭквайринговыеТерминалы
		|ГДЕ
		|	ЭквайринговыеТерминалы.Касса = &Касса
		|	И ЭквайринговыеТерминалы.ПометкаУдаления = ЛОЖЬ";

	Результат = Запрос.Выполнить();

	ВыборкаДетальныеЗаписи = Результат.Выбрать();

	Если ВыборкаДетальныеЗаписи.Следующий() Тогда
		Возврат ВыборкаДетальныеЗаписи.Ссылка;
	Иначе
		Возврат ОбщегоНазначенияСерверПовтИсп.ЗначениеКонстанты("ЭквайринговыйТерминалИМ");
	КонецЕсли;
	
КонецФункции

&НаСервере
Функция ПолучитьРТУЗаказа(Заказ) Экспорт
	
	РТУ = Документы.РеализацияТоваровУслуг.ПустаяСсылка();
	
	ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 1
	               |	РеализацияТоваровУслуг.Ссылка
	               |ИЗ
	               |	Документ.РеализацияТоваровУслуг КАК РеализацияТоваровУслуг
	               |ГДЕ
	               |	РеализацияТоваровУслуг.ЗаказКлиента = &Заказ
	               |	И РеализацияТоваровУслуг.Проведен = ИСТИНА
	               |АВТОУПОРЯДОЧИВАНИЕ";

	Запрос = Новый Запрос(ТекстЗапроса);
	Запрос.УстановитьПараметр("Заказ", Заказ);
	РезультатВыборка = Запрос.Выполнить().Выбрать();
	Пока РезультатВыборка.Следующий() Цикл
		РТУ = РезультатВыборка.Ссылка;
	КонецЦикла;
	
	Возврат РТУ;
	
КонецФункции

