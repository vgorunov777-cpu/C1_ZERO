#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	ИерархическаяВыгрузка = Истина;
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	Если ПустаяСтрока(ПутьККонфигуратору) Тогда
		ПутьККонфигуратору = КаталогПрограммы() + "1cv8.exe";
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовФормы

&НаКлиенте
Процедура КаталогВыгрузкиНачалоВыбора(Элемент, ДанныеВыбора, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	Диалог.Заголовок = "Выберите каталог выгрузки";
	Диалог.МножественныйВыбор = Ложь;
	Если Не ПустаяСтрока(КаталогВыгрузки) Тогда
		Диалог.Каталог = КаталогВыгрузки;
	КонецЕсли;
	ОповещениеЗавершения = Новый ОписаниеОповещения("КаталогВыгрузкиВыбран", ЭтотОбъект);
	Диалог.Показать(ОповещениеЗавершения);
КонецПроцедуры

&НаКлиенте
Процедура КаталогВыгрузкиВыбран(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	Если ВыбранныеФайлы = Неопределено Или ВыбранныеФайлы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	КаталогВыгрузки = ВыбранныеФайлы[0];
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ДобавитьФайлы(Команда)
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
	Диалог.Заголовок = "Выберите внешние обработки и/или отчеты";
	Диалог.Фильтр = "Внешние обработки и отчеты (*.epf;*.erf)|*.epf;*.erf|Все файлы (*.*)|*.*";
	Диалог.МножественныйВыбор = Истина;
	ОповещениеЗавершения = Новый ОписаниеОповещения("ФайлыДобавлены", ЭтотОбъект);
	Диалог.Показать(ОповещениеЗавершения);
КонецПроцедуры

&НаКлиенте
Процедура ФайлыДобавлены(ВыбранныеФайлы, ДополнительныеПараметры) Экспорт
	Если ВыбранныеФайлы = Неопределено Или ВыбранныеФайлы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	Для Каждого ВыбранныйФайл Из ВыбранныеФайлы Цикл
		НоваяСтрока = СписокФайлов.Добавить();
		НоваяСтрока.Пометка = Истина;
		НоваяСтрока.ИмяФайла = ВыбранныйФайл;
		НоваяСтрока.ИмяОбработки = ПолучитьИмяФайлаБезПути(ВыбранныйФайл);
		НоваяСтрока.Статус = "Ожидание";
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура УдалитьФайлы2(Команда)
	МассивКУдалению = Новый Массив;
	Для Каждого СтрокаТаблицы Из СписокФайлов Цикл
		Если СтрокаТаблицы.Пометка Тогда
			МассивКУдалению.Добавить(СтрокаТаблицы);
		КонецЕсли;
	КонецЦикла;
	Для Каждого СтрокаУдаления Из МассивКУдалению Цикл
		СписокФайлов.Удалить(СтрокаУдаления);
	КонецЦикла;
КонецПроцедуры

&НаКлиенте
Процедура ОчиститьСписок(Команда)
	СписокФайлов.Очистить();
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьОбработка(Команда)

	Если СписокФайлов.Количество() = 0 Тогда
		ПоказатьСообщениеПользователю("Список файлов пуст. Добавьте файлы для выгрузки.");
		Возврат;
	КонецЕсли;

	Если ПустаяСтрока(КаталогВыгрузки) Тогда
		ПоказатьСообщениеПользователю("Не выбран каталог выгрузки.");
		Возврат;
	КонецЕсли;

	Если ПустаяСтрока(ПутьККонфигуратору) Тогда
		ПоказатьСообщениеПользователю("Не указан путь к 1cv8.exe (конфигуратор).");
		Возврат;
	КонецЕсли;

	Формат = ?(ИерархическаяВыгрузка, "Hierarchical", "Plain");

	ФайлКаталога = Новый Файл(КаталогВыгрузки);
	Если Не ФайлКаталога.Существует() Тогда
		СоздатьКаталог(КаталогВыгрузки);
	ИначеЕсли Не ФайлКаталога.ЭтоКаталог() Тогда
		ПоказатьСообщениеПользователю("Путь выгрузки указывает не на каталог: " + КаталогВыгрузки);
		Возврат;
	КонецЕсли;

	КоличествоОбработано = 0;
	КоличествоОшибок = 0;

	Шелл = Новый COMОбъект("WScript.Shell");

	Для Каждого СтрокаФайла Из СписокФайлов Цикл

		Если Не СтрокаФайла.Пометка Тогда
			Продолжить;
		КонецЕсли;

		ИмяОбработки = ПолучитьИмяФайлаБезПути(СтрокаФайла.ИмяФайла);
		ИмяОбработкиБезРасширения = СтрЗаменить(ИмяОбработки, ".epf", "");
		ИмяОбработкиБезРасширения = СтрЗаменить(ИмяОбработкиБезРасширения, ".erf", "");

		КаталогОбработки = КаталогВыгрузки + "\" + ИмяОбработкиБезРасширения;
		ФайлОбработки = Новый Файл(КаталогОбработки);
		Если Не ФайлОбработки.Существует() Тогда
			СоздатьКаталог(КаталогОбработки);
		КонецЕсли;

		ПутьКорневогоФайла = КаталогОбработки + "\" + ИмяОбработкиБезРасширения + ".xml";
		ПутьЛога = КаталогОбработки + "\" + ИмяОбработкиБезРасширения + ".log";

		КоманднаяСтрока =
			"""" + ПутьККонфигуратору + """"
			+ " DESIGNER "
			+ "/DumpExternalDataProcessorOrReportToFiles "
			+ """" + ПутьКорневогоФайла + """ "
			+ """" + СтрокаФайла.ИмяФайла + """ "
			+ "-Format " + Формат + " "
			+ "/Out " + """" + ПутьЛога + """ "
			+ "/DisableStartupDialogs";

		СтрокаФайла.Статус = "Выгрузка...";

		Попытка
			// Синхронный запуск: ждём завершения конфигуратора (bWaitOnReturn = True)
			КодВозврата = Шелл.Run(КоманднаяСтрока, 0, Истина);

			Если КодВозврата = 0 Тогда
				СтрокаФайла.Статус = "Выгружено";
				КоличествоОбработано = КоличествоОбработано + 1;
			Иначе
				ТекстОшибки = ПрочитатьЛог(ПутьЛога);
				СтрокаФайла.Статус = "Ошибка (код " + КодВозврата + ")";
				КоличествоОшибок = КоличествоОшибок + 1;
				Если Не ПустаяСтрока(ТекстОшибки) Тогда
					ПоказатьСообщениеПользователю(ИмяОбработки + ": " + ТекстОшибки);
				КонецЕсли;
			КонецЕсли;
		Исключение
			СтрокаФайла.Статус = "Ошибка";
			КоличествоОшибок = КоличествоОшибок + 1;
			ПоказатьСообщениеПользователю(ИмяОбработки + ": " + ОписаниеОшибки());
		КонецПопытки;

	КонецЦикла;

	ПоказатьСообщениеПользователю(
		"Выгрузка завершена. Обработано: " + КоличествоОбработано
		+ ", ошибок: " + КоличествоОшибок
		+ ". Каталог: " + КаталогВыгрузки);

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиОповещений
#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Функция ПолучитьИмяФайлаБезПути(ПолноеИмя)
	ФайлДляИмени = Новый Файл(ПолноеИмя);
	Возврат ФайлДляИмени.Имя;
КонецФункции

&НаКлиенте
Процедура ПоказатьСообщениеПользователю(ТекстСообщения) Экспорт
	Сообщение = Новый СообщениеПользователю;
	Сообщение.Текст = ТекстСообщения;
	Сообщение.Сообщить();
КонецПроцедуры

&НаКлиенте
Функция ПрочитатьЛог(ПутьКЛогу)

	ФайлЛога = Новый Файл(ПутьКЛогу);
	Если Не ФайлЛога.Существует() Тогда
		Возврат "";
	КонецЕсли;

	Попытка
		ТекстЛога = Новый ЧтениеТекста(ПутьКЛогу, КодировкаТекста.UTF8);
		Содержимое = ТекстЛога.Прочитать();
		ТекстЛога.Закрыть();
		Возврат Содержимое;
	Исключение
		Возврат "";
	КонецПопытки;

КонецФункции

#КонецОбласти
